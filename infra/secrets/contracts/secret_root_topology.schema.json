{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/secrets/secret_root_topology.schema.json",
  "title": "Secret Root Topology Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "inventory_id",
    "provider_id",
    "flow_id",
    "policy_version",
    "run_id",
    "workspace_id",
    "operator_identity_alias",
    "selection_status",
    "selected_provider_stack_id_or_null",
    "root_posture",
    "phase_hsm_requirement",
    "provider_stack_options",
    "namespace_roots",
    "source_refs",
    "typed_gaps",
    "notes",
    "last_verified_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "inventory_id": {
      "const": "secret_root_inventory"
    },
    "provider_id": {
      "const": "platform-secret-root"
    },
    "flow_id": {
      "const": "provision-secrets-manager-kms-or-hsm-roots-and-access-policies"
    },
    "policy_version": {
      "const": "1.0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "operator_identity_alias": {
      "type": "string",
      "minLength": 1
    },
    "selection_status": {
      "enum": [
        "PROVIDER_SELECTION_REQUIRED",
        "PROVIDER_STACK_SELECTED"
      ]
    },
    "selected_provider_stack_id_or_null": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "enum": [
            "AWS_SECRETS_MANAGER_KMS_CLOUDHSM",
            "GCP_SECRET_MANAGER_CLOUD_KMS_HSM",
            "AZURE_KEY_VAULT_MANAGED_HSM",
            "HASHICORP_VAULT_AUTO_UNSEAL"
          ]
        }
      ]
    },
    "root_posture": {
      "const": "LOGICAL_TOPOLOGY_FROZEN_PROVIDER_UNRESOLVED"
    },
    "phase_hsm_requirement": {
      "const": "CLOUD_KMS_OR_MANAGED_HSM_CAPABLE_ROOT_SATISFIES_PHASE_01"
    },
    "provider_stack_options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/providerStackOption"
      }
    },
    "namespace_roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/namespaceRoot"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceRef"
      }
    },
    "typed_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_verified_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "rationale"
      ],
      "properties": {
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "providerStackOption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stack_id",
        "provider_label",
        "selection_state",
        "secret_store_summary",
        "key_root_summary",
        "hsm_summary",
        "soft_delete_summary",
        "docs_urls",
        "source_refs",
        "fit_notes"
      ],
      "properties": {
        "stack_id": {
          "enum": [
            "AWS_SECRETS_MANAGER_KMS_CLOUDHSM",
            "GCP_SECRET_MANAGER_CLOUD_KMS_HSM",
            "AZURE_KEY_VAULT_MANAGED_HSM",
            "HASHICORP_VAULT_AUTO_UNSEAL"
          ]
        },
        "provider_label": {
          "type": "string",
          "minLength": 1
        },
        "selection_state": {
          "enum": [
            "BLOCKED_BY_PLATFORM_PROVIDER_SELECTION",
            "SELF_HOST_DECISION_REQUIRED"
          ]
        },
        "secret_store_summary": {
          "type": "string",
          "minLength": 1
        },
        "key_root_summary": {
          "type": "string",
          "minLength": 1
        },
        "hsm_summary": {
          "type": "string",
          "minLength": 1
        },
        "soft_delete_summary": {
          "type": "string",
          "minLength": 1
        },
        "docs_urls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        },
        "fit_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "namespaceRoot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "namespace_ref",
        "environment_refs",
        "provider_environment_refs",
        "partition_label",
        "secret_mount_ref",
        "metadata_mount_ref",
        "wrapping_key_family_ref",
        "hardware_root_requirement",
        "adoption_disposition",
        "emergency_revoke_posture"
      ],
      "properties": {
        "namespace_ref": {
          "type": "string",
          "pattern": "^sec_[a-z0-9_]+$"
        },
        "environment_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^env_[a-z0-9_]+$"
          }
        },
        "provider_environment_refs": {
          "type": "array",
          "items": {
            "enum": [
              "sandbox",
              "production"
            ]
          }
        },
        "partition_label": {
          "type": "string",
          "minLength": 1
        },
        "secret_mount_ref": {
          "type": "string",
          "pattern": "^vault://kv/"
        },
        "metadata_mount_ref": {
          "type": "string",
          "pattern": "^vault://metadata/"
        },
        "wrapping_key_family_ref": {
          "type": "string",
          "pattern": "^key\\."
        },
        "hardware_root_requirement": {
          "enum": [
            "KMS_ONLY_ACCEPTABLE",
            "OPTIONAL_HSM_CAPABLE_ROOT"
          ]
        },
        "adoption_disposition": {
          "const": "TOPOLOGY_DECLARED_PROVIDER_UNRESOLVED"
        },
        "emergency_revoke_posture": {
          "const": "REVOKE_ALIAS_IMMEDIATELY_PROVIDER_SOFT_DELETE_IS_NOT_ACTIVE_STATE"
        }
      }
    }
  }
}
