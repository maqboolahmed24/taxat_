{
  "name": "@taxat/provisioning-automation",
  "private": true,
  "type": "module",
  "description": "Governed browser automation workspace for third-party provisioning flows.",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "playwright test -c playwright.config.ts",
    "test:unit": "playwright test -c playwright.config.ts --project=unit",
    "test:smoke": "playwright test -c playwright.config.ts --project=smoke --project=viewer",
    "viewer": "python3 -m http.server ${PROVISIONING_VIEWER_PORT:-4328} --bind 127.0.0.1",
    "resume": "node ./scripts/resume_checkpoint.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^24.7.2",
    "typescript": "^5.9.3"
  }
}
