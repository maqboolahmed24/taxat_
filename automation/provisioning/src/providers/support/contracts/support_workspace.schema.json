{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/support_workspace.schema.json",
  "title": "SupportWorkspaceSelectionRecord",
  "description": "Deterministic support-selection record for Taxat's contextual portal-help contract. The record freezes whether an external support workspace exists, preserves first-party truth boundaries, and never stores raw helpdesk credentials or transcripts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "selection_record_id",
    "provider_id",
    "provider_display_name",
    "run_id",
    "flow_id",
    "workspace_id",
    "operator_identity_alias",
    "selection_status",
    "decision_status",
    "selected_vendor_adapter_or_null",
    "selected_vendor_label_or_null",
    "future_default_vendor_adapter_or_null",
    "environment_scope",
    "first_party_truth_statement",
    "support_channel_policy_ref",
    "portal_help_mapping_ref",
    "support_webhook_contract_ref",
    "provider_docs_urls",
    "source_refs",
    "selection_notes",
    "typed_gaps",
    "last_verified_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "selection_record_id": {
      "type": "string",
      "const": "support_workspace_selection_record"
    },
    "provider_id": {
      "type": "string",
      "const": "support-operations-control-plane"
    },
    "provider_display_name": {
      "type": "string",
      "const": "Support Integration Control Plane"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "flow_id": {
      "type": "string",
      "const": "support-workspace-selection"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "operator_identity_alias": {
      "type": "string",
      "minLength": 1
    },
    "selection_status": {
      "type": "string",
      "enum": [
        "NOT_SELECTED",
        "SELECTED_WITH_GAPS",
        "SELECTED"
      ]
    },
    "decision_status": {
      "type": "string",
      "enum": [
        "OPTIONAL_VENDOR_SELECTION_NOT_RESOLVED",
        "SELECTED_PENDING_PROCUREMENT"
      ]
    },
    "selected_vendor_adapter_or_null": {
      "anyOf": [
        {
          "type": "string",
          "const": "ZENDESK_COMPATIBLE_BASELINE"
        },
        {
          "type": "null"
        }
      ]
    },
    "selected_vendor_label_or_null": {
      "type": [
        "string",
        "null"
      ]
    },
    "future_default_vendor_adapter_or_null": {
      "type": "string",
      "const": "ZENDESK_COMPATIBLE_BASELINE"
    },
    "environment_scope": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        {
          "type": "string",
          "const": "staging"
        },
        {
          "type": "string",
          "const": "production"
        }
      ],
      "items": false
    },
    "first_party_truth_statement": {
      "type": "string",
      "minLength": 1
    },
    "support_channel_policy_ref": {
      "type": "string",
      "const": "config/support/support_channel_policy.json"
    },
    "portal_help_mapping_ref": {
      "type": "string",
      "const": "config/support/portal_help_to_external_ticket_mapping.json"
    },
    "support_webhook_contract_ref": {
      "type": "string",
      "const": "config/support/support_webhook_endpoint_contract.json"
    },
    "provider_docs_urls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceRef"
      }
    },
    "selection_notes": {
      "$ref": "#/$defs/stringArray"
    },
    "typed_gaps": {
      "$ref": "#/$defs/stringArray"
    },
    "last_verified_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "rationale"
      ],
      "properties": {
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
