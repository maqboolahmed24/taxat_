{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/push_credential_record.schema.json",
  "title": "PushCredentialRecord",
  "description": "Deterministic device-messaging credential lineage row. This schema freezes environment-bound service-account and APNs key lineage with vault refs and safe fingerprints only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "credential_ref",
    "product_environment_id",
    "credential_kind",
    "source_disposition",
    "vault_secret_ref",
    "fingerprint",
    "bundle_identifier_or_null",
    "bound_web_origin_or_null",
    "key_id_alias_or_null",
    "team_id_alias_or_null",
    "rotation_rule",
    "secret_material_state",
    "source_refs",
    "notes"
  ],
  "properties": {
    "credential_ref": {
      "type": "string",
      "minLength": 1
    },
    "product_environment_id": {
      "type": "string",
      "enum": [
        "env_shared_sandbox_integration",
        "env_preproduction_verification",
        "env_production"
      ]
    },
    "credential_kind": {
      "type": "string",
      "enum": [
        "FCM_SERVICE_ACCOUNT",
        "APNS_AUTH_KEY"
      ]
    },
    "source_disposition": {
      "type": "string",
      "enum": [
        "CREATED_DURING_RUN",
        "ADOPTED_EXISTING"
      ]
    },
    "vault_secret_ref": {
      "type": "string",
      "minLength": 1
    },
    "fingerprint": {
      "type": "string",
      "pattern": "^sha256:[A-Fa-f0-9]{64}$"
    },
    "bundle_identifier_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "bound_web_origin_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "key_id_alias_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "team_id_alias_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "rotation_rule": {
      "type": "string",
      "minLength": 1
    },
    "secret_material_state": {
      "type": "string",
      "const": "VAULT_ONLY"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_ref",
          "rationale"
        ],
        "properties": {
          "source_ref": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
