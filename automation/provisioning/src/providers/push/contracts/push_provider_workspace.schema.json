{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/push_provider_workspace.schema.json",
  "title": "PushProviderWorkspaceRow",
  "description": "Deterministic device-messaging workspace row. This schema freezes environment-bound project identity, active delivery scope, client-surface bindings, and safe credential metadata refs without persisting raw provider secrets.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workspace_ref",
    "product_environment_id",
    "provider_environment_tag",
    "provider_project_label",
    "provider_project_alias",
    "project_id_alias",
    "project_number_alias",
    "fcm_sender_id_alias",
    "source_disposition",
    "delivery_scope",
    "channel_refs",
    "cloud_messaging_api_state",
    "registration_api_state",
    "bundle_identifier_or_null",
    "service_account_metadata_ref_or_null",
    "apns_binding_state",
    "source_refs",
    "notes"
  ],
  "properties": {
    "workspace_ref": {
      "type": "string",
      "minLength": 1
    },
    "product_environment_id": {
      "type": "string",
      "enum": [
        "env_local_provisioning_workstation",
        "env_shared_sandbox_integration",
        "env_preproduction_verification",
        "env_production"
      ]
    },
    "provider_environment_tag": {
      "type": "string",
      "enum": [
        "LOCAL_FIXTURE",
        "SANDBOX",
        "PREPRODUCTION",
        "PRODUCTION"
      ]
    },
    "provider_project_label": {
      "type": "string",
      "minLength": 1
    },
    "provider_project_alias": {
      "type": "string",
      "minLength": 1
    },
    "project_id_alias": {
      "type": "string",
      "minLength": 1
    },
    "project_number_alias": {
      "type": "string",
      "minLength": 1
    },
    "fcm_sender_id_alias": {
      "type": "string",
      "minLength": 1
    },
    "source_disposition": {
      "type": "string",
      "enum": [
        "CREATED_DURING_RUN",
        "ADOPTED_EXISTING"
      ]
    },
    "delivery_scope": {
      "type": "string",
      "enum": [
        "FIXTURE_ONLY",
        "NATIVE_MACOS_INTERNAL_ONLY"
      ]
    },
    "channel_refs": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "cloud_messaging_api_state": {
      "type": "string",
      "const": "ENABLED"
    },
    "registration_api_state": {
      "type": "string",
      "enum": [
        "NOT_REQUIRED_AT_THIS_STAGE",
        "FIXTURE_ONLY"
      ]
    },
    "bundle_identifier_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "service_account_metadata_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "apns_binding_state": {
      "type": "string",
      "enum": [
        "BOUND",
        "NOT_REQUIRED_AT_THIS_STAGE",
        "FIXTURE_ONLY",
        "MISSING_POLICY_BLOCK"
      ]
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_ref",
          "rationale"
        ],
        "properties": {
          "source_ref": {
            "type": "string",
            "minLength": 1
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
