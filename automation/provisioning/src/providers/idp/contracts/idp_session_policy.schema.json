{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/provisioning/idp/idp_session_policy.schema.json",
  "title": "IdpSessionPolicyMatrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "matrix_id",
    "provider_id",
    "provider_display_name",
    "provider_selection",
    "policy_version",
    "generated_on",
    "summary",
    "session_profiles",
    "typed_gaps",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "matrix_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "const": "oidc-external-idp-control-plane"
    },
    "provider_display_name": {
      "const": "OIDC External Identity Control Plane"
    },
    "provider_selection": {
      "$ref": "#/$defs/providerSelection"
    },
    "policy_version": {
      "const": "1.0"
    },
    "generated_on": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_profile_count",
        "interactive_human_profiles",
        "non_interactive_or_limited_profiles"
      ],
      "properties": {
        "session_profile_count": {
          "type": "integer",
          "minimum": 1
        },
        "interactive_human_profiles": {
          "type": "integer",
          "minimum": 1
        },
        "non_interactive_or_limited_profiles": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "session_profiles": {
      "type": "array",
      "minItems": 6,
      "items": {
        "$ref": "#/$defs/sessionProfile"
      }
    },
    "typed_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "rationale"
      ],
      "properties": {
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "providerSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_selection_status",
        "provider_family",
        "provider_vendor_adapter",
        "provider_vendor_label",
        "docs_urls",
        "source_refs"
      ],
      "properties": {
        "provider_selection_status": {
          "const": "PROVIDER_DEFAULT_APPLIED"
        },
        "provider_family": {
          "const": "OIDC_EXTERNAL_IDP"
        },
        "provider_vendor_adapter": {
          "const": "AUTH0_COMPATIBLE_DASHBOARD"
        },
        "provider_vendor_label": {
          "type": "string",
          "minLength": 1
        },
        "docs_urls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        }
      }
    },
    "surfaceFamily": {
      "enum": [
        "OPERATOR_BROWSER",
        "PORTAL_BROWSER",
        "NATIVE_MACOS_OPERATOR",
        "API_AUTOMATION",
        "BROWSER_LIMITED_ENTRY",
        "BROWSER_OR_MOBILE_TRANSFER"
      ]
    },
    "sessionProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_profile_ref",
        "flow_id",
        "label",
        "channel",
        "actor_classes",
        "allowed_surface_families",
        "session_carrier",
        "auth0_application_types",
        "auth0_cookie_mode",
        "default_idle_timeout_hours",
        "default_absolute_timeout_hours",
        "action_idle_timeout_hours",
        "action_absolute_timeout_hours",
        "refresh_token_rotation",
        "refresh_token_lifetime_seconds",
        "refresh_token_leeway_seconds",
        "offline_access_allowed",
        "base_authn_level",
        "escalated_authn_level",
        "post_step_up_rotation",
        "invalidation_events",
        "entry_posture",
        "storage_boundary",
        "source_refs",
        "notes"
      ],
      "properties": {
        "session_profile_ref": {
          "type": "string",
          "pattern": "^session\\.[a-z0-9.-]+$"
        },
        "flow_id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "channel": {
          "enum": [
            "BROWSER",
            "NATIVE_MACOS",
            "API_AUTOMATION",
            "BROWSER_LIMITED_ENTRY",
            "BROWSER_OR_MOBILE_TRANSFER"
          ]
        },
        "actor_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_surface_families": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/surfaceFamily"
          }
        },
        "session_carrier": {
          "type": "string",
          "minLength": 1
        },
        "auth0_application_types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "auth0_cookie_mode": {
          "enum": [
            "NON_PERSISTENT",
            "PERSISTENT",
            "NOT_APPLICABLE_NON_BROWSER"
          ]
        },
        "default_idle_timeout_hours": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "default_absolute_timeout_hours": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "action_idle_timeout_hours": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "action_absolute_timeout_hours": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "refresh_token_rotation": {
          "enum": [
            "DISABLED",
            "ROTATING_EXPIRING",
            "NOT_APPLICABLE"
          ]
        },
        "refresh_token_lifetime_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "refresh_token_leeway_seconds": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "offline_access_allowed": {
          "type": "boolean"
        },
        "base_authn_level": {
          "enum": [
            "BASIC",
            "MFA",
            "STEP_UP"
          ]
        },
        "escalated_authn_level": {
          "enum": [
            "BASIC",
            "MFA",
            "STEP_UP"
          ]
        },
        "post_step_up_rotation": {
          "type": "boolean"
        },
        "invalidation_events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "entry_posture": {
          "type": "string",
          "minLength": 1
        },
        "storage_boundary": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
