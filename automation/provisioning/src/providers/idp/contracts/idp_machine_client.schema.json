{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/provisioning/idp/idp_machine_client.schema.json",
  "title": "IdP Machine Client Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "inventory_id",
    "provider_id",
    "provider_display_name",
    "run_id",
    "flow_id",
    "workspace_id",
    "operator_identity_alias",
    "provider_selection",
    "tenant_record_ref",
    "machine_clients",
    "typed_gaps",
    "notes",
    "last_verified_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "inventory_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "const": "oidc-external-idp-control-plane"
    },
    "provider_display_name": {
      "const": "OIDC External Identity Control Plane"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "flow_id": {
      "const": "idp-tenant-and-clients-bootstrap"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "operator_identity_alias": {
      "type": "string",
      "minLength": 1
    },
    "provider_selection": {
      "$ref": "#/$defs/providerSelection"
    },
    "tenant_record_ref": {
      "type": "string",
      "minLength": 1
    },
    "machine_clients": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/machineClient"
      }
    },
    "typed_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_verified_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_ref", "rationale"],
      "properties": {
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "providerSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_selection_status",
        "provider_family",
        "provider_vendor_adapter",
        "provider_vendor_label",
        "docs_urls",
        "source_refs"
      ],
      "properties": {
        "provider_selection_status": {
          "const": "PROVIDER_DEFAULT_APPLIED"
        },
        "provider_family": {
          "const": "OIDC_EXTERNAL_IDP"
        },
        "provider_vendor_adapter": {
          "const": "AUTH0_COMPATIBLE_DASHBOARD"
        },
        "provider_vendor_label": {
          "type": "string",
          "minLength": 1
        },
        "docs_urls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        }
      }
    },
    "secretPosture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requires_vault_secret",
        "secret_namespace_ref",
        "secret_class_id",
        "client_id_metadata_store_ref",
        "client_secret_store_ref",
        "client_secret_metadata_ref",
        "vault_write_receipt_ref",
        "client_secret_fingerprint",
        "capture_posture"
      ],
      "properties": {
        "requires_vault_secret": {
          "const": true
        },
        "secret_namespace_ref": {
          "type": "string",
          "minLength": 1
        },
        "secret_class_id": {
          "enum": [
            "idp_machine_client_secret",
            "idp_management_client_secret"
          ]
        },
        "client_id_metadata_store_ref": {
          "type": "string",
          "minLength": 1
        },
        "client_secret_store_ref": {
          "type": "string",
          "minLength": 1
        },
        "client_secret_metadata_ref": {
          "type": "string",
          "minLength": 1
        },
        "vault_write_receipt_ref": {
          "type": "string",
          "minLength": 1
        },
        "client_secret_fingerprint": {
          "type": "string",
          "minLength": 1
        },
        "capture_posture": {
          "enum": [
            "IMMEDIATE_VAULT_CAPTURE",
            "ADOPT_EXISTING_VAULT_BINDING"
          ]
        }
      }
    },
    "machineClient": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "client_ref",
        "machine_client_family",
        "tenant_ref",
        "provider_environment_tag",
        "product_environment_id",
        "application_type",
        "client_visibility",
        "client_display_name",
        "client_id_alias",
        "client_id_fingerprint",
        "source_disposition",
        "grant_posture",
        "callback_urls",
        "logout_urls",
        "allowed_web_origins",
        "management_audience_ref",
        "mfa_posture",
        "secret_posture",
        "source_refs",
        "typed_gaps",
        "notes"
      ],
      "properties": {
        "client_ref": {
          "type": "string",
          "minLength": 1
        },
        "machine_client_family": {
          "enum": [
            "BACKEND_SERVICE_AUTOMATION",
            "PROVIDER_MANAGEMENT_BOOTSTRAP"
          ]
        },
        "tenant_ref": {
          "enum": [
            "idp_tenant_dev_shared",
            "idp_tenant_staging_runtime",
            "idp_tenant_production_runtime"
          ]
        },
        "provider_environment_tag": {
          "enum": ["Development", "Staging", "Production"]
        },
        "product_environment_id": {
          "enum": [
            "env_shared_sandbox_integration",
            "env_preproduction_verification",
            "env_production",
            null
          ]
        },
        "application_type": {
          "const": "MACHINE_TO_MACHINE_APPLICATION"
        },
        "client_visibility": {
          "const": "CONFIDENTIAL"
        },
        "client_display_name": {
          "type": "string",
          "minLength": 1
        },
        "client_id_alias": {
          "type": "string",
          "minLength": 1
        },
        "client_id_fingerprint": {
          "type": "string",
          "minLength": 1
        },
        "source_disposition": {
          "enum": ["CREATED_DURING_RUN", "ADOPTED_EXISTING"]
        },
        "grant_posture": {
          "type": "array",
          "prefixItems": [
            {
              "const": "client_credentials"
            }
          ],
          "items": false
        },
        "callback_urls": {
          "type": "array",
          "maxItems": 0
        },
        "logout_urls": {
          "type": "array",
          "maxItems": 0
        },
        "allowed_web_origins": {
          "type": "array",
          "maxItems": 0
        },
        "management_audience_ref": {
          "enum": [
            "urn:taxat:backend-service",
            "urn:auth0-management-api"
          ]
        },
        "mfa_posture": {
          "const": "NOT_APPLICABLE_MACHINE"
        },
        "secret_posture": {
          "$ref": "#/$defs/secretPosture"
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        },
        "typed_gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
