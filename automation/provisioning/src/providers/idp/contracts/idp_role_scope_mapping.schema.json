{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/provisioning/idp/idp_role_scope_mapping.schema.json",
  "title": "IdpRoleCatalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_pack_id",
    "provider_id",
    "provider_display_name",
    "provider_selection",
    "policy_version",
    "generated_on",
    "summary",
    "roles",
    "typed_gaps",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "policy_pack_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "const": "oidc-external-idp-control-plane"
    },
    "provider_display_name": {
      "const": "OIDC External Identity Control Plane"
    },
    "provider_selection": {
      "$ref": "#/$defs/providerSelection"
    },
    "policy_version": {
      "const": "1.0"
    },
    "generated_on": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role_count",
        "human_role_count",
        "service_role_count"
      ],
      "properties": {
        "role_count": {
          "type": "integer",
          "minimum": 1
        },
        "human_role_count": {
          "type": "integer",
          "minimum": 1
        },
        "service_role_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/roleRow"
      }
    },
    "typed_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "rationale"
      ],
      "properties": {
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "providerSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_selection_status",
        "provider_family",
        "provider_vendor_adapter",
        "provider_vendor_label",
        "docs_urls",
        "source_refs"
      ],
      "properties": {
        "provider_selection_status": {
          "const": "PROVIDER_DEFAULT_APPLIED"
        },
        "provider_family": {
          "const": "OIDC_EXTERNAL_IDP"
        },
        "provider_vendor_adapter": {
          "const": "AUTH0_COMPATIBLE_DASHBOARD"
        },
        "provider_vendor_label": {
          "type": "string",
          "minLength": 1
        },
        "docs_urls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        }
      }
    },
    "surfaceFamily": {
      "enum": [
        "OPERATOR_BROWSER",
        "PORTAL_BROWSER",
        "NATIVE_MACOS_OPERATOR",
        "API_AUTOMATION",
        "BROWSER_LIMITED_ENTRY",
        "BROWSER_OR_MOBILE_TRANSFER"
      ]
    },
    "roleRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role_ref",
        "provider_role_name",
        "label",
        "actor_classes",
        "allowed_surface_families",
        "baseline_scope_refs",
        "requestable_scope_refs",
        "assignment_posture",
        "engine_owned_dimensions",
        "source_refs",
        "notes"
      ],
      "properties": {
        "role_ref": {
          "type": "string",
          "pattern": "^role_[a-z0-9_]+$"
        },
        "provider_role_name": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "actor_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allowed_surface_families": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/surfaceFamily"
          }
        },
        "baseline_scope_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^scope\\.[a-z0-9._-]+$"
          }
        },
        "requestable_scope_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^scope\\.[a-z0-9._-]+$"
          }
        },
        "assignment_posture": {
          "enum": [
            "HUMAN_MEMBERSHIP_ROLE",
            "SERVICE_CLIENT_GRANT_ROLE"
          ]
        },
        "engine_owned_dimensions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
