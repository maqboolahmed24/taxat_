{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/provisioning/idp/idp_tenant_record.schema.json",
  "title": "IdP Tenant Record Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "provider_id",
    "provider_display_name",
    "run_id",
    "flow_id",
    "workspace_id",
    "operator_identity_alias",
    "execution_mode",
    "provider_selection",
    "tenant_records",
    "typed_gaps",
    "notes",
    "last_verified_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "const": "oidc-external-idp-control-plane"
    },
    "provider_display_name": {
      "const": "OIDC External Identity Control Plane"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "flow_id": {
      "const": "idp-tenant-and-clients-bootstrap"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "operator_identity_alias": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode": {
      "enum": ["fixture", "sandbox", "production"]
    },
    "provider_selection": {
      "$ref": "#/$defs/providerSelection"
    },
    "tenant_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tenantRow"
      }
    },
    "typed_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_verified_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_ref", "rationale"],
      "properties": {
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "providerSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_selection_status",
        "provider_family",
        "provider_vendor_adapter",
        "provider_vendor_label",
        "docs_urls",
        "source_refs"
      ],
      "properties": {
        "provider_selection_status": {
          "const": "PROVIDER_DEFAULT_APPLIED"
        },
        "provider_family": {
          "const": "OIDC_EXTERNAL_IDP"
        },
        "provider_vendor_adapter": {
          "const": "AUTH0_COMPATIBLE_DASHBOARD"
        },
        "provider_vendor_label": {
          "type": "string",
          "minLength": 1
        },
        "docs_urls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        }
      }
    },
    "tenantRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenant_ref",
        "tenant_label",
        "tenant_domain_alias",
        "custom_domain",
        "provider_environment_tag",
        "region",
        "product_environment_ids",
        "residency_posture",
        "automation_access_posture",
        "environment_tag_ref",
        "source_disposition",
        "secret_namespace_refs",
        "business_tenant_mapping_posture",
        "typed_gaps",
        "notes"
      ],
      "properties": {
        "tenant_ref": {
          "enum": [
            "idp_tenant_dev_shared",
            "idp_tenant_staging_runtime",
            "idp_tenant_production_runtime"
          ]
        },
        "tenant_label": {
          "type": "string",
          "minLength": 1
        },
        "tenant_domain_alias": {
          "type": "string",
          "minLength": 1
        },
        "custom_domain": {
          "type": ["string", "null"]
        },
        "provider_environment_tag": {
          "enum": ["Development", "Staging", "Production"]
        },
        "region": {
          "const": "EU"
        },
        "product_environment_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "env_local_provisioning_workstation",
              "env_shared_sandbox_integration",
              "env_preproduction_verification",
              "env_production"
            ]
          }
        },
        "residency_posture": {
          "type": "string",
          "minLength": 1
        },
        "automation_access_posture": {
          "type": "string",
          "minLength": 1
        },
        "environment_tag_ref": {
          "type": "string",
          "minLength": 1
        },
        "source_disposition": {
          "enum": ["CREATED_DURING_RUN", "ADOPTED_EXISTING"]
        },
        "secret_namespace_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "business_tenant_mapping_posture": {
          "const": "ONE_CONTROL_PLANE_TENANT_PER_PROVIDER_ENVIRONMENT_NOT_PER_TAXAT_BUSINESS_TENANT"
        },
        "typed_gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
