{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/manual_checkpoint_evidence_pack.schema.json",
  "title": "ManualCheckpointEvidencePack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "evidence_pack_id",
    "checkpoint_record_ref",
    "run_id",
    "provider_id",
    "evidence_root",
    "page_signature",
    "safe_copy_snapshot",
    "artifact_rows",
    "provider_docs_urls",
    "source_refs",
    "notes"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "evidence_pack_id": { "const": "manual_checkpoint_evidence_pack" },
    "checkpoint_record_ref": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "provider_id": { "type": "string", "minLength": 1 },
    "evidence_root": { "type": "string", "minLength": 1 },
    "page_signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title_hash_sha256",
        "url_hash_sha256",
        "dom_hash_sha256",
        "safe_route_fingerprint"
      ],
      "properties": {
        "title_hash_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "url_hash_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "dom_hash_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "safe_route_fingerprint": { "type": "string", "minLength": 1 }
      }
    },
    "safe_copy_snapshot": { "type": "string", "minLength": 1 },
    "artifact_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_ref",
          "artifact_kind",
          "capture_mode",
          "relative_path_or_null",
          "summary",
          "redaction_notes"
        ],
        "properties": {
          "artifact_ref": { "type": "string", "minLength": 1 },
          "artifact_kind": {
            "type": "string",
            "enum": [
              "MASKED_SCREENSHOT",
              "DOM_SIGNATURE",
              "TRACE_REFERENCE",
              "SAFE_COPY_SNAPSHOT"
            ]
          },
          "capture_mode": {
            "type": "string",
            "enum": ["REDACTED", "SUPPRESSED", "HASH_ONLY"]
          },
          "relative_path_or_null": {
            "type": ["string", "null"]
          },
          "summary": { "type": "string", "minLength": 1 },
          "redaction_notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "provider_docs_urls": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "format": "uri" }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_ref", "rationale"],
        "properties": {
          "source_ref": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 }
        }
      }
    },
    "notes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
