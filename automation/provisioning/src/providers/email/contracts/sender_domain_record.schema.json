{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.example/schemas/sender_domain_record.schema.json",
  "title": "Sender Domain Record",
  "type": "object",
  "required": [
    "schema_version",
    "record_id",
    "provider_id",
    "provider_display_name",
    "run_id",
    "flow_id",
    "workspace_record_ref",
    "operator_identity_alias",
    "provider_selection",
    "sender_domains",
    "truth_boundary_statement",
    "typed_gaps",
    "notes",
    "last_verified_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "const": "transactional-email-delivery-control-plane"
    },
    "provider_display_name": {
      "const": "Transactional Email Delivery Control Plane"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "flow_id": {
      "const": "email-workspace-and-sender-domain-bootstrap"
    },
    "workspace_record_ref": {
      "type": "string",
      "minLength": 1
    },
    "operator_identity_alias": {
      "type": "string",
      "minLength": 1
    },
    "provider_selection": {
      "type": "object",
      "required": [
        "provider_selection_status",
        "provider_family",
        "provider_vendor_adapter",
        "provider_vendor_label",
        "docs_urls",
        "source_refs"
      ],
      "properties": {
        "provider_selection_status": {
          "const": "PROVIDER_DEFAULT_APPLIED"
        },
        "provider_family": {
          "const": "TRANSACTIONAL_EMAIL_DELIVERY"
        },
        "provider_vendor_adapter": {
          "const": "POSTMARK_COMPATIBLE_CONTROL_PLANE"
        },
        "provider_vendor_label": {
          "type": "string",
          "minLength": 1
        },
        "docs_urls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        }
      },
      "additionalProperties": false
    },
    "sender_domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "domain_ref",
          "product_environment_id",
          "provider_environment_tag",
          "workspace_ref",
          "sender_domain",
          "return_path_domain",
          "dmarc_host",
          "source_disposition",
          "verification_state",
          "readiness_state",
          "manual_checkpoint_open",
          "dns_inventory_ref",
          "message_stream_catalog_ref",
          "sender_identities",
          "source_refs",
          "notes"
        ],
        "properties": {
          "domain_ref": {
            "type": "string",
            "minLength": 1
          },
          "product_environment_id": {
            "type": "string",
            "enum": [
              "env_shared_sandbox_integration",
              "env_preproduction_verification",
              "env_production"
            ]
          },
          "provider_environment_tag": {
            "type": "string",
            "enum": [
              "SANDBOX",
              "PREPRODUCTION",
              "PRODUCTION"
            ]
          },
          "workspace_ref": {
            "type": "string",
            "minLength": 1
          },
          "sender_domain": {
            "type": "string",
            "minLength": 1
          },
          "return_path_domain": {
            "type": "string",
            "minLength": 1
          },
          "dmarc_host": {
            "type": "string",
            "pattern": "^_dmarc\\."
          },
          "source_disposition": {
            "type": "string",
            "enum": [
              "CREATED_DURING_RUN",
              "ADOPTED_EXISTING"
            ]
          },
          "verification_state": {
            "type": "string",
            "enum": [
              "VERIFIED",
              "PENDING_DNS",
              "PENDING_PROVIDER_CONFIRMATION"
            ]
          },
          "readiness_state": {
            "type": "string",
            "enum": [
              "ACTIVE_AND_RUNTIME_VERIFIED",
              "MANUAL_CHECKPOINT_REQUIRED"
            ]
          },
          "manual_checkpoint_open": {
            "type": "boolean"
          },
          "dns_inventory_ref": {
            "type": "string",
            "minLength": 1
          },
          "message_stream_catalog_ref": {
            "type": "string",
            "minLength": 1
          },
          "sender_identities": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "identity_ref",
                "label",
                "from_address",
                "reply_to_address",
                "sender_signature_mode"
              ],
              "properties": {
                "identity_ref": {
                  "type": "string",
                  "minLength": 1
                },
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "from_address": {
                  "type": "string",
                  "pattern": "^[^@]+@[^@]+$"
                },
                "reply_to_address": {
                  "type": "string",
                  "pattern": "^[^@]+@[^@]+$"
                },
                "sender_signature_mode": {
                  "type": "string",
                  "enum": [
                    "DOMAIN_VERIFIED_ANY_MAILBOX_ALLOWED",
                    "OPTIONAL_REPLY_TO_SIGNATURE_ONLY"
                  ]
                }
              },
              "additionalProperties": false
            }
          },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/sourceRef"
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "truth_boundary_statement": {
      "type": "string",
      "minLength": 1
    },
    "typed_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_verified_at": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sourceRef": {
      "type": "object",
      "required": [
        "source_ref",
        "rationale"
      ],
      "properties": {
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
