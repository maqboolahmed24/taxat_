{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.example/schemas/provisioning/email/email_template_record.schema.json",
  "title": "EmailTemplateRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "template_ref",
    "template_alias",
    "label",
    "notification_family",
    "allowed_trigger_events",
    "visibility_class",
    "customer_safe_projection_required",
    "localization_posture",
    "sender_stream_ref",
    "sender_identity_profile_ref",
    "subject_template",
    "preheader_template",
    "headline_template",
    "body_template_paragraphs",
    "cta_label_template",
    "cta_route_template",
    "footer_template_paragraphs",
    "allowed_merge_variables",
    "required_merge_variables",
    "fallback_rules",
    "continuity",
    "provider_tracking_defaults",
    "sample_render_model",
    "source_refs",
    "notes"
  ],
  "properties": {
    "template_ref": {
      "type": "string",
      "pattern": "^email_template_[a-z0-9_]+$"
    },
    "template_alias": {
      "type": "string",
      "minLength": 1
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "notification_family": {
      "enum": [
        "REQUEST_INFO_CREATED",
        "STAFF_CUSTOMER_COMMENT_CREATED",
        "CUSTOMER_DUE_DATE_CHANGED",
        "ITEM_RESOLVED_OR_CLOSED",
        "PORTAL_HELP_ACKNOWLEDGED",
        "SUPPORT_CONTACT_ACKNOWLEDGED"
      ]
    },
    "allowed_trigger_events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "visibility_class": {
      "const": "CUSTOMER_VISIBLE"
    },
    "customer_safe_projection_required": {
      "const": true
    },
    "localization_posture": {
      "const": "EN_GB_ONLY"
    },
    "sender_stream_ref": {
      "const": "email_stream_customer_transactional"
    },
    "sender_identity_profile_ref": {
      "enum": [
        "customer_transactional_noreply",
        "support_acknowledgement_help"
      ]
    },
    "subject_template": {
      "type": "string",
      "minLength": 1
    },
    "preheader_template": {
      "type": "string",
      "minLength": 1
    },
    "headline_template": {
      "type": "string",
      "minLength": 1
    },
    "body_template_paragraphs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "cta_label_template": {
      "type": "string",
      "minLength": 1
    },
    "cta_route_template": {
      "type": "string",
      "minLength": 1
    },
    "footer_template_paragraphs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_merge_variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+$"
      }
    },
    "required_merge_variables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]+$"
      }
    },
    "fallback_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "continuity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shell_family",
        "object_anchor_ref_template",
        "target_route_ref_template",
        "focus_anchor_ref_template",
        "return_route_ref_template",
        "return_focus_anchor_ref_template",
        "fallback_route_ref_template",
        "fallback_focus_anchor_ref_template"
      ],
      "properties": {
        "shell_family": {
          "const": "CLIENT_PORTAL_SHELL"
        },
        "object_anchor_ref_template": {
          "type": "string",
          "minLength": 1
        },
        "target_route_ref_template": {
          "type": "string",
          "minLength": 1
        },
        "focus_anchor_ref_template": {
          "type": "string",
          "minLength": 1
        },
        "return_route_ref_template": {
          "type": "string",
          "minLength": 1
        },
        "return_focus_anchor_ref_template": {
          "type": "string",
          "minLength": 1
        },
        "fallback_route_ref_template": {
          "type": "string",
          "minLength": 1
        },
        "fallback_focus_anchor_ref_template": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "provider_tracking_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "track_opens",
        "track_links"
      ],
      "properties": {
        "track_opens": {
          "const": false
        },
        "track_links": {
          "const": "None"
        }
      }
    },
    "sample_render_model": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceRef"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "rationale"
      ],
      "properties": {
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
