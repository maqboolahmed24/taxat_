{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.example/schemas/email_provider_workspace.schema.json",
  "title": "Email Provider Workspace Record",
  "type": "object",
  "required": [
    "schema_version",
    "workspace_record_id",
    "provider_id",
    "provider_display_name",
    "run_id",
    "flow_id",
    "workspace_id",
    "operator_identity_alias",
    "provider_selection",
    "workspace_rows",
    "typed_gaps",
    "notes",
    "last_verified_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "workspace_record_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "const": "transactional-email-delivery-control-plane"
    },
    "provider_display_name": {
      "const": "Transactional Email Delivery Control Plane"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "flow_id": {
      "const": "email-workspace-and-sender-domain-bootstrap"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "operator_identity_alias": {
      "type": "string",
      "minLength": 1
    },
    "provider_selection": {
      "type": "object",
      "required": [
        "provider_selection_status",
        "provider_family",
        "provider_vendor_adapter",
        "provider_vendor_label",
        "docs_urls",
        "source_refs"
      ],
      "properties": {
        "provider_selection_status": {
          "const": "PROVIDER_DEFAULT_APPLIED"
        },
        "provider_family": {
          "const": "TRANSACTIONAL_EMAIL_DELIVERY"
        },
        "provider_vendor_adapter": {
          "const": "POSTMARK_COMPATIBLE_CONTROL_PLANE"
        },
        "provider_vendor_label": {
          "type": "string",
          "minLength": 1
        },
        "docs_urls": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        }
      },
      "additionalProperties": false
    },
    "workspace_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "workspace_ref",
          "product_environment_id",
          "provider_environment_tag",
          "server_label",
          "server_alias",
          "server_delivery_type",
          "sender_domain_ref",
          "source_disposition",
          "allows_live_recipients",
          "account_token_metadata_ref",
          "server_token_metadata_ref",
          "server_token_fingerprint",
          "webhook_configuration_state",
          "message_stream_refs",
          "suppression_posture_ref",
          "source_refs",
          "notes"
        ],
        "properties": {
          "workspace_ref": {
            "type": "string",
            "minLength": 1
          },
          "product_environment_id": {
            "type": "string",
            "enum": [
              "env_local_provisioning_workstation",
              "env_shared_sandbox_integration",
              "env_preproduction_verification",
              "env_production"
            ]
          },
          "provider_environment_tag": {
            "type": "string",
            "enum": [
              "LOCAL_BOOTSTRAP",
              "SANDBOX",
              "PREPRODUCTION",
              "PRODUCTION"
            ]
          },
          "server_label": {
            "type": "string",
            "minLength": 1
          },
          "server_alias": {
            "type": "string",
            "minLength": 1
          },
          "server_delivery_type": {
            "type": "string",
            "enum": [
              "Sandbox",
              "Live"
            ]
          },
          "sender_domain_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "source_disposition": {
            "type": "string",
            "enum": [
              "CREATED_DURING_RUN",
              "ADOPTED_EXISTING"
            ]
          },
          "allows_live_recipients": {
            "type": "boolean"
          },
          "account_token_metadata_ref": {
            "type": "string",
            "minLength": 1
          },
          "server_token_metadata_ref": {
            "type": "string",
            "minLength": 1
          },
          "server_token_fingerprint": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "webhook_configuration_state": {
            "type": "string",
            "enum": [
              "DEFERRED_TO_PC_0042",
              "NOT_APPLICABLE_ON_BOOTSTRAP"
            ]
          },
          "message_stream_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "suppression_posture_ref": {
            "type": "string",
            "minLength": 1
          },
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/sourceRef"
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "typed_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_verified_at": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false,
  "$defs": {
    "sourceRef": {
      "type": "object",
      "required": [
        "source_ref",
        "rationale"
      ],
      "properties": {
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
