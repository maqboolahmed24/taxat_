{
  "manifestId": "hmrc-sandbox-app-oauth-settings",
  "providerId": "hmrc-developer-hub",
  "flowId": "sandbox-app-registration",
  "selectors": [
    {
      "selectorId": "cookie-accept",
      "description": "Accept additional cookies button",
      "strategy": "ROLE",
      "value": "button",
      "accessibleName": "Accept additional cookies"
    },
    {
      "selectorId": "cookie-reject",
      "description": "Reject additional cookies button",
      "strategy": "ROLE",
      "value": "button",
      "accessibleName": "Reject additional cookies"
    },
    {
      "selectorId": "applications-heading",
      "description": "Applications console heading",
      "strategy": "ROLE",
      "value": "heading",
      "accessibleName": "Applications"
    },
    {
      "selectorId": "manage-redirect-uris",
      "description": "Link that opens redirect-URI settings for the current application",
      "strategy": "ROLE",
      "value": "link",
      "accessibleName": "Manage redirect URIs"
    },
    {
      "selectorId": "redirect-settings-heading",
      "description": "Redirect-URI settings heading",
      "strategy": "ROLE",
      "value": "heading",
      "accessibleName": "Redirect URIs"
    },
    {
      "selectorId": "redirect-uri-slot",
      "description": "Container for one redirect-URI slot",
      "strategy": "TEST_ID",
      "value": "redirect-uri-slot"
    },
    {
      "selectorId": "save-redirect-uris",
      "description": "Button that saves redirect-URI settings",
      "strategy": "ROLE",
      "value": "button",
      "accessibleName": "Save redirect URIs"
    },
    {
      "selectorId": "scope-summary",
      "description": "Read-only scope summary for the current sandbox app",
      "strategy": "TEXT",
      "value": "Requested scopes"
    }
  ]
}
