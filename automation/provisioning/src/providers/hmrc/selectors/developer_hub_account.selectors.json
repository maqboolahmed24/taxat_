{
  "manifestId": "hmrc-developer-hub-account-public-pages",
  "providerId": "hmrc-developer-hub",
  "flowId": "developer-hub-workspace-setup",
  "selectors": [
    {
      "selectorId": "cookie-accept",
      "description": "Accept optional cookies button shown on public Developer Hub pages",
      "strategy": "ROLE",
      "value": "button",
      "accessibleName": "Accept additional cookies"
    },
    {
      "selectorId": "cookie-reject",
      "description": "Reject optional cookies button shown on public Developer Hub pages",
      "strategy": "ROLE",
      "value": "button",
      "accessibleName": "Reject additional cookies"
    },
    {
      "selectorId": "applications-nav",
      "description": "Applications entry in the top-level Developer Hub navigation",
      "strategy": "ROLE",
      "value": "link",
      "accessibleName": "Applications"
    },
    {
      "selectorId": "registration-heading",
      "description": "Registration page heading",
      "strategy": "ROLE",
      "value": "heading",
      "accessibleName": "Register for a developer account"
    },
    {
      "selectorId": "registration-first-name",
      "description": "First name field on the registration form",
      "strategy": "LABEL",
      "value": "First name"
    },
    {
      "selectorId": "registration-last-name",
      "description": "Last name field on the registration form",
      "strategy": "LABEL",
      "value": "Last name"
    },
    {
      "selectorId": "registration-email",
      "description": "Email field on the registration form",
      "strategy": "LABEL",
      "value": "Email address"
    },
    {
      "selectorId": "registration-password",
      "description": "Password field on the registration form",
      "strategy": "LABEL",
      "value": "Create password"
    },
    {
      "selectorId": "registration-confirm-password",
      "description": "Password confirmation field on the registration form",
      "strategy": "LABEL",
      "value": "Confirm password"
    },
    {
      "selectorId": "registration-submit",
      "description": "Submit button on the registration form",
      "strategy": "ROLE",
      "value": "button",
      "accessibleName": "Register"
    },
    {
      "selectorId": "sign-in-heading",
      "description": "Sign-in page heading",
      "strategy": "ROLE",
      "value": "heading",
      "accessibleName": "Sign in"
    },
    {
      "selectorId": "sign-in-email",
      "description": "Email field on the sign-in form",
      "strategy": "LABEL",
      "value": "Email address"
    },
    {
      "selectorId": "sign-in-password",
      "description": "Password field on the sign-in form",
      "strategy": "LABEL",
      "value": "Password"
    },
    {
      "selectorId": "sign-in-submit",
      "description": "Submit button on the sign-in form",
      "strategy": "ROLE",
      "value": "button",
      "accessibleName": "Sign in"
    },
    {
      "selectorId": "forgot-password",
      "description": "Forgot password recovery link",
      "strategy": "ROLE",
      "value": "link",
      "accessibleName": "I've forgotten my password"
    },
    {
      "selectorId": "applications-heading",
      "description": "Applications landing heading after successful authentication",
      "strategy": "ROLE",
      "value": "heading",
      "accessibleName": "Applications"
    },
    {
      "selectorId": "add-application-link",
      "description": "Primary action from the Applications area",
      "strategy": "TEXT",
      "value": "Add an application"
    }
  ]
}
