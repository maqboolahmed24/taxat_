{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/provisioning/hmrc/hmrc_client_vault_binding.schema.json",
  "title": "HMRCClientVaultBinding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "binding_id",
    "provider_id",
    "provider_display_name",
    "run_id",
    "flow_id",
    "workspace_id",
    "provider_environment_target",
    "application_inventory_ref",
    "secret_lineage_ref",
    "capture_boundary",
    "environment_bindings",
    "typed_gaps",
    "notes",
    "last_verified_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "binding_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "type": "string",
      "const": "hmrc-developer-hub"
    },
    "provider_display_name": {
      "type": "string",
      "const": "HMRC Developer Hub"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "flow_id": {
      "type": "string",
      "const": "sandbox-client-credential-export"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_environment_target": {
      "type": "string",
      "const": "sandbox"
    },
    "application_inventory_ref": {
      "type": "string",
      "minLength": 1
    },
    "secret_lineage_ref": {
      "type": "string",
      "minLength": 1
    },
    "capture_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "capture_channel_id",
        "manual_checkpoint_policy",
        "raw_secret_persistence_policy",
        "sanitized_evidence_manifest_ref"
      ],
      "properties": {
        "capture_channel_id": {
          "type": "string",
          "enum": [
            "PROVIDER_ONE_TIME_REVEAL_CAPTURE",
            "ADOPT_EXISTING_LINEAGE"
          ]
        },
        "manual_checkpoint_policy": {
          "type": "string",
          "enum": [
            "MANUAL_CHECKPOINT_REQUIRED_IF_VISIBLE",
            "NOT_REQUIRED_FOR_ADOPTION"
          ]
        },
        "raw_secret_persistence_policy": {
          "type": "string",
          "const": "EPHEMERAL_MEMORY_ONLY_UNTIL_VAULT_WRITE"
        },
        "sanitized_evidence_manifest_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "environment_bindings": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/environmentBinding"
      }
    },
    "typed_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_verified_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "environmentBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_row_id",
        "environment_ref",
        "connection_method",
        "namespace_ref",
        "callback_profile_ref",
        "token_binding_profile_ref",
        "fraud_header_profile_ref",
        "authority_profile_refs",
        "scope_set_ref",
        "scopes",
        "client_id_store_ref",
        "client_secret_store_ref",
        "client_secret_metadata_ref",
        "active_secret_version_id",
        "vault_write_receipt_ref",
        "attestation_ref"
      ],
      "properties": {
        "binding_row_id": {
          "type": "string",
          "minLength": 1
        },
        "environment_ref": {
          "type": "string",
          "minLength": 1
        },
        "connection_method": {
          "type": "string",
          "enum": [
            "WEB_APP_VIA_SERVER",
            "DESKTOP_APP_VIA_SERVER"
          ]
        },
        "namespace_ref": {
          "type": "string",
          "minLength": 1
        },
        "callback_profile_ref": {
          "type": "string",
          "minLength": 1
        },
        "token_binding_profile_ref": {
          "type": "string",
          "minLength": 1
        },
        "fraud_header_profile_ref": {
          "type": "string",
          "minLength": 1
        },
        "authority_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "scope_set_ref": {
          "type": "string",
          "minLength": 1
        },
        "scopes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "client_id_store_ref": {
          "type": "string",
          "minLength": 1
        },
        "client_secret_store_ref": {
          "type": "string",
          "minLength": 1
        },
        "client_secret_metadata_ref": {
          "type": "string",
          "minLength": 1
        },
        "active_secret_version_id": {
          "type": "string",
          "minLength": 1
        },
        "vault_write_receipt_ref": {
          "type": "string",
          "minLength": 1
        },
        "attestation_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
