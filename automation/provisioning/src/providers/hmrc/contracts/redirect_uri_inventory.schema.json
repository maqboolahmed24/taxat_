{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/provisioning/hmrc/redirect_uri_inventory.schema.json",
  "title": "HMRCRedirectUriInventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "inventory_id",
    "provider_id",
    "provider_display_name",
    "run_id",
    "workspace_id",
    "flow_id",
    "application_record_ref",
    "required_api_baseline_ref",
    "provider_environment_target",
    "redirect_uri_budget_max",
    "configured_rows",
    "disallowed_rows",
    "unallocated_slot_count",
    "configured_redirect_uris",
    "typed_gaps",
    "evidence_refs",
    "notes",
    "last_verified_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "inventory_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "type": "string",
      "const": "hmrc-developer-hub"
    },
    "provider_display_name": {
      "type": "string",
      "const": "HMRC Developer Hub"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "flow_id": {
      "type": "string",
      "const": "sandbox-app-registration"
    },
    "application_record_ref": {
      "type": "string",
      "minLength": 1
    },
    "required_api_baseline_ref": {
      "type": "string",
      "minLength": 1
    },
    "provider_environment_target": {
      "type": "string",
      "const": "sandbox"
    },
    "redirect_uri_budget_max": {
      "type": "integer",
      "minimum": 1
    },
    "configured_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/redirectRow"
      }
    },
    "disallowed_rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/redirectRow"
      }
    },
    "unallocated_slot_count": {
      "type": "integer",
      "minimum": 0
    },
    "configured_redirect_uris": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "typed_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_verified_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "rationale"],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "redirectRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_index",
        "callback_profile_ref",
        "connection_method",
        "environment_ref",
        "owning_deployable_id",
        "redirect_uri",
        "registration_decision",
        "rationale",
        "host_separation_rule",
        "provider_ingress_uri_pattern",
        "source_refs"
      ],
      "properties": {
        "slot_index": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "callback_profile_ref": {
          "type": "string",
          "minLength": 1
        },
        "connection_method": {
          "type": "string",
          "enum": ["WEB_APP_VIA_SERVER", "DESKTOP_APP_VIA_SERVER"]
        },
        "environment_ref": {
          "type": "string",
          "minLength": 1
        },
        "owning_deployable_id": {
          "type": "string",
          "minLength": 1
        },
        "redirect_uri": {
          "type": "string",
          "minLength": 1
        },
        "registration_decision": {
          "type": "string",
          "enum": [
            "CONFIGURE_NOW",
            "DO_NOT_REGISTER_ON_SANDBOX_APP",
            "UNALLOCATED_FUTURE_SLOT"
          ]
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        },
        "host_separation_rule": {
          "type": "string",
          "minLength": 1
        },
        "provider_ingress_uri_pattern": {
          "type": ["string", "null"]
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        }
      }
    }
  }
}
