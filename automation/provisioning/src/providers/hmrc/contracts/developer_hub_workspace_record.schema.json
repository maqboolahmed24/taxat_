{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/provisioning/hmrc/developer_hub_workspace_record.schema.json",
  "title": "HMRCDeveloperHubWorkspaceRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workspace_record_id",
    "provider_id",
    "provider_display_name",
    "workspace_id",
    "run_id",
    "flow_id",
    "product_environment_id",
    "provider_environment",
    "operator_identity_alias",
    "developer_hub_account",
    "workspace_state",
    "secret_ref_bindings",
    "evidence_refs",
    "console_location_refs",
    "notes",
    "last_verified_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "workspace_record_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "type": "string",
      "const": "hmrc-developer-hub"
    },
    "provider_display_name": {
      "type": "string",
      "const": "HMRC Developer Hub"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "flow_id": {
      "type": "string",
      "const": "developer-hub-workspace-setup"
    },
    "product_environment_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_environment": {
      "type": "string",
      "enum": ["sandbox", "production", "fixture"]
    },
    "operator_identity_alias": {
      "type": "string",
      "minLength": 1
    },
    "developer_hub_account": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "account_alias",
        "email_alias",
        "account_status",
        "activation_status",
        "source_disposition"
      ],
      "properties": {
        "account_alias": {
          "type": "string",
          "minLength": 1
        },
        "email_alias": {
          "type": "string",
          "minLength": 1
        },
        "account_status": {
          "type": "string",
          "enum": [
            "ACTIVE",
            "ACTIVATION_PENDING",
            "SIGN_IN_REQUIRED",
            "SECURITY_REVIEW_REQUIRED"
          ]
        },
        "activation_status": {
          "type": "string",
          "enum": [
            "NOT_REQUIRED",
            "EMAIL_VERIFICATION_PENDING",
            "VERIFIED",
            "SECURITY_INTERSTITIAL_PENDING"
          ]
        },
        "source_disposition": {
          "type": "string",
          "enum": [
            "ADOPTED_EXISTING",
            "CREATED_DURING_RUN",
            "RESUMED_AFTER_PARTIAL_FAILURE"
          ]
        }
      }
    },
    "workspace_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "landing_status",
        "manual_checkpoint_open",
        "last_completed_step_id",
        "last_safe_page_url",
        "applications_console_url",
        "evidence_manifest_ref",
        "resume_snapshot_ref"
      ],
      "properties": {
        "landing_status": {
          "type": "string",
          "enum": [
            "APPLICATIONS_HOME_REACHED",
            "AUTHENTICATION_REQUIRED",
            "ACTIVATION_REQUIRED",
            "SECURITY_INTERSTITIAL_REQUIRED"
          ]
        },
        "manual_checkpoint_open": {
          "type": "boolean"
        },
        "last_completed_step_id": {
          "type": "string",
          "minLength": 1
        },
        "last_safe_page_url": {
          "type": "string",
          "minLength": 1
        },
        "applications_console_url": {
          "type": "string",
          "minLength": 1
        },
        "evidence_manifest_ref": {
          "type": "string",
          "minLength": 1
        },
        "resume_snapshot_ref": {
          "type": ["string", "null"]
        }
      }
    },
    "secret_ref_bindings": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["secret_class_id", "ref_kind", "ref_value"],
        "properties": {
          "secret_class_id": {
            "type": "string",
            "enum": [
              "developer_hub_account_alias",
              "developer_hub_password_ref",
              "developer_hub_activation_channel_ref",
              "developer_hub_mfa_recovery_material_ref",
              "provisioning_browser_storage_state_ref"
            ]
          },
          "ref_kind": {
            "type": "string",
            "minLength": 1
          },
          "ref_value": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "console_location_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_verified_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
