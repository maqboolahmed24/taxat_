{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/provisioning/hmrc/fraud_header_profile.schema.json",
  "title": "HMRCFraudHeaderProfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profile_id",
    "provider_id",
    "provider_display_name",
    "fraud_header_profile_ref",
    "connection_method",
    "verified_on",
    "validator_api",
    "capture_boundary",
    "fields",
    "source_refs",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "type": "string",
      "const": "hmrc-developer-hub"
    },
    "provider_display_name": {
      "type": "string",
      "const": "HMRC Developer Hub"
    },
    "fraud_header_profile_ref": {
      "type": "string",
      "minLength": 1
    },
    "connection_method": {
      "type": "string",
      "enum": [
        "WEB_APP_VIA_SERVER",
        "DESKTOP_APP_VIA_SERVER"
      ]
    },
    "verified_on": {
      "type": "string",
      "format": "date"
    },
    "validator_api": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_url",
        "validate_path",
        "validation_feedback_path"
      ],
      "properties": {
        "base_url": {
          "type": "string",
          "format": "uri"
        },
        "validate_path": {
          "type": "string",
          "pattern": "^/"
        },
        "validation_feedback_path": {
          "type": "string",
          "pattern": "^/"
        }
      }
    },
    "capture_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "originating_surface",
        "device_context_capture_owner",
        "header_serialization_owner",
        "raw_value_persistence_policy"
      ],
      "properties": {
        "originating_surface": {
          "type": "string",
          "minLength": 1
        },
        "device_context_capture_owner": {
          "type": "string",
          "minLength": 1
        },
        "header_serialization_owner": {
          "type": "string",
          "minLength": 1
        },
        "raw_value_persistence_policy": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fieldProfile"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceRef"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "rationale"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "missingDataPosture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_after_hmrc_agreement",
        "serialization_when_missing",
        "evidence_requirement"
      ],
      "properties": {
        "allowed_after_hmrc_agreement": {
          "type": "boolean"
        },
        "serialization_when_missing": {
          "type": "string",
          "enum": [
            "FORBID",
            "OMIT",
            "EMPTY_STRING"
          ]
        },
        "evidence_requirement": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "fieldProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_id",
        "header_name",
        "value_kind",
        "presence",
        "encoding_strategy",
        "collection_timing",
        "collected_by",
        "serialized_by",
        "stability_expectation",
        "sensitive_value_policy",
        "missing_data_posture",
        "notes"
      ],
      "properties": {
        "field_id": {
          "type": "string",
          "minLength": 1
        },
        "header_name": {
          "type": "string",
          "pattern": "^Gov-[A-Za-z0-9-]+$"
        },
        "value_kind": {
          "type": "string",
          "enum": [
            "SCALAR",
            "LIST",
            "KEY_VALUE_PAIRS",
            "LIST_OF_KEY_VALUE_PAIRS"
          ]
        },
        "presence": {
          "type": "string",
          "enum": [
            "MANDATORY",
            "CONDITIONALLY_UNAVAILABLE"
          ]
        },
        "encoding_strategy": {
          "type": "string",
          "enum": [
            "RAW",
            "PERCENT_ENCODE_VALUE",
            "PERCENT_ENCODE_LIST_ITEMS",
            "PERCENT_ENCODE_KV_COMPONENTS",
            "PERCENT_ENCODE_LIST_OF_KV_COMPONENTS"
          ]
        },
        "collection_timing": {
          "type": "string",
          "enum": [
            "DEVICE_BOOT_OR_INSTALL",
            "INTERACTION_TIME",
            "PER_REQUEST",
            "RELEASE_OR_DEPLOY_TIME"
          ]
        },
        "collected_by": {
          "type": "string",
          "minLength": 1
        },
        "serialized_by": {
          "type": "string",
          "minLength": 1
        },
        "stability_expectation": {
          "type": "string",
          "enum": [
            "STABLE_PER_INSTALL",
            "STABLE_PER_RELEASE",
            "REFRESH_PER_REQUEST",
            "REFRESH_PER_INTERACTION"
          ]
        },
        "sensitive_value_policy": {
          "type": "string",
          "enum": [
            "SUMMARY_ONLY_REPO_SAFE",
            "SUPPRESS_RAW_VALUE_IN_REPO_ARTIFACTS"
          ]
        },
        "missing_data_posture": {
          "$ref": "#/$defs/missingDataPosture"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
