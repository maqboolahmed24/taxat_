{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/provisioning/hmrc/hmrc_client_secret_lineage.schema.json",
  "title": "HMRCClientSecretLineage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lineage_id",
    "provider_id",
    "provider_display_name",
    "run_id",
    "flow_id",
    "workspace_id",
    "provider_environment_target",
    "application_inventory_ref",
    "secret_class_id",
    "binding_lineage_ref",
    "provider_limit_max_active_secrets",
    "taxat_overlap_limit_max_active_secrets",
    "versions",
    "active_version_ids",
    "retired_version_ids",
    "supersession_edges",
    "typed_gaps",
    "notes",
    "last_verified_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "lineage_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "type": "string",
      "const": "hmrc-developer-hub"
    },
    "provider_display_name": {
      "type": "string",
      "const": "HMRC Developer Hub"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "flow_id": {
      "type": "string",
      "const": "sandbox-client-credential-export"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_environment_target": {
      "type": "string",
      "const": "sandbox"
    },
    "application_inventory_ref": {
      "type": "string",
      "minLength": 1
    },
    "secret_class_id": {
      "type": "string",
      "const": "hmrc_sandbox_client_secret_version_ref"
    },
    "binding_lineage_ref": {
      "type": "string",
      "minLength": 1
    },
    "provider_limit_max_active_secrets": {
      "type": "integer",
      "const": 5
    },
    "taxat_overlap_limit_max_active_secrets": {
      "type": "integer",
      "const": 2
    },
    "versions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/versionRow"
      }
    },
    "active_version_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "retired_version_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "supersession_edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/supersessionEdge"
      }
    },
    "typed_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_verified_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "secretVersionContract": {
      "type": "object",
      "required": [
        "artifact_type",
        "secret_version_id",
        "secret_class",
        "store_ref",
        "key_version_ref",
        "policy_profile_ref",
        "lineage_ref",
        "issued_at",
        "expires_at",
        "rotation_state",
        "last_attested_at",
        "attestation_ref",
        "activated_at",
        "rotation_started_at",
        "retired_at",
        "revoked_at",
        "revocation_reason_code",
        "historical_read_window_until",
        "superseded_by_secret_version_id"
      ],
      "properties": {
        "artifact_type": {
          "const": "SecretVersion"
        },
        "secret_version_id": {
          "type": "string",
          "minLength": 1
        },
        "secret_class": {
          "type": "string",
          "const": "HMRC_SANDBOX_CLIENT_SECRET_VERSION_REF"
        },
        "store_ref": {
          "type": "string",
          "minLength": 1
        },
        "key_version_ref": {
          "type": "string",
          "minLength": 1
        },
        "policy_profile_ref": {
          "type": "string",
          "minLength": 1
        },
        "lineage_ref": {
          "type": "string",
          "minLength": 1
        },
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "rotation_state": {
          "type": "string",
          "enum": [
            "ISSUED",
            "ATTESTED",
            "ACTIVE",
            "ROTATING",
            "RETIRED",
            "REVOKED"
          ]
        },
        "last_attested_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "attestation_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "activated_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "rotation_started_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "retired_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "revoked_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "revocation_reason_code": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "historical_read_window_until": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "superseded_by_secret_version_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      }
    },
    "versionRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version_row_id",
        "secret_version_contract",
        "client_secret_fingerprint",
        "capture_channel_id",
        "capture_method",
        "manual_checkpoint_ref_or_null",
        "vault_write_receipt_ref",
        "token_exchange_verification_ref_or_null",
        "retirement_ref_or_null",
        "source_evidence_refs"
      ],
      "properties": {
        "version_row_id": {
          "type": "string",
          "minLength": 1
        },
        "secret_version_contract": {
          "$ref": "#/$defs/secretVersionContract"
        },
        "client_secret_fingerprint": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "capture_channel_id": {
          "type": "string",
          "enum": [
            "PROVIDER_ONE_TIME_REVEAL_CAPTURE",
            "ADOPT_EXISTING_LINEAGE"
          ]
        },
        "capture_method": {
          "type": "string",
          "minLength": 1
        },
        "manual_checkpoint_ref_or_null": {
          "type": [
            "string",
            "null"
          ]
        },
        "vault_write_receipt_ref": {
          "type": "string",
          "minLength": 1
        },
        "token_exchange_verification_ref_or_null": {
          "type": [
            "string",
            "null"
          ]
        },
        "retirement_ref_or_null": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_evidence_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "supersessionEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from_secret_version_id",
        "to_secret_version_id",
        "transition_reason"
      ],
      "properties": {
        "from_secret_version_id": {
          "type": "string",
          "minLength": 1
        },
        "to_secret_version_id": {
          "type": "string",
          "minLength": 1
        },
        "transition_reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
