{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/provisioning/hmrc/sandbox_application_record.schema.json",
  "title": "HMRCSandboxApplicationRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "application_record_id",
    "provider_id",
    "provider_display_name",
    "workspace_id",
    "run_id",
    "flow_id",
    "product_environment_id",
    "provider_environment",
    "operator_identity_alias",
    "developer_hub_workspace_record_ref",
    "required_api_baseline_ref",
    "subscription_matrix_ref",
    "sandbox_application",
    "portal_state",
    "evidence_refs",
    "console_location_refs",
    "notes",
    "last_verified_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "application_record_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "type": "string",
      "const": "hmrc-developer-hub"
    },
    "provider_display_name": {
      "type": "string",
      "const": "HMRC Developer Hub"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "flow_id": {
      "type": "string",
      "const": "sandbox-app-registration"
    },
    "product_environment_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_environment": {
      "type": "string",
      "enum": ["sandbox", "production", "fixture"]
    },
    "operator_identity_alias": {
      "type": "string",
      "minLength": 1
    },
    "developer_hub_workspace_record_ref": {
      "type": "string",
      "minLength": 1
    },
    "required_api_baseline_ref": {
      "type": "string",
      "minLength": 1
    },
    "subscription_matrix_ref": {
      "type": ["string", "null"]
    },
    "sandbox_application": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "application_alias",
        "application_display_name",
        "portal_environment",
        "source_disposition",
        "subscription_state",
        "application_console_url",
        "api_subscriptions_page_url"
      ],
      "properties": {
        "application_alias": {
          "type": "string",
          "minLength": 1
        },
        "application_display_name": {
          "type": "string",
          "minLength": 1
        },
        "portal_environment": {
          "type": "string",
          "const": "SANDBOX"
        },
        "source_disposition": {
          "type": "string",
          "enum": [
            "ADOPTED_EXISTING",
            "CREATED_DURING_RUN",
            "RECREATED_AFTER_RETENTION_EXPIRY"
          ]
        },
        "subscription_state": {
          "type": "string",
          "enum": [
            "NOT_YET_VERIFIED",
            "PARTIALLY_SUBSCRIBED",
            "REQUIRED_NOW_SUBSCRIBED"
          ]
        },
        "application_console_url": {
          "type": "string",
          "minLength": 1
        },
        "api_subscriptions_page_url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "portal_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applications_console_url",
        "last_safe_page_url",
        "last_completed_step_id",
        "manual_checkpoint_open",
        "evidence_manifest_ref"
      ],
      "properties": {
        "applications_console_url": {
          "type": "string",
          "minLength": 1
        },
        "last_safe_page_url": {
          "type": "string",
          "minLength": 1
        },
        "last_completed_step_id": {
          "type": "string",
          "minLength": 1
        },
        "manual_checkpoint_open": {
          "type": "boolean"
        },
        "evidence_manifest_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "console_location_refs": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_verified_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
