{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/provisioning/hmrc/hmrc_client_credential_record.schema.json",
  "title": "HMRCClientCredentialRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "inventory_id",
    "provider_id",
    "provider_display_name",
    "run_id",
    "flow_id",
    "workspace_id",
    "product_environment_id",
    "provider_environment_target",
    "application_record_ref",
    "oauth_profile_ref",
    "fraud_binding_evidence_ref",
    "authority_provider_profile_catalog_ref",
    "operator_identity_alias",
    "application_identity",
    "client_id_binding",
    "binding_summary",
    "secret_export_posture",
    "evidence_refs",
    "vault_write_receipt_refs",
    "manual_checkpoint_refs",
    "attestation_refs",
    "dimension_source_map",
    "typed_gaps",
    "notes",
    "last_verified_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "inventory_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_id": {
      "type": "string",
      "const": "hmrc-developer-hub"
    },
    "provider_display_name": {
      "type": "string",
      "const": "HMRC Developer Hub"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "flow_id": {
      "type": "string",
      "const": "sandbox-client-credential-export"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "product_environment_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_environment_target": {
      "type": "string",
      "const": "sandbox"
    },
    "application_record_ref": {
      "type": "string",
      "minLength": 1
    },
    "oauth_profile_ref": {
      "type": "string",
      "minLength": 1
    },
    "fraud_binding_evidence_ref": {
      "type": "string",
      "minLength": 1
    },
    "authority_provider_profile_catalog_ref": {
      "type": "string",
      "minLength": 1
    },
    "operator_identity_alias": {
      "type": "string",
      "minLength": 1
    },
    "application_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "application_alias",
        "application_display_name",
        "hmrc_application_id_alias",
        "portal_environment",
        "application_console_url",
        "credentials_console_url"
      ],
      "properties": {
        "application_alias": {
          "type": "string",
          "minLength": 1
        },
        "application_display_name": {
          "type": "string",
          "minLength": 1
        },
        "hmrc_application_id_alias": {
          "type": "string",
          "minLength": 1
        },
        "portal_environment": {
          "type": "string",
          "const": "SANDBOX"
        },
        "application_console_url": {
          "type": "string",
          "minLength": 1
        },
        "credentials_console_url": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "client_id_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "client_id_alias",
        "client_id_fingerprint",
        "client_id_hash",
        "client_id_metadata_store_ref",
        "client_id_secret_class_id",
        "source_disposition",
        "last_captured_at"
      ],
      "properties": {
        "client_id_alias": {
          "type": "string",
          "minLength": 1
        },
        "client_id_fingerprint": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "client_id_hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "client_id_metadata_store_ref": {
          "type": "string",
          "minLength": 1
        },
        "client_id_secret_class_id": {
          "type": "string",
          "const": "hmrc_sandbox_client_id_ref"
        },
        "source_disposition": {
          "type": "string",
          "enum": [
            "CAPTURED_DURING_RUN",
            "ADOPTED_EXISTING_LINEAGE"
          ]
        },
        "last_captured_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "binding_summary": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/bindingSummaryRow"
      }
    },
    "secret_export_posture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "binding_lineage_ref",
        "active_secret_version_id",
        "active_secret_count",
        "provider_limit_max_active_secrets",
        "taxat_overlap_limit_max_active_secrets",
        "one_time_reveal_posture",
        "capture_method",
        "attestation_state",
        "rotation_posture",
        "retirement_posture"
      ],
      "properties": {
        "binding_lineage_ref": {
          "type": "string",
          "minLength": 1
        },
        "active_secret_version_id": {
          "type": "string",
          "minLength": 1
        },
        "active_secret_count": {
          "type": "integer",
          "minimum": 1
        },
        "provider_limit_max_active_secrets": {
          "type": "integer",
          "const": 5
        },
        "taxat_overlap_limit_max_active_secrets": {
          "type": "integer",
          "const": 2
        },
        "one_time_reveal_posture": {
          "type": "string",
          "enum": [
            "MANUAL_CHECKPOINT_REQUIRED_IF_VISIBLE",
            "ADOPT_EXISTING_LINEAGE"
          ]
        },
        "capture_method": {
          "type": "string",
          "enum": [
            "PROVIDER_ONE_TIME_REVEAL_CAPTURE",
            "ADOPT_EXISTING_LINEAGE"
          ]
        },
        "attestation_state": {
          "type": "string",
          "enum": [
            "ATTESTED_PENDING_RUNTIME_VERIFICATION",
            "ACTIVE_AND_RUNTIME_VERIFIED"
          ]
        },
        "rotation_posture": {
          "type": "string",
          "minLength": 1
        },
        "retirement_posture": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "vault_write_receipt_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "manual_checkpoint_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "attestation_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dimension_source_map": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/dimensionSourceRow"
      }
    },
    "typed_gaps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_verified_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "rationale"
      ],
      "properties": {
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "bindingSummaryRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "environment_ref",
        "connection_method",
        "callback_profile_ref",
        "scope_set_ref",
        "scopes",
        "fraud_header_profile_ref",
        "token_binding_profile_ref",
        "authority_profile_refs"
      ],
      "properties": {
        "environment_ref": {
          "type": "string",
          "minLength": 1
        },
        "connection_method": {
          "type": "string",
          "enum": [
            "WEB_APP_VIA_SERVER",
            "DESKTOP_APP_VIA_SERVER"
          ]
        },
        "callback_profile_ref": {
          "type": "string",
          "minLength": 1
        },
        "scope_set_ref": {
          "type": "string",
          "minLength": 1
        },
        "scopes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "fraud_header_profile_ref": {
          "type": "string",
          "minLength": 1
        },
        "token_binding_profile_ref": {
          "type": "string",
          "minLength": 1
        },
        "authority_profile_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "dimensionSourceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension",
        "source_refs"
      ],
      "properties": {
        "dimension": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sourceRef"
          }
        }
      }
    }
  }
}
