{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/document_extraction_profile.schema.json",
  "title": "DocumentExtractionProfileRow",
  "description": "Deterministic OCR/document-extraction profile row. It freezes the accepted document class, file bounds, extraction family, candidate-fact families, and lineage requirements without implying that OCR output is canonical truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_ref",
    "document_class",
    "activation_state",
    "accepted_mime_types",
    "page_count_limit",
    "file_size_limit_mb",
    "language_posture",
    "handwriting_posture",
    "extraction_family",
    "provider_feature_flags",
    "processor_version_pinning_posture",
    "candidate_fact_families",
    "review_policy_ref",
    "lineage_requirements",
    "source_refs",
    "notes"
  ],
  "properties": {
    "profile_ref": {
      "type": "string",
      "pattern": "^doc_profile_[a-z0-9_]+$"
    },
    "document_class": {
      "type": "string",
      "minLength": 1
    },
    "activation_state": {
      "type": "string",
      "enum": [
        "READY_ONCE_PROVIDER_SELECTED",
        "NOT_ENABLED_IN_INITIAL_SCOPE"
      ]
    },
    "accepted_mime_types": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9.+-]+/[a-z0-9.+-]+$"
      }
    },
    "page_count_limit": {
      "type": "integer",
      "minimum": 1
    },
    "file_size_limit_mb": {
      "type": "integer",
      "minimum": 1
    },
    "language_posture": {
      "type": "string",
      "minLength": 1
    },
    "handwriting_posture": {
      "type": "string",
      "minLength": 1
    },
    "extraction_family": {
      "type": "string",
      "enum": [
        "RECEIPT_FIELDS_AND_LAYOUT",
        "INVOICE_FIELDS_AND_LAYOUT",
        "STATEMENT_LAYOUT_AND_TABLES",
        "CORRESPONDENCE_LAYOUT_AND_REFERENCE_EXTRACTION",
        "SCREENSHOT_LAYOUT_TEXT_ONLY",
        "HANDWRITING_LAYOUT_TEXT_ONLY"
      ]
    },
    "provider_feature_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "processor_version_pinning_posture": {
      "type": "string",
      "minLength": 1
    },
    "candidate_fact_families": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "_CANDIDATE$"
      }
    },
    "review_policy_ref": {
      "const": "document_extraction_review_thresholds"
    },
    "lineage_requirements": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceRef"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "rationale"
      ],
      "properties": {
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
