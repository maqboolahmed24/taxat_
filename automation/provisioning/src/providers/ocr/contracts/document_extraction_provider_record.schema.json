{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/document_extraction_provider_record.schema.json",
  "title": "DocumentExtractionSelectionRecord",
  "description": "Deterministic OCR/document-extraction selection record. It freezes whether Taxat has lawfully selected a managed provider, whether a self-host decision is still required, and the policy refs that later ingestion/runtime work must obey.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "selection_record_id",
    "provider_id",
    "provider_display_name",
    "run_id",
    "flow_id",
    "workspace_id",
    "operator_identity_alias",
    "selection_status",
    "managed_default_status",
    "selected_provider_adapter_or_null",
    "selected_provider_label_or_null",
    "self_host_runtime_family_or_null",
    "selection_posture_label",
    "processing_posture",
    "activation_gate_posture",
    "provider_inventory_ref",
    "profile_catalog_ref",
    "review_thresholds_ref",
    "candidate_fact_mapping_ref",
    "raw_output_retention_posture",
    "normalized_output_retention_posture",
    "candidate_fact_boundary_statement",
    "provider_docs_urls",
    "source_refs",
    "typed_gaps",
    "selection_notes",
    "last_verified_at"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "selection_record_id": {
      "const": "document_extraction_selection_record"
    },
    "provider_id": {
      "const": "document-extraction-control-plane"
    },
    "provider_display_name": {
      "const": "Document Extraction Control Plane"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "flow_id": {
      "const": "managed-document-extraction-project-selection"
    },
    "workspace_id": {
      "type": "string",
      "minLength": 1
    },
    "operator_identity_alias": {
      "type": "string",
      "minLength": 1
    },
    "selection_status": {
      "type": "string",
      "enum": [
        "SELF_HOST_DECISION_REQUIRED",
        "MANAGED_PROVIDER_SELECTED",
        "NOT_SELECTED"
      ]
    },
    "managed_default_status": {
      "type": "string",
      "enum": [
        "BLOCKED_BY_PLATFORM_PROVIDER_SELECTION",
        "READY_TO_ADOPT_MANAGED_PROVIDER",
        "MANAGED_PROVIDER_ADOPTED"
      ]
    },
    "selected_provider_adapter_or_null": {
      "type": [
        "string",
        "null"
      ]
    },
    "selected_provider_label_or_null": {
      "type": [
        "string",
        "null"
      ]
    },
    "self_host_runtime_family_or_null": {
      "type": [
        "string",
        "null"
      ]
    },
    "selection_posture_label": {
      "type": "string",
      "enum": [
        "Self-host decision required",
        "Managed provider selected",
        "Not selected"
      ]
    },
    "processing_posture": {
      "const": "ASYNC_QUEUE_REQUIRED"
    },
    "activation_gate_posture": {
      "const": "STABLE_OBJECT_VERSION_AND_SCAN_ADOPTION_REQUIRED"
    },
    "provider_inventory_ref": {
      "const": "data/provisioning/document_extraction_provider_inventory.template.json"
    },
    "profile_catalog_ref": {
      "const": "config/evidence/document_extraction_profile_catalog.json"
    },
    "review_thresholds_ref": {
      "const": "config/evidence/document_extraction_review_thresholds.json"
    },
    "candidate_fact_mapping_ref": {
      "const": "config/evidence/ocr_output_to_candidate_fact_mapping.json"
    },
    "raw_output_retention_posture": {
      "const": "PROVIDER_RAW_OUTPUT_SEPARATE_SHORT_LIVED_RESTRICTED"
    },
    "normalized_output_retention_posture": {
      "const": "NORMALIZED_EXTRACTION_JSON_RETAINED_WITH_EVIDENCE_LINEAGE"
    },
    "candidate_fact_boundary_statement": {
      "type": "string",
      "minLength": 1
    },
    "provider_docs_urls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "format": "uri"
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceRef"
      }
    },
    "typed_gaps": {
      "$ref": "#/$defs/stringArray"
    },
    "selection_notes": {
      "$ref": "#/$defs/stringArray"
    },
    "last_verified_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "sourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_ref",
        "rationale"
      ],
      "properties": {
        "source_ref": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "stringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
