{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/retention_governance_frame.schema.json",
  "title": "RetentionGovernanceFrame",
  "description": "Governance retention and privacy workspace contract for the Admin/Governance Console. This read-side schema freezes the active retention mode, readable policy matrix, legal-hold register, erasure queue, and promoted impact preview so statutory blockers and destructive-review posture remain explicit.",
  "type": "object",
  "required": [
    "frame_id",
    "artifact_type",
    "tenant_id",
    "shell_family",
    "object_anchor_ref",
    "dominant_question",
    "settlement_state",
    "recovery_posture",
    "interaction_layer",
    "policy_snapshot_hash",
    "focus_anchor_ref",
    "artifact_rows",
    "legal_hold_count",
    "erasure_queue_count",
    "limitation_count",
    "legal_hold_register_ref",
    "erasure_queue_ref",
    "retention_workspace",
    "retention_policy_matrix",
    "legal_hold_register",
    "erasure_queue",
    "retention_impact_preview",
    "updated_at"
  ],
  "properties": {
    "frame_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "RetentionGovernanceFrame"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "shell_family": {
      "const": "GOVERNANCE_DENSITY_SHELL"
    },
    "object_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "dominant_question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "settlement_state": {
      "$ref": "#/$defs/settlementState"
    },
    "recovery_posture": {
      "$ref": "#/$defs/recoveryPosture"
    },
    "interaction_layer": {
      "$ref": "https://taxat.dev/schemas/governance_interaction_layer.schema.json"
    },
    "policy_snapshot_hash": {
      "type": "string",
      "minLength": 1
    },
    "focus_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "artifact_rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/retentionArtifactRow"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "legal_hold_count": {
      "type": "integer",
      "minimum": 0
    },
    "erasure_queue_count": {
      "type": "integer",
      "minimum": 0
    },
    "limitation_count": {
      "type": "integer",
      "minimum": 0
    },
    "legal_hold_register_ref": {
      "type": "string",
      "minLength": 1
    },
    "erasure_queue_ref": {
      "type": "string",
      "minLength": 1
    },
    "retention_workspace": {
      "$ref": "#/$defs/retentionWorkspace"
    },
    "retention_policy_matrix": {
      "$ref": "#/$defs/retentionPolicyMatrix"
    },
    "legal_hold_register": {
      "$ref": "#/$defs/legalHoldRegister"
    },
    "erasure_queue": {
      "$ref": "#/$defs/erasureQueue"
    },
    "retention_impact_preview": {
      "$ref": "#/$defs/retentionImpactPreview"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "settlementState": {
      "type": "string",
      "enum": [
        "STEADY",
        "RECEIPT_PENDING",
        "FRESHENING",
        "STALE_REVIEW_REQUIRED",
        "DEGRADED_READ_ONLY",
        "RECOVERY_REQUIRED"
      ]
    },
    "recoveryPosture": {
      "type": "string",
      "enum": [
        "NONE",
        "INLINE_RECONNECT",
        "INLINE_REBASE",
        "READ_ONLY_LIMITED",
        "OBJECT_SUPERSEDED",
        "ACCESS_REBIND_REQUIRED"
      ]
    },
    "interactionLayer": {
      "type": "object",
      "required": [
        "selected_filter_chip_refs",
        "compaction_mode",
        "auxiliary_surface_presentation",
        "focus_trap_mode",
        "selection_persistence_mode",
        "preserved_context_codes"
      ],
      "properties": {
        "selected_filter_chip_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "compaction_mode": {
          "type": "string",
          "enum": [
            "WIDE",
            "AUXILIARY_DRAWER",
            "AUXILIARY_TRAY",
            "FOCUS_STACK"
          ]
        },
        "auxiliary_surface_presentation": {
          "type": "string",
          "enum": [
            "SIDECAR",
            "DRAWER",
            "INSPECTOR",
            "TRAY"
          ]
        },
        "focus_trap_mode": {
          "type": "string",
          "enum": [
            "NON_MODAL",
            "MODAL_EXPLICIT"
          ]
        },
        "selection_persistence_mode": {
          "const": "PRESERVE_WHILE_OBJECT_RESOLVES"
        },
        "preserved_context_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ACTIVE_FILTERS",
              "ACTIVE_SECTION",
              "SELECTION",
              "FOCUS_ANCHOR",
              "PROMOTED_SUPPORT_SURFACE",
              "STAGED_DIFF",
              "CHANGE_BASKET",
              "GUIDED_HANDSHAKE_STEP",
              "QUERY_SLICE"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "workspaceMode": {
      "type": "string",
      "enum": [
        "POLICIES",
        "LEGAL_HOLDS",
        "ERASURE"
      ]
    },
    "promotedSupportSurface": {
      "type": "string",
      "enum": [
        "AUDIT_SIDECAR",
        "RETENTION_IMPACT_PREVIEW"
      ]
    },
    "warningPosture": {
      "type": "string",
      "enum": [
        "NONE",
        "STATUTORY_BLOCK",
        "LEGAL_HOLD_BLOCK",
        "DESTRUCTIVE_REVIEW",
        "APPROVAL_OR_STEP_UP_REQUIRED"
      ]
    },
    "legalHoldState": {
      "type": "string",
      "enum": [
        "ACTIVE",
        "RELEASE_ELIGIBLE",
        "RELEASED"
      ]
    },
    "releaseEligibilityState": {
      "type": "string",
      "enum": [
        "BLOCKED",
        "RELEASE_ELIGIBLE",
        "NOT_APPLICABLE"
      ]
    },
    "erasureReadinessState": {
      "type": "string",
      "enum": [
        "ELIGIBLE",
        "BLOCKED",
        "PENDING_REVIEW"
      ]
    },
    "overrideState": {
      "type": "string",
      "enum": [
        "NONE",
        "APPLIED",
        "PENDING_APPROVAL",
        "BLOCKED_BY_STATUTORY_MINIMUM"
      ]
    },
    "retentionWorkspaceFilters": {
      "type": "object",
      "required": [
        "artifact_classes",
        "retention_classes",
        "client_refs",
        "legal_hold_states",
        "release_eligibility_states",
        "erasure_readiness_states"
      ],
      "properties": {
        "artifact_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "retention_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "client_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "legal_hold_states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/legalHoldState"
          },
          "default": [],
          "uniqueItems": true
        },
        "release_eligibility_states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/releaseEligibilityState"
          },
          "default": [],
          "uniqueItems": true
        },
        "erasure_readiness_states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/erasureReadinessState"
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "retentionWorkspace": {
      "type": "object",
      "required": [
        "surface_order",
        "workspace_mode",
        "active_filters",
        "selected_policy_row_ref",
        "selected_legal_hold_ref",
        "selected_erasure_item_ref",
        "promoted_support_surface",
        "warning_posture"
      ],
      "properties": {
        "surface_order": {
          "const": [
            "INVENTORY_RAIL",
            "WORKSPACE_CANVAS",
            "RETENTION_IMPACT_PREVIEW",
            "AUDIT_SIDECAR"
          ]
        },
        "workspace_mode": {
          "$ref": "#/$defs/workspaceMode"
        },
        "active_filters": {
          "$ref": "#/$defs/retentionWorkspaceFilters"
        },
        "selected_policy_row_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "selected_legal_hold_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "selected_erasure_item_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "promoted_support_surface": {
          "$ref": "#/$defs/promotedSupportSurface"
        },
        "warning_posture": {
          "$ref": "#/$defs/warningPosture"
        }
      },
      "additionalProperties": false
    },
    "retentionArtifactRow": {
      "type": "object",
      "required": [
        "row_ref",
        "artifact_class",
        "retention_class",
        "statutory_minimum_ref",
        "tenant_override_ref",
        "effective_minimum_ref",
        "override_state",
        "pseudonymisation_mode",
        "limitation_behavior",
        "export_posture",
        "legal_hold_count",
        "erasure_eligible_count",
        "limitation_count",
        "affected_artifact_count",
        "warning_posture",
        "inline_warning_ref_or_null",
        "blocking_reason_refs",
        "staged_change_ref_or_null",
        "legal_hold_register_ref_or_null",
        "erasure_queue_ref_or_null"
      ],
      "properties": {
        "row_ref": {
          "type": "string",
          "minLength": 1
        },
        "artifact_class": {
          "type": "string",
          "minLength": 1
        },
        "retention_class": {
          "type": "string",
          "minLength": 1
        },
        "statutory_minimum_ref": {
          "type": "string",
          "minLength": 1
        },
        "tenant_override_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "effective_minimum_ref": {
          "type": "string",
          "minLength": 1
        },
        "override_state": {
          "$ref": "#/$defs/overrideState"
        },
        "pseudonymisation_mode": {
          "type": "string",
          "minLength": 1
        },
        "limitation_behavior": {
          "type": "string",
          "minLength": 1
        },
        "export_posture": {
          "type": "string",
          "enum": [
            "FULL",
            "MASKED",
            "LIMITED",
            "DENIED"
          ]
        },
        "legal_hold_count": {
          "type": "integer",
          "minimum": 0
        },
        "erasure_eligible_count": {
          "type": "integer",
          "minimum": 0
        },
        "limitation_count": {
          "type": "integer",
          "minimum": 0
        },
        "affected_artifact_count": {
          "type": "integer",
          "minimum": 0
        },
        "warning_posture": {
          "$ref": "#/$defs/warningPosture"
        },
        "inline_warning_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "blocking_reason_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "staged_change_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "legal_hold_register_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "erasure_queue_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "override_state": {
                "const": "NONE"
              }
            },
            "required": [
              "override_state"
            ]
          },
          "then": {
            "properties": {
              "tenant_override_ref": {
                "type": "null"
              },
              "staged_change_ref_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "override_state": {
                "enum": [
                  "APPLIED",
                  "PENDING_APPROVAL",
                  "BLOCKED_BY_STATUTORY_MINIMUM"
                ]
              }
            },
            "required": [
              "override_state"
            ]
          },
          "then": {
            "properties": {
              "tenant_override_ref": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "override_state": {
                "const": "BLOCKED_BY_STATUTORY_MINIMUM"
              }
            },
            "required": [
              "override_state"
            ]
          },
          "then": {
            "properties": {
              "warning_posture": {
                "const": "STATUTORY_BLOCK"
              },
              "inline_warning_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "blocking_reason_refs": {
                "minItems": 1
              },
              "staged_change_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "warning_posture": {
                "const": "NONE"
              }
            },
            "required": [
              "warning_posture"
            ]
          },
          "then": {
            "properties": {
              "inline_warning_ref_or_null": {
                "type": "null"
              },
              "blocking_reason_refs": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "warning_posture": {
                "enum": [
                  "DESTRUCTIVE_REVIEW",
                  "APPROVAL_OR_STEP_UP_REQUIRED"
                ]
              }
            },
            "required": [
              "warning_posture"
            ]
          },
          "then": {
            "properties": {
              "inline_warning_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "staged_change_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "legal_hold_count": {
                "minimum": 1
              }
            },
            "required": [
              "legal_hold_count"
            ]
          },
          "then": {
            "properties": {
              "legal_hold_register_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "erasure_eligible_count": {
                "minimum": 1
              }
            },
            "required": [
              "erasure_eligible_count"
            ]
          },
          "then": {
            "properties": {
              "erasure_queue_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "retentionPolicyMatrix": {
      "type": "object",
      "required": [
        "column_order",
        "row_refs",
        "selected_row_ref",
        "editing_posture",
        "sticky_header_mode",
        "inline_blocker_visibility"
      ],
      "properties": {
        "column_order": {
          "const": [
            "ARTIFACT_CLASS",
            "STATUTORY_BASELINE",
            "TENANT_OVERRIDE",
            "EFFECTIVE_MINIMUM",
            "LIMITATION_BEHAVIOR",
            "PSEUDONYMISATION_MODE",
            "EXPORT_POSTURE"
          ]
        },
        "row_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "selected_row_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "editing_posture": {
          "const": "EXPLICIT_STAGE_ONLY"
        },
        "sticky_header_mode": {
          "const": "ROW_AND_COLUMN_HEADERS"
        },
        "inline_blocker_visibility": {
          "const": "ALWAYS_VISIBLE"
        }
      },
      "additionalProperties": false
    },
    "legalHoldRegister": {
      "type": "object",
      "required": [
        "column_order",
        "hold_refs",
        "selected_hold_ref_or_null",
        "blocking_hold_refs",
        "release_candidate_hold_refs",
        "release_preview_ref_or_null",
        "release_action_posture"
      ],
      "properties": {
        "column_order": {
          "const": [
            "CLIENT",
            "OBJECT_REF",
            "HOLD_REASON",
            "RELEASE_ELIGIBILITY",
            "BLOCKED_ERASURE_COUNT",
            "LAST_CHANGED_AT"
          ]
        },
        "hold_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "selected_hold_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "blocking_hold_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "release_candidate_hold_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "release_preview_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "release_action_posture": {
          "type": "string",
          "enum": [
            "NONE_SELECTED",
            "PREVIEW_ONLY",
            "CHANGE_BASKET_REQUIRED"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "release_action_posture": {
                "const": "NONE_SELECTED"
              }
            },
            "required": [
              "release_action_posture"
            ]
          },
          "then": {
            "properties": {
              "selected_hold_ref_or_null": {
                "type": "null"
              },
              "release_preview_ref_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "release_action_posture": {
                "enum": [
                  "PREVIEW_ONLY",
                  "CHANGE_BASKET_REQUIRED"
                ]
              }
            },
            "required": [
              "release_action_posture"
            ]
          },
          "then": {
            "properties": {
              "selected_hold_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "release_preview_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "erasureQueue": {
      "type": "object",
      "required": [
        "section_order",
        "eligible_item_refs",
        "blocked_item_refs",
        "pending_review_item_refs",
        "selected_item_ref_or_null",
        "destructive_flow_mode",
        "primary_blocker_ref_or_null"
      ],
      "properties": {
        "section_order": {
          "const": [
            "ELIGIBLE",
            "BLOCKED",
            "PENDING_REVIEW"
          ]
        },
        "eligible_item_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "blocked_item_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "pending_review_item_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "selected_item_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "destructive_flow_mode": {
          "const": "CHANGE_BASKET_ONLY"
        },
        "primary_blocker_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "primary_blocker_ref_or_null": {
                "type": "string"
              }
            },
            "required": [
              "primary_blocker_ref_or_null"
            ]
          },
          "then": {
            "properties": {
              "blocked_item_refs": {
                "minItems": 1
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "retentionImpactPreview": {
      "type": "object",
      "required": [
        "panel_mode",
        "preview_subject_ref_or_null",
        "preview_mode",
        "warning_posture",
        "blocked_reason_refs",
        "projected_provenance_limitation_refs",
        "affected_artifact_count",
        "affected_client_count",
        "projected_pseudonymisation_count",
        "action_posture"
      ],
      "properties": {
        "panel_mode": {
          "const": "RETENTION_IMPACT_PREVIEW"
        },
        "preview_subject_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "preview_mode": {
          "type": "string",
          "enum": [
            "NONE_SELECTED",
            "POLICY_CHANGE",
            "HOLD_RELEASE",
            "ERASURE_ACTION"
          ]
        },
        "warning_posture": {
          "$ref": "#/$defs/warningPosture"
        },
        "blocked_reason_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "projected_provenance_limitation_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "affected_artifact_count": {
          "type": "integer",
          "minimum": 0
        },
