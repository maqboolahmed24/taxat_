{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/schema_bundle.schema.json",
  "title": "SchemaBundle",
  "type": "object",
  "required": [
    "schema_bundle_hash",
    "entries"
  ],
  "properties": {
    "schema_bundle_hash": {
      "type": "string"
    },
    "published_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "compatibility_profile_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/schemaBundleEntry"
      },
      "minItems": 1
    }
  },
  "$defs": {
    "schemaBundleEntry": {
      "type": "object",
      "required": [
        "schema_id",
        "artifact_type",
        "semantic_version",
        "content_hash",
        "dialect_ref",
        "compatibility_class",
        "writer_min_reader_version",
        "allowed_upgrade_kinds"
      ],
      "properties": {
        "schema_id": {
          "type": "string"
        },
        "artifact_type": {
          "type": "string"
        },
        "semantic_version": {
          "type": "string"
        },
        "content_hash": {
          "type": "string"
        },
        "dialect_ref": {
          "type": "string"
        },
        "compatibility_class": {
          "type": "string"
        },
        "supersedes_schema_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "writer_min_reader_version": {
          "type": "string"
        },
        "allowed_upgrade_kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "PATCH_BACKWARD",
              "MINOR_BACKWARD",
              "MAJOR_BREAKING"
            ]
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "artifactContract": {
      "type": "object",
      "required": [
        "artifact_id",
        "schema_id",
        "artifact_type",
        "semantic_version",
        "content_hash",
        "dialect_ref",
        "compatibility_class",
        "writer_min_reader_version",
        "allowed_upgrade_kinds",
        "schema_bundle_hash",
        "artifact_content_hash",
        "writer_build_id"
      ],
      "properties": {
        "artifact_id": {
          "type": "string"
        },
        "schema_id": {
          "type": "string"
        },
        "artifact_type": {
          "type": "string"
        },
        "semantic_version": {
          "type": "string"
        },
        "content_hash": {
          "type": "string"
        },
        "dialect_ref": {
          "type": "string"
        },
        "compatibility_class": {
          "type": "string"
        },
        "supersedes_schema_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "writer_min_reader_version": {
          "type": "string"
        },
        "allowed_upgrade_kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "PATCH_BACKWARD",
              "MINOR_BACKWARD",
              "MAJOR_BREAKING"
            ]
          },
          "minItems": 1
        },
        "schema_bundle_hash": {
          "type": "string"
        },
        "artifact_content_hash": {
          "type": "string"
        },
        "writer_build_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
