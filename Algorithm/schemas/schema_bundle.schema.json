{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/schema_bundle.schema.json",
  "title": "SchemaBundle",
  "type": "object",
  "required": [
    "schema_bundle_hash",
    "compatibility_profile_ref",
    "schema_reader_window_contract",
    "entries"
  ],
  "properties": {
    "schema_bundle_hash": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "compatibility_profile_ref": {
      "type": "string",
      "minLength": 1
    },
    "schema_reader_window_contract": {
      "$ref": "https://taxat.dev/schemas/schema_reader_window_contract.schema.json"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/schemaBundleEntry"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "$defs": {
    "schemaBundleEntry": {
      "type": "object",
      "required": [
        "schema_id",
        "artifact_type",
        "semantic_version",
        "content_hash",
        "dialect_ref",
        "compatibility_class",
        "writer_min_reader_version",
        "allowed_upgrade_kinds"
      ],
      "properties": {
        "schema_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_type": {
          "type": "string",
          "minLength": 1
        },
        "semantic_version": {
          "type": "string",
          "minLength": 1
        },
        "content_hash": {
          "type": "string",
          "minLength": 1
        },
        "dialect_ref": {
          "type": "string",
          "minLength": 1
        },
        "compatibility_class": {
          "type": "string",
          "minLength": 1
        },
        "supersedes_schema_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "writer_min_reader_version": {
          "type": "string",
          "minLength": 1
        },
        "allowed_upgrade_kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "PATCH_BACKWARD",
              "MINOR_BACKWARD",
              "MAJOR_BREAKING"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "exactDecimalString": {
      "type": "string",
      "pattern": "^-?(0|[1-9]\\d*)(\\.\\d+)?$"
    },
    "moneyValue": {
      "description": "Exact fixed-scale money rendering. The owning artifact's `money_profile.scale` controls the required fractional width.",
      "$ref": "#/$defs/exactDecimalString"
    },
    "moneyProfile": {
      "type": "object",
      "required": [
        "currency_code",
        "scale",
        "rounding_mode",
        "aggregation_boundary",
        "serialization_profile"
      ],
      "properties": {
        "currency_code": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "scale": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9
        },
        "rounding_mode": {
          "type": "string",
          "enum": [
            "HALF_UP",
            "HALF_EVEN",
            "DOWN",
            "UP"
          ]
        },
        "aggregation_boundary": {
          "type": "string",
          "enum": [
            "DECLARED_AGGREGATION_BOUNDARY_ONLY"
          ]
        },
        "serialization_profile": {
          "const": "CANONICAL_DECIMAL_STRING_V1"
        }
      },
      "additionalProperties": false
    },
    "artifactContract": {
      "type": "object",
      "required": [
        "artifact_id",
        "schema_id",
        "artifact_type",
        "semantic_version",
        "content_hash",
        "dialect_ref",
        "compatibility_class",
        "writer_min_reader_version",
        "allowed_upgrade_kinds",
        "schema_bundle_hash",
        "artifact_content_hash",
        "writer_build_id"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "schema_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_type": {
          "type": "string",
          "minLength": 1
        },
        "semantic_version": {
          "type": "string",
          "minLength": 1
        },
        "content_hash": {
          "type": "string",
          "minLength": 1
        },
        "dialect_ref": {
          "type": "string",
          "minLength": 1
        },
        "compatibility_class": {
          "type": "string",
          "minLength": 1
        },
        "supersedes_schema_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "writer_min_reader_version": {
          "type": "string",
          "minLength": 1
        },
        "allowed_upgrade_kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "PATCH_BACKWARD",
              "MINOR_BACKWARD",
              "MAJOR_BREAKING"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "schema_bundle_hash": {
          "type": "string",
          "minLength": 1
        },
        "artifact_content_hash": {
          "type": "string",
          "minLength": 1
        },
        "writer_build_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
