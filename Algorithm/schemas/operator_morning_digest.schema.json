{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/operator_morning_digest.schema.json",
  "title": "OperatorMorningDigest",
  "description": "Next-morning overnight handoff contract. This schema freezes per-tenant coverage identity, source nightly batches, grouped queue summaries, highlighted client outcomes, and publication lineage for the operator digest emitted after nightly autopilot reaches quiescence.",
  "type": "object",
  "required": [
    "artifact_type",
    "digest_id",
    "tenant_id",
    "execution_mode_boundary_contract",
    "coverage_date",
    "source_batch_run_refs",
    "derivation_contract",
    "covered_selection_entry_refs",
    "summary_counts",
    "outcome_entry_refs",
    "queue_summaries",
    "highlighted_client_outcomes",
    "waiting_on_authority_refs",
    "late_data_hold_refs",
    "backlog_pressure",
    "portfolio_tail_risk",
    "stability_state",
    "published_workflow_item_refs",
    "published_notification_refs",
    "generated_by_principal_ref",
    "generated_at",
    "published_at",
    "supersedes_digest_id"
  ],
  "properties": {
    "artifact_type": {
      "const": "OperatorMorningDigest"
    },
    "digest_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode_boundary_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/execution_mode_boundary_contract.schema.json"
        },
        {
          "properties": {
            "run_kind": {
              "const": "NIGHTLY"
            },
            "execution_posture": {
              "const": "LIVE_COMPLIANCE"
            },
            "legal_effect_boundary": {
              "const": "COMPLIANCE_CAPABLE"
            }
          }
        }
      ]
    },
    "coverage_date": {
      "type": "string",
      "format": "date"
    },
    "source_batch_run_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "derivation_contract": {
      "$ref": "https://taxat.dev/schemas/operator_digest_derivation_contract.schema.json"
    },
    "covered_selection_entry_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "summary_counts": {
      "$ref": "#/$defs/summaryCounts"
    },
    "outcome_entry_refs": {
      "$ref": "#/$defs/outcomeEntryRefs"
    },
    "queue_summaries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/queueSummary"
      },
      "default": []
    },
    "highlighted_client_outcomes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/highlightedClientOutcome"
      },
      "default": []
    },
    "waiting_on_authority_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "late_data_hold_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "backlog_pressure": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "portfolio_tail_risk": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "stability_state": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "NORMAL",
        "SOFT_THROTTLE",
        "HARD_THROTTLE",
        null
      ]
    },
    "published_workflow_item_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "published_notification_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "generated_by_principal_ref": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "published_at": {
      "type": "string",
      "format": "date-time"
    },
    "supersedes_digest_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  },
  "$defs": {
    "summaryCounts": {
      "type": "object",
      "required": [
        "auto_completed",
        "waiting_on_authority",
        "waiting_on_late_data",
        "review_required",
        "request_client_info",
        "blocked_internal",
        "failed_retryable",
        "failed_non_retryable",
        "reused_result",
        "deferred",
        "skipped"
      ],
      "properties": {
        "auto_completed": {
          "type": "integer",
          "minimum": 0
        },
        "waiting_on_authority": {
          "type": "integer",
          "minimum": 0
        },
        "waiting_on_late_data": {
          "type": "integer",
          "minimum": 0
        },
        "review_required": {
          "type": "integer",
          "minimum": 0
        },
        "request_client_info": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_internal": {
          "type": "integer",
          "minimum": 0
        },
        "failed_retryable": {
          "type": "integer",
          "minimum": 0
        },
        "failed_non_retryable": {
          "type": "integer",
          "minimum": 0
        },
        "reused_result": {
          "type": "integer",
          "minimum": 0
        },
        "deferred": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "selectionEntryRefList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "outcomeEntryRefs": {
      "type": "object",
      "required": [
        "auto_completed",
        "waiting_on_authority",
        "waiting_on_late_data",
        "review_required",
        "request_client_info",
        "blocked_internal",
        "failed_retryable",
        "failed_non_retryable",
        "reused_result",
        "deferred",
        "skipped"
      ],
      "properties": {
        "auto_completed": {
          "$ref": "#/$defs/selectionEntryRefList"
        },
        "waiting_on_authority": {
          "$ref": "#/$defs/selectionEntryRefList"
        },
        "waiting_on_late_data": {
          "$ref": "#/$defs/selectionEntryRefList"
        },
        "review_required": {
          "$ref": "#/$defs/selectionEntryRefList"
        },
        "request_client_info": {
          "$ref": "#/$defs/selectionEntryRefList"
        },
        "blocked_internal": {
          "$ref": "#/$defs/selectionEntryRefList"
        },
        "failed_retryable": {
          "$ref": "#/$defs/selectionEntryRefList"
        },
        "failed_non_retryable": {
          "$ref": "#/$defs/selectionEntryRefList"
        },
        "reused_result": {
          "$ref": "#/$defs/selectionEntryRefList"
        },
        "deferred": {
          "$ref": "#/$defs/selectionEntryRefList"
        },
        "skipped": {
          "$ref": "#/$defs/selectionEntryRefList"
        }
      },
      "additionalProperties": false
    },
    "prioritySummary": {
      "type": "object",
      "required": [
        "deadline_bucket",
        "risk_bucket",
        "stable_tie_break_key"
      ],
      "properties": {
        "deadline_bucket": {
          "type": "integer",
          "minimum": 0
        },
        "risk_bucket": {
          "type": "integer",
          "minimum": 0
        },
        "stable_tie_break_key": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "queueSummary": {
      "type": "object",
      "required": [
        "queue_ref",
        "source_basis",
        "item_refs",
        "dominant_reason_codes",
        "item_count",
        "highest_priority"
      ],
      "properties": {
        "queue_ref": {
          "type": "string",
          "minLength": 1
        },
        "source_basis": {
          "const": "PUBLISHED_WORKFLOW_ITEMS"
        },
        "item_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "dominant_reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "item_count": {
          "type": "integer",
          "minimum": 1
        },
        "highest_priority": {
          "$ref": "#/$defs/prioritySummary"
        }
      },
      "additionalProperties": false
    },
    "highlightedClientOutcome": {
      "type": "object",
      "required": [
        "selection_entry_ref",
        "client_id",
        "period",
        "dominant_outcome",
        "highlight_rank",
        "entry_loss_score",
        "manifest_ref",
        "work_item_ref",
        "reason_codes",
        "next_checkpoint_at"
      ],
      "properties": {
        "selection_entry_ref": {
          "type": "string",
          "minLength": 1
        },
        "client_id": {
          "type": "string",
          "minLength": 1
        },
        "period": {
          "type": "string",
          "minLength": 1
        },
        "dominant_outcome": {
          "type": "string",
          "enum": [
            "AUTO_COMPLETED",
            "WAITING_ON_AUTHORITY",
            "WAITING_ON_LATE_DATA",
            "REVIEW_REQUIRED",
            "REQUEST_CLIENT_INFO",
            "BLOCKED_INTERNAL",
            "FAILED_RETRYABLE",
            "FAILED_NON_RETRYABLE",
            "REUSED_RESULT",
            "DEFERRED",
            "SKIPPED"
          ]
        },
        "highlight_rank": {
          "type": "integer",
          "minimum": 1
        },
        "entry_loss_score": {
          "type": "number",
          "minimum": 0
        },
        "manifest_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "work_item_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "next_checkpoint_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "dominant_outcome": {
                "enum": [
                  "WAITING_ON_AUTHORITY",
                  "WAITING_ON_LATE_DATA",
                  "REVIEW_REQUIRED",
                  "REQUEST_CLIENT_INFO",
                  "BLOCKED_INTERNAL",
                  "DEFERRED",
                  "FAILED_RETRYABLE",
                  "FAILED_NON_RETRYABLE"
                ]
              }
            },
            "required": [
              "dominant_outcome"
            ]
          },
          "then": {
            "properties": {
              "work_item_ref": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "dominant_outcome": {
                "enum": [
                  "WAITING_ON_AUTHORITY",
                  "WAITING_ON_LATE_DATA",
                  "DEFERRED"
                ]
              }
            },
            "required": [
              "dominant_outcome"
            ]
          },
          "then": {
            "properties": {
              "next_checkpoint_at": {
                "type": "string",
                "format": "date-time"
              }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "queue_summaries": {
            "minItems": 1
          }
        },
        "required": [
          "queue_summaries"
        ]
      },
      "then": {
        "properties": {
          "published_workflow_item_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "derivation_contract": {
            "type": "object",
            "properties": {
              "workflow_publication_state": {
                "const": "COMPLETE_WITH_NO_UNRESOLVED_ITEMS"
              }
            },
            "required": [
              "workflow_publication_state"
            ]
          }
        },
        "required": [
          "derivation_contract"
        ]
      },
      "then": {
        "properties": {
          "queue_summaries": {
            "maxItems": 0
          },
          "published_workflow_item_refs": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "derivation_contract": {
            "type": "object",
            "properties": {
              "workflow_publication_state": {
                "const": "COMPLETE_WITH_PUBLISHED_WORKFLOW_ITEMS"
              }
            },
            "required": [
              "workflow_publication_state"
            ]
          }
        },
        "required": [
          "derivation_contract"
        ]
      },
      "then": {
        "properties": {
          "queue_summaries": {
            "minItems": 1
          },
          "published_workflow_item_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "derivation_contract": {
            "type": "object",
            "properties": {
              "notification_publication_state": {
                "const": "COMPLETE_WITH_EXPLICIT_NONE"
              }
            },
            "required": [
              "notification_publication_state"
            ]
          }
        },
        "required": [
          "derivation_contract"
        ]
      },
      "then": {
        "properties": {
          "published_notification_refs": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "derivation_contract": {
            "type": "object",
            "properties": {
              "notification_publication_state": {
                "const": "COMPLETE_WITH_PUBLISHED_NOTIFICATION_REFS"
              }
            },
            "required": [
              "notification_publication_state"
            ]
          }
        },
        "required": [
          "derivation_contract"
        ]
      },
      "then": {
        "properties": {
          "published_notification_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "summary_counts": {
            "type": "object",
            "properties": {
              "waiting_on_authority": {
                "const": 0
              }
            },
            "required": [
              "waiting_on_authority"
            ]
          }
        },
        "required": [
          "summary_counts"
        ]
      },
      "then": {
        "properties": {
          "waiting_on_authority_refs": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "summary_counts": {
            "type": "object",
            "properties": {
              "waiting_on_authority": {
                "minimum": 1
              }
            },
            "required": [
              "waiting_on_authority"
            ]
          }
        },
        "required": [
          "summary_counts"
        ]
      },
      "then": {
        "properties": {
          "waiting_on_authority_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "summary_counts": {
            "type": "object",
            "properties": {
              "waiting_on_late_data": {
                "const": 0
              }
            },
            "required": [
              "waiting_on_late_data"
            ]
          }
        },
        "required": [
          "summary_counts"
        ]
      },
      "then": {
        "properties": {
          "late_data_hold_refs": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "summary_counts": {
            "type": "object",
            "properties": {
              "waiting_on_late_data": {
                "minimum": 1
              }
            },
            "required": [
              "waiting_on_late_data"
            ]
          }
        },
        "required": [
          "summary_counts"
        ]
      },
      "then": {
        "properties": {
          "late_data_hold_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "derivation_contract": {
            "type": "object",
            "properties": {
              "supersession_state": {
                "const": "RECOVERY_SUPERSESSION"
              }
            },
            "required": [
              "supersession_state"
            ]
          }
        },
        "required": [
          "derivation_contract"
        ]
      },
      "then": {
        "properties": {
          "supersedes_digest_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "supersedes_digest_id": {
            "type": "string"
          }
        },
        "required": [
          "supersedes_digest_id"
        ]
      },
      "then": {
        "properties": {
          "published_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "derivation_contract": {
            "type": "object",
            "properties": {
              "supersession_state": {
                "const": "INITIAL_PUBLICATION"
              }
            },
            "required": [
              "supersession_state"
            ]
          }
        },
        "required": [
          "derivation_contract"
        ]
      },
      "then": {
        "properties": {
          "supersedes_digest_id": {
            "type": "null"
          }
        }
      }
    }
  ],
  "additionalProperties": false,
  "unevaluatedProperties": false
}
