{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/twin_view.schema.json",
  "title": "TwinView",
  "description": "Cross-source Twin Lens root artifact. This schema freezes the lifecycle, mirrored lane snapshot linkage, paired timeline linkage, delta-arc set, mismatch summary, readiness posture, reconciliation posture, and interpretation state for one manifest-scoped comparative view.",
  "type": "object",
  "required": [
    "artifact_type",
    "twin_id",
    "manifest_id",
    "execution_mode_boundary_contract",
    "lifecycle_state",
    "comparison_key_profile_code",
    "delta_precedence_profile_code",
    "mismatch_ranking_profile_code",
    "comparison_basis_ref",
    "internal_state_ref",
    "authority_state_ref",
    "timeline_ref",
    "cross_source_delta_refs",
    "mismatch_summary_ref",
    "readiness_ref",
    "reconciliation_state_ref",
    "interpretation_state_ref",
    "parity_result_ref",
    "built_at",
    "stale_at",
    "superseded_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "TwinView"
    },
    "twin_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode_boundary_contract": {
      "$ref": "https://taxat.dev/schemas/execution_mode_boundary_contract.schema.json"
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "NOT_BUILT",
        "BUILT",
        "STALE",
        "SUPERSEDED"
      ]
    },
    "comparison_key_profile_code": {
      "const": "TWIN_KEY_V1_SHA256"
    },
    "delta_precedence_profile_code": {
      "const": "TWIN_DELTA_PRECEDENCE_V1"
    },
    "mismatch_ranking_profile_code": {
      "const": "TWIN_MISMATCH_SORT_V1"
    },
    "comparison_basis_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "internal_state_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "authority_state_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "timeline_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "cross_source_delta_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "mismatch_summary_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "readiness_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "reconciliation_state_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "interpretation_state_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "parity_result_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "built_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "stale_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "superseded_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "NOT_BUILT"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "comparison_basis_ref": {
            "type": "null"
          },
          "internal_state_ref": {
            "type": "null"
          },
          "authority_state_ref": {
            "type": "null"
          },
          "timeline_ref": {
            "type": "null"
          },
          "mismatch_summary_ref": {
            "type": "null"
          },
          "readiness_ref": {
            "type": "null"
          },
          "reconciliation_state_ref": {
            "type": "null"
          },
          "interpretation_state_ref": {
            "type": "null"
          },
          "parity_result_ref": {
            "type": "null"
          },
          "built_at": {
            "type": "null"
          },
          "stale_at": {
            "type": "null"
          },
          "superseded_at": {
            "type": "null"
          },
          "cross_source_delta_refs": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "BUILT"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "comparison_basis_ref": {
            "type": "string",
            "minLength": 1
          },
          "internal_state_ref": {
            "type": "string",
            "minLength": 1
          },
          "authority_state_ref": {
            "type": "string",
            "minLength": 1
          },
          "timeline_ref": {
            "type": "string",
            "minLength": 1
          },
          "mismatch_summary_ref": {
            "type": "string",
            "minLength": 1
          },
          "readiness_ref": {
            "type": "string",
            "minLength": 1
          },
          "reconciliation_state_ref": {
            "type": "string",
            "minLength": 1
          },
          "interpretation_state_ref": {
            "type": "string",
            "minLength": 1
          },
          "parity_result_ref": {
            "type": "string",
            "minLength": 1
          },
          "cross_source_delta_refs": {
            "minItems": 1
          },
          "built_at": {
            "type": "string",
            "format": "date-time"
          },
          "stale_at": {
            "type": "null"
          },
          "superseded_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "STALE"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "comparison_basis_ref": {
            "type": "string",
            "minLength": 1
          },
          "internal_state_ref": {
            "type": "string",
            "minLength": 1
          },
          "authority_state_ref": {
            "type": "string",
            "minLength": 1
          },
          "timeline_ref": {
            "type": "string",
            "minLength": 1
          },
          "mismatch_summary_ref": {
            "type": "string",
            "minLength": 1
          },
          "readiness_ref": {
            "type": "string",
            "minLength": 1
          },
          "reconciliation_state_ref": {
            "type": "string",
            "minLength": 1
          },
          "interpretation_state_ref": {
            "type": "string",
            "minLength": 1
          },
          "parity_result_ref": {
            "type": "string",
            "minLength": 1
          },
          "cross_source_delta_refs": {
            "minItems": 1
          },
          "built_at": {
            "type": "string",
            "format": "date-time"
          },
          "stale_at": {
            "type": "string",
            "format": "date-time"
          },
          "superseded_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "SUPERSEDED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "comparison_basis_ref": {
            "type": "string",
            "minLength": 1
          },
          "internal_state_ref": {
            "type": "string",
            "minLength": 1
          },
          "authority_state_ref": {
            "type": "string",
            "minLength": 1
          },
          "timeline_ref": {
            "type": "string",
            "minLength": 1
          },
          "mismatch_summary_ref": {
            "type": "string",
            "minLength": 1
          },
          "readiness_ref": {
            "type": "string",
            "minLength": 1
          },
          "reconciliation_state_ref": {
            "type": "string",
            "minLength": 1
          },
          "interpretation_state_ref": {
            "type": "string",
            "minLength": 1
          },
          "parity_result_ref": {
            "type": "string",
            "minLength": 1
          },
          "cross_source_delta_refs": {
            "minItems": 1
          },
          "built_at": {
            "type": "string",
            "format": "date-time"
          },
          "superseded_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "built_at": {
            "type": "string"
          }
        },
        "required": [
          "built_at"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "BUILT",
              "STALE",
              "SUPERSEDED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "stale_at": {
            "type": "string"
          }
        },
        "required": [
          "stale_at"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "const": "STALE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "superseded_at": {
            "type": "string"
          }
        },
        "required": [
          "superseded_at"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "const": "SUPERSEDED"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
