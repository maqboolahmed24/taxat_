{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/trust_sensitivity_contract.schema.json",
  "title": "TrustSensitivityContract",
  "description": "Frozen trust threshold, cap, and perturbation analysis for one TrustSummary. This contract separates numeric score posture from legal and operational caps, persists active guard-band triggers, and records the canonical trust perturbation probes so threshold drift remains explainable, monotonic, and fail-closed.",
  "type": "object",
  "required": [
    "contract_version",
    "sensitivity_contract_hash",
    "trust_input_basis_contract_hash",
    "execution_mode_boundary_hash",
    "execution_mode",
    "execution_legal_effect_boundary",
    "trust_score",
    "risk_score",
    "completeness_score",
    "graph_quality_score",
    "authority_uncertainty_score",
    "authority_penalty",
    "baseline_submission_state",
    "live_authority_progression_requested",
    "active_filing_critical_override_count",
    "critical_retention_limited_count",
    "required_human_step_count",
    "late_data_invalidation_state",
    "override_dependency_state",
    "score_band",
    "cap_band",
    "trust_band",
    "trust_input_state",
    "threshold_stability_state",
    "upstream_gate_cap",
    "automation_level",
    "filing_readiness",
    "trust_green_margin",
    "trust_amber_margin",
    "risk_automation_margin",
    "completeness_margin",
    "graph_filing_margin_or_null",
    "authority_review_margin_or_null",
    "authority_block_margin_or_null",
    "score_cap_alignment_state",
    "cap_driver_reason_codes",
    "edge_trigger_codes",
    "projected_case_results"
  ],
  "properties": {
    "contract_version": {
      "const": "TRUST_SENSITIVITY_V1"
    },
    "sensitivity_contract_hash": {
      "type": "string",
      "minLength": 1
    },
    "trust_input_basis_contract_hash": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode_boundary_hash": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "COMPLIANCE",
        "ANALYSIS"
      ]
    },
    "execution_legal_effect_boundary": {
      "type": "string",
      "enum": [
        "COMPLIANCE_CAPABLE",
        "MODELED_READ_ONLY",
        "HISTORICAL_REPLAY_READ_ONLY",
        "COUNTERFACTUAL_REPLAY_READ_ONLY"
      ]
    },
    "trust_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "risk_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "completeness_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "graph_quality_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "authority_uncertainty_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "authority_penalty": {
      "type": "integer",
      "minimum": 0,
      "maximum": 30
    },
    "baseline_submission_state": {
      "type": "string",
      "enum": [
        "KNOWN_MATCHED",
        "KNOWN_FILED",
        "UNKNOWN",
        "OUT_OF_BAND_UNRECONCILED",
        "NOT_APPLICABLE"
      ]
    },
    "live_authority_progression_requested": {
      "type": "boolean"
    },
    "active_filing_critical_override_count": {
      "type": "integer",
      "minimum": 0
    },
    "critical_retention_limited_count": {
      "type": "integer",
      "minimum": 0
    },
    "required_human_step_count": {
      "type": "integer",
      "minimum": 0
    },
    "late_data_invalidation_state": {
      "type": "string",
      "enum": [
        "NONE",
        "INVALIDATING_FINDING_PRESENT"
      ]
    },
    "override_dependency_state": {
      "type": "string",
      "enum": [
        "NO_ACTIVE_OR_VALID_OVERRIDES",
        "INVALID_OVERRIDE_RELIED_UPON"
      ]
    },
    "score_band": {
      "type": "string",
      "enum": [
        "RED",
        "AMBER",
        "GREEN"
      ]
    },
    "cap_band": {
      "type": "string",
      "enum": [
        "INSUFFICIENT_DATA",
        "RED",
        "AMBER",
        "GREEN"
      ]
    },
    "trust_band": {
      "type": "string",
      "enum": [
        "INSUFFICIENT_DATA",
        "RED",
        "AMBER",
        "GREEN"
      ]
    },
    "trust_input_state": {
      "type": "string",
      "enum": [
        "ADMISSIBLE_CURRENT",
        "ADMISSIBLE_STALE",
        "INCOMPLETE",
        "CONTRADICTED"
      ]
    },
    "threshold_stability_state": {
      "type": "string",
      "enum": [
        "STABLE",
        "EDGE_REVIEW"
      ]
    },
    "upstream_gate_cap": {
      "type": "string",
      "enum": [
        "AUTO_ELIGIBLE",
        "NOTICE_ONLY",
        "REVIEW_ONLY",
        "BLOCKED"
      ]
    },
    "automation_level": {
      "type": "string",
      "enum": [
        "ALLOWED",
        "LIMITED",
        "BLOCKED"
      ]
    },
    "filing_readiness": {
      "type": "string",
      "enum": [
        "READY_TO_SUBMIT",
        "READY_REVIEW",
        "NOT_READY"
      ]
    },
    "trust_green_margin": {
      "type": "integer"
    },
    "trust_amber_margin": {
      "type": "integer"
    },
    "risk_automation_margin": {
      "type": "integer"
    },
    "completeness_margin": {
      "type": "integer"
    },
    "graph_filing_margin_or_null": {
      "type": [
        "integer",
        "null"
      ]
    },
    "authority_review_margin_or_null": {
      "type": [
        "integer",
        "null"
      ]
    },
    "authority_block_margin_or_null": {
      "type": [
        "integer",
        "null"
      ]
    },
    "score_cap_alignment_state": {
      "type": "string",
      "enum": [
        "ALIGNED",
        "SCORE_STRICTER_THAN_CAP",
        "CAP_STRICTER_THAN_SCORE"
      ]
    },
    "cap_driver_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "TRUST_INPUT_INCOMPLETE",
          "TRUST_INPUT_CONTRADICTION",
          "TRUST_INPUT_STALE",
          "TRUST_OVERRIDE_INVALID",
          "TRUST_THRESHOLD_EDGE_REVIEW",
          "TRUST_UPSTREAM_GATE_BLOCK",
          "TRUST_UPSTREAM_GATE_REVIEW_REQUIRED",
          "TRUST_REQUIRED_HUMAN_STEPS",
          "TRUST_OVERRIDE_PENALTY",
          "TRUST_RETENTION_PENALTY",
          "TRUST_AUTHORITY_STATE_UNRESOLVED",
          "TRUST_AUTHORITY_PENALTY",
          "TRUST_ANALYSIS_MODE_CAP",
          "TRUST_NON_LIVE_EXECUTION_BOUNDARY_CAP",
          "TRUST_RECALCULATION_REQUIRED"
        ],
        "minLength": 1
      },
      "uniqueItems": true
    },
    "edge_trigger_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "TRUST_GREEN_GUARD_BAND",
          "TRUST_AMBER_GUARD_BAND",
          "RISK_AUTOMATION_GUARD_BAND",
          "COMPLETENESS_GUARD_BAND",
          "GRAPH_FILING_GUARD_BAND",
          "AUTHORITY_REVIEW_GUARD_BAND",
          "AUTHORITY_BLOCK_GUARD_BAND"
        ],
        "minLength": 1
      },
      "uniqueItems": true
    },
    "projected_case_results": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": [
          "case_code",
          "monotonicity_expectation",
          "projected_trust_score",
          "projected_score_band",
          "projected_cap_band",
          "projected_trust_band",
          "projected_trust_input_state",
          "projected_threshold_stability_state",
          "projected_automation_level",
          "projected_filing_readiness",
          "projected_trust_green_margin",
          "projected_trust_amber_margin",
          "projected_risk_automation_margin",
          "projected_completeness_margin",
          "projected_graph_filing_margin_or_null",
          "projected_authority_review_margin_or_null",
          "projected_authority_block_margin_or_null",
          "projected_edge_trigger_codes",
          "projected_reason_code_additions",
          "projected_reason_code_removals"
        ],
        "properties": {
          "case_code": {
            "type": "string",
            "enum": [
              "TRUST_SCORE_MINUS_ONE",
              "TRUST_SCORE_PLUS_ONE",
              "RISK_SCORE_PLUS_ONE",
              "AUTHORITY_UNCERTAINTY_PLUS_ONE",
              "FRESHNESS_INVALIDATED",
              "INVALID_OVERRIDE_RELIED_UPON"
            ]
          },
          "monotonicity_expectation": {
            "type": "string",
            "enum": [
              "NON_IMPROVING",
              "NON_DEGRADING"
            ]
          },
          "projected_trust_score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100
          },
          "projected_score_band": {
            "type": "string",
            "enum": [
              "RED",
              "AMBER",
              "GREEN"
            ]
          },
          "projected_cap_band": {
            "type": "string",
            "enum": [
              "INSUFFICIENT_DATA",
              "RED",
              "AMBER",
              "GREEN"
            ]
          },
          "projected_trust_band": {
            "type": "string",
            "enum": [
              "INSUFFICIENT_DATA",
              "RED",
              "AMBER",
              "GREEN"
            ]
          },
          "projected_trust_input_state": {
            "type": "string",
            "enum": [
              "ADMISSIBLE_CURRENT",
              "ADMISSIBLE_STALE",
              "INCOMPLETE",
              "CONTRADICTED"
            ]
          },
          "projected_threshold_stability_state": {
            "type": "string",
            "enum": [
              "STABLE",
              "EDGE_REVIEW"
            ]
          },
          "projected_automation_level": {
            "type": "string",
            "enum": [
              "ALLOWED",
              "LIMITED",
              "BLOCKED"
            ]
          },
          "projected_filing_readiness": {
            "type": "string",
            "enum": [
              "READY_TO_SUBMIT",
              "READY_REVIEW",
              "NOT_READY"
            ]
          },
          "projected_trust_green_margin": {
            "type": "integer"
          },
          "projected_trust_amber_margin": {
            "type": "integer"
          },
          "projected_risk_automation_margin": {
            "type": "integer"
          },
          "projected_completeness_margin": {
            "type": "integer"
          },
          "projected_graph_filing_margin_or_null": {
            "type": [
              "integer",
              "null"
            ]
          },
          "projected_authority_review_margin_or_null": {
            "type": [
              "integer",
              "null"
            ]
          },
          "projected_authority_block_margin_or_null": {
            "type": [
              "integer",
              "null"
            ]
          },
          "projected_edge_trigger_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "TRUST_GREEN_GUARD_BAND",
                "TRUST_AMBER_GUARD_BAND",
                "RISK_AUTOMATION_GUARD_BAND",
                "COMPLETENESS_GUARD_BAND",
                "GRAPH_FILING_GUARD_BAND",
                "AUTHORITY_REVIEW_GUARD_BAND",
                "AUTHORITY_BLOCK_GUARD_BAND"
              ],
              "minLength": 1
            },
            "uniqueItems": true
          },
          "projected_reason_code_additions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "projected_reason_code_removals": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "score_cap_alignment_state": {
            "const": "CAP_STRICTER_THAN_SCORE"
          }
        },
        "required": [
          "score_cap_alignment_state"
        ]
      },
      "then": {
        "properties": {
          "cap_driver_reason_codes": {
            "minItems": 1
          }
        }
      },
      "else": {
        "properties": {
          "cap_driver_reason_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "threshold_stability_state": {
            "const": "EDGE_REVIEW"
          }
        },
        "required": [
          "threshold_stability_state"
        ]
      },
      "then": {
        "properties": {
          "edge_trigger_codes": {
            "minItems": 1
          }
        }
      },
      "else": {
        "properties": {
          "edge_trigger_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "live_authority_progression_requested": {
            "const": true
          }
        },
        "required": [
          "live_authority_progression_requested"
        ]
      },
      "then": {
        "properties": {
          "graph_filing_margin_or_null": {
            "type": "integer"
          },
          "authority_review_margin_or_null": {
            "type": "integer"
          },
          "authority_block_margin_or_null": {
            "type": "integer"
          }
        }
      },
      "else": {
        "properties": {
          "graph_filing_margin_or_null": {
            "const": null
          },
          "authority_review_margin_or_null": {
            "const": null
          },
          "authority_block_margin_or_null": {
            "const": null
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
