{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/governance_mutation_hazard_contract.schema.json",
  "title": "GovernanceMutationHazardContract",
  "description": "Shared bounded governance mutation-hazard contract. This schema freezes the exact policy and access basis, bounded blast-radius interval, impacted-count classes, policy-risk contributors, approval and commit posture, confidence limits, and structured explanation drivers that reviewed preview, basket, blast-radius, and commit flows must preserve or stale-reject.",
  "type": "object",
  "required": [
    "contract_version",
    "hazard_contract_hash",
    "policy_snapshot_hash",
    "access_binding_hash",
    "dependency_topology_hash",
    "simulation_basis_hash",
    "count_class_profile_code",
    "commit_authority_posture",
    "impact_radius_lower_score",
    "impact_radius_upper_score",
    "impacted_principal_count",
    "impacted_principal_count_class",
    "impacted_client_count",
    "impacted_client_count_class",
    "impacted_authority_operation_count",
    "impacted_authority_operation_count_class",
    "impacted_workflow_count",
    "impacted_workflow_count_class",
    "impacted_limitation_count",
    "impacted_limitation_count_class",
    "privilege_gain_score",
    "scope_expansion_score",
    "masking_relaxation_score",
    "policy_risk_score",
    "approval_necessity_score",
    "approval_requirement",
    "bounded_safe_mutation",
    "required_approvals",
    "simulation_confidence_score",
    "predictability_score",
    "risk_driver_codes",
    "approval_trigger_codes",
    "confidence_limiter_codes",
    "bounded_safety_blocker_codes",
    "reason_codes"
  ],
  "properties": {
    "contract_version": {
      "const": "GOVERNANCE_MUTATION_HAZARD_CONTRACT_V1"
    },
    "hazard_contract_hash": {
      "type": "string",
      "minLength": 1
    },
    "policy_snapshot_hash": {
      "type": "string",
      "minLength": 1
    },
    "access_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "dependency_topology_hash": {
      "type": "string",
      "minLength": 1
    },
    "simulation_basis_hash": {
      "type": "string",
      "minLength": 1
    },
    "count_class_profile_code": {
      "const": "GOVERNANCE_IMPACT_COUNT_CLASS_V1"
    },
    "commit_authority_posture": {
      "type": "string",
      "enum": [
        "PREVIEW_ONLY",
        "APPROVAL_GATED",
        "BOUNDED_SAFE"
      ]
    },
    "impact_radius_lower_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "impact_radius_upper_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "impacted_principal_count": {
      "type": "integer",
      "minimum": 0
    },
    "impacted_principal_count_class": {
      "$ref": "#/$defs/impactedCountClass"
    },
    "impacted_client_count": {
      "type": "integer",
      "minimum": 0
    },
    "impacted_client_count_class": {
      "$ref": "#/$defs/impactedCountClass"
    },
    "impacted_authority_operation_count": {
      "type": "integer",
      "minimum": 0
    },
    "impacted_authority_operation_count_class": {
      "$ref": "#/$defs/impactedCountClass"
    },
    "impacted_workflow_count": {
      "type": "integer",
      "minimum": 0
    },
    "impacted_workflow_count_class": {
      "$ref": "#/$defs/impactedCountClass"
    },
    "impacted_limitation_count": {
      "type": "integer",
      "minimum": 0
    },
    "impacted_limitation_count_class": {
      "$ref": "#/$defs/impactedCountClass"
    },
    "privilege_gain_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "scope_expansion_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "masking_relaxation_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "policy_risk_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "approval_necessity_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "approval_requirement": {
      "type": "string",
      "enum": [
        "NOT_REQUIRED",
        "SINGLE_APPROVER",
        "DUAL_APPROVER",
        "SECURITY_REVIEW",
        "CHANGE_ADVISORY_QUORUM"
      ]
    },
    "bounded_safe_mutation": {
      "type": "integer",
      "enum": [
        0,
        1
      ]
    },
    "required_approvals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "simulation_confidence_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "predictability_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "risk_driver_codes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/riskDriverCode"
      },
      "default": [],
      "uniqueItems": true
    },
    "approval_trigger_codes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/approvalTriggerCode"
      },
      "default": [],
      "uniqueItems": true
    },
    "confidence_limiter_codes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/confidenceLimiterCode"
      },
      "default": [],
      "uniqueItems": true
    },
    "bounded_safety_blocker_codes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/boundedSafetyBlockerCode"
      },
      "default": [],
      "uniqueItems": true
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "$defs": {
    "impactedCountClass": {
      "type": "string",
      "enum": [
        "ZERO",
        "ONE",
        "SMALL_BATCH",
        "MEDIUM_BATCH",
        "LARGE_BATCH",
        "ESTATE_WIDE"
      ]
    },
    "riskDriverCode": {
      "type": "string",
      "enum": [
        "PRIVILEGE_GAIN",
        "SCOPE_EXPANSION",
        "MASKING_RELAXATION",
        "BROAD_BLAST_RADIUS"
      ]
    },
    "approvalTriggerCode": {
      "type": "string",
      "enum": [
        "SINGLE_APPROVER_REQUIRED",
        "DUAL_APPROVER_REQUIRED",
        "SECURITY_REVIEW_REQUIRED",
        "CHANGE_ADVISORY_QUORUM_REQUIRED"
      ]
    },
    "confidenceLimiterCode": {
      "type": "string",
      "enum": [
        "LOW_SIMULATION_CONFIDENCE",
        "LOW_PREDICTABILITY"
      ]
    },
    "boundedSafetyBlockerCode": {
      "type": "string",
      "enum": [
        "PRIVILEGE_GAIN_PRESENT",
        "SCOPE_EXPANSION_PRESENT",
        "MASKING_RELAXATION_PRESENT",
        "IMPACT_RADIUS_TOO_LARGE",
        "POLICY_RISK_TOO_HIGH",
        "CONFIDENCE_TOO_LOW",
        "PREDICTABILITY_TOO_LOW"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "bounded_safe_mutation": {
            "const": 1
          }
        },
        "required": [
          "bounded_safe_mutation"
        ]
      },
      "then": {
        "properties": {
          "approval_requirement": {
            "const": "NOT_REQUIRED"
          },
          "commit_authority_posture": {
            "const": "BOUNDED_SAFE"
          },
          "required_approvals": {
            "maxItems": 0
          },
          "approval_trigger_codes": {
            "maxItems": 0
          },
          "confidence_limiter_codes": {
            "maxItems": 0
          },
          "bounded_safety_blocker_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "bounded_safe_mutation": {
            "const": 0
          }
        },
        "required": [
          "bounded_safe_mutation"
        ]
      },
      "then": {
        "properties": {
          "approval_requirement": {
            "enum": [
              "SINGLE_APPROVER",
              "DUAL_APPROVER",
              "SECURITY_REVIEW",
              "CHANGE_ADVISORY_QUORUM"
            ]
          },
          "required_approvals": {
            "minItems": 1
          },
          "bounded_safety_blocker_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "approval_requirement": {
            "const": "NOT_REQUIRED"
          }
        },
        "required": [
          "approval_requirement"
        ]
      },
      "then": {
        "properties": {
          "bounded_safe_mutation": {
            "const": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "commit_authority_posture": {
            "const": "PREVIEW_ONLY"
          }
        },
        "required": [
          "commit_authority_posture"
        ]
      },
      "then": {
        "properties": {
          "bounded_safe_mutation": {
            "const": 0
          },
          "confidence_limiter_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "commit_authority_posture": {
            "const": "APPROVAL_GATED"
          }
        },
        "required": [
          "commit_authority_posture"
        ]
      },
      "then": {
        "properties": {
          "simulation_confidence_score": {
            "minimum": 80
          },
          "predictability_score": {
            "minimum": 75
          },
          "bounded_safe_mutation": {
            "const": 0
          },
          "approval_trigger_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "commit_authority_posture": {
            "const": "BOUNDED_SAFE"
          }
        },
        "required": [
          "commit_authority_posture"
        ]
      },
      "then": {
        "properties": {
          "simulation_confidence_score": {
            "minimum": 80
          },
          "predictability_score": {
            "minimum": 75
          },
          "bounded_safe_mutation": {
            "const": 1
          },
          "approval_requirement": {
            "const": "NOT_REQUIRED"
          },
          "required_approvals": {
            "maxItems": 0
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
