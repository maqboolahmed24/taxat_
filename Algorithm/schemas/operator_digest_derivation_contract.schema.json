{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/operator_digest_derivation_contract.schema.json",
  "title": "OperatorDigestDerivationContract",
  "description": "Immutable operator-digest derivation and publication proof. This schema freezes the persisted-truth basis, unresolved handoff coverage, queue-summary partitioning, highlight ranking policy, notification completion posture, portfolio-stability basis, operator_digest_derivation_contract_v1 identity, source_batch_identity_hash continuity, and monotonic supersession lineage for one published operator morning digest.",
  "type": "object",
  "required": [
    "contract_version",
    "derivation_contract_hash",
    "execution_mode_boundary_contract",
    "coverage_date",
    "nightly_window_key",
    "source_batch_set_hash",
    "source_batch_count",
    "source_batch_window_state",
    "truth_source_policy",
    "unresolved_handoff_policy",
    "queue_summary_policy",
    "highlight_ranking_profile",
    "highlight_source_policy",
    "publication_qa_profile",
    "publication_qa_state",
    "publication_qa_completed_at",
    "covered_selection_entry_ref_set_hash",
    "outcome_entry_partition_hash",
    "queue_partition_hash",
    "highlight_order_hash",
    "published_workflow_item_ref_set_hash",
    "published_notification_ref_set_hash",
    "waiting_on_authority_ref_set_hash",
    "late_data_hold_ref_set_hash",
    "workflow_publication_state",
    "workflow_publication_settled_at",
    "published_workflow_outcome_counts",
    "published_workflow_item_count",
    "notification_publication_state",
    "notification_publication_settled_at",
    "published_notification_ref_count",
    "persisted_outcome_counts",
    "covered_selection_entry_count",
    "backlog_pressure_basis_hash",
    "portfolio_tail_risk_basis_hash",
    "stability_basis_hash",
    "publication_generation",
    "supersession_state",
    "supersession_root_digest_id",
    "supersedes_digest_id_or_null",
    "supersession_reason_codes",
    "supersession_policy"
  ],
  "properties": {
    "contract_version": {
      "const": "OPERATOR_DIGEST_DERIVATION_V1"
    },
    "derivation_contract_hash": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode_boundary_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/execution_mode_boundary_contract.schema.json"
        },
        {
          "properties": {
            "run_kind": {
              "const": "NIGHTLY"
            },
            "execution_posture": {
              "const": "LIVE_COMPLIANCE"
            },
            "legal_effect_boundary": {
              "const": "COMPLIANCE_CAPABLE"
            }
          }
        }
      ]
    },
    "coverage_date": {
      "type": "string",
      "format": "date"
    },
    "nightly_window_key": {
      "type": "string",
      "minLength": 1
    },
    "source_batch_set_hash": {
      "type": "string",
      "minLength": 1
    },
    "source_batch_count": {
      "type": "integer",
      "minimum": 1
    },
    "source_batch_window_state": {
      "const": "SINGLE_NIGHTLY_WINDOW"
    },
    "truth_source_policy": {
      "const": "PERSISTED_BATCH_MANIFEST_DECISION_WORKFLOW_NOTIFICATION_AND_ERROR_TRUTH_ONLY"
    },
    "unresolved_handoff_policy": {
      "const": "EVERY_UNRESOLVED_OUTCOME_REQUIRES_PUBLISHED_WORKFLOW_HANDOFF"
    },
    "queue_summary_policy": {
      "const": "QUEUE_SUMMARIES_PARTITION_PUBLISHED_WORKFLOW_ITEMS"
    },
    "highlight_ranking_profile": {
      "const": "ENTRY_LOSS_THEN_PRIORITY_TUPLE_V1"
    },
    "highlight_source_policy": {
      "const": "HIGHLIGHTS_SUBSET_OF_PUBLISHED_WORKFLOW_AND_PERSISTED_OUTCOME_TRUTH"
    },
    "publication_qa_profile": {
      "const": "DIGEST_PUBLICATION_HANDOFF_QA_V1"
    },
    "publication_qa_state": {
      "const": "PASSED"
    },
    "publication_qa_completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "covered_selection_entry_ref_set_hash": {
      "type": "string",
      "minLength": 1
    },
    "outcome_entry_partition_hash": {
      "type": "string",
      "minLength": 1
    },
    "queue_partition_hash": {
      "type": "string",
      "minLength": 1
    },
    "highlight_order_hash": {
      "type": "string",
      "minLength": 1
    },
    "published_workflow_item_ref_set_hash": {
      "type": "string",
      "minLength": 1
    },
    "published_notification_ref_set_hash": {
      "type": "string",
      "minLength": 1
    },
    "waiting_on_authority_ref_set_hash": {
      "type": "string",
      "minLength": 1
    },
    "late_data_hold_ref_set_hash": {
      "type": "string",
      "minLength": 1
    },
    "workflow_publication_state": {
      "type": "string",
      "enum": [
        "COMPLETE_WITH_NO_UNRESOLVED_ITEMS",
        "COMPLETE_WITH_PUBLISHED_WORKFLOW_ITEMS"
      ]
    },
    "workflow_publication_settled_at": {
      "type": "string",
      "format": "date-time"
    },
    "published_workflow_outcome_counts": {
      "$ref": "#/$defs/summaryCounts"
    },
    "published_workflow_item_count": {
      "type": "integer",
      "minimum": 0
    },
    "notification_publication_state": {
      "type": "string",
      "enum": [
        "COMPLETE_WITH_EXPLICIT_NONE",
        "COMPLETE_WITH_PUBLISHED_NOTIFICATION_REFS"
      ]
    },
    "notification_publication_settled_at": {
      "type": "string",
      "format": "date-time"
    },
    "published_notification_ref_count": {
      "type": "integer",
      "minimum": 0
    },
    "persisted_outcome_counts": {
      "$ref": "#/$defs/summaryCounts"
    },
    "covered_selection_entry_count": {
      "type": "integer",
      "minimum": 1
    },
    "backlog_pressure_basis_hash": {
      "type": "string",
      "minLength": 1
    },
    "portfolio_tail_risk_basis_hash": {
      "type": "string",
      "minLength": 1
    },
    "stability_basis_hash": {
      "type": "string",
      "minLength": 1
    },
    "publication_generation": {
      "type": "integer",
      "minimum": 1
    },
    "supersession_state": {
      "type": "string",
      "enum": [
        "INITIAL_PUBLICATION",
        "RECOVERY_SUPERSESSION"
      ]
    },
    "supersession_root_digest_id": {
      "type": "string",
      "minLength": 1
    },
    "supersedes_digest_id_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "supersession_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "supersession_policy": {
      "const": "MONOTONIC_COVERAGE_DATE_PUBLICATION_WITH_EXPLICIT_SUPERSESSION"
    }
  },
  "$defs": {
    "summaryCounts": {
      "type": "object",
      "required": [
        "auto_completed",
        "waiting_on_authority",
        "waiting_on_late_data",
        "review_required",
        "request_client_info",
        "blocked_internal",
        "failed_retryable",
        "failed_non_retryable",
        "reused_result",
        "deferred",
        "skipped"
      ],
      "properties": {
        "auto_completed": {
          "type": "integer",
          "minimum": 0
        },
        "waiting_on_authority": {
          "type": "integer",
          "minimum": 0
        },
        "waiting_on_late_data": {
          "type": "integer",
          "minimum": 0
        },
        "review_required": {
          "type": "integer",
          "minimum": 0
        },
        "request_client_info": {
          "type": "integer",
          "minimum": 0
        },
        "blocked_internal": {
          "type": "integer",
          "minimum": 0
        },
        "failed_retryable": {
          "type": "integer",
          "minimum": 0
        },
        "failed_non_retryable": {
          "type": "integer",
          "minimum": 0
        },
        "reused_result": {
          "type": "integer",
          "minimum": 0
        },
        "deferred": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "workflow_publication_state": {
            "const": "COMPLETE_WITH_NO_UNRESOLVED_ITEMS"
          }
        },
        "required": [
          "workflow_publication_state"
        ]
      },
      "then": {
        "properties": {
          "published_workflow_item_count": {
            "const": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "workflow_publication_state": {
            "const": "COMPLETE_WITH_PUBLISHED_WORKFLOW_ITEMS"
          }
        },
        "required": [
          "workflow_publication_state"
        ]
      },
      "then": {
        "properties": {
          "published_workflow_item_count": {
            "minimum": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "notification_publication_state": {
            "const": "COMPLETE_WITH_EXPLICIT_NONE"
          }
        },
        "required": [
          "notification_publication_state"
        ]
      },
      "then": {
        "properties": {
          "published_notification_ref_count": {
            "const": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "notification_publication_state": {
            "const": "COMPLETE_WITH_PUBLISHED_NOTIFICATION_REFS"
          }
        },
        "required": [
          "notification_publication_state"
        ]
      },
      "then": {
        "properties": {
          "published_notification_ref_count": {
            "minimum": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "supersession_state": {
            "const": "INITIAL_PUBLICATION"
          }
        },
        "required": [
          "supersession_state"
        ]
      },
      "then": {
        "properties": {
          "publication_generation": {
            "const": 1
          },
          "supersedes_digest_id_or_null": {
            "type": "null"
          },
          "supersession_reason_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "supersession_state": {
            "const": "RECOVERY_SUPERSESSION"
          }
        },
        "required": [
          "supersession_state"
        ]
      },
      "then": {
        "properties": {
          "publication_generation": {
            "minimum": 2
          },
          "supersedes_digest_id_or_null": {
            "type": "string",
            "minLength": 1
          },
          "supersession_reason_codes": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false,
  "unevaluatedProperties": false
}
