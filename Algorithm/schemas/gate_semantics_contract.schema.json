{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/gate_semantics_contract.schema.json",
  "title": "GateSemanticsContract",
  "description": "Deterministic non-access gate semantics contract. This schema freezes the severity/rank mapping, monotone progression rank, and override-dependency posture for one persisted gate decision so downstream surfaces do not infer legal posture from the raw decision enum alone.",
  "type": "object",
  "required": [
    "contract_version",
    "evaluation_order_profile_code",
    "reason_order_profile_code",
    "severity_profile_code",
    "decision_rank",
    "progression_rank",
    "blocking_class",
    "progression_semantics",
    "override_dependency_state"
  ],
  "properties": {
    "contract_version": {
      "const": "GATE_SEMANTICS_CONTRACT_V1"
    },
    "evaluation_order_profile_code": {
      "const": "NON_ACCESS_GATE_ORDER_V1"
    },
    "reason_order_profile_code": {
      "const": "NON_ACCESS_GATE_REASON_PRIORITY_V1"
    },
    "severity_profile_code": {
      "const": "NON_ACCESS_GATE_SEVERITY_V1"
    },
    "decision_rank": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4
    },
    "progression_rank": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2
    },
    "blocking_class": {
      "type": "string",
      "enum": [
        "NON_BLOCKING",
        "REVIEW_REQUIRED",
        "BLOCKED"
      ]
    },
    "progression_semantics": {
      "type": "string",
      "enum": [
        "AUTOMATED_CONTINUE",
        "AUTOMATED_CONTINUE_WITH_NOTICE",
        "REVIEW_ONLY",
        "BLOCKED"
      ]
    },
    "override_dependency_state": {
      "type": "string",
      "enum": [
        "OVERRIDE_INDEPENDENT",
        "VALID_OVERRIDE_GOVERNED",
        "OVERRIDE_REQUIRED_MISSING",
        "OVERRIDE_FORBIDDEN"
      ]
    }
  },
  "additionalProperties": false
}
