{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/source_record.schema.json",
  "title": "SourceRecord",
  "type": "object",
  "required": [
    "source_record_id",
    "manifest_id",
    "artifact_type",
    "collection_boundary_ref",
    "source_class",
    "provider",
    "captured_at",
    "tenant_id",
    "client_id",
    "business_partition",
    "raw_hash",
    "raw_payload_ref",
    "ingestion_run_ref",
    "source_strength_tier",
    "freshness_state",
    "contract"
  ],
  "properties": {
    "source_record_id": {
      "type": "string"
    },
    "manifest_id": {
      "type": "string"
    },
    "artifact_type": {
      "const": "SourceRecord"
    },
    "collection_boundary_ref": {
      "type": "string"
    },
    "source_class": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "provider_account_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "capture_method": {
      "type": [
        "string",
        "null"
      ]
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "effective_period": {
      "type": [
        "string",
        "null"
      ]
    },
    "tenant_id": {
      "type": "string"
    },
    "client_id": {
      "type": "string"
    },
    "business_partition": {
      "type": "string"
    },
    "raw_hash": {
      "type": "string"
    },
    "raw_payload_ref": {
      "type": "string"
    },
    "ingestion_run_ref": {
      "type": "string"
    },
    "source_strength_tier": {
      "type": "string",
      "enum": [
        "TIER_1_AUTHORITY_FINAL",
        "TIER_2_AUTHORITY_REFERENCE",
        "TIER_3_STRUCTURED_EXTERNAL",
        "TIER_4_STRUCTURED_INTERNAL",
        "TIER_5_DOCUMENT_SUPPORT",
        "TIER_6_DECLARED_ONLY",
        "TIER_7_INFERRED",
        "TIER_8_GOVERNANCE_ONLY"
      ]
    },
    "freshness_state": {
      "type": "string",
      "enum": [
        "CURRENT",
        "STALE",
        "EXPIRED",
        "UNKNOWN",
        "SUPERSEDED"
      ]
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "additionalProperties": false
}
