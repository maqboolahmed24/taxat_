{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/collaboration_routing_contract.schema.json",
  "title": "CollaborationRoutingContract",
  "description": "Persisted quantitative collaboration-routing contract. This schema freezes the routing-profile identity, per-item scores, canonical ordering tuple, recommendation posture, and draft/focus continuity guards so browser, native, notifications, and automation consume one authoritative routing model instead of recomputing local heuristics.",
  "type": "object",
  "required": [
    "contract_version",
    "routing_scope",
    "routing_profile_code",
    "routing_profile_hash",
    "routing_queue_ref",
    "basis_hash",
    "canonical_sort_key",
    "assignment_efficiency_score",
    "ownership_confidence_score",
    "sla_pressure_score",
    "escalation_pressure_score",
    "escalation_pressure_threshold",
    "reassignment_gain_threshold",
    "resolution_confidence_score",
    "resolution_confidence_floor",
    "queue_health_score",
    "queue_pressure_score",
    "queue_health_floor",
    "queue_health_state",
    "escalation_rank",
    "collaboration_priority_score",
    "assignment_recommendation_state",
    "recommended_assignee_ref_or_null",
    "escalation_recommendation_state",
    "recommended_escalation_target_ref_or_null",
    "recommended_action_code_or_null",
    "focused_row_reorder_state",
    "draft_safety_state",
    "ordering_reason_codes",
    "recommendation_reason_codes"
  ],
  "properties": {
    "contract_version": {
      "const": "COLLABORATION_ROUTING_V1"
    },
    "routing_scope": {
      "type": "string",
      "enum": [
        "WORKFLOW_ITEM",
        "WORK_INBOX_ROW",
        "WORKSPACE_QUEUE_PROJECTION",
        "WORKSPACE_STREAM_EVENT",
        "WORK_ITEM_NOTIFICATION"
      ]
    },
    "routing_profile_code": {
      "const": "COLLABORATION_ROUTING_FORMULA_V1"
    },
    "routing_profile_hash": {
      "type": "string",
      "minLength": 1
    },
    "routing_queue_ref": {
      "type": "string",
      "minLength": 1
    },
    "basis_hash": {
      "type": "string",
      "minLength": 1
    },
    "canonical_sort_key": {
      "type": "object",
      "required": [
        "collaboration_priority_score",
        "escalation_rank",
        "effective_due_at_or_null",
        "resolution_confidence_score",
        "queue_entered_at",
        "item_id"
      ],
      "properties": {
        "collaboration_priority_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "escalation_rank": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "effective_due_at_or_null": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "resolution_confidence_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "queue_entered_at": {
          "type": "string",
          "format": "date-time"
        },
        "item_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "assignment_efficiency_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "ownership_confidence_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "sla_pressure_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "escalation_pressure_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "escalation_pressure_threshold": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "reassignment_gain_threshold": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "resolution_confidence_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "resolution_confidence_floor": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "queue_health_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "queue_pressure_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "queue_health_floor": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "queue_health_state": {
      "type": "string",
      "enum": [
        "HEALTHY",
        "DEGRADED",
        "SATURATED"
      ]
    },
    "escalation_rank": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "collaboration_priority_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "assignment_recommendation_state": {
      "type": "string",
      "enum": [
        "KEEP_CURRENT_OWNER",
        "ASSIGN_RECOMMENDED",
        "REASSIGN_RECOMMENDED",
        "NO_ELIGIBLE_OWNER"
      ]
    },
    "recommended_assignee_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "escalation_recommendation_state": {
      "type": "string",
      "enum": [
        "NO_ESCALATION",
        "ESCALATE_RECOMMENDED",
        "ESCALATED_ACTIVE",
        "MANUAL_REVIEW_REQUIRED"
      ]
    },
    "recommended_escalation_target_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "recommended_action_code_or_null": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[A-Z][A-Z0-9_]*$",
      "minLength": 1
    },
    "focused_row_reorder_state": {
      "type": "string",
      "enum": [
        "APPLY_IMMEDIATELY",
        "DEFER_REORDER_UNTIL_FOCUS_EXIT"
      ]
    },
    "draft_safety_state": {
      "type": "string",
      "enum": [
        "NO_DRAFT_LOCK",
        "DRAFT_LOCK_PREVENTS_TRANSFER",
        "COMMAND_PENDING_PREVENTS_TRANSFER"
      ]
    },
    "ordering_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "maxItems": 6,
      "uniqueItems": true
    },
    "recommendation_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "maxItems": 6,
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "assignment_recommendation_state": {
            "const": "KEEP_CURRENT_OWNER"
          }
        },
        "required": [
          "assignment_recommendation_state"
        ]
      },
      "then": {
        "properties": {
          "recommended_assignee_ref_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "assignment_recommendation_state": {
            "enum": [
              "ASSIGN_RECOMMENDED",
              "REASSIGN_RECOMMENDED"
            ]
          }
        },
        "required": [
          "assignment_recommendation_state"
        ]
      },
      "then": {
        "properties": {
          "recommended_assignee_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "recommended_action_code_or_null": {
            "type": "string",
            "minLength": 1
          },
          "recommendation_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "assignment_recommendation_state": {
            "const": "NO_ELIGIBLE_OWNER"
          }
        },
        "required": [
          "assignment_recommendation_state"
        ]
      },
      "then": {
        "properties": {
          "recommended_assignee_ref_or_null": {
            "type": "null"
          },
          "recommendation_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "escalation_recommendation_state": {
            "const": "NO_ESCALATION"
          }
        },
        "required": [
          "escalation_recommendation_state"
        ]
      },
      "then": {
        "properties": {
          "recommended_escalation_target_ref_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "escalation_recommendation_state": {
            "enum": [
              "ESCALATE_RECOMMENDED",
              "ESCALATED_ACTIVE"
            ]
          }
        },
        "required": [
          "escalation_recommendation_state"
        ]
      },
      "then": {
        "properties": {
          "recommended_escalation_target_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "recommendation_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "draft_safety_state": {
            "enum": [
              "DRAFT_LOCK_PREVENTS_TRANSFER",
              "COMMAND_PENDING_PREVENTS_TRANSFER"
            ]
          }
        },
        "required": [
          "draft_safety_state"
        ]
      },
      "then": {
        "properties": {
          "recommendation_reason_codes": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
