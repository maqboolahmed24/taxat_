{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/low_noise_experience_frame.schema.json",
  "title": "LowNoiseExperienceFrame",
  "description": "Route-stable low-noise experience snapshot contract. This schema freezes the published shell frame, the dominant question, settlement posture, the four peer surfaces, the ranked attention policy, the exact cognitive/copy budgets plus frozen dominance thresholds and refresh budgets, and one authoritative route-stability contract so reconnect-safe manifest shells cannot mix decision, shell, and frame markers across generations.",
  "type": "object",
  "required": [
    "artifact_type",
    "frame_id",
    "manifest_id",
    "decision_bundle_ref",
    "decision_bundle_hash",
    "trust_summary_ref",
    "experience_profile",
    "shell_family",
    "object_anchor_ref",
    "shell_route_key",
    "dominant_question",
    "dominance_contract",
    "state_taxonomy_contract",
    "cross_device_continuity_contract",
    "cache_isolation_contract",
    "semantic_accessibility_contract",
    "truth_boundary_contract",
    "frame_epoch",
    "last_published_sequence",
    "shell_stability_token",
    "resume_token",
    "stream_recovery_contract",
    "stability_contract",
    "connection_state",
    "truth_state",
    "checkpoint_state",
    "truth_origin",
    "settlement_state",
    "recovery_posture",
    "interaction_layer",
    "attention_policy",
    "cognitive_budget",
    "copy_budget",
    "low_noise_budget_audit",
    "surface_order",
    "context_bar",
    "decision_summary",
    "action_strip",
    "detail_drawer",
    "active_detail_surface_code",
    "focus_anchor_ref",
    "rendered_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "LowNoiseExperienceFrame"
    },
    "frame_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "decision_bundle_ref": {
      "type": "string",
      "minLength": 1
    },
    "decision_bundle_hash": {
      "type": "string",
      "minLength": 1
    },
    "trust_summary_ref": {
      "type": "string",
      "minLength": 1
    },
    "experience_profile": {
      "const": "LOW_NOISE"
    },
    "shell_family": {
      "const": "CALM_SHELL"
    },
    "object_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "shell_route_key": {
      "type": "string",
      "minLength": 1
    },
    "dominant_question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "dominance_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/shell_dominance_contract.schema.json"
        },
        {
          "properties": {
            "dominant_question_surface_code": {
              "const": "DECISION_SUMMARY"
            },
            "dominant_action_surface_code": {
              "const": "ACTION_STRIP"
            },
            "supplemental_queue_policy": {
              "const": "NOT_APPLICABLE"
            },
            "promoted_support_surface_code_or_null": {
              "enum": [
                "DETAIL_DRAWER",
                null
              ]
            }
          }
        }
      ]
    },
    "state_taxonomy_contract": {
      "$ref": "https://taxat.dev/schemas/shell_state_taxonomy_contract.schema.json"
    },
    "cross_device_continuity_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/cross_device_continuity_contract.schema.json"
        },
        {
          "properties": {
            "continuity_scope": {
              "const": "MANIFEST_ROUTE"
            }
          }
        }
      ]
    },
    "cache_isolation_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/cache_isolation_contract.schema.json"
        },
        {
          "properties": {
            "cache_scope_class": {
              "const": "LOW_NOISE_FRAME"
            }
          }
        }
      ]
    },
    "semantic_accessibility_contract": {
      "$ref": "https://taxat.dev/schemas/semantic_accessibility_contract.schema.json"
    },
    "truth_boundary_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/command_truth_boundary_contract.schema.json"
        },
        {
          "properties": {
            "artifact_role": {
              "const": "READ_SIDE_PROJECTION"
            },
            "authoritative_record_families": {
              "const": [
                "RUN_MANIFEST",
                "GATE_DECISION_RECORD",
                "WORKFLOW_ITEM",
                "AUTHORITY_INTERACTION_RECORD",
                "AUDIT_EVENT"
              ]
            },
            "observable_projection_families": {
              "const": []
            }
          }
        }
      ]
    },
    "frame_epoch": {
      "type": "integer",
      "minimum": 0
    },
    "last_published_sequence": {
      "type": "integer",
      "minimum": 0
    },
    "shell_stability_token": {
      "type": "string",
      "minLength": 1
    },
    "resume_token": {
      "type": "string",
      "minLength": 1
    },
    "stream_recovery_contract": {
      "$ref": "https://taxat.dev/schemas/stream_recovery_contract.schema.json"
    },
    "stability_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/route_stability_contract.schema.json"
        },
        {
          "properties": {
            "route_scope_class": {
              "const": "MANIFEST_EXPERIENCE"
            },
            "guard_vector_components": {
              "properties": {
                "decision_bundle_hash_or_null": {
                  "type": "string",
                  "minLength": 1
                },
                "shell_stability_token_or_null": {
                  "type": "string",
                  "minLength": 1
                },
                "frame_epoch_or_null": {
                  "type": "integer",
                  "minimum": 0
                },
                "work_item_version_or_null": {
                  "type": "null"
                },
                "customer_thread_head_or_null": {
                  "type": "null"
                },
                "internal_thread_head_or_null": {
                  "type": "null"
                },
                "request_state_version_or_null": {
                  "type": "null"
                },
                "client_portal_workspace_version_or_null": {
                  "type": "null"
                },
                "view_guard_ref_or_null": {
                  "type": "null"
                }
              }
            }
          }
        }
      ]
    },
    "connection_state": {
      "type": "string",
      "enum": [
        "CONNECTED",
        "RECONNECTING",
        "CATCHING_UP",
        "STALE",
        "DEGRADED"
      ]
    },
    "truth_state": {
      "type": "string",
      "enum": [
        "LOCAL_INTENT_ONLY",
        "PERSISTED_INTERNAL",
        "AUTHORITY_PENDING",
        "AUTHORITY_CONFIRMED",
        "AUTHORITY_REJECTED",
        "AUTHORITY_UNKNOWN",
        "AUTHORITY_OUT_OF_BAND"
      ]
    },
    "checkpoint_state": {
      "type": "string",
      "enum": [
        "NONE",
        "SOURCE_COLLECTION",
        "PROJECTION_PENDING",
        "HUMAN_REVIEW",
        "APPROVAL_PENDING",
        "AUTHORITY_PREFLIGHT",
        "TRANSMIT_PENDING",
        "PENDING_ACK",
        "RECONCILIATION_PENDING",
        "LATE_DATA_PENDING",
        "CONFIRMED",
        "REJECTED",
        "UNKNOWN",
        "OUT_OF_BAND"
      ]
    },
    "truth_origin": {
      "type": "string",
      "enum": [
        "LOCAL_INTENT",
        "PERSISTED_STATE",
        "AUTHORITY_ARTIFACT",
        "OUT_OF_BAND_DISCOVERY"
      ]
    },
    "settlement_state": {
      "$ref": "#/$defs/settlementState"
    },
    "recovery_posture": {
      "$ref": "#/$defs/recoveryPosture"
    },
    "interaction_layer": {
      "$ref": "https://taxat.dev/schemas/operator_interaction_layer.schema.json"
    },
    "attention_policy": {
      "$ref": "#/$defs/attentionPolicy"
    },
    "cognitive_budget": {
      "$ref": "#/$defs/cognitiveBudget"
    },
    "copy_budget": {
      "$ref": "#/$defs/copyBudget"
    },
    "low_noise_budget_audit": {
      "$ref": "https://taxat.dev/schemas/low_noise_budget_audit.schema.json"
    },
    "surface_order": {
      "type": "array",
      "prefixItems": [
        {
          "const": "CONTEXT_BAR"
        },
        {
          "const": "DECISION_SUMMARY"
        },
        {
          "const": "ACTION_STRIP"
        },
        {
          "const": "DETAIL_DRAWER"
        }
      ],
      "items": false,
      "minItems": 4,
      "maxItems": 4
    },
    "context_bar": {
      "$ref": "https://taxat.dev/schemas/context_bar_state.schema.json"
    },
    "decision_summary": {
      "$ref": "https://taxat.dev/schemas/decision_summary_state.schema.json"
    },
    "action_strip": {
      "$ref": "https://taxat.dev/schemas/action_strip_state.schema.json"
    },
    "detail_drawer": {
      "$ref": "https://taxat.dev/schemas/detail_drawer_state.schema.json"
    },
    "active_detail_surface_code": {
      "anyOf": [
        {
          "$ref": "#/$defs/detailModuleCode"
        },
        {
          "type": "null"
        }
      ]
    },
    "focus_anchor_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "rendered_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "lowNoiseSurfaceCode": {
      "type": "string",
      "enum": [
        "CONTEXT_BAR",
        "DECISION_SUMMARY",
        "ACTION_STRIP",
        "DETAIL_DRAWER"
      ]
    },
    "detailModuleCode": {
      "type": "string",
      "enum": [
        "EVIDENCE_TIDE",
        "PACKET_FORGE",
        "AUTHORITY_TUNNEL",
        "DRIFT_FIELD",
        "FOCUS_LENS",
        "TWIN_PANEL"
      ]
    },
    "settlementState": {
      "type": "string",
      "enum": [
        "STEADY",
        "RECEIPT_PENDING",
        "FRESHENING",
        "STALE_REVIEW_REQUIRED",
        "DEGRADED_READ_ONLY",
        "RECOVERY_REQUIRED"
      ]
    },
    "recoveryPosture": {
      "type": "string",
      "enum": [
        "NONE",
        "INLINE_RECONNECT",
        "INLINE_REBASE",
        "READ_ONLY_LIMITED",
        "OBJECT_SUPERSEDED",
        "ACCESS_REBIND_REQUIRED"
      ]
    },
    "attentionPolicy": {
      "type": "object",
      "required": [
        "policy_version",
        "attention_state",
        "primary_surface_code",
        "primary_object_ref",
        "actionability_state",
        "primary_action_code",
        "no_safe_action_reason_code",
        "secondary_notice_count",
        "detail_entry_points",
        "suggested_detail_surface_code",
        "primary_rank_score",
        "runner_up_rank_score",
        "dominance_margin",
        "ranking_basis",
        "default_detail_module_code",
        "visible_warning_count"
      ],
      "properties": {
        "policy_version": {
          "type": "string",
          "minLength": 1
        },
        "attention_state": {
          "type": "string",
          "enum": [
            "CALM",
            "NOTICE",
            "REVIEW",
            "BLOCKED",
            "WAITING",
            "LIMITED"
          ]
        },
        "primary_surface_code": {
          "$ref": "#/$defs/lowNoiseSurfaceCode"
        },
        "primary_object_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "actionability_state": {
          "type": "string",
          "enum": [
            "ACTION_AVAILABLE",
            "NO_SAFE_ACTION"
          ]
        },
        "primary_action_code": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "no_safe_action_reason_code": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "secondary_notice_count": {
          "type": "integer",
          "minimum": 0
        },
        "detail_entry_points": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/detailModuleCode"
          },
          "default": [],
          "maxItems": 5,
          "uniqueItems": true
        },
        "suggested_detail_surface_code": {
          "anyOf": [
            {
              "$ref": "#/$defs/detailModuleCode"
            },
            {
              "type": "null"
            }
          ]
        },
        "primary_rank_score": {
          "type": "integer",
          "minimum": 0
        },
        "runner_up_rank_score": {
          "type": "integer",
          "minimum": 0
        },
        "dominance_margin": {
          "type": "integer",
          "minimum": 0
        },
        "ranking_basis": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "maxItems": 8,
          "uniqueItems": true
        },
        "default_detail_module_code": {
          "anyOf": [
            {
              "$ref": "#/$defs/detailModuleCode"
            },
            {
              "type": "null"
            }
          ]
        },
        "visible_warning_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "actionability_state": {
                "const": "ACTION_AVAILABLE"
              }
            },
            "required": [
              "actionability_state"
            ]
          },
          "then": {
            "properties": {
              "primary_action_code": {
                "type": "string",
                "minLength": 1
              },
              "no_safe_action_reason_code": {
                "type": "null"
              },
              "suggested_detail_surface_code": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "actionability_state": {
                "const": "NO_SAFE_ACTION"
              }
            },
            "required": [
              "actionability_state"
            ]
          },
          "then": {
            "properties": {
              "primary_action_code": {
                "type": "null"
              },
              "no_safe_action_reason_code": {
                "type": "string",
                "minLength": 1
              },
              "suggested_detail_surface_code": {
                "$ref": "#/$defs/detailModuleCode"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "detail_entry_points": {
                "minItems": 1
              }
            },
            "required": [
              "detail_entry_points"
            ]
          },
          "then": {
            "properties": {
              "default_detail_module_code": {
                "$ref": "#/$defs/detailModuleCode"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "default_detail_module_code": {
                "$ref": "#/$defs/detailModuleCode"
              }
            },
            "required": [
              "default_detail_module_code"
            ]
          },
          "then": {
            "properties": {
              "detail_entry_points": {
                "minItems": 1
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "cognitiveBudget": {
      "type": "object",
      "required": [
        "persistent_surface_limit",
        "concurrent_primary_limit",
        "primary_reason_limit",
        "secondary_action_limit",
        "visible_warning_limit",
        "detail_entry_point_limit",
        "expanded_detail_module_limit",
        "visibility_budget_units",
        "prominent_motion_limit",
        "issue_dominance_min_margin",
        "action_dominance_min_margin",
        "primary_rank_hysteresis",
        "non_material_rank_swap_limit",
        "non_material_continuity_cost_limit",
        "refresh_coalescing_window_ms",
        "refresh_burst_visible_change_limit"
      ],
      "properties": {
        "persistent_surface_limit": {
          "const": 4
        },
        "concurrent_primary_limit": {
          "const": 1
        },
        "primary_reason_limit": {
          "const": 3
        },
        "secondary_action_limit": {
          "const": 2
        },
        "visible_warning_limit": {
          "const": 1
        },
        "detail_entry_point_limit": {
          "const": 5
        },
        "expanded_detail_module_limit": {
          "const": 1
        },
        "visibility_budget_units": {
          "const": 12
        },
        "prominent_motion_limit": {
          "const": 1
        },
        "issue_dominance_min_margin": {
          "const": 12
        },
        "action_dominance_min_margin": {
          "const": 15
        },
        "primary_rank_hysteresis": {
          "const": 8
        },
        "non_material_rank_swap_limit": {
          "const": 1
        },
        "non_material_continuity_cost_limit": {
          "const": 6
        },
        "refresh_coalescing_window_ms": {
          "const": 1500
        },
        "refresh_burst_visible_change_limit": {
          "const": 2
        }
      },
      "additionalProperties": false
    },
    "copyBudget": {
      "type": "object",
      "required": [
        "manifest_label_max_chars",
        "context_label_max_chars",
        "headline_max_chars",
        "reason_label_max_chars",
        "explanation_max_chars",
        "action_label_max_chars",
        "blocking_reason_max_chars",
        "uncertainty_max_chars",
        "detail_entry_label_max_chars",
        "detail_entry_reason_max_chars"
      ],
      "properties": {
        "manifest_label_max_chars": {
          "const": 64
        },
        "context_label_max_chars": {
          "const": 48
        },
        "headline_max_chars": {
          "const": 96
        },
        "reason_label_max_chars": {
          "const": 120
        },
        "explanation_max_chars": {
          "const": 240
        },
        "action_label_max_chars": {
          "const": 40
        },
        "blocking_reason_max_chars": {
          "const": 160
        },
        "uncertainty_max_chars": {
          "const": 160
        },
        "detail_entry_label_max_chars": {
          "const": 48
        },
        "detail_entry_reason_max_chars": {
          "const": 120
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "properties": {
        "interaction_layer": {
          "properties": {
            "recovery_notice_surface": {
              "const": "CONTEXT_BAR"
            },
            "notification_surface": {
              "const": "CONTEXT_BAR"
            },
            "artifact_preview_surface": {
              "const": "DETAIL_DRAWER"
            }
          },
          "required": [
            "recovery_notice_surface",
            "notification_surface",
            "artifact_preview_surface"
          ]
        }
      },
      "required": [
        "interaction_layer"
      ]
    },
    {
      "if": {
        "properties": {
          "recovery_posture": {
            "not": {
              "const": "NONE"
            }
          }
        },
        "required": [
          "recovery_posture"
        ]
      },
      "then": {
        "properties": {
          "action_strip": {
            "properties": {
              "mode_safety_posture": {
                "const": "NON_LIVE_MUTATIONS_FORBIDDEN"
              }
            },
            "required": [
              "mode_safety_posture"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "settlement_state": {
            "enum": [
              "STALE_REVIEW_REQUIRED",
              "DEGRADED_READ_ONLY",
              "RECOVERY_REQUIRED"
            ]
          }
        },
        "required": [
          "settlement_state"
        ]
      },
      "then": {
        "properties": {
          "action_strip": {
            "properties": {
              "mode_safety_posture": {
                "const": "NON_LIVE_MUTATIONS_FORBIDDEN"
              }
            },
            "required": [
              "mode_safety_posture"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "settlement_state": {
            "const": "RECOVERY_REQUIRED"
          }
        },
        "required": [
          "settlement_state"
        ]
      },
      "then": {
        "properties": {
          "recovery_posture": {
            "not": {
              "const": "NONE"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "attention_policy": {
            "properties": {
              "actionability_state": {
                "const": "ACTION_AVAILABLE"
              }
            },
            "required": [
              "actionability_state"
            ]
          }
        },
        "required": [
          "attention_policy"
        ]
      },
      "then": {
        "properties": {
          "action_strip": {
            "properties": {
              "actionability_state": {
                "const": "ACTION_AVAILABLE"
              }
            },
            "required": [
              "actionability_state"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "attention_policy": {
            "properties": {
              "actionability_state": {
                "const": "NO_SAFE_ACTION"
              }
            },
            "required": [
              "actionability_state"
            ]
          }
        },
        "required": [
          "attention_policy"
        ]
      },
      "then": {
        "properties": {
          "action_strip": {
            "properties": {
              "actionability_state": {
                "const": "NO_SAFE_ACTION"
              }
            },
            "required": [
              "actionability_state"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "connection_state": {
            "enum": [
              "RECONNECTING",
              "CATCHING_UP",
              "STALE",
              "DEGRADED"
            ]
          }
        },
        "required": [
          "connection_state"
        ]
      },
      "then": {
        "properties": {
          "action_strip": {
            "properties": {
              "mode_safety_posture": {
                "const": "NON_LIVE_MUTATIONS_FORBIDDEN"
              }
            },
            "required": [
              "mode_safety_posture"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "active_detail_surface_code": {
            "type": "null"
          }
        },
        "required": [
          "active_detail_surface_code"
        ]
      },
      "then": {
        "properties": {
          "detail_drawer": {
            "properties": {
              "expanded_module_code": {
                "type": "null"
              }
            },
            "required": [
              "expanded_module_code"
            ]
          },
          "focus_anchor_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "active_detail_surface_code": {
            "$ref": "#/$defs/detailModuleCode"
          }
        },
        "required": [
          "active_detail_surface_code"
        ]
      },
