{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/forecast_set.schema.json",
  "title": "ForecastSet",
  "description": "Deterministic analysis-only forecast artifact. This schema freezes the baseline compute binding, forecast profile, point forecasts, and optional Monte Carlo scenario seeds for one modeled run.",
  "type": "object",
  "required": [
    "forecast_id",
    "manifest_id",
    "artifact_type",
    "execution_mode",
    "analysis_only",
    "non_compliance_config_refs",
    "counterfactual_basis",
    "forecast_profile_ref",
    "baseline_compute_ref",
    "money_profile",
    "scenario_mode",
    "point_forecasts",
    "scenarios",
    "seeds",
    "created_at",
    "contract"
  ],
  "properties": {
    "forecast_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "ForecastSet"
    },
    "execution_mode": {
      "const": "ANALYSIS"
    },
    "analysis_only": {
      "const": true
    },
    "non_compliance_config_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "counterfactual_basis": {
      "type": "string",
      "minLength": 1
    },
    "forecast_profile_ref": {
      "type": "string",
      "minLength": 1
    },
    "baseline_compute_ref": {
      "type": "string",
      "minLength": 1
    },
    "money_profile": {
      "$ref": "./schema_bundle.schema.json#/$defs/moneyProfile"
    },
    "scenario_mode": {
      "type": "string",
      "enum": [
        "POINT_ONLY",
        "MONTE_CARLO"
      ]
    },
    "point_forecasts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pointForecast"
      },
      "minItems": 1
    },
    "scenarios": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scenario"
      },
      "default": []
    },
    "seeds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/scenarioSeed"
      },
      "default": [],
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "$defs": {
    "pointForecast": {
      "type": "object",
      "required": [
        "horizon_code",
        "category_code",
        "baseline_steps",
        "point_value",
        "normalized_seasonality",
        "annualized_growth_rate"
      ],
      "properties": {
        "horizon_code": {
          "type": "string",
          "minLength": 1
        },
        "category_code": {
          "type": "string",
          "minLength": 1
        },
        "baseline_steps": {
          "type": "integer",
          "minimum": 1
        },
        "point_value": {
          "$ref": "./schema_bundle.schema.json#/$defs/moneyValue"
        },
        "normalized_seasonality": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "annualized_growth_rate": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "scenario": {
      "type": "object",
      "required": [
        "scenario_id",
        "seed_ref",
        "values"
      ],
      "properties": {
        "scenario_id": {
          "type": "string",
          "minLength": 1
        },
        "seed_ref": {
          "type": "string",
          "minLength": 1
        },
        "values": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/scenarioValue"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "scenarioValue": {
      "type": "object",
      "required": [
        "horizon_code",
        "category_code",
        "simulated_value"
      ],
      "properties": {
        "horizon_code": {
          "type": "string",
          "minLength": 1
        },
        "category_code": {
          "type": "string",
          "minLength": 1
        },
        "simulated_value": {
          "$ref": "./schema_bundle.schema.json#/$defs/moneyValue"
        }
      },
      "additionalProperties": false
    },
    "scenarioSeed": {
      "type": "object",
      "required": [
        "scenario_id",
        "seed"
      ],
      "properties": {
        "scenario_id": {
          "type": "string",
          "minLength": 1
        },
        "seed": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "scenario_mode": {
            "const": "POINT_ONLY"
          }
        },
        "required": [
          "scenario_mode"
        ]
      },
      "then": {
        "properties": {
          "scenarios": {
            "maxItems": 0
          },
          "seeds": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scenario_mode": {
            "const": "MONTE_CARLO"
          }
        },
        "required": [
          "scenario_mode"
        ]
      },
      "then": {
        "properties": {
          "scenarios": {
            "minItems": 1
          },
          "seeds": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
