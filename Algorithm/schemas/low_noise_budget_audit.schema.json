{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/low_noise_budget_audit.schema.json",
  "title": "LowNoiseBudgetAudit",
  "description": "Deterministic calm-shell budget audit contract. This schema freezes the first-view surface count, dominant-story count, visible reason or action counts, detail-entry count, visible copy load, duplicate-posture detection, scan-load calculation, and non-material refresh budget state used to prove that low-noise frames stay within the governed compression profile.",
  "type": "object",
  "required": [
    "contract_version",
    "shell_family",
    "audit_scope",
    "rendered_surface_order",
    "persistent_surface_count",
    "concurrent_primary_count",
    "dominant_issue_count",
    "primary_mutation_action_count",
    "secondary_mutation_action_count",
    "visible_reason_count",
    "collapsed_reason_count",
    "visible_warning_count",
    "visible_action_count",
    "visible_detail_entry_count",
    "visible_shell_char_count",
    "prominent_motion_count",
    "scan_load",
    "copy_budget_state",
    "surface_budget_state",
    "attention_budget_state",
    "semantic_coverage_state",
    "duplicate_posture_codes",
    "duplicate_posture_cluster_count",
    "rank_swap_count_or_null",
    "continuity_cost_or_null",
    "visible_change_count_in_window_or_null",
    "coalesced_change_count_or_null",
    "refresh_budget_state",
    "detail_fallback_state"
  ],
  "properties": {
    "contract_version": {
      "const": "LOW_NOISE_BUDGET_AUDIT_V1"
    },
    "shell_family": {
      "const": "CALM_SHELL"
    },
    "audit_scope": {
      "type": "string",
      "enum": [
        "FIRST_VIEW",
        "NON_MATERIAL_REFRESH",
        "RECOVERY_RECONNECT"
      ]
    },
    "rendered_surface_order": {
      "type": "array",
      "prefixItems": [
        {
          "const": "CONTEXT_BAR"
        },
        {
          "const": "DECISION_SUMMARY"
        },
        {
          "const": "ACTION_STRIP"
        },
        {
          "const": "DETAIL_DRAWER"
        }
      ],
      "items": false,
      "minItems": 4,
      "maxItems": 4
    },
    "persistent_surface_count": {
      "type": "integer",
      "minimum": 0
    },
    "concurrent_primary_count": {
      "type": "integer",
      "minimum": 0
    },
    "dominant_issue_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1
    },
    "primary_mutation_action_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1
    },
    "secondary_mutation_action_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2
    },
    "visible_reason_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "collapsed_reason_count": {
      "type": "integer",
      "minimum": 0
    },
    "visible_warning_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1
    },
    "visible_action_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "visible_detail_entry_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5
    },
    "visible_shell_char_count": {
      "type": "integer",
      "minimum": 0
    },
    "prominent_motion_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1
    },
    "scan_load": {
      "type": "number",
      "minimum": 0,
      "multipleOf": 0.25
    },
    "copy_budget_state": {
      "const": "WITHIN_FROZEN_COPY_BUDGET"
    },
    "surface_budget_state": {
      "const": "WITHIN_FROZEN_SURFACE_BUDGET"
    },
    "attention_budget_state": {
      "const": "WITHIN_FROZEN_ATTENTION_BUDGET"
    },
    "semantic_coverage_state": {
      "const": "LOSSLESS_DECISIVE_ATOMS_VISIBLE_OR_ROUTE_STABLE"
    },
    "duplicate_posture_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "LIMITATION_STATEMENT_DUPLICATED",
          "BLOCKING_REASON_DUPLICATED",
          "DETAIL_ENTRY_REASON_DUPLICATED"
        ]
      },
      "default": [],
      "uniqueItems": true
    },
    "duplicate_posture_cluster_count": {
      "type": "integer",
      "minimum": 0
    },
    "rank_swap_count_or_null": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "continuity_cost_or_null": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "visible_change_count_in_window_or_null": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "coalesced_change_count_or_null": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "refresh_budget_state": {
      "type": "string",
      "enum": [
        "NOT_APPLICABLE",
        "WITHIN_NON_MATERIAL_REFRESH_BUDGET",
        "COALESCED_TO_PRESERVE_BUDGET"
      ]
    },
    "detail_fallback_state": {
      "type": "string",
      "enum": [
        "NOT_APPLICABLE",
        "ACTIVE_MODULE_PRESERVED",
        "FIRST_VALID_ENTRY_SELECTED",
        "SUGGESTED_MODULE_SELECTED",
        "COLLAPSED_ROOT_SELECTED"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "audit_scope": {
            "const": "FIRST_VIEW"
          }
        },
        "required": [
          "audit_scope"
        ]
      },
      "then": {
        "properties": {
          "rank_swap_count_or_null": {
            "type": "null"
          },
          "continuity_cost_or_null": {
            "type": "null"
          },
          "visible_change_count_in_window_or_null": {
            "type": "null"
          },
          "coalesced_change_count_or_null": {
            "type": "null"
          },
          "refresh_budget_state": {
            "const": "NOT_APPLICABLE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "audit_scope": {
            "enum": [
              "NON_MATERIAL_REFRESH",
              "RECOVERY_RECONNECT"
            ]
          }
        },
        "required": [
          "audit_scope"
        ]
      },
      "then": {
        "properties": {
          "rank_swap_count_or_null": {
            "type": "integer",
            "minimum": 0
          },
          "continuity_cost_or_null": {
            "type": "integer",
            "minimum": 0
          },
          "visible_change_count_in_window_or_null": {
            "type": "integer",
            "minimum": 0
          },
          "coalesced_change_count_or_null": {
            "type": "integer",
            "minimum": 0
          },
          "refresh_budget_state": {
            "enum": [
              "WITHIN_NON_MATERIAL_REFRESH_BUDGET",
              "COALESCED_TO_PRESERVE_BUDGET"
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
