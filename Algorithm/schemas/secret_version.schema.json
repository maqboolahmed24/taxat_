{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/secret_version.schema.json",
  "title": "SecretVersion",
  "description": "Versioned secret and key-material contract. This schema freezes secret lineage, attestation posture, activation and retirement windows, and revocation semantics so rotation cannot leave version binding ambiguous.",
  "type": "object",
  "required": [
    "artifact_type",
    "secret_version_id",
    "secret_class",
    "store_ref",
    "key_version_ref",
    "policy_profile_ref",
    "lineage_ref",
    "issued_at",
    "expires_at",
    "rotation_state",
    "last_attested_at",
    "attestation_ref",
    "activated_at",
    "rotation_started_at",
    "retired_at",
    "revoked_at",
    "revocation_reason_code",
    "historical_read_window_until",
    "superseded_by_secret_version_id"
  ],
  "properties": {
    "artifact_type": {
      "const": "SecretVersion"
    },
    "secret_version_id": {
      "type": "string",
      "minLength": 1
    },
    "secret_class": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "store_ref": {
      "type": "string",
      "minLength": 1
    },
    "key_version_ref": {
      "type": "string",
      "minLength": 1
    },
    "policy_profile_ref": {
      "type": "string",
      "minLength": 1
    },
    "lineage_ref": {
      "type": "string",
      "minLength": 1
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "rotation_state": {
      "type": "string",
      "enum": [
        "ISSUED",
        "ATTESTED",
        "ACTIVE",
        "ROTATING",
        "RETIRED",
        "REVOKED"
      ]
    },
    "last_attested_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "attestation_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "activated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "rotation_started_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "retired_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "revoked_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "revocation_reason_code": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "historical_read_window_until": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "superseded_by_secret_version_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "rotation_state": {
            "const": "ISSUED"
          }
        },
        "required": [
          "rotation_state"
        ]
      },
      "then": {
        "properties": {
          "last_attested_at": {
            "type": "null"
          },
          "attestation_ref": {
            "type": "null"
          },
          "activated_at": {
            "type": "null"
          },
          "rotation_started_at": {
            "type": "null"
          },
          "retired_at": {
            "type": "null"
          },
          "revoked_at": {
            "type": "null"
          },
          "revocation_reason_code": {
            "type": "null"
          },
          "historical_read_window_until": {
            "type": "null"
          },
          "superseded_by_secret_version_id": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "rotation_state": {
            "const": "ATTESTED"
          }
        },
        "required": [
          "rotation_state"
        ]
      },
      "then": {
        "properties": {
          "last_attested_at": {
            "type": "string",
            "format": "date-time"
          },
          "attestation_ref": {
            "type": "string",
            "minLength": 1
          },
          "activated_at": {
            "type": "null"
          },
          "rotation_started_at": {
            "type": "null"
          },
          "retired_at": {
            "type": "null"
          },
          "revoked_at": {
            "type": "null"
          },
          "revocation_reason_code": {
            "type": "null"
          },
          "historical_read_window_until": {
            "type": "null"
          },
          "superseded_by_secret_version_id": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "rotation_state": {
            "const": "ACTIVE"
          }
        },
        "required": [
          "rotation_state"
        ]
      },
      "then": {
        "properties": {
          "last_attested_at": {
            "type": "string",
            "format": "date-time"
          },
          "attestation_ref": {
            "type": "string",
            "minLength": 1
          },
          "activated_at": {
            "type": "string",
            "format": "date-time"
          },
          "rotation_started_at": {
            "type": "null"
          },
          "retired_at": {
            "type": "null"
          },
          "revoked_at": {
            "type": "null"
          },
          "revocation_reason_code": {
            "type": "null"
          },
          "historical_read_window_until": {
            "type": "null"
          },
          "superseded_by_secret_version_id": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "rotation_state": {
            "const": "ROTATING"
          }
        },
        "required": [
          "rotation_state"
        ]
      },
      "then": {
        "properties": {
          "last_attested_at": {
            "type": "string",
            "format": "date-time"
          },
          "attestation_ref": {
            "type": "string",
            "minLength": 1
          },
          "activated_at": {
            "type": "string",
            "format": "date-time"
          },
          "rotation_started_at": {
            "type": "string",
            "format": "date-time"
          },
          "retired_at": {
            "type": "null"
          },
          "revoked_at": {
            "type": "null"
          },
          "revocation_reason_code": {
            "type": "null"
          },
          "historical_read_window_until": {
            "type": "null"
          },
          "superseded_by_secret_version_id": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "rotation_state": {
            "const": "RETIRED"
          }
        },
        "required": [
          "rotation_state"
        ]
      },
      "then": {
        "properties": {
          "last_attested_at": {
            "type": "string",
            "format": "date-time"
          },
          "attestation_ref": {
            "type": "string",
            "minLength": 1
          },
          "rotation_started_at": {
            "type": "string",
            "format": "date-time"
          },
          "activated_at": {
            "type": "string",
            "format": "date-time"
          },
          "retired_at": {
            "type": "string",
            "format": "date-time"
          },
          "revoked_at": {
            "type": "null"
          },
          "revocation_reason_code": {
            "type": "null"
          },
          "historical_read_window_until": {
            "type": "string",
            "format": "date-time"
          },
          "superseded_by_secret_version_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "rotation_state": {
            "const": "REVOKED"
          }
        },
        "required": [
          "rotation_state"
        ]
      },
      "then": {
        "properties": {
          "revoked_at": {
            "type": "string",
            "format": "date-time"
          },
          "revocation_reason_code": {
            "type": "string",
            "minLength": 1
          },
          "superseded_by_secret_version_id": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "activated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "activated_at"
        ]
      },
      "then": {
        "properties": {
          "rotation_state": {
            "enum": [
              "ACTIVE",
              "ROTATING",
              "RETIRED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "rotation_started_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "rotation_started_at"
        ]
      },
      "then": {
        "properties": {
          "rotation_state": {
            "enum": [
              "ROTATING",
              "RETIRED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "retired_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "retired_at"
        ]
      },
      "then": {
        "properties": {
          "rotation_state": {
            "const": "RETIRED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "historical_read_window_until": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "historical_read_window_until"
        ]
      },
      "then": {
        "properties": {
          "rotation_state": {
            "const": "RETIRED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "superseded_by_secret_version_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "superseded_by_secret_version_id"
        ]
      },
      "then": {
        "properties": {
          "rotation_state": {
            "const": "RETIRED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "revoked_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "revoked_at"
        ]
      },
      "then": {
        "properties": {
          "rotation_state": {
            "const": "REVOKED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "revocation_reason_code": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "revocation_reason_code"
        ]
      },
      "then": {
        "properties": {
          "rotation_state": {
            "const": "REVOKED"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
