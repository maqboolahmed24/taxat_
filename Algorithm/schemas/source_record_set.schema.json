{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/source_record_set.schema.json",
  "title": "SourceRecordSet",
  "allOf": [
    {
      "type": "object",
      "required": [
        "set_id",
        "manifest_id",
        "artifact_type",
        "items",
        "contract"
      ],
      "properties": {
        "set_id": {
          "type": "string"
        },
        "manifest_id": {
          "type": "string"
        },
        "artifact_type": {
          "const": "SourceRecordSet"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "./source_record.schema.json"
          },
          "uniqueItems": true
        },
        "contract": {
          "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "artifact_contract_hash",
        "set_hash"
      ],
      "properties": {
        "artifact_contract_hash": {
          "type": "string"
        },
        "set_hash": {
          "type": "string"
        },
        "produced_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
