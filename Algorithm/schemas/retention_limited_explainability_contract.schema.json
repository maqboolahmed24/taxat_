{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/retention_limited_explainability_contract.schema.json",
  "title": "RetentionLimitedExplainabilityContract",
  "description": "Shared retention-limited explainability and audit-sufficiency contract. This schema freezes the governed boundary between retained decisive truth, explicit limitation disclosure, deterministic AVAILABLE versus LIMITED versus FAILED explanation posture, and minimum audit reconstruction context after payload expiry so lawful retention loss never degrades into silent absence.",
  "type": "object",
  "required": [
    "contract_version",
    "boundary_scope",
    "surface_role",
    "surface_specific_binding_policy",
    "decisive_limitations_policy",
    "explanation_state_policy",
    "omission_disclosure_policy",
    "audit_sufficiency_policy",
    "present_limited_truth_policy",
    "silent_ambiguity_policy"
  ],
  "properties": {
    "contract_version": {
      "const": "RETENTION_EXPLAINABILITY_V1"
    },
    "boundary_scope": {
      "type": "string",
      "enum": [
        "PROOF_BUNDLE",
        "EVIDENCE_GRAPH",
        "ENQUIRY_PACK",
        "AUDIT_EVENT"
      ]
    },
    "surface_role": {
      "type": "string",
      "enum": [
        "FILING_PROOF_ARTIFACT",
        "GRAPH_EXPLANATION_INDEX",
        "SCRUTINY_EXPORT_PACK",
        "AUDIT_RECONSTRUCTION_EVIDENCE"
      ]
    },
    "surface_specific_binding_policy": {
      "type": "string",
      "enum": [
        "PROOF_BUNDLE_RETAINS_DECISIVE_LIMITATION_AND_RETENTION_BINDING",
        "EVIDENCE_GRAPH_RETAINS_LIMITATION_NOTES_AND_TARGET_EXPLANATION_POSTURE",
        "ENQUIRY_PACK_RETAINS_LIMITATION_NOTES_OMISSIONS_AND_RETENTION_BINDING",
        "AUDIT_EVENT_RETAINS_MINIMUM_RECONSTRUCTION_CONTEXT_AFTER_PAYLOAD_EXPIRY"
      ]
    },
    "decisive_limitations_policy": {
      "const": "DECISIVE_LIMITATIONS_MUST_REMAIN_TYPED_AND_PRESENT"
    },
    "explanation_state_policy": {
      "const": "AVAILABLE_ONLY_WHEN_FULL_DECISIVE_RENDERABILITY_SURVIVES"
    },
    "omission_disclosure_policy": {
      "const": "LIMITATIONS_AND_OMISSIONS_MUST_BE_EXPLICIT_NOT_NEGATIVE_ABSENCE"
    },
    "audit_sufficiency_policy": {
      "const": "POST_EXPIRY_AUDIT_MUST_RETAIN_OBJECT_REASON_AND_LINEAGE_MINIMUM"
    },
    "present_limited_truth_policy": {
      "const": "RETENTION_LIMITED_TRUTH_REMAINS_PRESENT_BUT_LIMITED"
    },
    "silent_ambiguity_policy": {
      "const": "SILENT_LIMITATION_AMBIGUITY_FORBIDDEN"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "boundary_scope": {
            "const": "PROOF_BUNDLE"
          }
        },
        "required": [
          "boundary_scope"
        ]
      },
      "then": {
        "properties": {
          "surface_role": {
            "const": "FILING_PROOF_ARTIFACT"
          },
          "surface_specific_binding_policy": {
            "const": "PROOF_BUNDLE_RETAINS_DECISIVE_LIMITATION_AND_RETENTION_BINDING"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "boundary_scope": {
            "const": "EVIDENCE_GRAPH"
          }
        },
        "required": [
          "boundary_scope"
        ]
      },
      "then": {
        "properties": {
          "surface_role": {
            "const": "GRAPH_EXPLANATION_INDEX"
          },
          "surface_specific_binding_policy": {
            "const": "EVIDENCE_GRAPH_RETAINS_LIMITATION_NOTES_AND_TARGET_EXPLANATION_POSTURE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "boundary_scope": {
            "const": "ENQUIRY_PACK"
          }
        },
        "required": [
          "boundary_scope"
        ]
      },
      "then": {
        "properties": {
          "surface_role": {
            "const": "SCRUTINY_EXPORT_PACK"
          },
          "surface_specific_binding_policy": {
            "const": "ENQUIRY_PACK_RETAINS_LIMITATION_NOTES_OMISSIONS_AND_RETENTION_BINDING"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "boundary_scope": {
            "const": "AUDIT_EVENT"
          }
        },
        "required": [
          "boundary_scope"
        ]
      },
      "then": {
        "properties": {
          "surface_role": {
            "const": "AUDIT_RECONSTRUCTION_EVIDENCE"
          },
          "surface_specific_binding_policy": {
            "const": "AUDIT_EVENT_RETAINS_MINIMUM_RECONSTRUCTION_CONTEXT_AFTER_PAYLOAD_EXPIRY"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
