{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/workspace_cursor.schema.json",
  "title": "WorkspaceCursor",
  "description": "Reconnect-safe collaboration-workspace cursor contract. This contract freezes resume-token binding, workspace route and visibility lineage, the current and replacement route-stability contracts, the current stream-recovery contract, and expiry or revocation behavior for collaboration workspace streams.",
  "type": "object",
  "required": [
    "artifact_type",
    "cursor_scope_class",
    "cursor_id",
    "tenant_id",
    "principal_ref",
    "principal_class",
    "item_id",
    "workspace_route_key",
    "session_visibility_class",
    "shell_stability_token",
    "session_ref",
    "session_binding_hash",
    "access_binding_hash",
    "masking_posture_fingerprint",
    "frame_epoch",
    "workspace_version",
    "customer_head_sequence",
    "internal_head_sequence_or_null",
    "request_state_version_or_null",
    "last_ack_sequence",
    "last_published_sequence",
    "latest_snapshot_ref",
    "resume_token_hash",
    "stream_recovery_contract",
    "native_cache_hydration_contract",
    "stability_contract",
    "replacement_stability_contract_or_null",
    "cursor_state",
    "schema_compatibility_ref",
    "replacement_snapshot_ref",
    "invalidation_reason_code",
    "invalidated_at",
    "last_seen_at",
    "expires_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "WorkspaceCursor"
    },
    "cursor_scope_class": {
      "const": "WORKSPACE"
    },
    "cursor_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "principal_ref": {
      "type": "string",
      "minLength": 1
    },
    "principal_class": {
      "type": "string",
      "minLength": 1
    },
    "item_id": {
      "type": "string",
      "minLength": 1
    },
    "workspace_route_key": {
      "type": "string",
      "minLength": 1
    },
    "session_visibility_class": {
      "type": "string",
      "enum": [
        "STAFF_FULL",
        "CUSTOMER_VISIBLE"
      ]
    },
    "shell_stability_token": {
      "type": "string",
      "minLength": 1
    },
    "session_ref": {
      "type": "string",
      "minLength": 1
    },
    "session_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "access_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "masking_posture_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "frame_epoch": {
      "type": "integer",
      "minimum": 0
    },
    "workspace_version": {
      "type": "integer",
      "minimum": 0
    },
    "customer_head_sequence": {
      "type": "integer",
      "minimum": 0
    },
    "internal_head_sequence_or_null": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "request_state_version_or_null": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "last_ack_sequence": {
      "type": "integer",
      "minimum": 0
    },
    "last_published_sequence": {
      "type": "integer",
      "minimum": 0
    },
    "latest_snapshot_ref": {
      "type": "string",
      "minLength": 1
    },
    "resume_token_hash": {
      "type": "string",
      "minLength": 1
    },
    "stream_recovery_contract": {
      "$ref": "https://taxat.dev/schemas/stream_recovery_contract.schema.json"
    },
    "native_cache_hydration_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/native_cache_hydration_contract.schema.json"
        },
        {
          "properties": {
            "hydration_scope_class": {
              "const": "WORKSPACE_CURSOR"
            }
          }
        }
      ]
    },
    "stability_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/route_stability_contract.schema.json"
        },
        {
          "properties": {
            "route_scope_class": {
              "const": "WORKSPACE"
            }
          }
        }
      ]
    },
    "replacement_stability_contract_or_null": {
      "anyOf": [
        {
          "allOf": [
            {
              "$ref": "https://taxat.dev/schemas/route_stability_contract.schema.json"
            },
            {
              "properties": {
                "route_scope_class": {
                  "const": "WORKSPACE"
                }
              }
            }
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "cursor_state": {
      "type": "string",
      "enum": [
        "LIVE",
        "REBASED",
        "CLOSED",
        "REVOKED",
        "EXPIRED"
      ]
    },
    "schema_compatibility_ref": {
      "type": "string",
      "minLength": 1
    },
    "replacement_snapshot_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "invalidation_reason_code": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "FRAME_EPOCH_ADVANCED",
        "HISTORY_COMPACTED",
        "SHELL_STABILITY_CHANGED",
        "ROUTE_CONTEXT_CHANGED",
        "SESSION_REVOKED",
        "SESSION_BINDING_CHANGED",
        "ACCESS_BINDING_CHANGED",
        "MASKING_POSTURE_CHANGED",
        "SCHEMA_INCOMPATIBLE",
        "TENANT_SWITCHED",
        "PRINCIPAL_CLASS_CHANGED",
        "CURSOR_TTL_ELAPSED",
        "CLIENT_CLOSED",
        null
      ]
    },
    "invalidated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "last_seen_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "replacement_snapshot_ref": {
            "type": "string"
          }
        },
        "required": [
          "replacement_snapshot_ref"
        ]
      },
      "then": {
        "properties": {
          "cursor_state": {
            "const": "REBASED"
          },
          "replacement_stability_contract_or_null": {
            "$ref": "https://taxat.dev/schemas/route_stability_contract.schema.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "replacement_snapshot_ref": {
            "type": "null"
          }
        },
        "required": [
          "replacement_snapshot_ref"
        ]
      },
      "then": {
        "properties": {
          "replacement_stability_contract_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "invalidation_reason_code": {
            "type": "null"
          }
        },
        "required": [
          "invalidation_reason_code"
        ]
      },
      "then": {
        "properties": {
          "cursor_state": {
            "const": "LIVE"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
