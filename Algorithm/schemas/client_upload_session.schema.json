{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/client_upload_session.schema.json",
  "title": "ClientUploadSession",
  "description": "Governed binary-transfer session contract for portal uploads. This contract freezes request binding, resumability, integrity, and attachment-confirmation posture, and emits upload-confidence and recovery posture so transfer success never masquerades as accepted attachment completion.",
  "type": "object",
  "required": [
    "upload_session_id",
    "artifact_type",
    "tenant_id",
    "client_id",
    "manifest_id",
    "request_id",
    "request_version_ref",
    "upload_request_binding_contract",
    "request_binding_state",
    "initiated_by",
    "storage_ref",
    "filename",
    "media_type",
    "byte_count",
    "checksum",
    "surface_class",
    "capture_mode",
    "bytes_transferred",
    "retry_count",
    "resume_attempt_count",
    "resume_success_count",
    "integrity_state",
    "transfer_state",
    "malware_scan_state",
    "validation_state",
    "resumability_state",
    "resume_token_ref",
    "attachment_state",
    "attached_document_ref",
    "outcome_reason_code",
    "next_action_code",
    "submitted_at",
    "transfer_started_at",
    "last_activity_at",
    "scan_completed_at",
    "validation_completed_at",
    "finalized_at",
    "attachment_confirmed_at",
    "reconfirmed_at",
    "state_changed_at",
    "expires_at",
    "upload_confidence_score",
    "recovery_posture",
    "dominant_hazard_code"
  ],
  "properties": {
    "upload_session_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "ClientUploadSession"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "request_version_ref": {
      "type": "string",
      "minLength": 1
    },
    "upload_request_binding_contract": {
      "$ref": "https://taxat.dev/schemas/upload_request_binding_contract.schema.json"
    },
    "request_binding_state": {
      "type": "string",
      "enum": [
        "ORIGINAL_CURRENT",
        "RECONFIRMED_CURRENT",
        "RECONFIRMATION_REQUIRED",
        "SUPERSEDED"
      ]
    },
    "initiated_by": {
      "type": "string",
      "minLength": 1
    },
    "storage_ref": {
      "type": "string",
      "minLength": 1
    },
    "filename": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "media_type": {
      "type": "string",
      "minLength": 1
    },
    "byte_count": {
      "type": "integer",
      "minimum": 1
    },
    "checksum": {
      "type": "string",
      "minLength": 1
    },
    "surface_class": {
      "type": "string",
      "enum": [
        "MOBILE",
        "TABLET",
        "DESKTOP"
      ]
    },
    "capture_mode": {
      "type": "string",
      "enum": [
        "BROWSE",
        "DRAG_DROP",
        "CAMERA",
        "SYSTEM_SHARE"
      ]
    },
    "bytes_transferred": {
      "type": "integer",
      "minimum": 0
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0
    },
    "resume_attempt_count": {
      "type": "integer",
      "minimum": 0
    },
    "resume_success_count": {
      "type": "integer",
      "minimum": 0
    },
    "integrity_state": {
      "type": "string",
      "enum": [
        "PENDING",
        "VERIFIED",
        "FAILED"
      ]
    },
    "transfer_state": {
      "type": "string",
      "enum": [
        "QUEUED",
        "UPLOADING",
        "SCANNING",
        "ACCEPTED",
        "REJECTED",
        "FAILED"
      ]
    },
    "malware_scan_state": {
      "type": "string",
      "enum": [
        "PENDING",
        "CLEAN",
        "QUARANTINED"
      ]
    },
    "validation_state": {
      "type": "string",
      "enum": [
        "PENDING",
        "ACCEPTED",
        "REJECTED",
        "REQUIRES_REPLACEMENT"
      ]
    },
    "resumability_state": {
      "type": "string",
      "enum": [
        "RESUMABLE",
        "RESTART_REQUIRED",
        "CLOSED"
      ]
    },
    "resume_token_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "attachment_state": {
      "type": "string",
      "enum": [
        "STAGED",
        "CONFIRMATION_REQUIRED",
        "ATTACHED",
        "REBIND_REQUIRED"
      ]
    },
    "attached_document_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "outcome_reason_code": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "next_action_code": {
      "type": "string",
      "enum": [
        "NONE",
        "RESUME_UPLOAD",
        "CONFIRM_ATTACHMENT",
        "RECONFIRM_REQUEST",
        "RETRY_UPLOAD",
        "UPLOAD_REPLACEMENT",
        "CONTACT_SUPPORT"
      ]
    },
    "submitted_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "transfer_started_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "last_activity_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "scan_completed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "validation_completed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "finalized_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "attachment_confirmed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "reconfirmed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "state_changed_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "upload_confidence_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "recovery_posture": {
      "type": "string",
      "enum": [
        "NONE",
        "INLINE_RESUME",
        "RECONFIRM_INLINE",
        "STALE_REVIEW_REQUIRED",
        "STEP_UP_RETRY",
        "HARD_RESET_REQUIRED",
        "SUPPORT_REQUIRED"
      ]
    },
    "dominant_hazard_code": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "transfer_state": {
            "enum": [
              "UPLOADING",
              "SCANNING",
              "ACCEPTED",
              "REJECTED",
              "FAILED"
            ]
          }
        },
        "required": [
          "transfer_state"
        ]
      },
      "then": {
        "properties": {
          "submitted_at": {
            "type": "string"
          },
          "transfer_started_at": {
            "type": "string"
          },
          "last_activity_at": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "transfer_state": {
            "enum": [
              "QUEUED",
              "UPLOADING",
              "SCANNING"
            ]
          }
        },
        "required": [
          "transfer_state"
        ]
      },
      "then": {
        "properties": {
          "malware_scan_state": {
            "const": "PENDING"
          },
          "validation_state": {
            "const": "PENDING"
          },
          "attachment_state": {
            "const": "STAGED"
          },
          "attached_document_ref": {
            "type": "null"
          },
          "attachment_confirmed_at": {
            "type": "null"
          },
          "scan_completed_at": {
            "type": "null"
          },
          "validation_completed_at": {
            "type": "null"
          },
          "finalized_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "transfer_state": {
            "const": "QUEUED"
          }
        },
        "required": [
          "transfer_state"
        ]
      },
      "then": {
        "properties": {
          "transfer_started_at": {
            "type": "null"
          },
          "bytes_transferred": {
            "const": 0
          },
          "last_activity_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "transfer_state": {
            "const": "SCANNING"
          }
        },
        "required": [
          "transfer_state"
        ]
      },
      "then": {
        "properties": {
          "resumability_state": {
            "enum": [
              "RESUMABLE",
              "RESTART_REQUIRED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "transfer_state": {
            "const": "ACCEPTED"
          }
        },
        "required": [
          "transfer_state"
        ]
      },
      "then": {
        "properties": {
          "integrity_state": {
            "const": "VERIFIED"
          },
          "malware_scan_state": {
            "const": "CLEAN"
          },
          "validation_state": {
            "const": "ACCEPTED"
          },
          "resumability_state": {
            "const": "CLOSED"
          },
          "scan_completed_at": {
            "type": "string"
          },
          "validation_completed_at": {
            "type": "string"
          },
          "finalized_at": {
            "type": "string"
          },
          "attachment_state": {
            "enum": [
              "CONFIRMATION_REQUIRED",
              "ATTACHED",
              "REBIND_REQUIRED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "transfer_state": {
            "const": "REJECTED"
          }
        },
        "required": [
          "transfer_state"
        ]
      },
      "then": {
        "properties": {
          "validation_state": {
            "enum": [
              "REJECTED",
              "REQUIRES_REPLACEMENT"
            ]
          },
          "resumability_state": {
            "const": "CLOSED"
          },
          "finalized_at": {
            "type": "string"
          },
          "attachment_state": {
            "const": "STAGED"
          },
          "attached_document_ref": {
            "type": "null"
          },
          "attachment_confirmed_at": {
            "type": "null"
          },
          "outcome_reason_code": {
            "type": "string",
            "minLength": 1
          },
          "next_action_code": {
            "enum": [
              "UPLOAD_REPLACEMENT",
              "CONTACT_SUPPORT"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "transfer_state": {
            "const": "FAILED"
          }
        },
        "required": [
          "transfer_state"
        ]
      },
      "then": {
        "properties": {
          "malware_scan_state": {
            "const": "PENDING"
          },
          "validation_state": {
            "const": "PENDING"
          },
          "resumability_state": {
            "const": "CLOSED"
          },
          "finalized_at": {
            "type": "string"
          },
          "attachment_state": {
            "const": "STAGED"
          },
          "attached_document_ref": {
            "type": "null"
          },
          "attachment_confirmed_at": {
            "type": "null"
          },
          "outcome_reason_code": {
            "type": "string",
            "minLength": 1
          },
          "next_action_code": {
            "enum": [
              "RETRY_UPLOAD",
              "CONTACT_SUPPORT"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "malware_scan_state": {
            "enum": [
              "CLEAN",
              "QUARANTINED"
            ]
          }
        },
        "required": [
          "malware_scan_state"
        ]
      },
      "then": {
        "properties": {
          "scan_completed_at": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "malware_scan_state": {
            "const": "QUARANTINED"
          }
        },
        "required": [
          "malware_scan_state"
        ]
      },
      "then": {
        "properties": {
          "transfer_state": {
            "const": "REJECTED"
          },
          "validation_state": {
            "enum": [
              "REJECTED",
              "REQUIRES_REPLACEMENT"
            ]
          },
          "finalized_at": {
            "type": "string"
          },
          "outcome_reason_code": {
            "type": "string",
            "minLength": 1
          },
          "next_action_code": {
            "const": "UPLOAD_REPLACEMENT"
          },
          "upload_confidence_score": {
            "const": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "validation_state": {
            "enum": [
              "ACCEPTED",
              "REJECTED",
              "REQUIRES_REPLACEMENT"
            ]
          }
        },
        "required": [
          "validation_state"
        ]
      },
      "then": {
        "properties": {
          "validation_completed_at": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "validation_state": {
            "const": "REQUIRES_REPLACEMENT"
          }
        },
        "required": [
          "validation_state"
        ]
      },
      "then": {
        "properties": {
          "transfer_state": {
            "const": "REJECTED"
          },
          "finalized_at": {
            "type": "string"
          },
          "outcome_reason_code": {
            "type": "string",
            "minLength": 1
          },
          "next_action_code": {
            "const": "UPLOAD_REPLACEMENT"
          },
          "upload_confidence_score": {
            "const": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "validation_state": {
            "const": "ACCEPTED"
          }
        },
        "required": [
          "validation_state"
        ]
      },
      "then": {
        "properties": {
          "transfer_state": {
            "const": "ACCEPTED"
          },
          "malware_scan_state": {
            "const": "CLEAN"
          },
          "integrity_state": {
            "const": "VERIFIED"
          },
          "finalized_at": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resumability_state": {
            "const": "RESUMABLE"
          }
        },
        "required": [
          "resumability_state"
        ]
      },
      "then": {
        "properties": {
          "transfer_state": {
            "enum": [
              "QUEUED",
              "UPLOADING",
              "SCANNING"
            ]
          },
          "resume_token_ref": {
            "type": "string",
            "minLength": 1
          },
          "last_activity_at": {
            "type": "string"
          },
          "next_action_code": {
            "const": "RESUME_UPLOAD"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resumability_state": {
            "const": "RESTART_REQUIRED"
          }
        },
        "required": [
          "resumability_state"
        ]
      },
      "then": {
        "properties": {
          "transfer_state": {
            "enum": [
              "UPLOADING",
              "SCANNING"
            ]
          },
          "resume_token_ref": {
            "type": "null"
          },
          "last_activity_at": {
            "type": "string"
          },
          "next_action_code": {
            "const": "RETRY_UPLOAD"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resumability_state": {
            "const": "CLOSED"
          }
        },
        "required": [
          "resumability_state"
        ]
      },
      "then": {
        "properties": {
          "resume_token_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "request_binding_state": {
            "const": "ORIGINAL_CURRENT"
          }
        },
        "required": [
          "request_binding_state"
        ]
      },
      "then": {
        "properties": {
          "reconfirmed_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "request_binding_state": {
            "const": "RECONFIRMED_CURRENT"
          }
        },
        "required": [
          "request_binding_state"
        ]
      },
      "then": {
        "properties": {
          "reconfirmed_at": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "request_binding_state": {
            "const": "RECONFIRMATION_REQUIRED"
          }
        },
        "required": [
          "request_binding_state"
        ]
      },
      "then": {
        "properties": {
          "attached_document_ref": {
            "type": "null"
          },
          "attachment_confirmed_at": {
            "type": "null"
          },
          "reconfirmed_at": {
            "type": "null"
          },
          "dominant_hazard_code": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "request_binding_state": {
            "const": "SUPERSEDED"
          }
        },
        "required": [
          "request_binding_state"
        ]
      },
      "then": {
        "properties": {
          "attached_document_ref": {
            "type": "null"
          },
          "attachment_confirmed_at": {
            "type": "null"
          },
          "reconfirmed_at": {
            "type": "null"
          },
          "dominant_hazard_code": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "request_binding_state": {
            "enum": [
              "RECONFIRMATION_REQUIRED",
              "SUPERSEDED"
            ]
          }
        },
        "required": [
          "request_binding_state"
        ]
      },
      "then": {
        "properties": {
          "attached_document_ref": {
            "type": "null"
          },
          "attachment_confirmed_at": {
            "type": "null"
          },
          "reconfirmed_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "request_binding_state": {
            "const": "RECONFIRMATION_REQUIRED"
          },
          "transfer_state": {
            "const": "ACCEPTED"
          }
        },
        "required": [
          "request_binding_state",
          "transfer_state"
        ]
      },
      "then": {
        "properties": {
          "attachment_state": {
            "const": "REBIND_REQUIRED"
          },
          "next_action_code": {
            "const": "RECONFIRM_REQUEST"
          },
          "recovery_posture": {
            "const": "RECONFIRM_INLINE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "request_binding_state": {
            "const": "SUPERSEDED"
          },
          "transfer_state": {
            "const": "ACCEPTED"
          }
        },
        "required": [
          "request_binding_state",
          "transfer_state"
        ]
      },
      "then": {
        "properties": {
          "attachment_state": {
            "const": "REBIND_REQUIRED"
          },
          "next_action_code": {
            "const": "RECONFIRM_REQUEST"
          },
          "recovery_posture": {
            "const": "STALE_REVIEW_REQUIRED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "attachment_state": {
            "const": "STAGED"
          }
        },
        "required": [
          "attachment_state"
        ]
      },
      "then": {
        "properties": {
          "attached_document_ref": {
            "type": "null"
          },
          "attachment_confirmed_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "attachment_state": {
            "const": "CONFIRMATION_REQUIRED"
          }
        },
        "required": [
          "attachment_state"
        ]
      },
      "then": {
        "properties": {
          "transfer_state": {
            "const": "ACCEPTED"
          },
          "validation_state": {
            "const": "ACCEPTED"
          },
          "request_binding_state": {
            "enum": [
              "ORIGINAL_CURRENT",
              "RECONFIRMED_CURRENT"
            ]
          },
          "attached_document_ref": {
            "type": "null"
          },
          "attachment_confirmed_at": {
            "type": "null"
          },
          "next_action_code": {
            "const": "CONFIRM_ATTACHMENT"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "attachment_state": {
            "const": "ATTACHED"
          }
        },
        "required": [
          "attachment_state"
        ]
      },
      "then": {
        "properties": {
          "transfer_state": {
            "const": "ACCEPTED"
          },
          "malware_scan_state": {
            "const": "CLEAN"
          },
          "validation_state": {
            "const": "ACCEPTED"
          },
          "integrity_state": {
            "const": "VERIFIED"
          },
          "request_binding_state": {
            "enum": [
              "ORIGINAL_CURRENT",
              "RECONFIRMED_CURRENT"
            ]
          },
          "attached_document_ref": {
            "type": "string",
            "minLength": 1
          },
          "attachment_confirmed_at": {
            "type": "string"
          },
          "upload_confidence_score": {
            "minimum": 85
          },
          "next_action_code": {
            "const": "NONE"
          }
        }
      }
    },
