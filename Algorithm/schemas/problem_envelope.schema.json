{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/problem_envelope.schema.json",
  "title": "ProblemEnvelope",
  "description": "Typed northbound failure contract. This schema freezes user-consumable recovery hints, authoritative rebase refs, explicit mutation precondition profiles where applicable, authoritative stale-guard value echo, retry posture, and actionability semantics for non-success API responses.",
  "type": "object",
  "required": [
    "artifact_type",
    "problem_code",
    "title",
    "detail",
    "reason_codes",
    "retryable",
    "correlation_id",
    "manifest_id",
    "latest_decision_bundle_ref",
    "latest_workspace_snapshot_ref",
    "latest_approval_pack_ref",
    "latest_client_portal_workspace_ref",
    "latest_upload_session_ref",
    "latest_policy_snapshot_ref",
    "latest_command_receipt_ref",
    "truth_boundary_contract",
    "mutation_precondition_binding_or_null",
    "stale_guard_family",
    "latest_stale_guard_value",
    "latest_resume_token",
    "latest_stability_contract_or_null",
    "rebase_required",
    "actionability_state",
    "suggested_detail_surface_code"
  ],
  "properties": {
    "artifact_type": {
      "const": "ProblemEnvelope"
    },
    "problem_code": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96
    },
    "detail": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "retryable": {
      "type": "boolean"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "latest_decision_bundle_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "latest_workspace_snapshot_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "latest_approval_pack_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "latest_client_portal_workspace_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "latest_upload_session_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "latest_policy_snapshot_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "latest_command_receipt_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "truth_boundary_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/command_truth_boundary_contract.schema.json"
        },
        {
          "properties": {
            "artifact_role": {
              "const": "BOUNDARY_RECEIPT"
            },
            "authoritative_record_families": {
              "const": [
                "RUN_MANIFEST",
                "WORKFLOW_ITEM",
                "AUTHORITY_INTERACTION_RECORD",
                "GOVERNANCE_DOMAIN_OBJECT",
                "AUDIT_EVENT",
                "API_COMMAND_RECEIPT"
              ]
            },
            "observable_projection_families": {
              "const": [
                "DECISION_BUNDLE",
                "WORKSPACE_SNAPSHOT",
                "CLIENT_PORTAL_WORKSPACE",
                "CLIENT_APPROVAL_PACK",
                "CLIENT_UPLOAD_SESSION",
                "GOVERNANCE_POLICY_SNAPSHOT"
              ]
            }
          }
        }
      ]
    },
    "mutation_precondition_binding_or_null": {
      "anyOf": [
        {
          "$ref": "https://taxat.dev/schemas/mutation_precondition_binding.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "stale_guard_family": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "DECISION_BUNDLE_HASH",
        "SHELL_STABILITY_TOKEN",
        "FRAME_EPOCH",
        "WORK_ITEM_VERSION",
        "INTERNAL_THREAD_HEAD",
        "CUSTOMER_THREAD_HEAD",
        "REQUEST_STATE_VERSION",
        "APPROVAL_PACK_HASH",
        "CLIENT_PORTAL_WORKSPACE_VERSION",
        "POLICY_SNAPSHOT_HASH",
        "DEPENDENCY_TOPOLOGY_HASH",
        "SIMULATION_BASIS_HASH",
        "MUTATION_BASIS_CONTRACT_HASH",
        null
