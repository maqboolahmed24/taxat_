              "INTERNAL_THREAD_HEAD",
              "CUSTOMER_THREAD_HEAD",
              "REQUEST_STATE_VERSION",
              "CLIENT_PORTAL_WORKSPACE_VERSION"
            ]
          }
        },
        "required": [
          "stale_guard_family"
