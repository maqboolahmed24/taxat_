    },
    "latest_stale_guard_value": {
      "type": [
        "string",
        "integer",
        "null"
      ],
      "minLength": 1,
      "minimum": 0
    },
    "latest_resume_token": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "latest_stability_contract_or_null": {
      "anyOf": [
        {
          "$ref": "https://taxat.dev/schemas/route_stability_contract.schema.json"
        },
        {
          "type": "null"
        }
      ]
    },
    "rebase_required": {
      "type": "boolean"
    },
    "actionability_state": {
      "type": "string",
      "enum": [
        "ACTION_AVAILABLE",
        "NO_SAFE_ACTION"
      ]
    },
    "suggested_detail_surface_code": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "EVIDENCE_TIDE",
        "PACKET_FORGE",
        "AUTHORITY_TUNNEL",
        "DRIFT_FIELD",
        "FOCUS_LENS",
        "TWIN_PANEL",
        "CUSTOMER_ACTIVITY",
        "INTERNAL_ACTIVITY",
        "FILES",
        "LINKED_CONTEXT",
        "AUDIT_TRAIL",
        null
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "rebase_required": {
            "const": true
          }
        },
        "required": [
          "rebase_required"
        ]
      },
      "then": {
        "properties": {
          "mutation_precondition_binding_or_null": {
            "$ref": "https://taxat.dev/schemas/mutation_precondition_binding.schema.json"
