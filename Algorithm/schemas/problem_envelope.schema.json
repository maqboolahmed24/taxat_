    },
    {
      "if": {
        "properties": {
          "rebase_required": {
            "const": false
          }
        },
        "required": [
          "rebase_required"
        ]
      },
      "then": {
        "properties": {
          "mutation_precondition_binding_or_null": {
            "type": "null"
