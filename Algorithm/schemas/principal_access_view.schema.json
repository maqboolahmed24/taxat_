{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/principal_access_view.schema.json",
  "title": "PrincipalAccessView",
  "description": "Governance access-detail read-side projection for one principal. This schema freezes the access-route shell order, selected-cell inspector posture, ordered authority-chain explanation, and policy-simulator linkage so access semantics do not collapse into a generic pass/fail matrix.",
  "type": "object",
  "required": [
    "artifact_type",
    "tenant_id",
    "shell_family",
    "object_anchor_ref",
    "dominant_question",
    "settlement_state",
    "recovery_posture",
    "interaction_layer",
    "cache_isolation_contract",
    "principal_id",
    "principal_type",
    "effective_role_set",
    "delegation_summaries",
    "authn_level",
    "approval_capabilities",
    "run_kind_capabilities",
    "action_matrix",
    "focus_anchor_ref",
    "access_workspace",
    "selected_action_detail",
    "last_step_up_at",
    "last_modified_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "PrincipalAccessView"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "shell_family": {
      "const": "GOVERNANCE_DENSITY_SHELL"
    },
    "object_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "dominant_question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "settlement_state": {
      "$ref": "#/$defs/settlementState"
    },
    "recovery_posture": {
      "$ref": "#/$defs/recoveryPosture"
    },
    "interaction_layer": {
      "$ref": "https://taxat.dev/schemas/governance_interaction_layer.schema.json"
    },
    "cache_isolation_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/cache_isolation_contract.schema.json"
        },
        {
          "properties": {
            "cache_scope_class": {
              "const": "PRINCIPAL_ACCESS_VIEW"
            }
          }
        }
      ]
    },
    "principal_id": {
      "type": "string",
      "minLength": 1
    },
    "principal_type": {
      "type": "string",
      "enum": [
        "HUMAN",
        "SERVICE",
        "EXTERNAL"
      ]
    },
    "effective_role_set": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "delegation_summaries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/delegationSummary"
      },
      "default": [],
      "uniqueItems": true
    },
    "authn_level": {
      "type": "string",
      "enum": [
        "BASIC",
        "MFA",
        "STEP_UP"
      ]
    },
    "approval_capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "run_kind_capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "action_matrix": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/actionMatrixCell"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "focus_anchor_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "access_workspace": {
      "$ref": "#/$defs/accessWorkspace"
    },
    "selected_action_detail": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/selectedActionDetail"
        }
      ]
    },
    "last_step_up_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "last_modified_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "settlementState": {
      "type": "string",
      "enum": [
        "STEADY",
        "RECEIPT_PENDING",
        "FRESHENING",
        "STALE_REVIEW_REQUIRED",
        "DEGRADED_READ_ONLY",
        "RECOVERY_REQUIRED"
      ]
    },
    "recoveryPosture": {
      "type": "string",
      "enum": [
        "NONE",
        "INLINE_RECONNECT",
        "INLINE_REBASE",
        "READ_ONLY_LIMITED",
        "OBJECT_SUPERSEDED",
        "ACCESS_REBIND_REQUIRED"
      ]
    },
    "interactionLayer": {
      "type": "object",
      "required": [
        "selected_filter_chip_refs",
        "compaction_mode",
        "auxiliary_surface_presentation",
        "focus_trap_mode",
        "selection_persistence_mode",
        "preserved_context_codes"
      ],
      "properties": {
        "selected_filter_chip_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "compaction_mode": {
          "type": "string",
          "enum": [
            "WIDE",
            "AUXILIARY_DRAWER",
            "AUXILIARY_TRAY",
            "FOCUS_STACK"
          ]
        },
        "auxiliary_surface_presentation": {
          "type": "string",
          "enum": [
            "SIDECAR",
            "DRAWER",
            "INSPECTOR",
            "TRAY"
          ]
        },
        "focus_trap_mode": {
          "type": "string",
          "enum": [
            "NON_MODAL",
            "MODAL_EXPLICIT"
          ]
        },
        "selection_persistence_mode": {
          "const": "PRESERVE_WHILE_OBJECT_RESOLVES"
        },
        "preserved_context_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ACTIVE_FILTERS",
              "ACTIVE_SECTION",
              "SELECTION",
              "FOCUS_ANCHOR",
              "PROMOTED_SUPPORT_SURFACE",
              "STAGED_DIFF",
              "CHANGE_BASKET",
              "GUIDED_HANDSHAKE_STEP",
              "QUERY_SLICE"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "workspaceMode": {
      "type": "string",
      "enum": [
        "PRINCIPALS",
        "ROLES",
        "SIMULATOR"
      ]
    },
    "inspectorState": {
      "type": "string",
      "enum": [
        "HIDDEN",
        "CELL_SELECTED",
        "ROLE_EDITING",
        "SIMULATION_SELECTED"
      ]
    },
    "promotedSupportSurface": {
      "type": "string",
      "enum": [
        "AUDIT_SIDECAR",
        "AUTHORITY_CHAIN_PANEL",
        "POLICY_SIMULATOR"
      ]
    },
    "chainLayerOutcome": {
      "type": "string",
      "enum": [
        "ALLOW",
        "ALLOW_MASKED",
        "REQUIRE_STEP_UP",
        "REQUIRE_APPROVAL",
        "DENY",
        "NOT_APPLICABLE"
      ]
    },
    "delegationSummary": {
      "type": "object",
      "required": [
        "client_id",
        "delegation_basis",
        "scope_refs",
        "lifecycle_state"
      ],
      "properties": {
        "client_id": {
          "type": "string",
          "minLength": 1
        },
        "delegation_basis": {
          "type": "string",
          "enum": [
            "SELF_ACTING",
            "CLIENT_GRANTED",
            "SELF_ASSESSMENT_IMPORTED",
            "DIGITAL_HANDSHAKE",
            "TENANT_INTERNAL",
            "SYSTEM_ASSIGNED"
          ]
        },
        "scope_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "lifecycle_state": {
          "type": "string",
          "minLength": 1
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "authorityChainLayerBase": {
      "type": "object",
      "required": [
        "layer_code",
        "layer_outcome",
        "reason_codes"
      ],
      "properties": {
        "layer_code": {
          "type": "string",
          "minLength": 1
        },
        "layer_outcome": {
          "$ref": "#/$defs/chainLayerOutcome"
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "sessionAuthnLayer": {
      "allOf": [
        {
          "$ref": "#/$defs/authorityChainLayerBase"
        },
        {
          "type": "object",
          "properties": {
            "layer_code": {
              "const": "SESSION_AUTHN_POSTURE"
            }
          }
        }
      ]
    },
    "tenantOperationalAuthorityLayer": {
      "allOf": [
        {
          "$ref": "#/$defs/authorityChainLayerBase"
        },
        {
          "type": "object",
          "properties": {
            "layer_code": {
              "const": "TENANT_OPERATIONAL_AUTHORITY"
            }
          }
        }
      ]
    },
    "clientDelegationCoverageLayer": {
      "allOf": [
        {
          "$ref": "#/$defs/authorityChainLayerBase"
        },
        {
          "type": "object",
          "properties": {
            "layer_code": {
              "const": "CLIENT_DELEGATION_COVERAGE"
            }
          }
        }
      ]
    },
    "externalAuthorityLinkReadinessLayer": {
      "allOf": [
        {
          "$ref": "#/$defs/authorityChainLayerBase"
        },
        {
          "type": "object",
          "properties": {
            "layer_code": {
              "const": "EXTERNAL_AUTHORITY_LINK_READINESS"
            }
          }
        }
      ]
    },
    "authorityOfRecordOutcomeLayer": {
      "allOf": [
        {
          "$ref": "#/$defs/authorityChainLayerBase"
        },
        {
          "type": "object",
          "properties": {
            "layer_code": {
              "const": "AUTHORITY_OF_RECORD_OUTCOME"
            }
          }
        }
      ]
    },
    "authorityChainLayerStack": {
      "type": "array",
      "minItems": 4,
      "maxItems": 5,
      "prefixItems": [
        {
          "$ref": "#/$defs/sessionAuthnLayer"
        },
        {
          "$ref": "#/$defs/tenantOperationalAuthorityLayer"
        },
        {
          "$ref": "#/$defs/clientDelegationCoverageLayer"
        },
        {
          "$ref": "#/$defs/externalAuthorityLinkReadinessLayer"
        }
      ],
      "items": {
        "$ref": "#/$defs/authorityOfRecordOutcomeLayer"
      }
    },
    "actionMatrixCell": {
      "type": "object",
      "required": [
        "cell_ref",
        "resource_class",
        "action_family",
        "decision",
        "reason_codes",
        "effective_scope",
        "masking_rules",
        "required_approvals",
        "required_authn_level",
        "authority_chain_layers"
      ],
      "properties": {
        "cell_ref": {
          "type": "string",
          "minLength": 1
        },
        "resource_class": {
          "type": "string",
          "minLength": 1
        },
        "action_family": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": [
            "ALLOW",
            "ALLOW_MASKED",
            "REQUIRE_STEP_UP",
            "REQUIRE_APPROVAL",
            "DENY"
          ]
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "effective_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "masking_rules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "required_approvals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "required_authn_level": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "BASIC",
            "MFA",
            "STEP_UP",
            null
          ]
        },
        "policy_path_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "authority_chain_layers": {
          "$ref": "#/$defs/authorityChainLayerStack"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "decision": {
                "enum": [
                  "ALLOW",
                  "ALLOW_MASKED",
                  "REQUIRE_APPROVAL",
                  "DENY"
                ]
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "required_authn_level": {
                "const": null
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "enum": [
                  "ALLOW",
                  "ALLOW_MASKED",
                  "REQUIRE_STEP_UP",
                  "DENY"
                ]
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "required_approvals": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "enum": [
                  "ALLOW",
                  "REQUIRE_STEP_UP",
                  "REQUIRE_APPROVAL",
                  "DENY"
                ]
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "masking_rules": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "const": "DENY"
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "effective_scope": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "not": {
                  "const": "DENY"
                }
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "effective_scope": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "const": "ALLOW_MASKED"
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "masking_rules": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "const": "REQUIRE_APPROVAL"
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "required_approvals": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "const": "REQUIRE_STEP_UP"
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "required_authn_level": {
                "enum": [
                  "MFA",
                  "STEP_UP"
                ]
              }
            }
          }
        }
      ]
    },
    "activeFilters": {
      "type": "object",
      "required": [
        "principal_types",
        "principal_states",
        "role_refs",
        "delegated_client_refs",
        "recent_change_owner_refs"
      ],
      "properties": {
        "principal_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "HUMAN",
              "SERVICE",
              "EXTERNAL"
            ]
          },
          "default": [],
          "uniqueItems": true
        },
        "principal_states": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "role_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "delegated_client_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "recent_change_owner_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "accessWorkspace": {
      "type": "object",
      "required": [
        "surface_order",
        "workspace_mode",
        "active_filters",
        "selected_principal_ref",
        "selected_role_template_ref",
        "selected_cell_ref",
        "grid_navigation_model",
        "inspector_state",
        "promoted_support_surface",
        "latest_simulation_ref",
        "role_editor_pending_change_refs"
      ],
      "properties": {
        "surface_order": {
          "const": [
            "PRINCIPAL_DIRECTORY",
            "WORKSPACE_CANVAS",
            "ACCESS_INSPECTOR",
            "AUTHORITY_CHAIN_PANEL",
            "POLICY_SIMULATOR"
          ]
        },
        "workspace_mode": {
          "$ref": "#/$defs/workspaceMode"
        },
        "active_filters": {
          "$ref": "#/$defs/activeFilters"
        },
        "selected_principal_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "selected_role_template_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "selected_cell_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "grid_navigation_model": {
          "const": "ROW_COLUMN_ROVING_TABINDEX"
        },
        "inspector_state": {
          "$ref": "#/$defs/inspectorState"
        },
        "promoted_support_surface": {
          "$ref": "#/$defs/promotedSupportSurface"
        },
        "latest_simulation_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "role_editor_pending_change_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "selectedActionDetail": {
      "type": "object",
      "required": [
        "panel_mode",
        "cell_ref",
        "resource_class",
        "action_family",
        "decision",
        "reason_codes",
        "effective_scope",
        "masking_rules",
        "required_approvals",
        "required_authn_level",
        "policy_path_ref",
        "authority_chain_layers"
      ],
      "properties": {
        "panel_mode": {
          "const": "ACCESS_INSPECTOR"
        },
        "cell_ref": {
          "type": "string",
          "minLength": 1
        },
        "resource_class": {
          "type": "string",
          "minLength": 1
        },
        "action_family": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": [
            "ALLOW",
            "ALLOW_MASKED",
            "REQUIRE_STEP_UP",
            "REQUIRE_APPROVAL",
            "DENY"
          ]
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "effective_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "masking_rules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "required_approvals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "required_authn_level": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "BASIC",
            "MFA",
            "STEP_UP",
            null
          ]
        },
        "policy_path_ref": {
          "type": "string",
          "minLength": 1
        },
        "authority_chain_layers": {
          "$ref": "#/$defs/authorityChainLayerStack"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "settlement_state": {
            "const": "RECOVERY_REQUIRED"
          }
        },
        "required": [
          "settlement_state"
        ]
      },
      "then": {
        "properties": {
          "recovery_posture": {
            "not": {
              "const": "NONE"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "access_workspace": {
            "properties": {
              "workspace_mode": {
                "const": "PRINCIPALS"
              }
            },
            "required": [
              "workspace_mode"
            ]
          }
        },
        "required": [
          "access_workspace"
        ]
      },
      "then": {
        "properties": {
          "access_workspace": {
            "properties": {
              "selected_principal_ref": {
                "type": "string",
                "minLength": 1
              },
              "selected_role_template_ref": {
                "const": null
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "access_workspace": {
            "properties": {
              "workspace_mode": {
                "const": "ROLES"
              }
            },
            "required": [
              "workspace_mode"
            ]
          }
        },
        "required": [
          "access_workspace"
        ]
      },
      "then": {
        "properties": {
          "access_workspace": {
            "properties": {
              "selected_role_template_ref": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
