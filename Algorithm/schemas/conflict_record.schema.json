{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/conflict_record.schema.json",
  "title": "ConflictRecord",
  "type": "object",
  "required": [
    "conflict_id",
    "manifest_id",
    "artifact_type",
    "conflict_type",
    "involved_fact_refs",
    "severity",
    "reason_codes",
    "blocking_class",
    "resolution_state",
    "contract"
  ],
  "properties": {
    "conflict_id": {
      "type": "string"
    },
    "manifest_id": {
      "type": "string"
    },
    "artifact_type": {
      "const": "ConflictRecord"
    },
    "conflict_type": {
      "type": "string"
    },
    "involved_fact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 2,
      "uniqueItems": true
    },
    "severity": {
      "type": "string",
      "enum": [
        "INFO",
        "NOTICE",
        "WARNING",
        "ERROR",
        "CRITICAL"
      ]
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "blocking_class": {
      "type": "string"
    },
    "resolution_state": {
      "type": "string"
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "additionalProperties": false
}
