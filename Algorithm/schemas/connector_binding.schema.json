{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/connector_binding.schema.json",
  "title": "ConnectorBinding",
  "description": "Sealed provider-connector binding contract. This schema freezes the client-bound provider credential lineage, executable scope ceiling, delegation readiness, and token-health posture so connector access cannot be inferred from token presence alone.",
  "type": "object",
  "required": [
    "artifact_type",
    "binding_id",
    "tenant_id",
    "client_id",
    "provider",
    "provider_environment",
    "provider_api_version",
    "subject_ref",
    "scopes",
    "partition_scope_refs",
    "token_ref",
    "token_version_ref",
    "binding_lineage_ref",
    "lifecycle_state",
    "health_state",
    "delegation_state",
    "client_binding_state",
    "last_validated_at",
    "expires_at",
    "revoked_at",
    "superseded_by_binding_id",
    "blocked_reason_codes",
    "source_evidence_refs"
  ],
  "properties": {
    "artifact_type": {
      "const": "ConnectorBinding"
    },
    "binding_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "provider_environment": {
      "type": "string",
      "minLength": 1
    },
    "provider_api_version": {
      "type": "string",
      "minLength": 1
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "partition_scope_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "token_ref": {
      "type": "string",
      "minLength": 1
    },
    "token_version_ref": {
      "type": "string",
      "minLength": 1
    },
    "binding_lineage_ref": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "PENDING_VALIDATION",
        "ACTIVE",
        "LIMITED",
        "TOKEN_INVALID",
        "REVOKED",
        "EXPIRED",
        "SUPERSEDED"
      ]
    },
    "health_state": {
      "type": "string",
      "enum": [
        "HEALTHY",
        "LIMITED_SCOPE",
        "EXPIRING_SOON",
        "TOKEN_INVALID",
        "CLIENT_BINDING_MISMATCH",
        "DELEGATION_GAP",
        "ENVIRONMENT_DRIFT",
        "REVOKED",
        "EXPIRED",
        "UNKNOWN"
      ]
    },
    "delegation_state": {
      "type": "string",
      "enum": [
        "NOT_REQUIRED",
        "SATISFIED",
        "LIMITED",
        "MISSING",
        "EXPIRED",
        "UNKNOWN"
      ]
    },
    "client_binding_state": {
      "type": "string",
      "enum": [
        "BOUND",
        "MISMATCH",
        "UNVERIFIED"
      ]
    },
    "last_validated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "revoked_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "superseded_by_binding_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "blocked_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "source_evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "client_binding_state": {
            "const": "MISMATCH"
          }
        },
        "required": [
          "client_binding_state"
        ]
      },
      "then": {
        "properties": {
          "health_state": {
            "const": "CLIENT_BINDING_MISMATCH"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "health_state": {
            "const": "CLIENT_BINDING_MISMATCH"
          }
        },
        "required": [
          "health_state"
        ]
      },
      "then": {
        "properties": {
          "client_binding_state": {
            "const": "MISMATCH"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "delegation_state": {
            "enum": [
              "MISSING",
              "EXPIRED"
            ]
          }
        },
        "required": [
          "delegation_state"
        ]
      },
      "then": {
        "properties": {
          "health_state": {
            "const": "DELEGATION_GAP"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "health_state": {
            "const": "DELEGATION_GAP"
          }
        },
        "required": [
          "health_state"
        ]
      },
      "then": {
        "properties": {
          "delegation_state": {
            "enum": [
              "MISSING",
              "EXPIRED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "delegation_state": {
            "const": "LIMITED"
          }
        },
        "required": [
          "delegation_state"
        ]
      },
      "then": {
        "properties": {
          "health_state": {
            "const": "LIMITED_SCOPE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "health_state": {
            "const": "LIMITED_SCOPE"
          }
        },
        "required": [
          "health_state"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "const": "LIMITED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "health_state": {
            "enum": [
              "HEALTHY",
              "EXPIRING_SOON"
            ]
          }
        },
        "required": [
          "health_state"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "const": "ACTIVE"
          },
          "client_binding_state": {
            "const": "BOUND"
          },
          "delegation_state": {
            "enum": [
              "NOT_REQUIRED",
              "SATISFIED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "ACTIVE"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "health_state": {
            "enum": [
              "HEALTHY",
              "EXPIRING_SOON"
            ]
          },
          "blocked_reason_codes": {
            "maxItems": 0
          },
          "last_validated_at": {
            "type": "string",
            "format": "date-time"
          },
          "revoked_at": {
            "type": "null"
          },
          "superseded_by_binding_id": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "LIMITED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "blocked_reason_codes": {
            "minItems": 1
          },
          "last_validated_at": {
            "type": "string",
            "format": "date-time"
          },
          "revoked_at": {
            "type": "null"
          },
          "superseded_by_binding_id": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "PENDING_VALIDATION"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "last_validated_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "TOKEN_INVALID"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "health_state": {
            "const": "TOKEN_INVALID"
          },
          "blocked_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "REVOKED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "health_state": {
            "const": "REVOKED"
          },
          "revoked_at": {
            "type": "string",
            "format": "date-time"
          },
          "blocked_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "EXPIRED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "health_state": {
            "const": "EXPIRED"
          },
          "expires_at": {
            "type": "string",
            "format": "date-time"
          },
          "blocked_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "SUPERSEDED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "superseded_by_binding_id": {
            "type": "string",
            "minLength": 1
          },
          "blocked_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "revoked_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "revoked_at"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "const": "REVOKED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "superseded_by_binding_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "superseded_by_binding_id"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "const": "SUPERSEDED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "health_state": {
            "enum": [
              "HEALTHY",
              "EXPIRING_SOON"
            ]
          }
        },
        "required": [
          "health_state"
        ]
      },
      "then": {
        "properties": {
          "blocked_reason_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "health_state": {
            "not": {
              "enum": [
                "HEALTHY",
                "EXPIRING_SOON"
              ]
            }
          }
        },
        "required": [
          "health_state"
        ]
      },
      "then": {
        "properties": {
          "blocked_reason_codes": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
