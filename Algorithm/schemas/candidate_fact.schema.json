{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/candidate_fact.schema.json",
  "title": "CandidateFact",
  "type": "object",
  "required": [
    "candidate_fact_id",
    "manifest_id",
    "artifact_type",
    "execution_mode",
    "analysis_only",
    "non_compliance_config_refs",
    "counterfactual_basis",
    "fact_family",
    "value_payload_ref",
    "confidence",
    "source_strength_tier",
    "promotion_state",
    "collection_boundary_ref",
    "normalization_context_ref",
    "source_record_refs",
    "source_record_lineage_hash",
    "supporting_evidence_refs",
    "evidence_lineage_hash",
    "partition_scope",
    "partition_scope_refs",
    "partition_isolation_state",
    "visibility_basis",
    "candidate_identity_hash",
    "dedupe_key",
    "conflict_membership_refs",
    "promotion_readiness",
    "contract"
  ],
  "properties": {
    "candidate_fact_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "CandidateFact"
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "COMPLIANCE",
        "ANALYSIS"
      ]
    },
    "analysis_only": {
      "type": "boolean"
    },
    "non_compliance_config_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "counterfactual_basis": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "fact_family": {
      "type": "string",
      "enum": [
        "TRANSACTION_FACT",
        "RECORD_FACT",
        "CATEGORY_TOTAL_FACT",
        "ADJUSTMENT_FACT",
        "PROFILE_FACT",
        "OBLIGATION_FACT",
        "SUBMISSION_STATE_FACT",
        "AUTHORITY_COMPARISON_FACT",
        "RISK_FEATURE_FACT",
        "WORKFLOW_CONTEXT_FACT"
      ]
    },
    "value_payload_ref": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "source_strength_tier": {
      "type": "string",
      "enum": [
        "TIER_1_AUTHORITY_FINAL",
        "TIER_2_AUTHORITY_REFERENCE",
        "TIER_3_STRUCTURED_EXTERNAL",
        "TIER_4_STRUCTURED_INTERNAL",
        "TIER_5_DOCUMENT_SUPPORT",
        "TIER_6_DECLARED_ONLY",
        "TIER_7_INFERRED",
        "TIER_8_GOVERNANCE_ONLY"
      ]
    },
    "promotion_state": {
      "type": "string",
      "enum": [
        "CANDIDATE",
        "PROVISIONAL",
        "CONTESTED",
        "SUPERSEDED",
        "RETIRED"
      ]
    },
    "collection_boundary_ref": {
      "type": "string",
      "minLength": 1
    },
    "normalization_context_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_record_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "source_record_lineage_hash": {
      "type": "string",
      "minLength": 1
    },
    "supporting_evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "evidence_lineage_hash": {
      "type": "string",
      "minLength": 1
    },
    "partition_scope": {
      "type": "string",
      "minLength": 1
    },
    "partition_scope_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "maxItems": 1,
      "uniqueItems": true
    },
    "partition_isolation_state": {
      "const": "EXACT_SINGLE_PARTITION"
    },
    "visibility_basis": {
      "const": "UNMASKED_AUTHORITATIVE_ONLY"
    },
    "candidate_identity_hash": {
      "type": "string",
      "minLength": 1
    },
    "dedupe_key": {
      "type": "string",
      "minLength": 1
    },
    "conflict_membership_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "promotion_readiness": {
      "$ref": "#/$defs/promotionReadiness"
    },
    "adjustment_binding": {
      "oneOf": [
        {
          "$ref": "#/$defs/adjustmentBinding"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "$defs": {
    "promotionReadiness": {
      "type": "object",
      "required": [
        "readiness_state",
        "conflict_set_ref",
        "resolution_frontier",
        "blocking_conflict_ids",
        "blocking_conflict_count",
        "promotion_rule_ref",
        "approved_override_ref_or_null",
        "frozen_collection_boundary_required",
        "evidence_lineage_complete",
        "visibility_safe_for_authority"
      ],
      "properties": {
        "readiness_state": {
          "type": "string",
          "enum": [
            "CANDIDATE_ONLY",
            "PROVISIONAL_ALLOWED",
            "READY_FOR_CANONICAL",
            "CONFLICT_BLOCKED"
          ]
        },
        "conflict_set_ref": {
          "type": "string",
          "minLength": 1
        },
        "resolution_frontier": {
          "type": "string",
          "enum": [
            "CLEAR",
            "MONITORING_ONLY",
            "BLOCKING_PRESENT"
          ]
        },
        "blocking_conflict_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "blocking_conflict_count": {
          "type": "integer",
          "minimum": 0
        },
        "promotion_rule_ref": {
          "type": "string",
          "minLength": 1
        },
        "approved_override_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "frozen_collection_boundary_required": {
          "const": true
        },
        "evidence_lineage_complete": {
          "const": true
        },
        "visibility_safe_for_authority": {
          "const": true
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "blocking_conflict_count": {
                "const": 0
              }
            },
            "required": [
              "blocking_conflict_count"
            ]
          },
          "then": {
            "properties": {
              "blocking_conflict_ids": {
                "maxItems": 0
              },
              "resolution_frontier": {
                "enum": [
                  "CLEAR",
                  "MONITORING_ONLY"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "blocking_conflict_count": {
                "minimum": 1
              }
            },
            "required": [
              "blocking_conflict_count"
            ]
          },
          "then": {
            "properties": {
              "blocking_conflict_ids": {
                "minItems": 1
              },
              "resolution_frontier": {
                "const": "BLOCKING_PRESENT"
              },
              "readiness_state": {
                "const": "CONFLICT_BLOCKED"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "readiness_state": {
                "const": "READY_FOR_CANONICAL"
              }
            },
            "required": [
              "readiness_state"
            ]
          },
          "then": {
            "properties": {
              "blocking_conflict_count": {
                "const": 0
              },
              "resolution_frontier": {
                "enum": [
                  "CLEAR",
                  "MONITORING_ONLY"
                ]
              }
            }
          }
        }
      ]
    },
    "adjustmentBinding": {
      "type": "object",
      "required": [
        "applicable_reporting_scopes",
        "quarterly_basis_profile",
        "time_window_basis",
        "window_start_date_or_null",
        "window_end_date_or_null",
        "partition_application",
        "analysis_mode_treatment"
      ],
      "properties": {
        "applicable_reporting_scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "year_end",
              "quarterly_update",
              "estimate_only"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "quarterly_basis_profile": {
          "type": "string",
          "enum": [
            "NOT_APPLICABLE",
            "PERIODIC",
            "CUMULATIVE"
          ]
        },
        "time_window_basis": {
          "type": "string",
          "enum": [
            "FULL_TAX_YEAR",
            "CURRENT_QUARTER_ONLY",
            "TAX_YEAR_TO_DATE",
            "EXPLICIT_WINDOW"
          ]
        },
        "window_start_date_or_null": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "window_end_date_or_null": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        },
        "partition_application": {
          "type": "string",
          "enum": [
            "EXACT_PARTITION_ONLY"
          ]
        },
        "analysis_mode_treatment": {
          "type": "string",
          "enum": [
            "MATCH_COMPLIANCE_BASIS",
            "COUNTERFACTUAL_ONLY"
          ]
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "time_window_basis": {
                "const": "EXPLICIT_WINDOW"
              }
            },
            "required": [
              "time_window_basis"
            ]
          },
          "then": {
            "properties": {
              "window_start_date_or_null": {
                "type": "string",
                "format": "date"
              },
              "window_end_date_or_null": {
                "type": "string",
                "format": "date"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "time_window_basis": {
                "not": {
                  "const": "EXPLICIT_WINDOW"
                }
              }
            },
            "required": [
              "time_window_basis"
            ]
          },
          "then": {
            "properties": {
              "window_start_date_or_null": {
                "type": "null"
              },
              "window_end_date_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "applicable_reporting_scopes": {
                "contains": {
                  "const": "quarterly_update"
                }
              }
            },
            "required": [
              "applicable_reporting_scopes"
            ]
          },
          "then": {
            "properties": {
              "quarterly_basis_profile": {
                "enum": [
                  "PERIODIC",
                  "CUMULATIVE"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "applicable_reporting_scopes": {
                "not": {
                  "contains": {
                    "const": "quarterly_update"
                  }
                }
              }
            },
            "required": [
              "applicable_reporting_scopes"
            ]
          },
          "then": {
            "properties": {
              "quarterly_basis_profile": {
                "const": "NOT_APPLICABLE"
              }
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "execution_mode": {
            "const": "COMPLIANCE"
          }
        },
        "required": [
          "execution_mode"
        ]
      },
      "then": {
        "properties": {
          "analysis_only": {
            "const": false
          },
          "non_compliance_config_refs": {
            "maxItems": 0
          },
          "counterfactual_basis": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "fact_family": {
            "const": "ADJUSTMENT_FACT"
          }
        },
        "required": [
          "fact_family"
        ]
      },
      "then": {
        "required": [
          "adjustment_binding"
        ],
        "properties": {
          "adjustment_binding": {
            "$ref": "#/$defs/adjustmentBinding"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "fact_family": {
            "not": {
              "const": "ADJUSTMENT_FACT"
            }
          }
        },
        "required": [
          "fact_family"
        ]
      },
      "then": {
        "properties": {
          "adjustment_binding": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "execution_mode": {
            "const": "ANALYSIS"
          }
        },
        "required": [
          "execution_mode"
        ]
      },
      "then": {
        "properties": {
          "analysis_only": {
            "const": true
          },
          "counterfactual_basis": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "promotion_state": {
            "const": "CONTESTED"
          }
        },
        "required": [
          "promotion_state"
        ]
      },
      "then": {
        "properties": {
          "conflict_membership_refs": {
            "minItems": 1
          },
          "promotion_readiness": {
            "type": "object",
            "properties": {
              "blocking_conflict_count": {
                "minimum": 1
              }
            },
            "required": [
              "blocking_conflict_count"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "execution_mode": {
            "const": "COMPLIANCE"
          },
          "fact_family": {
            "const": "ADJUSTMENT_FACT"
          }
        },
        "required": [
          "execution_mode",
          "fact_family"
        ]
      },
      "then": {
        "properties": {
          "adjustment_binding": {
            "type": "object",
            "properties": {
              "analysis_mode_treatment": {
                "const": "MATCH_COMPLIANCE_BASIS"
              }
            },
            "required": [
              "analysis_mode_treatment"
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
