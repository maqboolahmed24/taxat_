{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/twin_mismatch_summary.schema.json",
  "title": "TwinMismatchSummary",
  "description": "Low-noise mismatch-summary contract for Twin Lens rendering. This schema freezes aggregate mismatch counts and the top ranked mismatch refs so clients do not have to reconstruct the operator summary from raw delta rows.",
  "type": "object",
  "required": [
    "artifact_type",
    "mismatch_summary_id",
    "twin_id",
    "ranking_profile_code",
    "total_subject_count",
    "matched_count",
    "mismatch_count",
    "comparable_mismatch_count",
    "waiting_count",
    "partial_ack_count",
    "non_comparable_count",
    "contradictory_count",
    "blocking_count",
    "material_count",
    "review_count",
    "informational_count",
    "limited_count",
    "stale_count",
    "out_of_band_count",
    "highest_priority_rank",
    "highest_materiality_class",
    "top_mismatch_refs",
    "top_ranked_mismatches",
    "suppressed_match_count",
    "generated_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "TwinMismatchSummary"
    },
    "mismatch_summary_id": {
      "type": "string",
      "minLength": 1
    },
    "twin_id": {
      "type": "string",
      "minLength": 1
    },
    "ranking_profile_code": {
      "const": "TWIN_MISMATCH_SORT_V1"
    },
    "total_subject_count": {
      "type": "integer",
      "minimum": 0
    },
    "matched_count": {
      "type": "integer",
      "minimum": 0
    },
    "mismatch_count": {
      "type": "integer",
      "minimum": 0
    },
    "comparable_mismatch_count": {
      "type": "integer",
      "minimum": 0
    },
    "waiting_count": {
      "type": "integer",
      "minimum": 0
    },
    "partial_ack_count": {
      "type": "integer",
      "minimum": 0
    },
    "non_comparable_count": {
      "type": "integer",
      "minimum": 0
    },
    "contradictory_count": {
      "type": "integer",
      "minimum": 0
    },
    "blocking_count": {
      "type": "integer",
      "minimum": 0
    },
    "material_count": {
      "type": "integer",
      "minimum": 0
    },
    "review_count": {
      "type": "integer",
      "minimum": 0
    },
    "informational_count": {
      "type": "integer",
      "minimum": 0
    },
    "limited_count": {
      "type": "integer",
      "minimum": 0
    },
    "stale_count": {
      "type": "integer",
      "minimum": 0
    },
    "out_of_band_count": {
      "type": "integer",
      "minimum": 0
    },
    "highest_priority_rank": {
      "type": "integer",
      "minimum": 0
    },
    "highest_materiality_class": {
      "type": "string",
      "enum": [
        "NONE",
        "INFORMATIONAL",
        "REVIEW",
        "MATERIAL",
        "BLOCKING"
      ]
    },
    "top_mismatch_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "top_ranked_mismatches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "delta_arc_ref",
          "comparison_key",
          "comparability_state",
          "comparability_reason_code",
          "priority_rank",
          "last_compared_at",
          "materiality_class"
        ],
        "properties": {
          "delta_arc_ref": {
            "type": "string",
            "minLength": 1
          },
          "comparison_key": {
            "type": "string",
            "minLength": 1
          },
          "comparability_state": {
            "type": "string",
            "enum": [
              "COMPARABLE",
              "WAITING_ON_AUTHORITY",
              "PARTIALLY_COMPARABLE",
              "NON_COMPARABLE",
              "OUT_OF_BAND",
              "CONTRADICTORY"
            ]
          },
          "comparability_reason_code": {
            "type": "string",
            "enum": [
              "NONE",
              "BASELINE_MISSING",
              "STALE_COMPARISON",
              "LIMITED_VISIBILITY",
              "REPLAY_NON_AUTHORITATIVE",
              "ACK_PENDING",
              "ACK_PARTIAL",
              "ACK_CONTRADICTORY",
              "OUT_OF_BAND",
              "CONTRADICTION_COMPONENTS"
            ]
          },
          "priority_rank": {
            "type": "integer",
            "minimum": 1
          },
          "last_compared_at": {
            "type": "string",
            "format": "date-time"
          },
          "materiality_class": {
            "type": "string",
            "enum": [
              "INFORMATIONAL",
              "REVIEW",
              "MATERIAL",
              "BLOCKING"
            ]
          }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "suppressed_match_count": {
      "type": "integer",
      "minimum": 0
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "mismatch_count": {
            "const": 0
          }
        },
        "required": [
          "mismatch_count"
        ]
      },
      "then": {
        "properties": {
          "blocking_count": {
            "const": 0
          },
          "comparable_mismatch_count": {
            "const": 0
          },
          "waiting_count": {
            "const": 0
          },
          "partial_ack_count": {
            "const": 0
          },
          "non_comparable_count": {
            "const": 0
          },
          "contradictory_count": {
            "const": 0
          },
          "material_count": {
            "const": 0
          },
          "review_count": {
            "const": 0
          },
          "informational_count": {
            "const": 0
          },
          "limited_count": {
            "const": 0
          },
          "stale_count": {
            "const": 0
          },
          "out_of_band_count": {
            "const": 0
          },
          "highest_priority_rank": {
            "const": 0
          },
          "highest_materiality_class": {
            "const": "NONE"
          },
          "top_mismatch_refs": {
            "maxItems": 0
          },
          "top_ranked_mismatches": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mismatch_count": {
            "minimum": 1
          }
        },
        "required": [
          "mismatch_count"
        ]
      },
      "then": {
        "properties": {
          "highest_priority_rank": {
            "minimum": 1
          },
          "highest_materiality_class": {
            "enum": [
              "INFORMATIONAL",
              "REVIEW",
              "MATERIAL",
              "BLOCKING"
            ]
          },
          "top_mismatch_refs": {
            "minItems": 1
          },
          "top_ranked_mismatches": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
