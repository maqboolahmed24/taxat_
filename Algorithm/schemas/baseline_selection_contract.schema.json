{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/baseline_selection_contract.schema.json",
  "title": "BaselineSelectionContract",
  "description": "Deterministic exact-scope baseline-selection contract for drift and amendment workflows. This schema freezes the active exact scope, the chosen dominance ranks, continuity posture, and baseline-anchor uncertainty so a persisted DriftBaselineEnvelope cannot later be reinterpreted as a broader, stronger, or more lineage-continuous baseline than the selector actually proved.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "selection_profile_code",
    "dominance_key_profile_code",
    "selection_contract_hash",
    "active_exact_scope_key",
    "target_scope_refs",
    "selected_scope_refs",
    "scope_match_class",
    "scope_resolution_state",
    "scope_rank",
    "exact_scope_candidate_present",
    "selected_baseline_type",
    "same_scope_truth_resolution_state",
    "precedence_rank",
    "authority_resolution_class",
    "authority_resolution_rank",
    "continuity_class",
    "chain_continuity_rank",
    "selected_effective_at_or_null",
    "selected_manifest_generation_or_null",
    "stable_selection_id",
    "internal_chain_continuity_asserted",
    "baseline_anchor_weight",
    "uncertainty_reason_codes",
    "automation_ceiling",
    "review_recommendation_floor",
    "amendment_progression_ceiling",
    "benign_drift_eligibility_state"
  ],
  "properties": {
    "selection_profile_code": {
      "const": "DRIFT_BASELINE_SELECTION_V1"
    },
    "dominance_key_profile_code": {
      "const": "DRIFT_BASELINE_DOMINANCE_KEY_V1"
    },
    "selection_contract_hash": {
      "type": "string",
      "minLength": 1
    },
    "active_exact_scope_key": {
      "type": "string",
      "minLength": 1
    },
    "target_scope_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "selected_scope_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "scope_match_class": {
      "type": "string",
      "enum": [
        "EXACT_SCOPE_MATCH",
        "SCOPE_SLICED_SUBSET_MATCH",
        "BROADER_CLIENT_PERIOD_MATCH"
      ]
    },
    "scope_resolution_state": {
      "type": "string",
      "enum": [
        "EXACT_SCOPE_SELECTED",
        "SCOPE_SLICED_SUBSET_SELECTED_NO_EXACT_CANDIDATE",
        "BROADER_SCOPE_SELECTED_NO_EXACT_CANDIDATE"
      ]
    },
    "scope_rank": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "exact_scope_candidate_present": {
      "type": "boolean"
    },
    "selected_baseline_type": {
      "type": "string",
      "enum": [
        "WORKING",
        "FILED",
        "AMENDED",
        "AUTHORITY_CORRECTED",
        "OUT_OF_BAND"
      ]
    },
    "same_scope_truth_resolution_state": {
      "type": "string",
      "enum": [
        "NO_STRONGER_EXTERNAL_TRUTH_PRESENT",
        "AUTHORITY_CORRECTED_TRUTH_SELECTED",
        "OUT_OF_BAND_EXTERNAL_TRUTH_BLOCKS_INTERNAL_LINEAGE"
      ]
    },
    "precedence_rank": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "authority_resolution_class": {
      "type": "string",
      "enum": [
        "EXACT_AUTHORITY_CONFIRMED",
        "AUTHORITY_OBSERVED_EXTERNAL",
        "ENGINE_CHAIN_UNREFRESHED",
        "WORKING_ONLY"
      ]
    },
    "authority_resolution_rank": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "continuity_class": {
      "type": "string",
      "enum": [
        "INTERNAL_CHAIN_CONTINUITY",
        "AUTHORITY_CORRECTED_EXTERNAL_CONTINUITY",
        "OUT_OF_BAND_EXTERNAL_CONTINUITY",
        "WORKING_LOCAL_ONLY"
      ]
    },
    "chain_continuity_rank": {
      "type": "integer",
      "minimum": 0,
      "maximum": 2
    },
    "selected_effective_at_or_null": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "selected_manifest_generation_or_null": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "stable_selection_id": {
      "type": "string",
      "minLength": 1
    },
    "internal_chain_continuity_asserted": {
      "type": "boolean"
    },
    "baseline_anchor_weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "uncertainty_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "automation_ceiling": {
      "type": "string",
      "enum": [
        "ALLOWED",
        "LIMITED",
        "BLOCKED"
      ]
    },
    "review_recommendation_floor": {
      "type": "string",
      "enum": [
        "NONE",
        "REVIEW_REQUIRED",
        "RECONCILIATION_REQUIRED"
      ]
    },
    "amendment_progression_ceiling": {
      "type": "string",
      "enum": [
        "ELIGIBLE_NOW_ALLOWED",
        "REVIEW_ONLY",
        "RECONCILE_FIRST"
      ]
    },
    "benign_drift_eligibility_state": {
      "type": "string",
      "enum": [
        "ALLOWED",
        "FORBIDDEN"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "exact_scope_candidate_present": {
            "const": true
          }
        },
        "required": [
          "exact_scope_candidate_present"
        ]
      },
      "then": {
        "properties": {
          "scope_match_class": {
            "const": "EXACT_SCOPE_MATCH"
          },
          "scope_resolution_state": {
            "const": "EXACT_SCOPE_SELECTED"
          },
          "scope_rank": {
            "const": 3
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scope_match_class": {
            "const": "EXACT_SCOPE_MATCH"
          }
        },
        "required": [
          "scope_match_class"
        ]
      },
      "then": {
        "properties": {
          "scope_resolution_state": {
            "const": "EXACT_SCOPE_SELECTED"
          },
          "scope_rank": {
            "const": 3
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scope_match_class": {
            "const": "SCOPE_SLICED_SUBSET_MATCH"
          }
        },
        "required": [
          "scope_match_class"
        ]
      },
      "then": {
        "properties": {
          "scope_resolution_state": {
            "const": "SCOPE_SLICED_SUBSET_SELECTED_NO_EXACT_CANDIDATE"
          },
          "scope_rank": {
            "const": 2
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scope_match_class": {
            "const": "BROADER_CLIENT_PERIOD_MATCH"
          }
        },
        "required": [
          "scope_match_class"
        ]
      },
      "then": {
        "properties": {
          "scope_resolution_state": {
            "const": "BROADER_SCOPE_SELECTED_NO_EXACT_CANDIDATE"
          },
          "scope_rank": {
            "const": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "continuity_class": {
            "const": "INTERNAL_CHAIN_CONTINUITY"
          }
        },
        "required": [
          "continuity_class"
        ]
      },
      "then": {
        "properties": {
          "internal_chain_continuity_asserted": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "continuity_class": {
            "enum": [
              "AUTHORITY_CORRECTED_EXTERNAL_CONTINUITY",
              "OUT_OF_BAND_EXTERNAL_CONTINUITY",
              "WORKING_LOCAL_ONLY"
            ]
          }
        },
        "required": [
          "continuity_class"
        ]
      },
      "then": {
        "properties": {
          "internal_chain_continuity_asserted": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_baseline_type": {
            "enum": [
              "WORKING",
              "FILED",
              "AMENDED"
            ]
          }
        },
        "required": [
          "selected_baseline_type"
        ]
      },
      "then": {
        "properties": {
          "same_scope_truth_resolution_state": {
            "const": "NO_STRONGER_EXTERNAL_TRUTH_PRESENT"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_baseline_type": {
            "const": "AUTHORITY_CORRECTED"
          }
        },
        "required": [
          "selected_baseline_type"
        ]
      },
      "then": {
        "properties": {
          "same_scope_truth_resolution_state": {
            "const": "AUTHORITY_CORRECTED_TRUTH_SELECTED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_baseline_type": {
            "const": "OUT_OF_BAND"
          }
        },
        "required": [
          "selected_baseline_type"
        ]
      },
      "then": {
        "properties": {
          "same_scope_truth_resolution_state": {
            "const": "OUT_OF_BAND_EXTERNAL_TRUTH_BLOCKS_INTERNAL_LINEAGE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "uncertainty_reason_codes": {
            "minItems": 1
          }
        },
        "required": [
          "uncertainty_reason_codes"
        ]
      },
      "then": {
        "properties": {
          "baseline_anchor_weight": {
            "exclusiveMaximum": 1
          },
          "automation_ceiling": {
            "enum": [
              "LIMITED",
              "BLOCKED"
            ]
          },
          "review_recommendation_floor": {
            "enum": [
              "REVIEW_REQUIRED",
              "RECONCILIATION_REQUIRED"
            ]
          },
          "amendment_progression_ceiling": {
            "enum": [
              "REVIEW_ONLY",
              "RECONCILE_FIRST"
            ]
          },
          "benign_drift_eligibility_state": {
            "const": "FORBIDDEN"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_baseline_type": {
            "const": "WORKING"
          }
        },
        "required": [
          "selected_baseline_type"
        ]
      },
      "then": {
        "properties": {
          "automation_ceiling": {
            "const": "BLOCKED"
          },
          "review_recommendation_floor": {
            "const": "REVIEW_REQUIRED"
          },
          "amendment_progression_ceiling": {
            "const": "REVIEW_ONLY"
          },
          "benign_drift_eligibility_state": {
            "const": "FORBIDDEN"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "scope_resolution_state": {
            "enum": [
              "SCOPE_SLICED_SUBSET_SELECTED_NO_EXACT_CANDIDATE",
              "BROADER_SCOPE_SELECTED_NO_EXACT_CANDIDATE"
            ]
          }
        },
        "required": [
          "scope_resolution_state"
        ]
      },
      "then": {
        "properties": {
          "automation_ceiling": {
            "enum": [
              "LIMITED",
              "BLOCKED"
            ]
          },
          "review_recommendation_floor": {
            "enum": [
              "REVIEW_REQUIRED",
              "RECONCILIATION_REQUIRED"
            ]
          },
          "amendment_progression_ceiling": {
            "enum": [
              "REVIEW_ONLY",
              "RECONCILE_FIRST"
            ]
          },
          "benign_drift_eligibility_state": {
            "const": "FORBIDDEN"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_resolution_class": {
            "enum": [
              "WORKING_ONLY",
              "ENGINE_CHAIN_UNREFRESHED"
            ]
          }
        },
        "required": [
          "authority_resolution_class"
        ]
      },
      "then": {
        "properties": {
          "automation_ceiling": {
            "enum": [
              "LIMITED",
              "BLOCKED"
            ]
          },
          "review_recommendation_floor": {
            "enum": [
              "REVIEW_REQUIRED",
              "RECONCILIATION_REQUIRED"
            ]
          },
          "amendment_progression_ceiling": {
            "enum": [
              "REVIEW_ONLY",
              "RECONCILE_FIRST"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "same_scope_truth_resolution_state": {
            "const": "OUT_OF_BAND_EXTERNAL_TRUTH_BLOCKS_INTERNAL_LINEAGE"
          }
        },
        "required": [
          "same_scope_truth_resolution_state"
        ]
      },
      "then": {
        "properties": {
          "automation_ceiling": {
            "const": "BLOCKED"
          },
          "review_recommendation_floor": {
            "const": "RECONCILIATION_REQUIRED"
          },
          "amendment_progression_ceiling": {
            "const": "RECONCILE_FIRST"
          },
          "benign_drift_eligibility_state": {
            "const": "FORBIDDEN"
          }
        }
      }
    }
  ]
}
