{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/late_data_indicator_set.schema.json",
  "title": "LateDataIndicatorSet",
  "description": "Deterministically ordered late-data indicator set for one manifest and runtime scope. This contract freezes the exact indicator population seen during post-seal monitoring before those indicators are aggregated into findings and gate-visible status.",
  "allOf": [
    {
      "type": "object",
      "required": [
        "set_id",
        "manifest_id",
        "artifact_type",
        "collection_boundary_ref",
        "source_plan_ref",
        "runtime_scope_refs",
        "items",
        "contract"
      ],
      "properties": {
        "set_id": {
          "type": "string",
          "minLength": 1
        },
        "manifest_id": {
          "type": "string",
          "minLength": 1
        },
        "artifact_type": {
          "const": "LateDataIndicatorSet"
        },
        "collection_boundary_ref": {
          "type": "string",
          "minLength": 1
        },
        "source_plan_ref": {
          "type": "string",
          "minLength": 1
        },
        "runtime_scope_refs": {
          "$ref": "./late_data_policy_binding.schema.json#/$defs/runtimeScopeRefs"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "./late_data_indicator.schema.json"
          },
          "uniqueItems": true
        },
        "contract": {
          "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
        }
      }
    },
    {
      "type": "object",
      "required": [
        "artifact_contract_hash",
        "item_identity_hash",
        "produced_at",
        "set_hash"
      ],
      "properties": {
        "artifact_contract_hash": {
          "type": "string",
          "minLength": 1
        },
        "item_identity_hash": {
          "type": "string",
          "minLength": 1
        },
        "set_hash": {
          "type": "string",
          "minLength": 1
        },
        "produced_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
