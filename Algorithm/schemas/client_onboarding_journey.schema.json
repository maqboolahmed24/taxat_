{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/client_onboarding_journey.schema.json",
  "title": "ClientOnboardingJourney",
  "description": "Guided onboarding journey contract for the client portal. This contract preserves one-primary-step semantics, typed save-and-return continuity, and completion integrity.",
  "type": "object",
  "required": [
    "journey_id",
    "artifact_type",
    "tenant_id",
    "client_id",
    "lifecycle_state",
    "current_step_code",
    "required_steps",
    "completed_steps",
    "verification_state",
    "authority_link_requirement",
    "authority_link_state",
    "document_request_refs",
    "help_channel_ref",
    "resume_state",
    "resume_step_code",
    "draft_upload_session_refs",
    "reconfirmation_step_codes",
    "invited_at",
    "state_changed_at",
    "completed_at",
    "completion_summary_ref",
    "completion_timeline_event_ref",
    "expires_at",
    "expired_at",
    "abandoned_at",
    "abandonment_reason_code",
    "language_contract",
    "customer_safe_projection"
  ],
  "properties": {
    "journey_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "ClientOnboardingJourney"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "INVITED",
        "PROFILE_PENDING",
        "IDENTITY_PENDING",
        "AUTHORITY_LINK_PENDING",
        "DOCUMENTS_PENDING",
        "READY_FOR_REVIEW",
        "COMPLETED",
        "EXPIRED",
        "ABANDONED"
      ]
    },
    "current_step_code": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "INVITE_ACCEPTANCE",
        "PROFILE_CONFIRMATION",
        "IDENTITY_VERIFICATION",
        "AUTHORITY_LINK_SETUP",
        "DOCUMENT_COLLECTION",
        "REVIEW_CONFIRMATION",
        null
      ]
    },
    "required_steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stepCode"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "completed_steps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stepCode"
      },
      "default": [],
      "uniqueItems": true
    },
    "verification_state": {
      "type": "string",
      "enum": [
        "NOT_STARTED",
        "PENDING",
        "VERIFIED",
        "WAIVED",
        "FAILED_RETRYABLE",
        "FAILED_REVIEW_REQUIRED"
      ]
    },
    "authority_link_requirement": {
      "type": "string",
      "enum": [
        "UNRESOLVED",
        "REQUIRED",
        "OPTIONAL",
        "NOT_REQUIRED"
      ]
    },
    "authority_link_state": {
      "type": "string",
      "enum": [
        "UNRESOLVED",
        "PENDING",
        "LINKED",
        "WAIVED",
        "NOT_REQUIRED"
      ]
    },
    "document_request_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "help_channel_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "resume_state": {
      "type": "string",
      "enum": [
        "NONE",
        "LIVE",
        "RECONFIRMATION_REQUIRED",
        "STALE_REVIEW_REQUIRED"
      ]
    },
    "resume_step_code": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "INVITE_ACCEPTANCE",
        "PROFILE_CONFIRMATION",
        "IDENTITY_VERIFICATION",
        "AUTHORITY_LINK_SETUP",
        "DOCUMENT_COLLECTION",
        "REVIEW_CONFIRMATION",
        null
      ]
    },
    "draft_upload_session_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "reconfirmation_step_codes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stepCode"
      },
      "default": [],
      "uniqueItems": true
    },
    "invited_at": {
      "type": "string",
      "format": "date-time"
    },
    "state_changed_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "completion_summary_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "completion_timeline_event_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "expired_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "abandoned_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "abandonment_reason_code": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "language_contract": {
      "$ref": "https://taxat.dev/schemas/portal_language_contract.schema.json"
    },
    "customer_safe_projection": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/customer_safe_projection_contract.schema.json"
        },
        {
          "properties": {
            "boundary_scope": {
              "const": "CLIENT_ONBOARDING_JOURNEY"
            },
            "projection_audience": {
              "const": "CLIENT_PORTAL"
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "stepCode": {
      "type": "string",
      "enum": [
        "INVITE_ACCEPTANCE",
        "PROFILE_CONFIRMATION",
        "IDENTITY_VERIFICATION",
        "AUTHORITY_LINK_SETUP",
        "DOCUMENT_COLLECTION",
        "REVIEW_CONFIRMATION"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "current_step_code": {
            "const": "INVITE_ACCEPTANCE"
          }
        },
        "required": [
          "current_step_code"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "INVITE_ACCEPTANCE"
            }
          },
          "completed_steps": {
            "not": {
              "contains": {
                "const": "INVITE_ACCEPTANCE"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "current_step_code": {
            "const": "PROFILE_CONFIRMATION"
          }
        },
        "required": [
          "current_step_code"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "PROFILE_CONFIRMATION"
            }
          },
          "completed_steps": {
            "not": {
              "contains": {
                "const": "PROFILE_CONFIRMATION"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "current_step_code": {
            "const": "IDENTITY_VERIFICATION"
          }
        },
        "required": [
          "current_step_code"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "IDENTITY_VERIFICATION"
            }
          },
          "completed_steps": {
            "not": {
              "contains": {
                "const": "IDENTITY_VERIFICATION"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "current_step_code": {
            "const": "AUTHORITY_LINK_SETUP"
          }
        },
        "required": [
          "current_step_code"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "AUTHORITY_LINK_SETUP"
            }
          },
          "completed_steps": {
            "not": {
              "contains": {
                "const": "AUTHORITY_LINK_SETUP"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "current_step_code": {
            "const": "DOCUMENT_COLLECTION"
          }
        },
        "required": [
          "current_step_code"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "DOCUMENT_COLLECTION"
            }
          },
          "completed_steps": {
            "not": {
              "contains": {
                "const": "DOCUMENT_COLLECTION"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "current_step_code": {
            "const": "REVIEW_CONFIRMATION"
          }
        },
        "required": [
          "current_step_code"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "REVIEW_CONFIRMATION"
            }
          },
          "completed_steps": {
            "not": {
              "contains": {
                "const": "REVIEW_CONFIRMATION"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "completed_steps": {
            "contains": {
              "const": "INVITE_ACCEPTANCE"
            }
          }
        },
        "required": [
          "completed_steps"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "INVITE_ACCEPTANCE"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "completed_steps": {
            "contains": {
              "const": "PROFILE_CONFIRMATION"
            }
          }
        },
        "required": [
          "completed_steps"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "PROFILE_CONFIRMATION"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "completed_steps": {
            "contains": {
              "const": "IDENTITY_VERIFICATION"
            }
          }
        },
        "required": [
          "completed_steps"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "IDENTITY_VERIFICATION"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "completed_steps": {
            "contains": {
              "const": "AUTHORITY_LINK_SETUP"
            }
          }
        },
        "required": [
          "completed_steps"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "AUTHORITY_LINK_SETUP"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "completed_steps": {
            "contains": {
              "const": "DOCUMENT_COLLECTION"
            }
          }
        },
        "required": [
          "completed_steps"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "DOCUMENT_COLLECTION"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "completed_steps": {
            "contains": {
              "const": "REVIEW_CONFIRMATION"
            }
          }
        },
        "required": [
          "completed_steps"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "REVIEW_CONFIRMATION"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reconfirmation_step_codes": {
            "contains": {
              "const": "INVITE_ACCEPTANCE"
            }
          }
        },
        "required": [
          "reconfirmation_step_codes"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "INVITE_ACCEPTANCE"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reconfirmation_step_codes": {
            "contains": {
              "const": "PROFILE_CONFIRMATION"
            }
          }
        },
        "required": [
          "reconfirmation_step_codes"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "PROFILE_CONFIRMATION"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reconfirmation_step_codes": {
            "contains": {
              "const": "IDENTITY_VERIFICATION"
            }
          }
        },
        "required": [
          "reconfirmation_step_codes"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "IDENTITY_VERIFICATION"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reconfirmation_step_codes": {
            "contains": {
              "const": "AUTHORITY_LINK_SETUP"
            }
          }
        },
        "required": [
          "reconfirmation_step_codes"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "AUTHORITY_LINK_SETUP"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reconfirmation_step_codes": {
            "contains": {
              "const": "DOCUMENT_COLLECTION"
            }
          }
        },
        "required": [
          "reconfirmation_step_codes"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "DOCUMENT_COLLECTION"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reconfirmation_step_codes": {
            "contains": {
              "const": "REVIEW_CONFIRMATION"
            }
          }
        },
        "required": [
          "reconfirmation_step_codes"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "REVIEW_CONFIRMATION"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "INVITE_ACCEPTANCE"
            }
          },
          "lifecycle_state": {
            "const": "COMPLETED"
          }
        },
        "required": [
          "required_steps",
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "completed_steps": {
            "contains": {
              "const": "INVITE_ACCEPTANCE"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "PROFILE_CONFIRMATION"
            }
          },
          "lifecycle_state": {
            "const": "COMPLETED"
          }
        },
        "required": [
          "required_steps",
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "completed_steps": {
            "contains": {
              "const": "PROFILE_CONFIRMATION"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "IDENTITY_VERIFICATION"
            }
          },
          "lifecycle_state": {
            "const": "COMPLETED"
          }
        },
        "required": [
          "required_steps",
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "completed_steps": {
            "contains": {
              "const": "IDENTITY_VERIFICATION"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "AUTHORITY_LINK_SETUP"
            }
          },
          "lifecycle_state": {
            "const": "COMPLETED"
          }
        },
        "required": [
          "required_steps",
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "completed_steps": {
            "contains": {
              "const": "AUTHORITY_LINK_SETUP"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "DOCUMENT_COLLECTION"
            }
          },
          "lifecycle_state": {
            "const": "COMPLETED"
          }
        },
        "required": [
          "required_steps",
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "completed_steps": {
            "contains": {
              "const": "DOCUMENT_COLLECTION"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "REVIEW_CONFIRMATION"
            }
          },
          "lifecycle_state": {
            "const": "COMPLETED"
          }
        },
        "required": [
          "required_steps",
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "completed_steps": {
            "contains": {
              "const": "REVIEW_CONFIRMATION"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "DOCUMENT_COLLECTION"
            }
          }
        },
        "required": [
          "required_steps"
        ]
      },
      "then": {
        "properties": {
          "document_request_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "required_steps": {
            "not": {
              "contains": {
                "const": "DOCUMENT_COLLECTION"
              }
            }
          }
        },
        "required": [
          "required_steps"
        ]
      },
      "then": {
        "properties": {
          "document_request_refs": {
            "maxItems": 0
          },
          "draft_upload_session_refs": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "INVITED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "current_step_code": {
            "const": "INVITE_ACCEPTANCE"
          },
          "verification_state": {
            "const": "NOT_STARTED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "PROFILE_PENDING"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "current_step_code": {
            "const": "PROFILE_CONFIRMATION"
          },
          "verification_state": {
            "const": "NOT_STARTED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "IDENTITY_PENDING"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "current_step_code": {
            "const": "IDENTITY_VERIFICATION"
          },
          "verification_state": {
            "enum": [
              "PENDING",
              "FAILED_RETRYABLE",
              "FAILED_REVIEW_REQUIRED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "AUTHORITY_LINK_PENDING"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "current_step_code": {
            "const": "AUTHORITY_LINK_SETUP"
          },
          "verification_state": {
            "enum": [
              "VERIFIED",
              "WAIVED"
            ]
          },
          "authority_link_requirement": {
            "enum": [
              "REQUIRED",
              "OPTIONAL"
            ]
          },
          "authority_link_state": {
            "const": "PENDING"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "DOCUMENTS_PENDING"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "current_step_code": {
            "const": "DOCUMENT_COLLECTION"
          },
          "verification_state": {
            "enum": [
              "VERIFIED",
              "WAIVED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "READY_FOR_REVIEW"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "current_step_code": {
            "const": "REVIEW_CONFIRMATION"
          },
          "verification_state": {
            "enum": [
              "VERIFIED",
              "WAIVED"
            ]
          },
          "completed_steps": {
            "contains": {
              "const": "DOCUMENT_COLLECTION"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_link_requirement": {
            "const": "REQUIRED"
          }
        },
        "required": [
          "authority_link_requirement"
        ]
      },
      "then": {
        "properties": {
          "required_steps": {
            "contains": {
              "const": "AUTHORITY_LINK_SETUP"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_link_requirement": {
            "const": "NOT_REQUIRED"
          }
        },
        "required": [
          "authority_link_requirement"
        ]
      },
      "then": {
        "properties": {
          "authority_link_state": {
            "const": "NOT_REQUIRED"
          },
          "required_steps": {
            "not": {
              "contains": {
                "const": "AUTHORITY_LINK_SETUP"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
