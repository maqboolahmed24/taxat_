{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/source_plan.schema.json",
  "title": "SourcePlan",
  "type": "object",
  "required": [
    "source_plan_id",
    "manifest_id",
    "artifact_type",
    "required_domains",
    "planned_sources",
    "contract"
  ],
  "properties": {
    "source_plan_id": { "type": "string" },
    "manifest_id": { "type": "string" },
    "artifact_type": { "const": "SourcePlan" },
    "required_domains": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "planned_sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/plannedSource" }
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "$defs": {
    "plannedSource": {
      "type": "object",
      "required": [
        "source_domain",
        "source_class",
        "provider_binding_ref",
        "partition_scope_refs",
        "query_basis_ref",
        "cursor_strategy_ref",
        "read_model",
        "late_data_policy_ref",
        "freshness_slo_ref",
        "required_schema_refs"
      ],
      "properties": {
        "source_domain": { "type": "string" },
        "source_class": { "type": "string" },
        "provider_binding_ref": { "type": "string" },
        "partition_scope_refs": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "query_basis_ref": { "type": "string" },
        "cursor_strategy_ref": { "type": "string" },
        "read_model": {
          "type": "string",
          "enum": ["AS_OF", "WINDOWED", "POINT_IN_TIME", "LATEST_ALLOWED"]
        },
        "late_data_policy_ref": {
          "type": "string",
          "enum": ["EXCLUDE_LATE", "SPAWN_CHILD_MANIFEST", "REVIEW_IF_LATE"]
        },
        "freshness_slo_ref": { "type": "string" },
        "required_schema_refs": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "required_source_class_refs": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
