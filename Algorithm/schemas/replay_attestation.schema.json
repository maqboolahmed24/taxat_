{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/replay_attestation.schema.json",
  "title": "ReplayAttestation",
  "description": "Durable replay-comparison artifact. This schema freezes basis validation, outcome comparison, mismatch inventory, and operator or auditor explanation for one replay child.",
  "type": "object",
  "required": [
    "replay_attestation_id",
    "manifest_id",
    "replay_of_manifest_id",
    "artifact_type",
    "execution_mode",
    "analysis_only",
    "non_compliance_config_refs",
    "counterfactual_basis",
    "execution_mode_boundary_contract",
    "replay_class",
    "comparison_mode",
    "basis_validation_state",
    "basis_identity_verdict",
    "deterministic_equivalence_verdict",
    "basis_dimension_results",
    "outcome_component_results",
    "basis_coverage",
    "basis_match_ratio",
    "outcome_coverage",
    "outcome_match_ratio",
    "material_outcome_coverage",
    "material_outcome_match_ratio",
    "signature_verification_state",
    "attestation_envelope_ref",
    "verification_material_refs",
    "attestation_confidence_score",
    "attestation_confidence_band",
    "outcome_class",
    "basis_integrity_contract",
    "expected_execution_basis_hash",
    "actual_execution_basis_hash",
    "expected_deterministic_outcome_hash",
    "actual_deterministic_outcome_hash",
    "difference_reason_codes",
    "limitation_codes",
    "mismatch_inventory",
    "plain_summary",
    "operator_summary_ref",
    "auditor_summary_ref",
    "compared_at",
    "contract"
  ],
  "properties": {
    "replay_attestation_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "replay_of_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "ReplayAttestation"
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "COMPLIANCE",
        "ANALYSIS"
      ]
    },
    "analysis_only": {
      "type": "boolean"
    },
    "non_compliance_config_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "counterfactual_basis": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "execution_mode_boundary_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/execution_mode_boundary_contract.schema.json"
        },
        {
          "properties": {
            "run_kind": {
              "const": "REPLAY"
            }
          }
        }
      ]
    },
    "replay_class": {
      "type": "string",
      "enum": [
        "STANDARD_REPLAY",
        "AUDIT_REPLAY",
        "COUNTERFACTUAL_ANALYSIS"
      ]
    },
    "comparison_mode": {
      "type": "string",
      "enum": [
        "EXACT_HASH_MATCH",
        "COUNTERFACTUAL_DECLARED",
        "LIMITED_HISTORICAL_COMPARISON",
        "BASIS_INCOMPLETE",
        "BASIS_CORRUPT"
      ]
    },
    "basis_validation_state": {
      "type": "string",
      "enum": [
        "VALID",
        "RETENTION_LIMITED",
        "MISSING_DEPENDENCY",
        "CORRUPT",
        "SCHEMA_INCOMPATIBLE",
        "BUILD_UNAVAILABLE"
      ]
    },
    "outcome_class": {
      "type": "string",
      "enum": [
        "EXACT_MATCH",
        "EXPECTED_EQUIVALENCE",
        "EXPECTED_DIFFERENCE",
        "LIMITED_COMPARABLE",
        "BASIS_INCOMPLETE",
        "BASIS_CORRUPT",
        "UNEXPECTED_MISMATCH"
      ]
    },
    "basis_integrity_contract": {
      "$ref": "https://taxat.dev/schemas/replay_basis_integrity_contract.schema.json"
    },
    "basis_identity_verdict": {
      "type": "string",
      "enum": [
        "IDENTICAL",
        "DIFFERENT",
        "UNDECIDABLE",
        "CORRUPT"
      ]
    },
    "deterministic_equivalence_verdict": {
      "type": "string",
      "enum": [
        "IDENTICAL",
        "DIFFERENT",
        "UNDECIDABLE",
        "CORRUPT"
      ]
    },
    "expected_execution_basis_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "actual_execution_basis_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "expected_deterministic_outcome_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "actual_deterministic_outcome_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "basis_dimension_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/basisDimensionResult"
      },
      "minItems": 6,
      "maxItems": 6,
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": {
              "dimension_code": {
                "const": "IDENTITY_AUTHORITY"
              }
            },
            "required": [
              "dimension_code"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "dimension_code": {
                "const": "EXECUTABLE"
              }
            },
            "required": [
              "dimension_code"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "dimension_code": {
                "const": "CONFIG"
              }
            },
            "required": [
              "dimension_code"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "dimension_code": {
                "const": "INPUT"
              }
            },
            "required": [
              "dimension_code"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "dimension_code": {
                "const": "POST_SEAL"
              }
            },
            "required": [
              "dimension_code"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "dimension_code": {
                "const": "DETERMINISM"
              }
            },
            "required": [
              "dimension_code"
            ]
          }
        }
      ]
    },
    "outcome_component_results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/outcomeComponentResult"
      },
      "minItems": 14,
      "maxItems": 14,
      "uniqueItems": true,
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": {
              "component_class": {
                "const": "DECISION_BUNDLE"
              }
            },
            "required": [
              "component_class"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "component_class": {
                "const": "GATE_SEQUENCE"
              }
            },
            "required": [
              "component_class"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "component_class": {
                "const": "SNAPSHOT"
              }
            },
            "required": [
              "component_class"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "component_class": {
                "const": "COMPUTE_RESULT"
              }
            },
            "required": [
              "component_class"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "component_class": {
                "const": "FORECAST_SET"
              }
            },
            "required": [
              "component_class"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "component_class": {
                "const": "RISK_REPORT"
              }
            },
            "required": [
              "component_class"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "component_class": {
                "const": "PARITY_RESULT"
              }
            },
            "required": [
              "component_class"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "component_class": {
                "const": "TRUST_SUMMARY"
              }
            },
            "required": [
              "component_class"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "component_class": {
                "const": "EVIDENCE_GRAPH"
              }
            },
            "required": [
              "component_class"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "component_class": {
                "const": "TWIN_VIEW"
              }
            },
            "required": [
              "component_class"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "component_class": {
                "const": "FILING_PACKET"
              }
            },
            "required": [
              "component_class"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "component_class": {
                "const": "AUTHORITY_RESULT"
              }
            },
            "required": [
              "component_class"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "component_class": {
                "const": "LATE_DATA_BASIS"
              }
            },
            "required": [
              "component_class"
            ]
          }
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "component_class": {
                "const": "DRIFT_RECORD"
              }
            },
            "required": [
              "component_class"
            ]
          }
        }
      ]
    },
    "basis_coverage": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "basis_match_ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "outcome_coverage": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "outcome_match_ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "material_outcome_coverage": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "material_outcome_match_ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "difference_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "limitation_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "mismatch_inventory": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mismatchItem"
      },
      "default": [],
      "uniqueItems": true
    },
    "plain_summary": {
      "type": "string",
      "minLength": 1
    },
    "operator_summary_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "auditor_summary_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "compared_at": {
      "type": "string",
      "format": "date-time"
    },
    "signature_verification_state": {
      "type": "string",
      "enum": [
        "VERIFIED",
        "NOT_SIGNED",
        "VERIFICATION_MATERIAL_MISSING",
        "SIGNATURE_INVALID"
      ]
    },
    "attestation_envelope_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "verification_material_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "attestation_confidence_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "attestation_confidence_band": {
      "type": "string",
      "enum": [
        "VERY_HIGH",
        "HIGH",
        "MODERATE",
        "LOW",
        "INSUFFICIENT"
      ]
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "$defs": {
    "mismatchItem": {
      "type": "object",
      "required": [
        "component_class",
        "mismatch_class",
        "materiality",
        "variance_class",
        "comparison_weight",
        "expected_hash",
        "actual_hash",
        "reason_codes"
      ],
      "properties": {
        "component_class": {
          "type": "string",
          "enum": [
            "EXECUTION_BASIS",
            "CONFIG_FREEZE",
            "INPUT_FREEZE",
            "AUTHORITY_BASIS",
            "LATE_DATA_BASIS",
            "GATE_SEQUENCE",
            "SNAPSHOT",
            "COMPUTE_RESULT",
            "FORECAST_SET",
            "RISK_REPORT",
            "PARITY_RESULT",
            "TRUST_SUMMARY",
            "EVIDENCE_GRAPH",
            "TWIN_VIEW",
            "FILING_PACKET",
            "AUTHORITY_RESULT",
            "DRIFT_RECORD",
            "DECISION_BUNDLE",
            "OTHER"
          ]
        },
        "component_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "mismatch_class": {
          "type": "string",
          "enum": [
            "HASH_DIFFERENCE",
            "MISSING_EXPECTED",
            "MISSING_ACTUAL",
            "CORRUPT_EXPECTED",
            "CORRUPT_ACTUAL",
            "SCHEMA_READER_INCOMPATIBLE",
            "RETENTION_LIMITED",
            "DECLARED_COUNTERFACTUAL",
            "VALUE_DIFFERENCE"
          ]
        },
        "materiality": {
          "type": "string",
          "enum": [
            "NON_MATERIAL",
            "MATERIAL",
            "BLOCKING"
          ]
        },
        "expected_hash": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "actual_hash": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "variance_class": {
          "type": "string",
          "enum": [
            "DECLARED_COUNTERFACTUAL",
            "UNDECLARED_BASIS_VARIANCE",
            "NON_MATERIAL_OUTCOME_VARIANCE",
            "MATERIAL_OUTCOME_VARIANCE",
            "BLOCKING_OUTCOME_VARIANCE",
            "LIMITATION_ONLY",
            "INTEGRITY_FAILURE"
          ]
        },
        "comparison_weight": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "component_class": {
                "enum": [
                  "GATE_SEQUENCE",
                  "SNAPSHOT",
                  "COMPUTE_RESULT",
                  "FORECAST_SET",
                  "RISK_REPORT",
                  "PARITY_RESULT",
                  "TRUST_SUMMARY",
                  "EVIDENCE_GRAPH",
                  "TWIN_VIEW",
                  "FILING_PACKET",
                  "AUTHORITY_RESULT",
                  "LATE_DATA_BASIS",
                  "DRIFT_RECORD",
                  "DECISION_BUNDLE"
                ]
              }
            },
            "required": [
              "component_class"
            ]
          },
          "then": {
            "properties": {
              "component_ref": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ]
    },
    "basisDimensionResult": {
      "type": "object",
      "required": [
        "dimension_code",
        "comparison_state",
        "variance_class",
        "comparison_weight",
        "expected_hash",
        "actual_hash",
        "reason_codes"
      ],
      "properties": {
        "dimension_code": {
          "type": "string",
          "enum": [
            "IDENTITY_AUTHORITY",
            "EXECUTABLE",
            "CONFIG",
            "INPUT",
            "POST_SEAL",
            "DETERMINISM"
          ]
        },
        "comparison_state": {
          "type": "string",
          "enum": [
            "MATCH",
            "MISMATCH",
            "DECLARED_CHANGE",
            "UNOBSERVABLE",
            "CORRUPT"
          ]
        },
        "variance_class": {
          "type": "string",
          "enum": [
            "NONE",
            "DECLARED_COUNTERFACTUAL",
            "UNDECLARED_BASIS_VARIANCE",
            "LIMITATION_ONLY",
            "INTEGRITY_FAILURE"
          ]
        },
        "comparison_weight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "expected_hash": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "actual_hash": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "comparison_state": {
                "const": "MATCH"
              }
            },
            "required": [
              "comparison_state"
            ]
          },
          "then": {
            "properties": {
              "variance_class": {
                "const": "NONE"
              },
              "expected_hash": {
                "type": "string"
              },
              "actual_hash": {
                "type": "string"
              },
              "reason_codes": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison_state": {
                "const": "DECLARED_CHANGE"
              }
            },
            "required": [
              "comparison_state"
            ]
          },
          "then": {
            "properties": {
              "variance_class": {
                "const": "DECLARED_COUNTERFACTUAL"
              },
              "reason_codes": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison_state": {
                "const": "MISMATCH"
              }
            },
            "required": [
              "comparison_state"
            ]
          },
          "then": {
            "properties": {
              "variance_class": {
                "const": "UNDECLARED_BASIS_VARIANCE"
              },
              "reason_codes": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison_state": {
                "const": "UNOBSERVABLE"
              }
            },
            "required": [
              "comparison_state"
            ]
          },
          "then": {
            "properties": {
              "variance_class": {
                "const": "LIMITATION_ONLY"
              },
              "reason_codes": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison_state": {
                "const": "CORRUPT"
              }
            },
            "required": [
              "comparison_state"
            ]
          },
          "then": {
            "properties": {
              "variance_class": {
                "const": "INTEGRITY_FAILURE"
              },
              "reason_codes": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "outcomeComponentResult": {
      "type": "object",
      "required": [
        "component_class",
        "comparison_state",
        "variance_class",
        "comparison_weight",
        "materiality",
        "expected_hash",
        "actual_hash",
        "reason_codes"
      ],
      "properties": {
        "component_class": {
          "type": "string",
          "enum": [
            "DECISION_BUNDLE",
            "GATE_SEQUENCE",
            "SNAPSHOT",
            "COMPUTE_RESULT",
            "FORECAST_SET",
            "RISK_REPORT",
            "PARITY_RESULT",
            "TRUST_SUMMARY",
            "EVIDENCE_GRAPH",
            "TWIN_VIEW",
            "FILING_PACKET",
            "AUTHORITY_RESULT",
            "LATE_DATA_BASIS",
            "DRIFT_RECORD"
          ]
        },
        "component_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "comparison_state": {
          "type": "string",
          "enum": [
            "MATCH",
            "MISMATCH",
            "DECLARED_CHANGE",
            "UNOBSERVABLE",
            "CORRUPT"
          ]
        },
        "variance_class": {
          "type": "string",
          "enum": [
            "NONE",
            "DECLARED_COUNTERFACTUAL",
            "NON_MATERIAL_OUTCOME_VARIANCE",
            "MATERIAL_OUTCOME_VARIANCE",
            "BLOCKING_OUTCOME_VARIANCE",
            "LIMITATION_ONLY",
            "INTEGRITY_FAILURE"
          ]
        },
        "comparison_weight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "materiality": {
          "type": "string",
          "enum": [
            "NON_MATERIAL",
            "MATERIAL",
            "BLOCKING"
          ]
        },
        "expected_hash": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "actual_hash": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "comparison_state": {
                "enum": [
                  "MATCH",
                  "DECLARED_CHANGE",
                  "MISMATCH",
                  "CORRUPT"
                ]
              }
            },
            "required": [
              "comparison_state"
            ]
          },
          "then": {
            "properties": {
              "component_ref": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison_state": {
                "const": "MATCH"
              }
            },
            "required": [
              "comparison_state"
            ]
          },
          "then": {
            "properties": {
              "variance_class": {
                "const": "NONE"
              },
              "expected_hash": {
                "type": "string"
              },
              "actual_hash": {
                "type": "string"
              },
              "reason_codes": {
                "maxItems": 0
              }
            }
          }
        },
