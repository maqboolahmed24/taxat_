{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/native_cache_hydration_contract.schema.json",
  "title": "NativeCacheHydrationContract",
  "description": "Shared native cache hydration contract. This schema freezes the legality envelope that must match before cached native content may render, the current lawful resume binding, the restoration anchor, the supported contract window, and the regulated local-artifact purge policies so macOS hydration, scene restoration, cursor reuse, and local derivatives cannot outrun backend legality.",
  "type": "object",
  "required": [
    "contract_version",
    "hydration_scope_class",
    "tenant_id",
    "principal_class",
    "session_binding_hash",
    "session_lineage_ref_or_null",
    "access_binding_hash_or_null",
    "masking_posture_fingerprint",
    "route_identity_ref",
    "canonical_object_ref",
    "shell_family",
    "schema_compatibility_ref",
    "projection_guard_ref",
    "resume_binding_ref_or_null",
    "restoration_anchor_ref_or_null",
    "preview_subject_ref_or_null",
    "compatibility_dimensions",
    "purge_trigger_reason_codes",
    "regulated_local_artifact_classes",
    "first_paint_policy",
    "purge_execution_policy",
    "cursor_lineage_policy",
    "restoration_reuse_policy",
    "mutation_gate_policy",
    "local_artifact_purge_policy"
  ],
  "properties": {
    "contract_version": {
      "const": "NATIVE_CACHE_HYDRATION_V1"
    },
    "hydration_scope_class": {
      "type": "string",
      "enum": [
        "EXPERIENCE_CURSOR",
        "WORKSPACE_CURSOR",
        "NATIVE_PRIMARY_SCENE",
        "NATIVE_SECONDARY_WINDOW"
      ]
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "principal_class": {
      "type": "string",
      "minLength": 1
    },
    "session_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "session_lineage_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "access_binding_hash_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "masking_posture_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "route_identity_ref": {
      "type": "string",
      "minLength": 1
    },
    "canonical_object_ref": {
      "type": "string",
      "minLength": 1
    },
    "shell_family": {
      "type": "string",
      "minLength": 1
    },
    "schema_compatibility_ref": {
      "type": "string",
      "minLength": 1
    },
    "projection_guard_ref": {
      "type": "string",
      "minLength": 1
    },
    "resume_binding_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "restoration_anchor_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "preview_subject_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "compatibility_dimensions": {
      "type": "array",
      "prefixItems": [
        {
          "const": "TENANT_ID"
        },
        {
          "const": "PRINCIPAL_CLASS"
        },
        {
          "const": "SESSION_BINDING"
        },
        {
          "const": "SESSION_LINEAGE"
        },
        {
          "const": "ACCESS_BINDING_OR_NULL"
        },
        {
          "const": "MASKING_POSTURE"
        },
        {
          "const": "ROUTE_IDENTITY"
        },
        {
          "const": "CANONICAL_OBJECT"
        },
        {
          "const": "SUPPORTED_CONTRACT_WINDOW"
        },
        {
          "const": "PROJECTION_GUARD"
        }
      ],
      "items": false,
      "minItems": 10,
      "maxItems": 10
    },
    "purge_trigger_reason_codes": {
      "type": "array",
      "prefixItems": [
        {
          "const": "TENANT_SWITCH"
        },
        {
          "const": "PRINCIPAL_CLASS_CHANGE"
        },
        {
          "const": "PRIVILEGE_DOWNGRADE"
        },
        {
          "const": "SESSION_REVOKED"
        },
        {
          "const": "SESSION_BINDING_CHANGE"
        },
        {
          "const": "ACCESS_BINDING_CHANGE"
        },
        {
          "const": "MASKING_CHANGE"
        },
        {
          "const": "SCHEMA_INCOMPATIBLE"
        },
        {
          "const": "ROUTE_OR_OBJECT_DRIFT"
        }
      ],
      "items": false,
      "minItems": 9,
      "maxItems": 9
    },
    "regulated_local_artifact_classes": {
      "type": "array",
      "prefixItems": [
        {
          "const": "STRUCTURED_CACHE"
        },
        {
          "const": "RESUME_METADATA"
        },
        {
          "const": "SCENE_RESTORATION_PAYLOAD"
        },
        {
          "const": "NSUSERACTIVITY"
        },
        {
          "const": "PREVIEW_CACHE"
        },
        {
          "const": "TEMP_EXPORT_FILE"
        },
        {
          "const": "LOCAL_SEARCH_INDEX"
        }
      ],
      "items": false,
      "minItems": 7,
      "maxItems": 7
    },
    "first_paint_policy": {
      "const": "VERIFY_COMPATIBILITY_BEFORE_RENDER_OR_RESTORE"
    },
    "purge_execution_policy": {
      "const": "SELECTIVE_IMMEDIATE_PURGE_ON_SCOPE_SESSION_MASKING_OR_SCHEMA_DRIFT"
    },
    "cursor_lineage_policy": {
      "const": "RESUME_AND_DELTA_REUSE_REQUIRE_EXACT_LIVE_CURSOR_LINEAGE"
    },
    "restoration_reuse_policy": {
      "const": "SAME_OBJECT_SAME_SHELL_ONLY_WHEN_FULL_LEGALITY_ENVELOPE_MATCHES"
    },
    "mutation_gate_policy": {
      "const": "NO_MUTATION_OR_FILING_AFTER_CACHE_ONLY_RESTORE_OR_CONTEXT_DRIFT"
    },
    "local_artifact_purge_policy": {
      "const": "PURGE_NSUSERACTIVITY_PREVIEW_EXPORT_AND_INDEX_WITH_CACHE_STATE"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "hydration_scope_class": {
            "enum": [
              "EXPERIENCE_CURSOR",
              "WORKSPACE_CURSOR"
            ]
          }
        },
        "required": [
          "hydration_scope_class"
        ]
      },
      "then": {
        "properties": {
          "restoration_anchor_ref_or_null": {
            "type": "null"
          },
          "preview_subject_ref_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "hydration_scope_class": {
            "const": "NATIVE_PRIMARY_SCENE"
          }
        },
        "required": [
          "hydration_scope_class"
        ]
      },
      "then": {
        "properties": {
          "restoration_anchor_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "preview_subject_ref_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "hydration_scope_class": {
            "const": "NATIVE_SECONDARY_WINDOW"
          }
        },
        "required": [
          "hydration_scope_class"
        ]
      },
      "then": {
        "properties": {
          "restoration_anchor_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "preview_subject_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
