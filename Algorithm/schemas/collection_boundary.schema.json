{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/collection_boundary.schema.json",
  "title": "CollectionBoundary",
  "type": "object",
  "required": [
    "collection_boundary_id",
    "manifest_id",
    "artifact_type",
    "source_window_id",
    "read_cutoff_at",
    "connector_profile_ref",
    "connector_build_id",
    "source_boundaries",
    "contract"
  ],
  "properties": {
    "collection_boundary_id": { "type": "string" },
    "manifest_id": { "type": "string" },
    "artifact_type": { "const": "CollectionBoundary" },
    "source_window_id": { "type": "string" },
    "read_cutoff_at": {
      "type": "string",
      "format": "date-time"
    },
    "connector_profile_ref": { "type": "string" },
    "connector_build_id": { "type": "string" },
    "source_boundaries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sourceBoundary" }
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "$defs": {
    "sourceBoundary": {
      "type": "object",
      "required": [
        "source_domain",
        "provider_environment_ref",
        "provider_api_version",
        "provider_schema_version",
        "cursor_checkpoint_ref",
        "revision_ref",
        "request_audit_refs",
        "completeness_expectation_ref",
        "late_data_policy_ref"
      ],
      "properties": {
        "source_domain": { "type": "string" },
        "provider_environment_ref": { "type": "string" },
        "provider_api_version": { "type": "string" },
        "provider_schema_version": { "type": "string" },
        "cursor_checkpoint_ref": { "type": "string" },
        "revision_ref": { "type": "string" },
        "request_audit_refs": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "page_request_audit_refs": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "completeness_expectation_ref": { "type": "string" },
        "late_data_policy_ref": {
          "type": "string",
          "enum": ["EXCLUDE_LATE", "SPAWN_CHILD_MANIFEST", "REVIEW_IF_LATE"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
