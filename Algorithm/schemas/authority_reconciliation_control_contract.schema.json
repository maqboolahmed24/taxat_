          "reconciliation_cadence_seconds_or_null": {
            "type": "null"
          },
          "attempts_remaining_count": {
            "const": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reconciliation_method": {
            "enum": [
              "READ_AFTER_WRITE",
              "POLL_STATUS",
              "POLL_OBLIGATIONS"
            ]
          }
        },
        "required": [
          "reconciliation_method"
        ]
      },
      "then": {
        "properties": {
          "max_auto_reconciliation_attempts": {
            "minimum": 1
