{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/authority_reconciliation_control_contract.schema.json",
  "title": "AuthorityReconciliationControlContract",
  "description": "Durable reconciliation-control contract for one authority interaction lineage. This schema freezes the persisted budget, resend posture, unresolved authority class, escalation handoff packet, and replay/resume policy so live workers, restore/replay flows, and downstream legal-state artifacts never recompute retry economics from transient runtime memory.",
  "type": "object",
  "required": [
    "contract_version",
    "binding_scope_class",
    "control_contract_hash",
    "interaction_ref_or_null",
    "authority_operation_profile_ref_or_null",
    "provider_environment_or_null",
    "operation_family_or_null",
    "duplicate_meaning_key_or_null",
    "authority_truth_state",
    "submission_lifecycle_state_or_null",
    "reconciliation_method",
    "max_auto_reconciliation_attempts",
    "reconciliation_attempt_count",
    "attempts_remaining_count",
    "reconciliation_cadence_seconds_or_null",
    "reconciliation_budget_state",
    "reconciliation_deadline_at_or_null",
    "next_reconciliation_at_or_null",
    "unresolved_authority_posture",
    "unresolved_reason_codes",
    "resend_legality_state",
    "resend_control_reason_codes",
    "replay_resume_policy",
    "blind_resend_policy",
    "escalation_state",
    "escalation_owner_ref_or_null",
    "escalation_workflow_item_ref_or_null",
    "escalation_reason_codes",
    "escalation_evidence_refs",
    "escalation_due_at_or_null",
    "last_budget_event_at",
    "outcome_class_for_analytics"
  ],
  "properties": {
    "contract_version": {
      "const": "AUTHORITY_RECONCILIATION_CONTROL_V1"
    },
    "binding_scope_class": {
      "type": "string",
      "enum": [
        "AUTHORITY_INTERACTION_RECORD",
        "SUBMISSION_RECORD",
        "OBLIGATION_MIRROR"
      ]
    },
    "control_contract_hash": {
      "type": "string",
      "minLength": 1
    },
    "interaction_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "authority_operation_profile_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "provider_environment_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "operation_family_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "duplicate_meaning_key_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "authority_truth_state": {
      "type": "string",
      "enum": [
        "NOT_APPLICABLE",
        "NOT_REQUESTED",
        "UNKNOWN",
        "PENDING_ACK",
        "PARTIAL_ACK",
        "CONFIRMED",
        "REJECTED",
        "OUT_OF_BAND"
      ]
    },
    "submission_lifecycle_state_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "INTENT_RECORDED",
        "TRANSMIT_PENDING",
        "TRANSMITTED",
        "PENDING_ACK",
        "CONFIRMED",
        "REJECTED",
        "UNKNOWN",
        "OUT_OF_BAND",
        "SUPERSEDED",
        null
      ]
    },
    "reconciliation_method": {
      "type": "string",
      "enum": [
        "NONE",
        "READ_AFTER_WRITE",
        "POLL_STATUS",
        "POLL_OBLIGATIONS",
        "MANUAL_ONLY"
      ]
    },
    "max_auto_reconciliation_attempts": {
      "type": "integer",
      "minimum": 0
    },
    "reconciliation_attempt_count": {
      "type": "integer",
      "minimum": 0
    },
    "attempts_remaining_count": {
      "type": "integer",
      "minimum": 0
    },
    "reconciliation_cadence_seconds_or_null": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "reconciliation_budget_state": {
      "type": "string",
      "enum": [
        "NOT_OPENED",
        "ACTIVE",
        "EXHAUSTED",
        "ESCALATED",
        "CLOSED"
      ]
    },
    "reconciliation_deadline_at_or_null": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "next_reconciliation_at_or_null": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "unresolved_authority_posture": {
      "type": "string",
      "enum": [
        "NO_UNRESOLVED_AUTHORITY",
        "PENDING_ACK_UNRESOLVED",
        "UNKNOWN_UNRESOLVED",
        "CONTRADICTORY_EVIDENCE",
        "OUT_OF_BAND_CONFLICT",
        "MANUAL_REVIEW_REQUIRED"
      ]
    },
    "unresolved_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "resend_legality_state": {
      "type": "string",
      "enum": [
        "UNASSESSED",
        "IDEMPOTENT_RECOVERY_ONLY",
        "FOLLOW_UP_READ_ONLY",
        "BLOCKED_BY_RECONCILIATION",
        "BLOCKED_BY_ESCALATION",
        "CLOSED_NO_RESEND"
      ]
    },
    "resend_control_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "IN_FLIGHT_REQUEST_LINEAGE_EXISTS",
          "QUEUE_REBUILD_REQUIRES_IDEMPOTENT_RECOVERY",
          "PENDING_OR_UNKNOWN_REQUIRES_RECONCILIATION",
          "TIMEOUT_PLACEHOLDER_REQUIRES_RECONCILIATION",
          "AUTO_RECONCILIATION_BUDGET_EXHAUSTED",
          "RECONCILIATION_DEADLINE_EXPIRED",
          "CONTRADICTORY_AUTHORITY_EVIDENCE",
          "OUT_OF_BAND_AUTHORITY_STATE_PRESENT",
          "DUPLICATE_BUCKET_OCCUPIED",
          "STRONGER_EXTERNAL_TRUTH_PRESENT",
          "TERMINAL_AUTHORITY_STATE_RECORDED",
          "INTERACTION_FINALIZED_NO_RESEND"
        ]
      },
      "default": [],
      "uniqueItems": true
    },
    "replay_resume_policy": {
      "const": "RESUME_PERSISTED_BUDGET_ONLY"
    },
    "blind_resend_policy": {
      "const": "BLOCK_ON_AMBIGUITY_OR_EXHAUSTION"
    },
    "escalation_state": {
      "type": "string",
      "enum": [
        "NOT_REQUIRED",
        "READY_FOR_ESCALATION",
        "ESCALATED"
