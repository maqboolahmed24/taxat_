      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "escalation_workflow_item_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "escalation_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "escalation_evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "escalation_due_at_or_null": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "last_budget_event_at": {
      "type": "string",
      "format": "date-time"
    },
    "outcome_class_for_analytics": {
      "type": "string",
      "enum": [
        "NO_RESPONSE_YET",
        "PENDING_ACK",
        "UNKNOWN",
        "AMBIGUOUS",
        "OUT_OF_BAND",
        "CONFIRMED",
        "REJECTED",
        "ESCALATED"
      ]
    }
