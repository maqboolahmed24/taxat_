          "resend_control_reason_codes": {
            "minItems": 1
          },
          "escalation_state": {
            "const": "NOT_REQUIRED"
          },
          "escalation_owner_ref_or_null": {
            "type": "null"
          },
          "escalation_workflow_item_ref_or_null": {
            "type": "null"
          },
          "escalation_reason_codes": {
            "maxItems": 0
          },
          "escalation_evidence_refs": {
            "maxItems": 0
          },
          "escalation_due_at_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reconciliation_budget_state": {
            "const": "EXHAUSTED"
          }
