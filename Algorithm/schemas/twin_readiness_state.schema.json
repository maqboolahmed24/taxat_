{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/twin_readiness_state.schema.json",
  "title": "TwinReadinessState",
  "description": "Twin Lens readiness overlay contract. This schema freezes filing-readiness posture together with twin-specific actionability, authority posture, baseline posture, and mismatch buckets so the compare surface is decision-useful without client-local inference.",
  "type": "object",
  "required": [
    "artifact_type",
    "twin_readiness_id",
    "twin_id",
    "execution_mode_boundary_contract",
    "filing_readiness",
    "twin_readiness_class",
    "safe_action_state",
    "decision_usefulness",
    "trust_summary_ref",
    "decision_bundle_ref",
    "gate_decision_refs",
    "authority_posture",
    "baseline_state",
    "usefulness_cap_reason_codes",
    "blocking_reason_codes",
    "review_reason_codes",
    "unresolved_conflict_refs",
    "blocking_mismatch_refs",
    "review_mismatch_refs",
    "waiting_mismatch_refs",
    "reconciliation_mismatch_refs",
    "contradictory_mismatch_refs",
    "non_comparable_mismatch_refs",
    "out_of_band_mismatch_refs",
    "no_safe_action_reason_codes",
    "last_evaluated_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "TwinReadinessState"
    },
    "twin_readiness_id": {
      "type": "string",
      "minLength": 1
    },
    "twin_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode_boundary_contract": {
      "$ref": "https://taxat.dev/schemas/execution_mode_boundary_contract.schema.json"
    },
    "filing_readiness": {
      "type": "string",
      "enum": [
        "NOT_READY",
        "READY_REVIEW",
        "READY_TO_SUBMIT"
      ]
    },
    "twin_readiness_class": {
      "type": "string",
      "enum": [
        "READY",
        "REVIEW_REQUIRED",
        "WAITING_ON_AUTHORITY",
        "RECONCILIATION_REQUIRED",
        "BLOCKED"
      ]
    },
    "safe_action_state": {
      "type": "string",
      "enum": [
        "SAFE_TO_ACT",
        "REVIEW_BEFORE_ACT",
        "WAIT_ONLY",
        "REFRESH_REQUIRED",
        "NO_SAFE_ACTION"
      ]
    },
    "decision_usefulness": {
      "type": "string",
      "enum": [
        "HIGH",
        "MEDIUM",
        "LOW",
        "NONE"
      ]
    },
    "trust_summary_ref": {
      "type": "string",
      "minLength": 1
    },
    "decision_bundle_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "gate_decision_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "authority_posture": {
      "type": "string",
      "enum": [
        "NOT_REQUESTED",
        "CURRENT_MATCHED",
        "CURRENT_MISMATCHED",
        "PENDING",
        "PARTIAL",
        "STALE",
        "UNKNOWN",
        "OUT_OF_BAND"
      ]
    },
    "baseline_state": {
      "type": "string",
      "enum": [
        "NOT_APPLICABLE",
        "PROVED",
        "PARTIAL",
        "MISSING",
        "STALE"
      ]
    },
    "usefulness_cap_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "blocking_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "review_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "unresolved_conflict_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "blocking_mismatch_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "review_mismatch_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "waiting_mismatch_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "reconciliation_mismatch_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "contradictory_mismatch_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "non_comparable_mismatch_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "out_of_band_mismatch_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "no_safe_action_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "last_evaluated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "twin_readiness_class": {
            "const": "READY"
          }
        },
        "required": [
          "twin_readiness_class"
        ]
      },
      "then": {
        "properties": {
          "filing_readiness": {
            "const": "READY_TO_SUBMIT"
          },
          "safe_action_state": {
            "const": "SAFE_TO_ACT"
          },
          "decision_usefulness": {
            "const": "HIGH"
          },
          "authority_posture": {
            "enum": [
              "NOT_REQUESTED",
              "CURRENT_MATCHED"
            ]
          },
          "baseline_state": {
            "enum": [
              "NOT_APPLICABLE",
              "PROVED"
            ]
          },
          "usefulness_cap_reason_codes": {
            "maxItems": 0
          },
          "decision_bundle_ref": {
            "type": "string",
            "minLength": 1
          },
          "gate_decision_refs": {
            "minItems": 1
          },
          "blocking_reason_codes": {
            "maxItems": 0
          },
          "review_reason_codes": {
            "maxItems": 0
          },
          "unresolved_conflict_refs": {
            "maxItems": 0
          },
          "blocking_mismatch_refs": {
            "maxItems": 0
          },
          "review_mismatch_refs": {
            "maxItems": 0
          },
          "waiting_mismatch_refs": {
            "maxItems": 0
          },
          "reconciliation_mismatch_refs": {
            "maxItems": 0
          },
          "contradictory_mismatch_refs": {
            "maxItems": 0
          },
          "non_comparable_mismatch_refs": {
            "maxItems": 0
          },
          "out_of_band_mismatch_refs": {
            "maxItems": 0
          },
          "no_safe_action_reason_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "twin_readiness_class": {
            "const": "REVIEW_REQUIRED"
          }
        },
        "required": [
          "twin_readiness_class"
        ]
      },
      "then": {
        "properties": {
          "safe_action_state": {
            "enum": [
              "REVIEW_BEFORE_ACT",
              "REFRESH_REQUIRED"
            ]
          }
        },
        "anyOf": [
          {
            "properties": {
              "review_reason_codes": {
                "minItems": 1
              }
            }
          },
          {
            "properties": {
              "review_mismatch_refs": {
                "minItems": 1
              }
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "safe_action_state": {
            "const": "SAFE_TO_ACT"
          }
        },
        "required": [
          "safe_action_state"
        ]
      },
      "then": {
        "properties": {
          "twin_readiness_class": {
            "const": "READY"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision_usefulness": {
            "const": "HIGH"
          }
        },
        "required": [
          "decision_usefulness"
        ]
      },
      "then": {
        "properties": {
          "twin_readiness_class": {
            "const": "READY"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "twin_readiness_class": {
            "const": "WAITING_ON_AUTHORITY"
          }
        },
        "required": [
          "twin_readiness_class"
        ]
      },
      "then": {
        "properties": {
          "safe_action_state": {
            "const": "WAIT_ONLY"
          },
          "waiting_mismatch_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "twin_readiness_class": {
            "const": "RECONCILIATION_REQUIRED"
          }
        },
        "required": [
          "twin_readiness_class"
        ]
      },
      "then": {
        "properties": {
          "safe_action_state": {
            "enum": [
              "REVIEW_BEFORE_ACT",
              "NO_SAFE_ACTION"
            ]
          },
          "reconciliation_mismatch_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "safe_action_state": {
            "const": "WAIT_ONLY"
          }
        },
        "required": [
          "safe_action_state"
        ]
      },
      "then": {
        "properties": {
          "twin_readiness_class": {
            "const": "WAITING_ON_AUTHORITY"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "waiting_mismatch_refs": {
            "minItems": 1
          }
        },
        "required": [
          "waiting_mismatch_refs"
        ]
      },
      "then": {
        "properties": {
          "twin_readiness_class": {
            "const": "WAITING_ON_AUTHORITY"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "non_comparable_mismatch_refs": {
            "minItems": 1
          }
        },
        "required": [
          "non_comparable_mismatch_refs"
        ]
      },
      "then": {
        "properties": {
          "safe_action_state": {
            "enum": [
              "REFRESH_REQUIRED",
              "NO_SAFE_ACTION"
            ]
          },
          "decision_usefulness": {
            "enum": [
              "LOW",
              "NONE"
            ]
          },
          "usefulness_cap_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "out_of_band_mismatch_refs": {
            "minItems": 1
          }
        },
        "required": [
          "out_of_band_mismatch_refs"
        ]
      },
      "then": {
        "properties": {
          "twin_readiness_class": {
            "enum": [
              "RECONCILIATION_REQUIRED",
              "BLOCKED"
            ]
          },
          "decision_usefulness": {
            "enum": [
              "LOW",
              "NONE"
            ]
          },
          "usefulness_cap_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "contradictory_mismatch_refs": {
            "minItems": 1
          }
        },
        "required": [
          "contradictory_mismatch_refs"
        ]
      },
      "then": {
        "properties": {
          "twin_readiness_class": {
            "enum": [
              "RECONCILIATION_REQUIRED",
              "BLOCKED"
            ]
          },
          "safe_action_state": {
            "enum": [
              "REVIEW_BEFORE_ACT",
              "NO_SAFE_ACTION"
            ]
          },
          "decision_usefulness": {
            "enum": [
              "LOW",
              "NONE"
            ]
          },
          "usefulness_cap_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "twin_readiness_class": {
            "const": "BLOCKED"
          }
        },
        "required": [
          "twin_readiness_class"
        ]
      },
      "then": {
        "properties": {
          "safe_action_state": {
            "const": "NO_SAFE_ACTION"
          },
          "decision_usefulness": {
            "enum": [
              "LOW",
              "NONE"
            ]
          }
        },
        "anyOf": [
          {
            "properties": {
              "filing_readiness": {
                "const": "NOT_READY"
              }
            }
          },
          {
            "properties": {
              "blocking_reason_codes": {
                "minItems": 1
              }
            }
          },
          {
            "properties": {
              "blocking_mismatch_refs": {
                "minItems": 1
              }
            }
          },
          {
            "properties": {
              "baseline_state": {
                "const": "MISSING"
              }
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "authority_posture": {
            "enum": [
              "PARTIAL",
              "STALE",
              "UNKNOWN",
              "OUT_OF_BAND"
            ]
          }
        },
        "required": [
          "authority_posture"
        ]
      },
      "then": {
        "properties": {
          "decision_usefulness": {
            "enum": [
              "LOW",
              "NONE"
            ]
          },
          "usefulness_cap_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "safe_action_state": {
            "const": "NO_SAFE_ACTION"
          }
        },
        "required": [
          "safe_action_state"
        ]
      },
      "then": {
        "properties": {
          "no_safe_action_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "usefulness_cap_reason_codes": {
            "minItems": 1
          }
        },
        "required": [
          "usefulness_cap_reason_codes"
        ]
      },
      "then": {
        "properties": {
          "decision_usefulness": {
            "enum": [
              "LOW",
              "NONE"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reconciliation_mismatch_refs": {
            "minItems": 1
          }
        },
        "required": [
          "reconciliation_mismatch_refs"
        ]
      },
      "then": {
        "properties": {
          "twin_readiness_class": {
            "const": "RECONCILIATION_REQUIRED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "out_of_band_mismatch_refs": {
            "minItems": 1
          }
        },
        "required": [
          "out_of_band_mismatch_refs"
        ]
      },
      "then": {
        "properties": {
          "twin_readiness_class": {
            "enum": [
              "RECONCILIATION_REQUIRED",
              "BLOCKED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "contradictory_mismatch_refs": {
            "minItems": 1
          }
        },
        "required": [
          "contradictory_mismatch_refs"
        ]
      },
      "then": {
        "properties": {
          "twin_readiness_class": {
            "enum": [
              "RECONCILIATION_REQUIRED",
              "BLOCKED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "blocking_reason_codes": {
            "minItems": 1
          }
        },
        "required": [
          "blocking_reason_codes"
        ]
      },
      "then": {
        "properties": {
          "twin_readiness_class": {
            "const": "BLOCKED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "blocking_mismatch_refs": {
            "minItems": 1
          }
        },
        "required": [
          "blocking_mismatch_refs"
        ]
      },
      "then": {
        "properties": {
          "twin_readiness_class": {
            "const": "BLOCKED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "safe_action_state": {
            "not": {
              "const": "NO_SAFE_ACTION"
            }
          }
        },
        "required": [
          "safe_action_state"
        ]
      },
      "then": {
        "properties": {
          "no_safe_action_reason_codes": {
            "maxItems": 0
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
