{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/amendment_eligibility_contract.schema.json",
  "title": "AmendmentEligibilityContract",
  "description": "Deterministic amendment trigger, eligibility, and readiness-reuse contract. This schema freezes whether amendment-aware workflow was triggered, whether live amendment is legally eligible now, and whether any persisted intent-to-amend readiness may still be reused, so trigger pressure, legal eligibility, and stale readiness cannot collapse into one coarse state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "eligibility_profile_code",
    "execution_mode_boundary_contract",
    "trigger_state",
    "eligibility_state",
    "window_state_or_null",
    "readiness_reuse_state",
    "baseline_frozen_hash_or_null",
    "baseline_selection_contract_hash_or_null",
    "baseline_progression_ceiling_or_null",
    "baseline_limitation_reason_codes",
    "retroactive_impact_hash_or_null",
    "amendment_window_evaluation_hash_or_null",
    "authority_operation_profile_ref_or_null",
    "readiness_context_ref_or_null",
    "trigger_reason_codes",
    "eligibility_reason_codes",
    "readiness_invalidation_reason_codes"
  ],
  "properties": {
    "eligibility_profile_code": {
      "const": "AMENDMENT_ELIGIBILITY_V1"
    },
    "execution_mode_boundary_contract": {
      "$ref": "https://taxat.dev/schemas/execution_mode_boundary_contract.schema.json"
    },
    "trigger_state": {
      "type": "string",
      "enum": [
        "NOT_TRIGGERED",
        "TRIGGERED"
      ]
    },
    "eligibility_state": {
      "type": "string",
      "enum": [
        "NOT_EVALUATED",
        "ELIGIBLE_NOW",
        "REVIEW_ONLY",
        "RECONCILE_FIRST",
        "WINDOW_CLOSED",
        "UNPROVEN"
      ]
    },
    "window_state_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "OPEN",
        "CLOSED",
        "UNPROVEN",
        null
      ]
    },
    "readiness_reuse_state": {
      "type": "string",
      "enum": [
        "NOT_APPLICABLE",
        "FRESH",
        "STALE"
      ]
    },
    "baseline_frozen_hash_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "baseline_selection_contract_hash_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "baseline_progression_ceiling_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "ELIGIBLE_NOW_ALLOWED",
        "REVIEW_ONLY",
        "RECONCILE_FIRST",
        null
      ]
    },
    "baseline_limitation_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "retroactive_impact_hash_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "amendment_window_evaluation_hash_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "authority_operation_profile_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "readiness_context_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "trigger_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "eligibility_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "readiness_invalidation_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "trigger_state": {
            "const": "NOT_TRIGGERED"
          }
        },
        "required": [
          "trigger_state"
        ]
      },
      "then": {
        "properties": {
          "eligibility_state": {
            "const": "NOT_EVALUATED"
          },
          "window_state_or_null": {
            "type": "null"
          },
          "readiness_reuse_state": {
            "const": "NOT_APPLICABLE"
          },
          "baseline_frozen_hash_or_null": {
            "type": "null"
          },
          "baseline_selection_contract_hash_or_null": {
            "type": "null"
          },
          "baseline_progression_ceiling_or_null": {
            "type": "null"
          },
          "baseline_limitation_reason_codes": {
            "maxItems": 0
          },
          "retroactive_impact_hash_or_null": {
            "type": "null"
          },
          "amendment_window_evaluation_hash_or_null": {
            "type": "null"
          },
          "authority_operation_profile_ref_or_null": {
            "type": "null"
          },
          "readiness_context_ref_or_null": {
            "type": "null"
          },
          "trigger_reason_codes": {
            "maxItems": 0
          },
          "eligibility_reason_codes": {
            "maxItems": 0
          },
          "readiness_invalidation_reason_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "trigger_state": {
            "const": "TRIGGERED"
          }
        },
        "required": [
          "trigger_state"
        ]
      },
      "then": {
        "properties": {
          "trigger_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "eligibility_state": {
            "enum": [
              "ELIGIBLE_NOW",
              "REVIEW_ONLY",
              "RECONCILE_FIRST",
              "WINDOW_CLOSED",
              "UNPROVEN"
            ]
          }
        },
        "required": [
          "eligibility_state"
        ]
      },
      "then": {
        "properties": {
          "eligibility_reason_codes": {
            "minItems": 1
          },
          "baseline_selection_contract_hash_or_null": {
            "type": "string",
            "minLength": 1
          },
          "baseline_progression_ceiling_or_null": {
            "enum": [
              "ELIGIBLE_NOW_ALLOWED",
              "REVIEW_ONLY",
              "RECONCILE_FIRST"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "baseline_progression_ceiling_or_null": {
            "enum": [
              "REVIEW_ONLY",
              "RECONCILE_FIRST"
            ]
          }
        },
        "required": [
          "baseline_progression_ceiling_or_null"
        ]
      },
      "then": {
        "properties": {
          "baseline_limitation_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "baseline_progression_ceiling_or_null": {
            "const": "ELIGIBLE_NOW_ALLOWED"
          }
        },
        "required": [
          "baseline_progression_ceiling_or_null"
        ]
      },
      "then": {
        "properties": {
          "baseline_limitation_reason_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "eligibility_state": {
            "const": "ELIGIBLE_NOW"
          }
        },
        "required": [
          "eligibility_state"
        ]
      },
      "then": {
        "properties": {
          "window_state_or_null": {
            "const": "OPEN"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "eligibility_state": {
            "const": "WINDOW_CLOSED"
          }
        },
        "required": [
          "eligibility_state"
        ]
      },
      "then": {
        "properties": {
          "window_state_or_null": {
            "const": "CLOSED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "eligibility_state": {
            "const": "UNPROVEN"
          }
        },
        "required": [
          "eligibility_state"
        ]
      },
      "then": {
        "properties": {
          "window_state_or_null": {
            "const": "UNPROVEN"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "readiness_reuse_state": {
            "const": "FRESH"
          }
        },
        "required": [
          "readiness_reuse_state"
        ]
      },
      "then": {
        "properties": {
          "baseline_frozen_hash_or_null": {
            "type": "string",
            "minLength": 1
          },
          "retroactive_impact_hash_or_null": {
            "type": "string",
            "minLength": 1
          },
          "amendment_window_evaluation_hash_or_null": {
            "type": "string",
            "minLength": 1
          },
          "authority_operation_profile_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "readiness_context_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "readiness_invalidation_reason_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "readiness_reuse_state": {
            "const": "STALE"
          }
        },
        "required": [
          "readiness_reuse_state"
        ]
      },
      "then": {
        "properties": {
          "baseline_frozen_hash_or_null": {
            "type": "string",
            "minLength": 1
          },
          "retroactive_impact_hash_or_null": {
            "type": "string",
            "minLength": 1
          },
          "amendment_window_evaluation_hash_or_null": {
            "type": "string",
            "minLength": 1
          },
          "authority_operation_profile_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "readiness_context_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "readiness_invalidation_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "readiness_reuse_state": {
            "const": "NOT_APPLICABLE"
          }
        },
        "required": [
          "readiness_reuse_state"
        ]
      },
      "then": {
        "properties": {
          "readiness_invalidation_reason_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "readiness_invalidation_reason_codes": {
            "minItems": 1
          }
        },
        "required": [
          "readiness_invalidation_reason_codes"
        ]
      },
      "then": {
        "properties": {
          "readiness_reuse_state": {
            "const": "STALE"
          }
        }
      }
    }
  ]
}
