{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/erasure_proof.schema.json",
  "title": "ErasureProof",
  "description": "Append-only proof artifact for completed erasure or pseudonymisation work. This contract freezes the minimum trail needed to prove that the request, target, and execution outcome were durably recorded.",
  "type": "object",
  "required": [
    "erasure_proof_id",
    "manifest_id",
    "target_ref",
    "erasure_action_ref",
    "proof_hash",
    "created_at"
  ],
  "properties": {
    "erasure_proof_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "target_ref": {
      "type": "string",
      "minLength": 1
    },
    "erasure_action_ref": {
      "type": "string",
      "minLength": 1
    },
    "proof_hash": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
