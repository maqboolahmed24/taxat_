{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/input_freeze.schema.json",
  "title": "InputFreeze",
  "type": "object",
  "required": [
    "input_freeze_id",
    "manifest_id",
    "artifact_type",
    "source_plan_ref",
    "collection_boundary_ref",
    "source_window_ref",
    "read_cutoff_at",
    "source_record_refs",
    "evidence_item_refs",
    "candidate_fact_refs",
    "canonical_fact_refs",
    "conflict_refs",
    "late_data_policy_bindings",
    "normalization_context_ref",
    "normalization_context_hash",
    "artifact_contract_refs",
    "artifact_contract_hash",
    "input_set_hash",
    "contract"
  ],
  "properties": {
    "input_freeze_id": {
      "type": "string"
    },
    "manifest_id": {
      "type": "string"
    },
    "artifact_type": {
      "const": "InputFreeze"
    },
    "source_plan_ref": {
      "type": "string"
    },
    "collection_boundary_ref": {
      "type": "string"
    },
    "input_policy_ref": {
      "type": ["string", "null"]
    },
    "source_window_ref": {
      "type": "string"
    },
    "read_cutoff_at": {
      "type": "string",
      "format": "date-time"
    },
    "provider_environment_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "uniqueItems": true
    },
    "provider_api_versions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "uniqueItems": true
    },
    "provider_schema_versions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "uniqueItems": true
    },
    "connector_profile_ref": {
      "type": ["string", "null"]
    },
    "connector_build_id": {
      "type": ["string", "null"]
    },
    "cursor_checkpoint_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "uniqueItems": true
    },
    "request_audit_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "uniqueItems": true
    },
    "late_data_policy_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/lateDataPolicyBinding"
      },
      "uniqueItems": true
    },
    "source_record_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "evidence_item_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "candidate_fact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "canonical_fact_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "conflict_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "exclusion_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "uniqueItems": true
    },
    "missing_source_declarations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "uniqueItems": true
    },
    "stale_source_declarations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "uniqueItems": true
    },
    "normalization_context_ref": {
      "type": "string"
    },
    "normalization_context_hash": {
      "type": "string"
    },
    "artifact_contract_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "artifact_contract_hash": {
      "type": "string"
    },
    "input_set_hash": {
      "type": "string"
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "$defs": {
    "lateDataPolicyBinding": {
      "type": "object",
      "required": [
        "source_domain",
        "late_data_policy_ref"
      ],
      "properties": {
        "source_domain": {
          "type": "string"
        },
        "source_class": {
          "type": ["string", "null"]
        },
        "partition_scope_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "uniqueItems": true
        },
        "late_data_policy_ref": {
          "type": "string",
          "enum": [
            "EXCLUDE_LATE",
            "SPAWN_CHILD_MANIFEST",
            "REVIEW_IF_LATE"
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
