{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/input_freeze.schema.json",
  "title": "InputFreeze",
  "type": "object",
  "required": [
    "input_freeze_id",
    "manifest_id",
    "artifact_type",
    "source_plan_ref",
    "source_plan_hash",
    "collection_boundary_ref",
    "collection_boundary_hash",
    "input_policy_ref",
    "source_window_ref",
    "source_window_hash",
    "read_cutoff_at",
    "provider_environment_refs",
    "provider_api_versions",
    "provider_schema_versions",
    "connector_profile_ref",
    "connector_build_id",
    "cursor_checkpoint_refs",
    "request_audit_refs",
    "source_record_refs",
    "evidence_item_refs",
    "candidate_fact_refs",
    "canonical_fact_refs",
    "conflict_refs",
    "open_conflict_count",
    "blocking_conflict_count",
    "resolution_frontier",
    "dominant_blocking_class",
    "late_data_policy_bindings",
    "exclusion_refs",
    "no_data_confirmed_declarations",
    "missing_source_declarations",
    "stale_source_declarations",
    "source_domain_postures",
    "normalization_context_ref",
    "normalization_context_hash",
    "artifact_contract_refs",
    "artifact_contract_hash",
    "input_set_hash",
    "input_consumption_mode",
    "late_data_adoption_policy",
    "contract"
  ],
  "properties": {
    "input_freeze_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "InputFreeze"
    },
    "source_plan_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_plan_hash": {
      "type": "string",
      "minLength": 1
    },
    "collection_boundary_ref": {
      "type": "string",
      "minLength": 1
    },
    "collection_boundary_hash": {
      "type": "string",
      "minLength": 1
    },
    "input_policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_window_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_window_hash": {
      "type": "string",
      "minLength": 1
    },
    "read_cutoff_at": {
      "type": "string",
      "format": "date-time"
    },
    "provider_environment_refs": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "default": [],
        "uniqueItems": true
    },
    "provider_api_versions": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "default": [],
        "uniqueItems": true
    },
    "provider_schema_versions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "connector_profile_ref": {
      "type": "string",
      "minLength": 1
    },
    "connector_build_id": {
      "type": "string",
      "minLength": 1
    },
    "cursor_checkpoint_refs": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "default": [],
        "uniqueItems": true
    },
    "request_audit_refs": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "default": [],
        "uniqueItems": true
    },
    "late_data_policy_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./late_data_policy_binding.schema.json"
      },
      "uniqueItems": true
    },
    "source_record_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "evidence_item_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "candidate_fact_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "canonical_fact_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "conflict_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "open_conflict_count": {
      "type": "integer",
      "minimum": 0
    },
    "blocking_conflict_count": {
      "type": "integer",
      "minimum": 0
    },
    "resolution_frontier": {
      "type": "string",
      "enum": [
        "CLEAR",
        "MONITORING_ONLY",
        "BLOCKING_PRESENT"
      ]
    },
    "dominant_blocking_class": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "BLOCKS_AUTOMATION",
        "BLOCKS_REVIEW_PROGRESS",
        "BLOCKS_FILING",
        "BLOCKS_AMENDMENT",
        "BLOCKS_ERASURE",
        "BLOCKS_RUN",
        "BLOCKS_AUTHORITY_CALL",
        null
      ]
    },
    "exclusion_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "no_data_confirmed_declarations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "missing_source_declarations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "stale_source_declarations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "source_domain_postures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceDomainPosture"
      },
      "uniqueItems": true
    },
    "normalization_context_ref": {
      "type": "string",
      "minLength": 1
    },
    "normalization_context_hash": {
      "type": "string",
      "minLength": 1
    },
    "artifact_contract_refs": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "artifact_contract_hash": {
      "type": "string",
      "minLength": 1
    },
    "input_set_hash": {
      "type": "string",
      "minLength": 1
    },
    "input_consumption_mode": {
      "const": "FROZEN_INPUT_ONLY"
    },
    "late_data_adoption_policy": {
      "const": "CHILD_REVIEW_OR_EXCLUDE_ONLY"
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "$defs": {
    "sourceDomainPosture": {
      "type": "object",
      "required": [
        "source_domain",
        "source_class",
        "partition_scope_refs",
        "runtime_scope_refs",
        "boundary_disposition",
        "late_data_policy_ref",
        "source_record_count",
        "evidence_item_count",
        "candidate_fact_count",
        "canonical_fact_count",
        "conflict_count"
      ],
      "properties": {
        "source_domain": {
          "type": "string",
          "minLength": 1
        },
        "source_class": {
          "$ref": "./late_data_policy_binding.schema.json#/$defs/sourceClassOrNull"
        },
        "partition_scope_refs": {
          "$ref": "./late_data_policy_binding.schema.json#/$defs/partitionScopeRefs"
        },
        "runtime_scope_refs": {
          "$ref": "./late_data_policy_binding.schema.json#/$defs/runtimeScopeRefs"
        },
        "boundary_disposition": {
          "type": "string",
          "enum": [
            "IN_SCOPE_COLLECTED",
            "NO_DATA_CONFIRMED_AT_CUTOFF",
            "EXCLUDED_BY_POLICY",
            "MISSING_AT_CUTOFF",
            "STALE_AT_CUTOFF"
          ]
        },
        "late_data_policy_ref": {
          "$ref": "./late_data_policy_binding.schema.json#/$defs/lateDataPolicyRef"
        },
        "source_record_count": {
          "type": "integer",
          "minimum": 0
        },
        "evidence_item_count": {
          "type": "integer",
          "minimum": 0
        },
        "candidate_fact_count": {
          "type": "integer",
          "minimum": 0
        },
        "canonical_fact_count": {
          "type": "integer",
          "minimum": 0
        },
        "conflict_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "input_consumption_mode": {
            "const": "FROZEN_INPUT_ONLY"
          }
        },
        "required": [
          "input_consumption_mode"
        ]
      },
      "then": {
        "properties": {
          "late_data_adoption_policy": {
            "const": "CHILD_REVIEW_OR_EXCLUDE_ONLY"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "open_conflict_count": {
            "const": 0
          }
        },
        "required": [
          "open_conflict_count"
        ]
      },
      "then": {
        "properties": {
          "resolution_frontier": {
            "const": "CLEAR"
          },
          "blocking_conflict_count": {
            "const": 0
          },
          "dominant_blocking_class": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "open_conflict_count": {
            "minimum": 1
          },
          "blocking_conflict_count": {
            "const": 0
          }
        },
        "required": [
          "open_conflict_count",
          "blocking_conflict_count"
        ]
      },
      "then": {
        "properties": {
          "resolution_frontier": {
            "const": "MONITORING_ONLY"
          },
          "dominant_blocking_class": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "blocking_conflict_count": {
            "minimum": 1
          }
        },
        "required": [
          "blocking_conflict_count"
        ]
      },
      "then": {
        "properties": {
          "resolution_frontier": {
            "const": "BLOCKING_PRESENT"
          },
          "dominant_blocking_class": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "dominant_blocking_class": {
            "type": "string"
          }
        },
        "required": [
          "dominant_blocking_class"
        ]
      },
      "then": {
        "properties": {
          "resolution_frontier": {
            "const": "BLOCKING_PRESENT"
          },
          "blocking_conflict_count": {
            "minimum": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resolution_frontier": {
            "const": "CLEAR"
          }
        },
        "required": [
          "resolution_frontier"
        ]
      },
      "then": {
        "properties": {
          "open_conflict_count": {
            "const": 0
          },
          "blocking_conflict_count": {
            "const": 0
          },
          "dominant_blocking_class": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resolution_frontier": {
            "const": "MONITORING_ONLY"
          }
        },
        "required": [
          "resolution_frontier"
        ]
      },
      "then": {
        "properties": {
          "open_conflict_count": {
            "minimum": 1
          },
          "blocking_conflict_count": {
            "const": 0
          },
          "dominant_blocking_class": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resolution_frontier": {
            "const": "BLOCKING_PRESENT"
          }
        },
        "required": [
          "resolution_frontier"
        ]
      },
      "then": {
        "properties": {
          "open_conflict_count": {
            "minimum": 1
          },
          "blocking_conflict_count": {
            "minimum": 1
          },
          "dominant_blocking_class": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "source_domain_postures": {
            "contains": {
              "type": "object",
              "properties": {
                "boundary_disposition": {
                  "const": "IN_SCOPE_COLLECTED"
                }
              },
              "required": [
                "boundary_disposition"
              ]
            }
          }
        },
        "required": [
          "source_domain_postures"
        ]
      },
      "then": {
        "properties": {
          "source_record_refs": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
