{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/semantic_accessibility_contract.schema.json",
  "title": "SemanticAccessibilityContract",
  "description": "Cross-shell semantic selector and accessibility contract. This schema freezes the meaning-driven selector profile, browser/native identifier parity, landmark and heading structure, keyboard and focus laws, live-update announcement posture, reduced-motion discipline, and the addressable semantic anchors that automation and assistive technology rely on so layouts may restack without changing machine-readable meaning.",
  "type": "object",
  "required": [
    "contract_version",
    "shell_family",
    "selector_profile",
    "identifier_semantics_policy",
    "browser_identifier_policy",
    "native_identifier_policy",
    "landmark_structure_policy",
    "heading_navigation_policy",
    "focus_order_policy",
    "focus_entry_policy",
    "focus_restore_policy",
    "keyboard_completion_policy",
    "live_update_focus_policy",
    "live_region_policy",
    "conditional_notice_anchor_policy",
    "support_region_access_policy",
    "detail_module_access_policy",
    "artifact_handoff_policy",
    "reduced_motion_policy",
    "required_anchor_codes",
    "semantic_focus_order",
    "announced_change_kinds"
  ],
  "properties": {
    "contract_version": {
      "const": "SEMANTIC_ACCESSIBILITY_V1"
    },
    "shell_family": {
      "type": "string",
      "enum": [
        "CALM_SHELL",
        "CLIENT_PORTAL_SHELL",
        "GOVERNANCE_DENSITY_SHELL"
      ]
    },
    "selector_profile": {
      "type": "string",
      "enum": [
        "OPERATOR_SEMANTIC_SELECTORS_V1",
        "PORTAL_SEMANTIC_SELECTORS_V1",
        "GOVERNANCE_SEMANTIC_SELECTORS_V1"
      ]
    },
    "identifier_semantics_policy": {
      "const": "DOMAIN_MEANING_OVER_VISUAL_STYLING"
    },
    "browser_identifier_policy": {
      "const": "DATA_TESTID_MIRRORS_SEMANTIC_ANCHOR"
    },
    "native_identifier_policy": {
      "const": "ACCESSIBILITY_IDENTIFIER_MIRRORS_SEMANTIC_ANCHOR"
    },
    "landmark_structure_policy": {
      "const": "STABLE_SHELL_SUMMARY_ACTION_SUPPORT_AND_NOTICE_LANDMARKS"
    },
    "heading_navigation_policy": {
      "const": "PRIMARY_HEADING_AND_PROMOTED_REGION_HEADINGS"
    },
    "focus_order_policy": {
      "const": "VISIBLE_SEMANTIC_ORDER_ONLY"
    },
    "focus_entry_policy": {
      "const": "REQUESTED_ANCHOR_OR_PRIMARY_HEADING_OR_EXPLICIT_NOTICE"
    },
    "focus_restore_policy": {
      "const": "RETURN_TO_INVOKER_OR_LAWFUL_ANCESTOR"
    },
    "keyboard_completion_policy": {
      "const": "ALL_GOVERNED_ACTIONS_KEYBOARD_OPERABLE"
    },
    "live_update_focus_policy": {
      "const": "NEVER_STEAL_ACTIVE_INPUT_OR_PICKER_FOCUS"
    },
    "live_region_policy": {
      "const": "POLITE_ACTIVITY_ASSERTIVE_FAILURE_ONLY"
    },
    "conditional_notice_anchor_policy": {
      "const": "LIMITATION_AND_RECOVERY_NOTICES_REQUIRE_ADDRESSABLE_ANCHORS"
    },
    "support_region_access_policy": {
      "const": "PROMOTED_SUPPORT_REGION_KEYBOARD_REACHABLE_AND_ESCAPABLE"
    },
    "detail_module_access_policy": {
      "const": "SUPPORT_MODULES_KEYBOARD_AND_ASSISTIVE_TECH_REACHABLE"
    },
    "artifact_handoff_policy": {
      "const": "CURRENT_AND_HISTORY_ANCHORS_SEPARATE"
    },
    "reduced_motion_policy": {
      "const": "MEANING_PRESERVED_WITH_MINIMAL_OR_NO_MOTION"
    },
    "required_anchor_codes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/anchorCode"
      },
      "minItems": 6,
      "uniqueItems": true
    },
    "semantic_focus_order": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/focusRegionCode"
      },
      "minItems": 2,
      "uniqueItems": true
    },
    "announced_change_kinds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/announcedChangeKind"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "$defs": {
    "anchorCode": {
      "type": "string",
      "enum": [
        "SHELL_ROOT",
        "SHELL_FAMILY",
        "OBJECT_ANCHOR",
        "DOMINANT_QUESTION",
        "DOMINANT_ACTION",
        "SETTLEMENT_POSTURE",
        "RECOVERY_POSTURE",
        "WORKSPACE_POSTURE",
        "CONTEXT_BAR",
        "DECISION_SUMMARY",
        "ACTION_STRIP",
        "PRIMARY_ACTION",
        "NO_SAFE_ACTION_REASON",
        "DETAIL_DRAWER",
        "PROMOTED_SUPPORT_REGION",
        "LIMITATION_NOTICE",
        "RECOVERY_NOTICE",
        "ARTIFACT_HANDOFF",
        "ARTIFACT_STATE_LABEL",
        "RETURN_PATH_CONTROL",
        "ROUTE_TABS",
        "REQUEST_FOCUS",
        "CURRENT_ARTIFACT",
        "HISTORY_LIST",
        "SECTION_NAV",
        "PRIMARY_WORKLIST",
        "WORKSPACE_HEADER",
        "ATTENTION_SUMMARY",
        "RISK_LEDGER",
        "LEADING_SIDEBAR",
        "PRIMARY_CANVAS",
        "TRAILING_INSPECTOR",
        "IDENTITY_HEADER",
        "SUMMARY_CARD",
        "DETAIL_BODY"
      ]
    },
    "focusRegionCode": {
      "type": "string",
      "enum": [
        "CONTEXT_BAR",
        "DECISION_SUMMARY",
        "ACTION_STRIP",
        "DETAIL_DRAWER",
        "PORTAL_HEADER",
        "STATUS_HERO",
        "PRIMARY_ACTION",
        "PROMOTED_SUPPORT_REGION",
        "SUPPORTING_DETAIL",
        "SECTION_NAV",
        "PRIMARY_WORKLIST",
        "WORKSPACE_HEADER",
        "ATTENTION_SUMMARY",
        "PROMOTED_AUXILIARY_SURFACE",
        "LEADING_SIDEBAR",
        "PRIMARY_CANVAS",
        "TRAILING_INSPECTOR",
        "IDENTITY_HEADER",
        "SUMMARY_CARD",
        "DETAIL_BODY"
      ]
    },
    "announcedChangeKind": {
      "type": "string",
      "enum": [
        "ACTIVITY_DELTA",
        "BADGE_DELTA",
        "LIMITATION_NOTICE",
        "RECOVERY_NOTICE",
        "COMMAND_FAILURE",
        "TERMINAL_SETTLEMENT"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "shell_family": {
            "const": "CALM_SHELL"
          }
        },
        "required": [
          "shell_family"
        ]
      },
      "then": {
        "properties": {
          "selector_profile": {
            "const": "OPERATOR_SEMANTIC_SELECTORS_V1"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "shell_family": {
            "const": "CLIENT_PORTAL_SHELL"
          }
        },
        "required": [
          "shell_family"
        ]
      },
      "then": {
        "properties": {
          "selector_profile": {
            "const": "PORTAL_SEMANTIC_SELECTORS_V1"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "shell_family": {
            "const": "GOVERNANCE_DENSITY_SHELL"
          }
        },
        "required": [
          "shell_family"
        ]
      },
      "then": {
        "properties": {
          "selector_profile": {
            "const": "GOVERNANCE_SEMANTIC_SELECTORS_V1"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
