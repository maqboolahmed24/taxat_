{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/artifact_retention.schema.json",
  "title": "ArtifactRetention",
  "description": "Retention lifecycle control object for one governed artifact. This contract freezes canonical retention-tag binding, expiry basis, pending follow-up posture, surviving limitation semantics, and erasure-proof lineage as typed state rather than passive notes.",
  "type": "object",
  "required": [
    "artifact_type",
    "retention_scope_class",
    "retention_id",
    "tenant_id",
    "artifact_ref",
    "retention_tag_ref",
    "retention_class",
    "lifecycle_state",
    "minimum_expiry_at",
    "policy_expiry_at",
    "effective_expiry_at",
    "state_changed_at",
    "last_evaluated_at",
    "hold_ref",
    "next_checkpoint_at",
    "workflow_item_refs",
    "limitation_behavior",
    "limitation_reason_codes",
    "erasure_request_ref",
    "erasure_action_ref",
    "erasure_proof_ref"
  ],
  "properties": {
    "artifact_type": {
      "const": "ArtifactRetention"
    },
    "retention_scope_class": {
      "const": "GOVERNED_ARTIFACT"
    },
    "retention_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_ref": {
      "type": "string",
      "minLength": 1
    },
    "retention_tag_ref": {
      "type": "string",
      "minLength": 1
    },
    "retention_class": {
      "type": "string",
      "enum": [
        "regulated_record",
        "derived_artifact",
        "operational_log",
        "analytics_projection",
        "policy_governed_other"
      ]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "ACTIVE",
        "LIMITED",
        "LEGAL_HOLD",
        "ERASURE_PENDING",
        "PSEUDONYMISED",
        "ERASED"
      ]
    },
    "minimum_expiry_at": {
      "type": "string",
      "format": "date-time"
    },
    "policy_expiry_at": {
      "type": "string",
      "format": "date-time"
    },
    "effective_expiry_at": {
      "type": "string",
      "format": "date-time"
    },
    "state_changed_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_evaluated_at": {
      "type": "string",
      "format": "date-time"
    },
    "hold_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "next_checkpoint_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "workflow_item_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "limitation_behavior": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "limitation_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "erasure_request_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "erasure_action_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "erasure_proof_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "LEGAL_HOLD"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "hold_ref": {
            "type": "string",
            "minLength": 1
          },
          "next_checkpoint_at": {
            "type": "string",
            "format": "date-time"
          },
          "workflow_item_refs": {
            "minItems": 1
          },
          "limitation_behavior": {
            "type": "null"
          },
          "limitation_reason_codes": {
            "maxItems": 0
          },
          "erasure_request_ref": {
            "type": "null"
          },
          "erasure_action_ref": {
            "type": "null"
          },
          "erasure_proof_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "ACTIVE"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "hold_ref": {
            "type": "null"
          },
          "next_checkpoint_at": {
            "type": "null"
          },
          "workflow_item_refs": {
            "maxItems": 0
          },
          "limitation_behavior": {
            "type": "null"
          },
          "limitation_reason_codes": {
            "maxItems": 0
          },
          "erasure_request_ref": {
            "type": "null"
          },
          "erasure_action_ref": {
            "type": "null"
          },
          "erasure_proof_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "LIMITED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "hold_ref": {
            "type": "null"
          },
          "next_checkpoint_at": {
            "type": "null"
          },
          "workflow_item_refs": {
            "maxItems": 0
          },
          "limitation_behavior": {
            "type": "string",
            "minLength": 1
          },
          "limitation_reason_codes": {
            "minItems": 1
          },
          "erasure_request_ref": {
            "type": "null"
          },
          "erasure_action_ref": {
            "type": "null"
          },
          "erasure_proof_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "hold_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "hold_ref"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "const": "LEGAL_HOLD"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "next_checkpoint_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "next_checkpoint_at"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "LEGAL_HOLD",
              "ERASURE_PENDING"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "workflow_item_refs": {
            "minItems": 1
          }
        },
        "required": [
          "workflow_item_refs"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "LEGAL_HOLD",
              "ERASURE_PENDING"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "limitation_behavior": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "limitation_behavior"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "LIMITED",
              "PSEUDONYMISED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "limitation_reason_codes": {
            "minItems": 1
          }
        },
        "required": [
          "limitation_reason_codes"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "LIMITED",
              "PSEUDONYMISED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "erasure_request_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "erasure_request_ref"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "ERASURE_PENDING",
              "PSEUDONYMISED",
              "ERASED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "erasure_action_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "erasure_action_ref"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "PSEUDONYMISED",
              "ERASED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "erasure_proof_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "erasure_proof_ref"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "PSEUDONYMISED",
              "ERASED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "ERASURE_PENDING"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "hold_ref": {
            "type": "null"
          },
          "next_checkpoint_at": {
            "type": "string",
            "format": "date-time"
          },
          "workflow_item_refs": {
            "minItems": 1
          },
          "limitation_behavior": {
            "type": "null"
          },
          "limitation_reason_codes": {
            "maxItems": 0
          },
          "erasure_request_ref": {
            "type": "string",
            "minLength": 1
          },
          "erasure_action_ref": {
            "type": "null"
          },
          "erasure_proof_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "PSEUDONYMISED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "hold_ref": {
            "type": "null"
          },
          "next_checkpoint_at": {
            "type": "null"
          },
          "workflow_item_refs": {
            "maxItems": 0
          },
          "limitation_behavior": {
            "type": "string",
            "minLength": 1
          },
          "limitation_reason_codes": {
            "minItems": 1
          },
          "erasure_request_ref": {
            "type": "string",
            "minLength": 1
          },
          "erasure_action_ref": {
            "type": "string",
            "minLength": 1
          },
          "erasure_proof_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "ERASED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "hold_ref": {
            "type": "null"
          },
          "next_checkpoint_at": {
            "type": "null"
          },
          "workflow_item_refs": {
            "maxItems": 0
          },
          "limitation_behavior": {
            "type": "null"
          },
          "limitation_reason_codes": {
            "maxItems": 0
          },
          "erasure_request_ref": {
            "type": "string",
            "minLength": 1
          },
          "erasure_action_ref": {
            "type": "string",
            "minLength": 1
          },
          "erasure_proof_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
