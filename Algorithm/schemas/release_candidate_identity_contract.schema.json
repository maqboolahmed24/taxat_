{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/release_candidate_identity_contract.schema.json",
  "title": "ReleaseCandidateIdentityContract",
  "description": "Shared release-candidate identity contract. This schema freezes the canonical candidate tuple, build_artifact_hash semantics for the promoted binary, and the exact candidate_identity_hash used to prove that release evidence, admissibility records, canary results, restore drills, client compatibility matrices, and deployment records all describe the same promotion candidate.",
  "type": "object",
  "required": [
    "contract_version",
    "candidate_identity_hash",
    "candidate_environment_ref",
    "build_artifact_ref",
    "artifact_digest",
    "schema_bundle_hash",
    "config_bundle_hash",
    "migration_plan_ref_or_null",
    "enabled_provider_profile_refs",
    "supported_client_window_ref_or_null",
    "array_canonicalization_policy",
    "suite_context_policy",
    "admissibility_binding_policy"
  ],
  "properties": {
    "contract_version": {
      "const": "RELEASE_CANDIDATE_IDENTITY_V1"
    },
    "candidate_identity_hash": {
      "type": "string",
      "minLength": 1
    },
    "candidate_environment_ref": {
      "type": "string",
      "minLength": 1
    },
    "build_artifact_ref": {
      "type": "string",
      "minLength": 1
    },
    "artifact_digest": {
      "type": "string",
      "minLength": 1
    },
    "schema_bundle_hash": {
      "type": "string",
      "minLength": 1
    },
    "config_bundle_hash": {
      "type": "string",
      "minLength": 1
    },
    "migration_plan_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "enabled_provider_profile_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "supported_client_window_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "array_canonicalization_policy": {
      "const": "SORTED_UNIQUE_ARRAY_COMPONENTS_ONLY"
    },
    "suite_context_policy": {
      "const": "SUITE_SPECIFIC_DIMENSIONS_MUST_BE_DECLARED_OR_EXPLICITLY_NULL"
    },
    "admissibility_binding_policy": {
      "const": "GREEN_GATES_REQUIRE_EXACT_CANDIDATE_BINDING"
    }
  },
  "additionalProperties": false
}
