{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/evidence_item.schema.json",
  "title": "EvidenceItem",
  "type": "object",
  "required": [
    "evidence_item_id",
    "manifest_id",
    "artifact_type",
    "source_record_id",
    "evidence_kind",
    "content_ref",
    "source_strength_tier",
    "freshness_state",
    "lineage_refs",
    "retention_tag",
    "business_partition",
    "period_partition",
    "contract"
  ],
  "properties": {
    "evidence_item_id": {
      "type": "string"
    },
    "manifest_id": {
      "type": "string"
    },
    "artifact_type": {
      "const": "EvidenceItem"
    },
    "source_record_id": {
      "type": "string"
    },
    "evidence_kind": {
      "type": "string"
    },
    "content_ref": {
      "type": "string"
    },
    "extraction_method": {
      "type": [
        "string",
        "null"
      ]
    },
    "extraction_confidence": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "source_strength_tier": {
      "type": "string",
      "enum": [
        "TIER_1_AUTHORITY_FINAL",
        "TIER_2_AUTHORITY_REFERENCE",
        "TIER_3_STRUCTURED_EXTERNAL",
        "TIER_4_STRUCTURED_INTERNAL",
        "TIER_5_DOCUMENT_SUPPORT",
        "TIER_6_DECLARED_ONLY",
        "TIER_7_INFERRED",
        "TIER_8_GOVERNANCE_ONLY"
      ]
    },
    "freshness_state": {
      "type": "string",
      "enum": [
        "CURRENT",
        "STALE",
        "EXPIRED",
        "UNKNOWN",
        "SUPERSEDED"
      ]
    },
    "lineage_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "retention_tag": {
      "type": "string"
    },
    "erasure_state": {
      "type": [
        "string",
        "null"
      ]
    },
    "business_partition": {
      "type": "string"
    },
    "period_partition": {
      "type": "string"
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "additionalProperties": false
}
