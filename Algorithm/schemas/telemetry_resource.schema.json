      "type": "string",
      "minLength": 1
    },
    "environment_ref": {
      "type": "string",
      "minLength": 1
    },
    "build_ref": {
      "type": "string",
      "minLength": 1
    },
    "deployment_identity": {
      "type": "object",
      "required": [
        "deployment_ref",
        "instance_ref",
        "started_at"
