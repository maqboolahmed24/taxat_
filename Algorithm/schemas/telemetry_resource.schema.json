  "$id": "https://taxat.dev/schemas/telemetry_resource.schema.json",
  "title": "TelemetryResource",
  "description": "Shared observability resource identity carried across traces, metrics, logs, and correlated audit evidence. This contract freezes the runtime service/build/deployment tuple used to join signals safely.",
