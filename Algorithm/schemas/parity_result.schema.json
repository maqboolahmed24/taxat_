{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/parity_result.schema.json",
  "title": "ParityResult",
  "description": "Deterministic parity artifact. This schema freezes the comparison basis, per-field deltas, aggregate coverage and pressure, and lifecycle state for one authority or baseline comparison run.",
  "type": "object",
  "required": [
    "parity_id",
    "manifest_id",
    "artifact_type",
    "execution_mode",
    "analysis_only",
    "non_compliance_config_refs",
    "counterfactual_basis",
    "lifecycle_state",
    "comparison_basis_ref",
    "comparison_requirement",
    "parity_threshold_profile_ref",
    "comparison_set_state",
    "ordered_field_codes",
    "money_profile",
    "parity_classification",
    "parity_score",
    "comparison_coverage",
    "weighted_parity_pressure",
    "critical_blocking_field_count",
    "critical_material_field_count",
    "dominant_reason_code",
    "reason_codes",
    "temporal_propagation_event_refs",
    "deltas",
    "cause_hypotheses",
    "evaluated_at",
    "contract"
  ],
  "properties": {
    "parity_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "ParityResult"
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "COMPLIANCE",
        "ANALYSIS"
      ]
    },
    "analysis_only": {
      "type": "boolean"
    },
    "non_compliance_config_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "counterfactual_basis": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "NOT_EVALUATED",
        "EVALUATED",
        "SUPERSEDED"
      ]
    },
    "comparison_basis_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "comparison_requirement": {
      "type": "string",
      "enum": [
        "MANDATORY",
        "DESIRABLE",
        "NOT_REQUIRED"
      ]
    },
    "parity_threshold_profile_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "comparison_set_state": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "VALID",
        "INVALID",
        null
      ]
    },
    "ordered_field_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "money_profile": {
      "$ref": "./schema_bundle.schema.json#/$defs/moneyProfile"
    },
    "parity_classification": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "MATCH",
        "MINOR_DIFFERENCE",
        "MATERIAL_DIFFERENCE",
        "BLOCKING_DIFFERENCE",
        "NOT_COMPARABLE",
        null
      ]
    },
    "parity_score": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "comparison_coverage": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 1
    },
    "weighted_parity_pressure": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "critical_blocking_field_count": {
      "type": "integer",
      "minimum": 0
    },
    "critical_material_field_count": {
      "type": "integer",
      "minimum": 0
    },
    "dominant_reason_code": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "temporal_propagation_event_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "deltas": {
      "type": "object",
      "default": {},
      "additionalProperties": {
        "$ref": "#/$defs/fieldDelta"
      }
    },
    "cause_hypotheses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "evaluated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "$defs": {
    "fieldDelta": {
      "type": "object",
      "required": [
        "field_code",
        "criticality_class",
        "criticality_weight",
        "abs_threshold",
        "rel_threshold",
        "abs_floor",
        "effective_abs_floor",
        "comparison_input_state",
        "field_class",
        "internal_value",
        "authority_value",
        "delta_signed",
        "delta_abs",
        "delta_rel",
        "breach_ratio",
        "reason_codes"
      ],
      "properties": {
        "field_code": {
          "type": "string",
          "minLength": 1
        },
        "criticality_class": {
          "type": "string",
          "enum": [
            "CRITICAL",
            "HIGH",
            "NORMAL"
          ]
        },
        "criticality_weight": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "abs_threshold": {
          "$ref": "./schema_bundle.schema.json#/$defs/moneyValue"
        },
        "rel_threshold": {
          "type": "number",
          "minimum": 0
        },
        "abs_floor": {
          "$ref": "./schema_bundle.schema.json#/$defs/moneyValue"
        },
        "effective_abs_floor": {
          "$ref": "./schema_bundle.schema.json#/$defs/moneyValue"
        },
        "comparison_input_state": {
          "type": "string",
          "enum": [
            "COMPARABLE",
            "AUTHORITY_MISSING",
            "INVALID_INPUT"
          ]
        },
        "field_class": {
          "type": "string",
          "enum": [
            "MATCH",
            "MINOR_DIFFERENCE",
            "MATERIAL_DIFFERENCE",
            "BLOCKING_DIFFERENCE",
            "NOT_COMPARABLE"
          ]
        },
        "internal_value": {
          "oneOf": [
            {
              "$ref": "./schema_bundle.schema.json#/$defs/moneyValue"
            },
            {
              "type": "null"
            }
          ]
        },
        "authority_value": {
          "oneOf": [
            {
              "$ref": "./schema_bundle.schema.json#/$defs/moneyValue"
            },
            {
              "type": "null"
            }
          ]
        },
        "delta_signed": {
          "oneOf": [
            {
              "$ref": "./schema_bundle.schema.json#/$defs/moneyValue"
            },
            {
              "type": "null"
            }
          ]
        },
        "delta_abs": {
          "oneOf": [
            {
              "$ref": "./schema_bundle.schema.json#/$defs/moneyValue"
            },
            {
              "type": "null"
            }
          ]
        },
        "delta_rel": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "breach_ratio": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "comparison_input_state": {
                "const": "COMPARABLE"
              }
            },
            "required": [
              "comparison_input_state"
            ]
          },
          "then": {
            "properties": {
              "field_class": {
                "enum": [
                  "MATCH",
                  "MINOR_DIFFERENCE",
                  "MATERIAL_DIFFERENCE",
                  "BLOCKING_DIFFERENCE"
                ]
              },
              "internal_value": {
                "$ref": "./schema_bundle.schema.json#/$defs/moneyValue"
              },
              "authority_value": {
                "$ref": "./schema_bundle.schema.json#/$defs/moneyValue"
              },
              "delta_signed": {
                "$ref": "./schema_bundle.schema.json#/$defs/moneyValue"
              },
              "delta_abs": {
                "$ref": "./schema_bundle.schema.json#/$defs/moneyValue"
              },
              "delta_rel": {
                "type": "number"
              },
              "breach_ratio": {
                "type": "number"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "comparison_input_state": {
                "enum": [
                  "AUTHORITY_MISSING",
                  "INVALID_INPUT"
                ]
              }
            },
            "required": [
              "comparison_input_state"
            ]
          },
          "then": {
            "properties": {
              "field_class": {
                "const": "NOT_COMPARABLE"
              },
              "delta_signed": {
                "type": "null"
              },
              "delta_abs": {
                "type": "null"
              },
              "delta_rel": {
                "type": "null"
              },
              "breach_ratio": {
                "type": "null"
              },
              "reason_codes": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "field_class": {
                "const": "MATCH"
              }
            },
            "required": [
              "field_class"
            ]
          },
          "then": {
            "properties": {
              "breach_ratio": {
                "exclusiveMaximum": 0.25
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "field_class": {
                "const": "MINOR_DIFFERENCE"
              }
            },
            "required": [
              "field_class"
            ]
          },
          "then": {
            "properties": {
              "breach_ratio": {
                "minimum": 0.25,
                "exclusiveMaximum": 1.0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "field_class": {
                "const": "MATERIAL_DIFFERENCE"
              }
            },
            "required": [
              "field_class"
            ]
          },
          "then": {
            "properties": {
              "breach_ratio": {
                "minimum": 1.0,
                "exclusiveMaximum": 2.5
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "field_class": {
                "const": "BLOCKING_DIFFERENCE"
              }
            },
            "required": [
              "field_class"
            ]
          },
          "then": {
            "properties": {
              "breach_ratio": {
                "minimum": 2.5
              }
            }
          }
        }
      ]
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "execution_mode": {
            "const": "COMPLIANCE"
          }
        },
        "required": [
          "execution_mode"
        ]
      },
      "then": {
        "properties": {
          "analysis_only": {
            "const": false
          },
          "non_compliance_config_refs": {
            "maxItems": 0
          },
          "counterfactual_basis": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "execution_mode": {
            "const": "ANALYSIS"
          }
        },
        "required": [
          "execution_mode"
        ]
      },
      "then": {
        "properties": {
          "analysis_only": {
            "const": true
          },
          "counterfactual_basis": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "NOT_EVALUATED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "parity_classification": {
            "const": null
          },
          "parity_threshold_profile_ref": {
            "type": "null"
          },
          "comparison_set_state": {
            "type": "null"
          },
          "ordered_field_codes": {
            "maxItems": 0
          },
          "parity_score": {
            "type": "null"
          },
          "comparison_coverage": {
            "type": "null"
          },
          "weighted_parity_pressure": {
            "type": "null"
          },
          "critical_blocking_field_count": {
            "const": 0
          },
          "critical_material_field_count": {
            "const": 0
          },
          "dominant_reason_code": {
            "type": "null"
          },
          "reason_codes": {
            "maxItems": 0
          },
          "deltas": {
            "maxProperties": 0
          },
          "cause_hypotheses": {
            "maxItems": 0
          },
          "evaluated_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "EVALUATED",
              "SUPERSEDED"
            ]
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "parity_threshold_profile_ref": {
            "type": "string",
            "minLength": 1
          },
          "comparison_set_state": {
            "type": "string",
            "enum": [
              "VALID",
              "INVALID"
            ]
          },
          "parity_classification": {
            "type": "string",
            "enum": [
              "MATCH",
              "MINOR_DIFFERENCE",
              "MATERIAL_DIFFERENCE",
              "BLOCKING_DIFFERENCE",
              "NOT_COMPARABLE"
            ]
          },
          "parity_score": {
            "type": "number"
          },
          "comparison_coverage": {
            "type": "number"
          },
          "weighted_parity_pressure": {
            "type": "number"
          },
          "dominant_reason_code": {
            "type": "string",
            "minLength": 1
          },
          "reason_codes": {
            "minItems": 1
          },
          "deltas": {
            "type": "object"
          },
          "evaluated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "comparison_requirement": {
            "enum": [
              "MANDATORY",
              "DESIRABLE"
            ]
          }
        },
        "required": [
          "comparison_requirement"
        ]
      },
      "then": {
        "properties": {
          "comparison_basis_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "comparison_set_state": {
            "const": "VALID"
          }
        },
        "required": [
          "comparison_set_state"
        ]
      },
      "then": {
        "properties": {
          "ordered_field_codes": {
            "minItems": 1
          },
          "deltas": {
            "minProperties": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "comparison_set_state": {
            "const": "INVALID"
          }
        },
        "required": [
          "comparison_set_state"
        ]
      },
      "then": {
        "properties": {
          "parity_classification": {
            "const": "NOT_COMPARABLE"
          },
          "parity_score": {
            "const": 0
          },
          "comparison_coverage": {
            "const": 0
          },
          "weighted_parity_pressure": {
            "const": 0
          },
          "critical_blocking_field_count": {
            "const": 0
          },
          "critical_material_field_count": {
            "const": 0
          },
          "ordered_field_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "parity_classification": {
            "const": "MATERIAL_DIFFERENCE"
          }
        },
        "required": [
          "parity_classification"
        ]
      },
      "then": {
        "properties": {
          "critical_blocking_field_count": {
            "const": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "parity_classification": {
            "const": "MINOR_DIFFERENCE"
          }
        },
        "required": [
          "parity_classification"
        ]
      },
      "then": {
        "properties": {
          "critical_blocking_field_count": {
            "const": 0
          },
          "critical_material_field_count": {
            "const": 0
          },
          "weighted_parity_pressure": {
            "exclusiveMaximum": 1.0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "parity_classification": {
            "const": "NOT_COMPARABLE"
          }
        },
        "required": [
          "parity_classification"
        ]
      },
      "then": {
        "properties": {
          "cause_hypotheses": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "parity_classification": {
            "const": "BLOCKING_DIFFERENCE"
          }
        },
        "required": [
          "parity_classification"
        ]
      },
      "then": {
        "properties": {
          "critical_blocking_field_count": {
            "minimum": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "parity_classification": {
            "const": "MATCH"
          }
        },
        "required": [
          "parity_classification"
        ]
      },
      "then": {
        "properties": {
          "critical_blocking_field_count": {
            "const": 0
          },
          "critical_material_field_count": {
            "const": 0
          },
          "cause_hypotheses": {
            "maxItems": 0
          },
          "weighted_parity_pressure": {
            "exclusiveMaximum": 0.25
          }
        }
      }
    }
  ]
}
