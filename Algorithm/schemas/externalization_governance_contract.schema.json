{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/externalization_governance_contract.schema.json",
  "title": "ExternalizationGovernanceContract",
  "description": "Shared export, download, print, and external-handoff governance boundary contract. This schema freezes the exact governed slice, delivery_scope_class semantics, current-versus-history meaning, masking or limitation posture, approval gating, delivery targets, and handoff blocking context so externalization cannot drift onto broader, fresher, stale, or detached scope.",
  "type": "object",
  "required": [
    "contract_version",
    "boundary_scope",
    "tenant_id",
    "shell_family_or_null",
    "context_anchor_ref",
    "slice_binding_ref",
    "delivery_surface_kind",
    "history_meaning_state",
    "eligibility_state",
    "approval_state",
    "access_binding_hash_or_null",
    "masking_state",
    "masking_posture_fingerprint_or_null",
    "limitation_state",
    "visibility_cache_partition_key_or_null",
    "preview_target_ref_or_null",
    "download_target_ref_or_null",
    "print_target_ref_or_null",
    "external_handoff_target_ref_or_null",
    "approval_requirement_token_or_null",
    "blocking_context_tokens",
    "delivery_binding_hash",
    "slice_binding_policy",
    "background_scope_policy",
    "direct_url_policy",
    "posture_preservation_policy",
    "handoff_target_policy",
    "reentry_validation_policy",
    "delivery_context_policy",
    "signed_url_binding_policy",
    "temporary_artifact_policy"
  ],
  "properties": {
    "contract_version": {
      "const": "EXTERNALIZATION_GOVERNANCE_V1"
    },
    "boundary_scope": {
      "type": "string",
      "enum": [
        "AUDIT_INVESTIGATION_FRAME",
        "CLIENT_DOCUMENT_REQUEST",
        "CLIENT_APPROVAL_PACK",
        "ENQUIRY_PACK",
        "AUTHORITY_LINK_HANDOFF"
      ]
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "shell_family_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "CLIENT_PORTAL_SHELL",
        "GOVERNANCE_DENSITY_SHELL",
        null
      ]
    },
    "context_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "slice_binding_ref": {
      "type": "string",
      "minLength": 1
    },
    "delivery_surface_kind": {
      "type": "string",
      "enum": [
        "FILTERED_AUDIT_EXPORT",
        "PORTAL_DOCUMENT_DOWNLOAD",
        "PORTAL_APPROVAL_EXPORT",
        "EXPLANATION_EXPORT",
        "AUTHORITY_LINK_EXTERNAL_HANDOFF"
      ]
    },
    "history_meaning_state": {
      "type": "string",
      "enum": [
        "ACTIVE_FILTERED_SLICE",
        "CURRENT_ONLY",
        "CURRENT_WITH_HISTORY_EXPLICIT",
        "CURRENT_DECLARATION_OR_ISSUED_RECEIPT",
        "LIMITED_EXPLANATION_EXPLICIT",
        "HANDOFF_TARGET_EXPLICIT"
      ]
    },
    "eligibility_state": {
      "type": "string",
      "enum": [
        "READY",
        "MASKED_ONLY",
        "LIMITED_READY",
        "APPROVAL_REQUIRED",
        "BLOCKED",
        "PENDING_RETURN"
      ]
    },
    "approval_state": {
      "type": "string",
      "enum": [
        "NOT_REQUIRED",
        "REQUIRED_PENDING",
        "SATISFIED",
        "DENIED"
      ]
    },
    "access_binding_hash_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "masking_state": {
      "type": "string",
      "enum": [
        "NONE",
        "CUSTOMER_SAFE_ONLY",
        "MASKED_EXPORT_ONLY",
        "LIMITED_EXPORT",
        "NOT_APPLICABLE"
      ]
    },
    "masking_posture_fingerprint_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "limitation_state": {
      "type": "string",
      "enum": [
        "FULL",
        "INTEGRITY_LIMITED",
        "HISTORY_LIMITED",
        "RETENTION_LIMITED",
        "PREFLIGHT_BLOCKED",
        "POLICY_LIMITED",
        "NOT_APPLICABLE"
      ]
    },
    "visibility_cache_partition_key_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "preview_target_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "download_target_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "print_target_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "external_handoff_target_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "approval_requirement_token_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "blocking_context_tokens": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "delivery_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "slice_binding_policy": {
      "const": "ACTIVE_GOVERNED_SLICE_REQUIRED"
    },
    "background_scope_policy": {
      "const": "DETACHED_BACKGROUND_SCOPE_FORBIDDEN"
    },
    "direct_url_policy": {
      "const": "DIRECT_URL_BYPASS_FORBIDDEN"
    },
    "posture_preservation_policy": {
      "const": "CURRENT_HISTORY_MASKING_LIMITATION_AND_APPROVAL_PRESERVED"
    },
    "handoff_target_policy": {
      "const": "EXTERNAL_TARGET_AND_BLOCKING_CONTEXT_EXPLICIT"
    },
    "reentry_validation_policy": {
      "const": "RETURN_AND_DELIVERY_REQUIRE_GOVERNED_REVALIDATION"
    },
    "delivery_context_policy": {
      "const": "TENANT_AND_SECURITY_CONTEXT_BOUND_AT_INVOCATION"
    },
    "signed_url_binding_policy": {
      "const": "SIGNED_URLS_REQUIRE_CURRENT_GOVERNED_BINDING"
    },
    "temporary_artifact_policy": {
      "const": "TEMP_FILES_AND_NATIVE_PREVIEWS_REQUIRE_MATCHING_BINDING"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "eligibility_state": {
            "const": "APPROVAL_REQUIRED"
          }
        },
        "required": [
          "eligibility_state"
        ]
      },
      "then": {
        "properties": {
          "approval_state": {
            "const": "REQUIRED_PENDING"
          },
          "approval_requirement_token_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "eligibility_state": {
            "const": "MASKED_ONLY"
          }
        },
        "required": [
          "eligibility_state"
        ]
      },
      "then": {
        "properties": {
          "preview_target_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "boundary_scope": {
            "const": "AUDIT_INVESTIGATION_FRAME"
          }
        },
        "required": [
          "boundary_scope"
        ]
      },
      "then": {
        "properties": {
          "shell_family_or_null": {
            "const": "GOVERNANCE_DENSITY_SHELL"
          },
          "delivery_surface_kind": {
            "const": "FILTERED_AUDIT_EXPORT"
          },
          "history_meaning_state": {
            "const": "ACTIVE_FILTERED_SLICE"
          },
          "download_target_ref_or_null": {
            "type": "null"
          },
          "print_target_ref_or_null": {
            "type": "null"
          },
          "external_handoff_target_ref_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "boundary_scope": {
            "const": "CLIENT_DOCUMENT_REQUEST"
          }
        },
        "required": [
          "boundary_scope"
        ]
      },
      "then": {
        "properties": {
          "shell_family_or_null": {
            "const": "CLIENT_PORTAL_SHELL"
          },
          "delivery_surface_kind": {
            "const": "PORTAL_DOCUMENT_DOWNLOAD"
          },
          "approval_state": {
            "const": "NOT_REQUIRED"
          },
          "print_target_ref_or_null": {
            "type": "null"
          },
          "external_handoff_target_ref_or_null": {
            "type": "null"
          },
          "approval_requirement_token_or_null": {
            "type": "null"
          },
          "access_binding_hash_or_null": {
            "type": "string",
            "minLength": 1
          },
          "masking_posture_fingerprint_or_null": {
            "type": "string",
            "minLength": 1
          },
          "visibility_cache_partition_key_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "boundary_scope": {
            "const": "CLIENT_APPROVAL_PACK"
          }
        },
        "required": [
          "boundary_scope"
        ]
      },
      "then": {
        "properties": {
          "shell_family_or_null": {
            "const": "CLIENT_PORTAL_SHELL"
          },
          "delivery_surface_kind": {
            "const": "PORTAL_APPROVAL_EXPORT"
          },
          "external_handoff_target_ref_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "boundary_scope": {
            "const": "ENQUIRY_PACK"
          }
        },
        "required": [
          "boundary_scope"
        ]
      },
      "then": {
        "properties": {
          "shell_family_or_null": {
            "type": "null"
          },
          "delivery_surface_kind": {
            "const": "EXPLANATION_EXPORT"
          },
          "history_meaning_state": {
            "const": "LIMITED_EXPLANATION_EXPLICIT"
          },
          "print_target_ref_or_null": {
            "type": "null"
          },
          "external_handoff_target_ref_or_null": {
            "type": "null"
          },
          "approval_requirement_token_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "boundary_scope": {
            "const": "AUTHORITY_LINK_HANDOFF"
          }
        },
        "required": [
          "boundary_scope"
        ]
      },
      "then": {
        "properties": {
          "shell_family_or_null": {
            "const": "GOVERNANCE_DENSITY_SHELL"
          },
          "delivery_surface_kind": {
            "const": "AUTHORITY_LINK_EXTERNAL_HANDOFF"
          },
          "history_meaning_state": {
            "const": "HANDOFF_TARGET_EXPLICIT"
          },
          "masking_state": {
            "const": "NOT_APPLICABLE"
          },
          "preview_target_ref_or_null": {
            "type": "null"
          },
          "download_target_ref_or_null": {
            "type": "null"
          },
          "print_target_ref_or_null": {
            "type": "null"
          },
          "approval_requirement_token_or_null": {
            "type": "null"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
