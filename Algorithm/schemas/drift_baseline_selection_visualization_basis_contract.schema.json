{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/drift_baseline_selection_visualization_basis_contract.schema.json",
  "title": "DriftBaselineSelectionVisualizationBasisContract",
  "description": "Frozen basis for the drift baseline selection visualizer. This contract binds one exact-scope baseline-selection run to the declared candidate universe, execution boundary, and supersession policy so replay, amendment, and drift surfaces can explain why one baseline won without re-scanning live state.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "basis_contract_hash",
    "execution_mode_boundary_hash",
    "source_manifest_id",
    "source_manifest_hash",
    "source_period",
    "active_exact_scope_key",
    "target_scope_refs",
    "candidate_refs",
    "candidate_universe_hash",
    "prior_active_baseline_envelope_ref_or_null",
    "prior_active_baseline_frozen_hash_or_null",
    "selection_profile_code",
    "dominance_key_profile_code",
    "scope_widening_policy",
    "external_truth_policy",
    "supersession_policy",
    "tie_break_policy",
    "uncertainty_policy",
    "replay_reuse_policy"
  ],
  "properties": {
    "contract_version": {
      "const": "DRIFT_BASELINE_SELECTION_VISUALIZATION_BASIS_V1"
    },
    "basis_contract_hash": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode_boundary_hash": {
      "type": "string",
      "minLength": 1
    },
    "source_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "source_manifest_hash": {
      "type": "string",
      "minLength": 1
    },
    "source_period": {
      "type": "string",
      "minLength": 1
    },
    "active_exact_scope_key": {
      "type": "string",
      "minLength": 1
    },
    "target_scope_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "candidate_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "candidate_universe_hash": {
      "type": "string",
      "minLength": 1
    },
    "prior_active_baseline_envelope_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "prior_active_baseline_frozen_hash_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "selection_profile_code": {
      "const": "DRIFT_BASELINE_SELECTION_V1"
    },
    "dominance_key_profile_code": {
      "const": "DRIFT_BASELINE_DOMINANCE_KEY_V1"
    },
    "scope_widening_policy": {
      "const": "EXACT_SCOPE_FIRST_NO_SILENT_CROSS_PARTITION_WIDENING"
    },
    "external_truth_policy": {
      "const": "SAME_SCOPE_AUTHORITY_AND_OUT_OF_BAND_TRUTH_MUST_REMAIN_SCOPE_BOUND"
    },
    "supersession_policy": {
      "const": "IMMUTABLE_ENVELOPE_REUSE_OR_SUCCESSOR_ONLY"
    },
    "tie_break_policy": {
      "const": "LEXICOGRAPHIC_DOMINANCE_KEY_WITH_STABLE_ID_TIEBREAK"
    },
    "uncertainty_policy": {
      "const": "BASELINE_ANCHOR_WEIGHT_RAISES_UNCERTAINTY_ONLY"
    },
    "replay_reuse_policy": {
      "const": "PERSISTED_ENVELOPE_AND_CANDIDATE_LINEAGE_ONLY"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "prior_active_baseline_envelope_ref_or_null": {
            "type": "string"
          }
        },
        "required": [
          "prior_active_baseline_envelope_ref_or_null"
        ]
      },
      "then": {
        "properties": {
          "prior_active_baseline_frozen_hash_or_null": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "prior_active_baseline_frozen_hash_or_null"
        ]
      },
      "else": {
        "properties": {
          "prior_active_baseline_frozen_hash_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "prior_active_baseline_frozen_hash_or_null": {
            "type": "string"
          }
        },
        "required": [
          "prior_active_baseline_frozen_hash_or_null"
        ]
      },
      "then": {
        "properties": {
          "prior_active_baseline_envelope_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "prior_active_baseline_envelope_ref_or_null"
        ]
      },
      "else": {
        "properties": {
          "prior_active_baseline_envelope_ref_or_null": {
            "type": "null"
          }
        }
      }
    }
  ]
}
