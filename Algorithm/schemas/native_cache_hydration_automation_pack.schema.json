{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/native_cache_hydration_automation_pack.schema.json",
  "title": "NativeCacheHydrationAutomationPack",
  "description": "Deterministic macOS cache hydration and purge automation suite. This schema freezes the native UI and persistence-fixture case inventory that proves compatibility checks complete before render, incompatible envelopes purge immediately, scene restoration stays same-object same-shell only when lawful, and cache-only restoration cannot mutate until live legality is re-established.",
  "type": "object",
  "required": [
    "contract_version",
    "pack_id",
    "deterministic_seed",
    "suite_profile",
    "run_mode",
    "first_paint_assertion_policy",
    "purge_assertion_policy",
    "action_gate_assertion_policy",
    "coverage_policy",
    "cases"
  ],
  "properties": {
    "contract_version": {
      "const": "NATIVE_CACHE_HYDRATION_AUTOMATION_PACK_V1"
    },
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "deterministic_seed": {
      "type": "integer",
      "minimum": 0
    },
    "suite_profile": {
      "const": "MACOS_CACHE_HYDRATION_PURGE_REBASE_AND_RESTORATION_MATRIX"
    },
    "run_mode": {
      "const": "DETERMINISTIC_SEEDED_ENUMERATION"
    },
    "first_paint_assertion_policy": {
      "const": "COMPATIBILITY_VERIFIED_BEFORE_RENDERED_CONTENT"
    },
    "purge_assertion_policy": {
      "const": "IMMEDIATE_SELECTIVE_PURGE_ACROSS_CACHE_AND_LOCAL_ARTIFACTS"
    },
    "action_gate_assertion_policy": {
      "const": "CACHE_ONLY_RESTORE_CANNOT_MUTATE_UNTIL_LIVE_REBASE"
    },
    "coverage_policy": {
      "const": "COLD_START_RECONNECT_TENANT_SWITCH_DOWNGRADE_REVOCATION_AND_SCHEMA_DRIFT"
    },
    "cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/automationCase"
      },
      "minItems": 7,
      "uniqueItems": true
    }
  },
  "$defs": {
    "automationHarness": {
      "type": "string",
      "enum": [
        "XCUITEST",
        "NATIVE_PERSISTENCE_FIXTURE"
      ]
    },
    "hydrationScopeClass": {
      "type": "string",
      "enum": [
        "EXPERIENCE_CURSOR",
        "WORKSPACE_CURSOR",
        "NATIVE_PRIMARY_SCENE",
        "NATIVE_SECONDARY_WINDOW"
      ]
    },
    "scenarioClass": {
      "type": "string",
      "enum": [
        "COLD_START_COMPATIBLE_CACHE",
        "COLD_START_SCHEMA_INCOMPATIBLE",
        "TENANT_SWITCH",
        "PRIVILEGE_DOWNGRADE",
        "SESSION_REVOCATION",
        "CACHE_ONLY_RESTORE_REBASE_REQUIRED",
        "SECONDARY_WINDOW_MASKING_PURGE"
      ]
    },
    "purgeReason": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "TENANT_SWITCH",
        "PRIVILEGE_DOWNGRADE",
        "SESSION_REVOKED",
        "SCHEMA_INCOMPATIBLE",
        "MASKING_CHANGE",
        null
      ]
    },
    "artifactClass": {
      "type": "string",
      "enum": [
        "STRUCTURED_CACHE",
        "RESUME_METADATA",
        "SCENE_RESTORATION_PAYLOAD",
        "NSUSERACTIVITY",
        "PREVIEW_CACHE",
        "TEMP_EXPORT_FILE",
        "LOCAL_SEARCH_INDEX"
      ]
    },
    "firstPaintOutcome": {
      "type": "string",
      "enum": [
        "CACHED_RENDER_AFTER_CHECK",
        "PLACEHOLDER_UNTIL_FRESH_SNAPSHOT",
        "PURGED_NO_RESTORE"
      ]
    },
    "actionOutcome": {
      "type": "string",
      "enum": [
        "LIVE_ACTIONS_ALLOWED",
        "MUTATION_BLOCKED_PENDING_REBASE",
        "MUTATION_BLOCKED_PENDING_ACCESS_REBIND"
      ]
    },
    "resumeBindingState": {
      "type": "string",
      "enum": [
        "UNCHANGED_LIVE",
        "CLEARED_FOR_REBASE",
        "CLEARED_FOR_ACCESS_REBIND"
      ]
    },
    "automationCase": {
      "type": "object",
      "required": [
        "case_id",
        "automation_harness",
        "hydration_scope_class",
        "scenario_class",
        "compatibility_check_completed_before_render",
        "incompatible_content_rendered",
        "purge_reason_code_or_null",
        "purged_artifact_classes",
        "resume_lineage_reused_illegally",
        "restoration_reopened_stale_context",
        "expected_first_paint_outcome",
        "expected_action_outcome",
        "expected_resume_binding_state"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "automation_harness": {
          "$ref": "#/$defs/automationHarness"
        },
        "hydration_scope_class": {
          "$ref": "#/$defs/hydrationScopeClass"
        },
        "scenario_class": {
          "$ref": "#/$defs/scenarioClass"
        },
        "compatibility_check_completed_before_render": {
          "type": "boolean"
        },
        "incompatible_content_rendered": {
          "type": "boolean"
        },
        "purge_reason_code_or_null": {
          "$ref": "#/$defs/purgeReason"
        },
        "purged_artifact_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifactClass"
          },
          "uniqueItems": true
        },
        "resume_lineage_reused_illegally": {
          "type": "boolean"
        },
        "restoration_reopened_stale_context": {
          "type": "boolean"
        },
        "expected_first_paint_outcome": {
          "$ref": "#/$defs/firstPaintOutcome"
        },
        "expected_action_outcome": {
          "$ref": "#/$defs/actionOutcome"
        },
        "expected_resume_binding_state": {
          "$ref": "#/$defs/resumeBindingState"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
