{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/amendment_bundle.schema.json",
  "title": "AmendmentBundle",
  "description": "Frozen authority-facing amendment package tying together baseline, drift, retroactive impact, calculation basis, confirmation, and payload identity.",
  "type": "object",
  "required": [
    "artifact_type",
    "amendment_bundle_id",
    "manifest_id",
    "execution_mode_boundary_contract",
    "amendment_case_ref",
    "drift_ref",
    "baseline_envelope_ref",
    "baseline_frozen_hash",
    "retroactive_impact_ref",
    "retroactive_impact_hash",
    "amendment_window_context_ref",
    "amendment_window_evaluation_hash",
    "calculation_basis_ref",
    "calculation_basis_hash",
    "user_confirmation_ref",
    "authority_operation_profile_ref",
    "affected_scope_refs",
    "packet_ref",
    "payload_hash",
    "bundle_identity_hash",
    "bundle_state",
    "supersedes_bundle_id",
    "created_at",
    "superseded_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "AmendmentBundle"
    },
    "amendment_bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode_boundary_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/execution_mode_boundary_contract.schema.json"
        },
        {
          "properties": {
            "execution_posture": {
              "const": "LIVE_COMPLIANCE"
            },
            "legal_effect_boundary": {
              "const": "COMPLIANCE_CAPABLE"
            }
          }
        }
      ]
    },
    "amendment_case_ref": {
      "type": "string",
      "minLength": 1
    },
    "drift_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "baseline_envelope_ref": {
      "type": "string",
      "minLength": 1
    },
    "baseline_frozen_hash": {
      "type": "string",
      "minLength": 1
    },
    "retroactive_impact_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "retroactive_impact_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "amendment_window_context_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "amendment_window_evaluation_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "calculation_basis_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "calculation_basis_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "user_confirmation_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "authority_operation_profile_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "affected_scope_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "packet_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "payload_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "bundle_identity_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "bundle_state": {
      "type": "string",
      "enum": [
        "PREPARED",
        "FROZEN",
        "SUBMITTED",
        "CONFIRMED",
        "VOID",
        "SUPERSEDED"
      ]
    },
    "supersedes_bundle_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "superseded_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "bundle_state": {
            "enum": [
              "PREPARED",
              "FROZEN",
              "SUBMITTED",
              "CONFIRMED"
            ]
          }
        },
        "required": [
          "bundle_state"
        ]
      },
      "then": {
        "properties": {
          "retroactive_impact_ref": {
            "type": "string",
            "minLength": 1
          },
          "retroactive_impact_hash": {
            "type": "string",
            "minLength": 1
          },
          "amendment_window_context_ref": {
            "type": "string",
            "minLength": 1
          },
          "amendment_window_evaluation_hash": {
            "type": "string",
            "minLength": 1
          },
          "calculation_basis_ref": {
            "type": "string",
            "minLength": 1
          },
          "calculation_basis_hash": {
            "type": "string",
            "minLength": 1
          },
          "user_confirmation_ref": {
            "type": "string",
            "minLength": 1
          },
          "authority_operation_profile_ref": {
            "type": "string",
            "minLength": 1
          },
          "payload_hash": {
            "type": "string",
            "minLength": 1
          },
          "bundle_identity_hash": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "bundle_state": {
            "enum": [
              "SUBMITTED",
              "CONFIRMED"
            ]
          }
        },
        "required": [
          "bundle_state"
        ]
      },
      "then": {
        "properties": {
          "packet_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "bundle_state": {
            "enum": [
              "PREPARED",
              "FROZEN",
              "VOID"
            ]
          }
        },
        "required": [
          "bundle_state"
        ]
      },
      "then": {
        "properties": {
          "packet_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "retroactive_impact_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "retroactive_impact_ref"
        ]
      },
      "then": {
        "properties": {
          "retroactive_impact_hash": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "retroactive_impact_hash": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "retroactive_impact_hash"
        ]
      },
      "then": {
        "properties": {
          "retroactive_impact_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "amendment_window_context_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "amendment_window_context_ref"
        ]
      },
      "then": {
        "properties": {
          "amendment_window_evaluation_hash": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "amendment_window_evaluation_hash": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "amendment_window_evaluation_hash"
        ]
      },
      "then": {
        "properties": {
          "amendment_window_context_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "calculation_basis_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "calculation_basis_ref"
        ]
      },
      "then": {
        "properties": {
          "calculation_basis_hash": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "calculation_basis_hash": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "calculation_basis_hash"
        ]
      },
      "then": {
        "properties": {
          "calculation_basis_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "packet_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "packet_ref"
        ]
      },
      "then": {
        "properties": {
          "bundle_state": {
            "enum": [
              "SUBMITTED",
              "CONFIRMED",
              "SUPERSEDED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "bundle_state": {
            "const": "SUPERSEDED"
          }
        },
        "required": [
          "bundle_state"
        ]
      },
      "then": {
        "properties": {
          "superseded_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "superseded_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "superseded_at"
        ]
      },
      "then": {
        "properties": {
          "bundle_state": {
            "const": "SUPERSEDED"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
