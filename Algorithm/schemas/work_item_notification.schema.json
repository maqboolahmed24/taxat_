{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/work_item_notification.schema.json",
  "title": "WorkItemNotification",
  "description": "Visibility-scoped collaboration notification contract. This schema freezes target shell ownership, mounted object anchor, governed target and parent-return routing, request-for-info linkage, access-binding revalidation posture, and suppression semantics for work-item notifications.",
  "type": "object",
  "required": [
    "notification_id",
    "item_id",
    "recipient_ref",
    "visibility_class",
    "notification_type",
    "delivery_channel",
    "dedupe_key",
    "semantic_action_id",
    "visibility_partition",
    "access_binding_hash",
    "customer_safe_projection",
    "queue_projection",
    "shell_family",
    "object_anchor_ref",
    "cross_device_continuity_contract",
    "target_route_ref",
    "target_module_code",
    "focus_anchor_ref",
    "focus_restoration",
    "return_route_ref",
    "return_focus_anchor_ref",
    "fallback_route_ref",
    "fallback_focus_anchor_ref",
    "fallback_reason_code_or_null",
    "workspace_version_at_queue",
    "request_info_ref",
    "queued_at",
    "delivered_at",
    "read_at",
    "suppressed_reason_codes"
  ],
  "properties": {
    "notification_id": {
      "type": "string",
      "minLength": 1
    },
    "item_id": {
      "type": "string",
      "minLength": 1
    },
    "recipient_ref": {
      "type": "string",
      "minLength": 1
    },
    "visibility_class": {
      "type": "string",
      "enum": [
        "CUSTOMER_VISIBLE",
        "INTERNAL_ONLY"
      ]
    },
    "notification_type": {
      "type": "string",
      "enum": [
        "NEW_ASSIGNMENT",
        "REASSIGNMENT",
        "ESCALATION",
        "CUSTOMER_REPLY",
        "CUSTOMER_DUE_DATE_CHANGED",
        "SLA_DUE_SOON",
        "SLA_OVERDUE",
        "SLA_BREACHED",
        "ITEM_RESOLVED",
        "ITEM_CANCELLED",
        "REQUEST_INFO_OPENED",
        "CUSTOMER_VISIBLE_COMMENT"
      ]
    },
    "delivery_channel": {
      "type": "string",
      "enum": [
        "IN_APP",
        "EMAIL",
        "PUSH"
      ]
    },
    "dedupe_key": {
      "type": "string",
      "minLength": 1
    },
    "semantic_action_id": {
      "type": "string",
      "minLength": 1
    },
    "visibility_partition": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/visibility_partition_contract.schema.json"
        },
        {
          "properties": {
            "partition_scope": {
              "const": "WORK_ITEM_NOTIFICATION"
            }
          }
        }
      ]
    },
    "access_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "customer_safe_projection": {
      "anyOf": [
        {
          "allOf": [
            {
              "$ref": "https://taxat.dev/schemas/customer_safe_projection_contract.schema.json"
            },
            {
              "properties": {
                "boundary_scope": {
                  "const": "WORK_ITEM_NOTIFICATION"
                },
                "projection_audience": {
                  "const": "CLIENT_PORTAL"
                }
              }
            }
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "queue_projection": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/collaboration_queue_projection_contract.schema.json"
        },
        {
          "properties": {
            "projection_scope": {
              "const": "WORK_ITEM_NOTIFICATION"
            }
          }
        }
      ]
    },
    "shell_family": {
      "type": "string",
      "enum": [
        "CALM_SHELL",
        "CLIENT_PORTAL_SHELL"
      ]
    },
    "object_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "cross_device_continuity_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/cross_device_continuity_contract.schema.json"
        },
        {
          "properties": {
            "continuity_scope": {
              "const": "WORK_ITEM_NOTIFICATION"
            }
          }
        }
      ]
    },
    "target_route_ref": {
      "type": "string",
      "minLength": 1
    },
    "target_module_code": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "CUSTOMER_ACTIVITY",
        "INTERNAL_ACTIVITY",
        "FILES",
        "LINKED_CONTEXT",
        "AUDIT_TRAIL",
        null
      ]
    },
    "focus_anchor_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "focus_restoration": {
      "$ref": "https://taxat.dev/schemas/focus_restoration_contract.schema.json"
    },
    "return_route_ref": {
      "type": "string",
      "minLength": 1
    },
    "return_focus_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "fallback_route_ref": {
      "type": "string",
      "minLength": 1
    },
    "fallback_focus_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "fallback_reason_code_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "workspace_version_at_queue": {
      "type": "integer",
      "minimum": 0
    },
    "request_info_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "queued_at": {
      "type": "string",
      "format": "date-time"
    },
    "delivered_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "read_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "suppressed_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "visibility_class": {
            "const": "CUSTOMER_VISIBLE"
          }
        },
        "required": [
          "visibility_class"
        ]
      },
      "then": {
        "properties": {
          "customer_safe_projection": {
            "type": "object"
          },
          "shell_family": {
            "const": "CLIENT_PORTAL_SHELL"
          },
          "notification_type": {
            "enum": [
              "REQUEST_INFO_OPENED",
              "CUSTOMER_VISIBLE_COMMENT",
              "CUSTOMER_DUE_DATE_CHANGED",
              "ITEM_RESOLVED",
              "ITEM_CANCELLED"
            ]
          },
          "target_route_ref": {
            "pattern": "^/portal/requests/[^\\s]+$"
          },
          "return_route_ref": {
            "pattern": "^(/portal|/portal/requests|/portal/approvals|/portal/help)$"
          },
          "fallback_route_ref": {
            "pattern": "^(/portal|/portal/requests|/portal/approvals|/portal/help)$"
          },
          "target_module_code": {
            "enum": [
              "CUSTOMER_ACTIVITY",
              "FILES",
              null
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "visibility_class": {
            "const": "INTERNAL_ONLY"
          }
        },
        "required": [
          "visibility_class"
        ]
      },
      "then": {
        "properties": {
          "customer_safe_projection": {
            "type": "null"
          },
          "shell_family": {
            "const": "CALM_SHELL"
          },
          "target_route_ref": {
            "pattern": "^/work/items/[^\\s]+$"
          },
          "return_route_ref": {
            "pattern": "^(/work|/manifests/[^\\s]+\\?focus=workflow:[^\\s]+)$"
          },
          "fallback_route_ref": {
            "pattern": "^(/work|/manifests/[^\\s]+\\?focus=workflow:[^\\s]+)$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "target_module_code": {
            "not": {
              "type": "null"
            }
          }
        },
        "required": [
          "target_module_code"
        ]
      },
      "then": {
        "properties": {
          "focus_anchor_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "target_module_code": {
            "type": "null"
          }
        },
        "required": [
          "target_module_code"
        ]
      },
      "then": {
        "properties": {
          "focus_anchor_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "focus_anchor_ref": {
            "type": "string"
          }
        },
        "required": [
          "focus_anchor_ref"
        ]
      },
      "then": {
        "properties": {
          "target_module_code": {
            "not": {
              "type": "null"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "read_at": {
            "type": "string"
          }
        },
        "required": [
          "read_at"
        ]
      },
      "then": {
        "properties": {
          "delivered_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "suppressed_reason_codes": {
            "minItems": 1
          }
        },
        "required": [
          "suppressed_reason_codes"
        ]
      },
      "then": {
        "properties": {
          "delivered_at": {
            "type": "null"
          },
          "read_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "notification_type": {
            "const": "REQUEST_INFO_OPENED"
          }
        },
        "required": [
          "notification_type"
        ]
      },
      "then": {
        "properties": {
          "visibility_class": {
            "const": "CUSTOMER_VISIBLE"
          },
          "request_info_ref": {
            "type": "string",
            "minLength": 1
          },
          "focus_anchor_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "notification_type": {
            "const": "CUSTOMER_VISIBLE_COMMENT"
          }
        },
        "required": [
          "notification_type"
        ]
      },
      "then": {
        "properties": {
          "visibility_class": {
            "const": "CUSTOMER_VISIBLE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "notification_type": {
            "enum": [
              "NEW_ASSIGNMENT",
              "REASSIGNMENT",
              "ESCALATION",
              "CUSTOMER_REPLY",
              "SLA_DUE_SOON",
              "SLA_OVERDUE",
              "SLA_BREACHED"
            ]
          }
        },
        "required": [
          "notification_type"
        ]
      },
      "then": {
        "properties": {
          "visibility_class": {
            "const": "INTERNAL_ONLY"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "notification_type": {
            "not": {
              "const": "REQUEST_INFO_OPENED"
            }
          }
        },
        "required": [
          "notification_type"
        ]
      },
      "then": {
        "properties": {
          "request_info_ref": {
            "type": "null"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
