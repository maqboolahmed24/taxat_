{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/failure_investigation.schema.json",
  "title": "FailureInvestigation",
  "description": "Typed investigation contract for complex or ambiguity-bearing failures. This schema freezes investigation class, ownership, forensic anchors, remediation follow-up linkage, and terminal accepted-risk or supersession posture.",
  "type": "object",
  "required": [
    "investigation_id",
    "error_id",
    "manifest_id",
    "root_manifest_id",
    "failure_resolution_contract",
    "investigation_class",
    "retention_class",
    "artifact_retention_ref",
    "workflow_item_id",
    "owner_type",
    "owner_ref",
    "priority",
    "investigation_state",
    "investigation_steps_ref",
    "due_at",
    "opened_at",
    "last_activity_at",
    "resolved_at",
    "resolution_basis_ref",
    "outcome",
    "accepted_risk_approval_ref",
    "superseded_by_investigation_id",
    "closure_evidence_refs",
    "remediation_task_refs",
    "audit_refs",
    "provenance_refs"
  ],
  "properties": {
    "investigation_id": {
      "type": "string",
      "minLength": 1
    },
    "error_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "root_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "failure_resolution_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/failure_resolution_contract.schema.json"
        },
        {
          "properties": {
            "lifecycle_role": {
              "const": "FAILURE_INVESTIGATION"
            },
            "role_specific_binding_policy": {
              "const": "INVESTIGATION_CLOSURE_RETAINS_OUTCOME_AND_EVIDENCE"
            }
          }
        }
      ]
    },
    "investigation_class": {
      "type": "string",
      "enum": [
        "AUTHORITY_STATE_AMBIGUITY",
        "AMENDMENT_READINESS",
        "RETENTION_PRIVACY_EXCEPTION",
        "AUDIT_PROVENANCE_DIVERGENCE",
        "SECURITY_ACCESS_ANOMALY",
        "SYSTEM_INVARIANT_BREACH",
        "MULTI_ERROR_CORRELATION"
      ]
    },
    "retention_class": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "regulated_record",
        "derived_artifact",
        "operational_log",
        "analytics_projection",
        "policy_governed_other",
        null
      ]
    },
    "artifact_retention_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "workflow_item_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "owner_type": {
      "type": "string",
      "enum": [
        "SERVICE_OPERATOR",
        "REVIEWER",
        "APPROVER",
        "TENANT_ADMIN",
        "SECURITY_OPERATOR"
      ]
    },
    "owner_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "priority": {
      "type": "string",
      "enum": [
        "LOW",
        "NORMAL",
        "HIGH",
        "URGENT",
        "CRITICAL"
      ]
    },
    "investigation_state": {
      "type": "string",
      "enum": [
        "OPEN",
        "EVIDENCE_GATHERING",
        "AWAITING_EXTERNAL_INPUT",
        "IN_REVIEW",
        "RESOLVED",
        "ACCEPTED_RISK",
        "SUPERSEDED",
        "CANCELLED"
      ]
    },
    "investigation_steps_ref": {
      "type": "string",
      "minLength": 1
    },
    "due_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "opened_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_activity_at": {
      "type": "string",
      "format": "date-time"
    },
    "resolved_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "resolution_basis_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "outcome": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "ROOT_CAUSE_CONFIRMED",
        "FALSE_POSITIVE",
        "RETRY_AUTHORIZED",
        "RECONCILIATION_REQUIRED",
        "REMEDIATION_SPAWNED",
        "ACCEPTED_RISK",
        "SUPERSEDED",
        "CANCELLED",
        null
      ]
    },
    "accepted_risk_approval_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "superseded_by_investigation_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "closure_evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "remediation_task_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "audit_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "provenance_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "retention_class": {
            "type": "string",
            "enum": [
              "regulated_record",
              "derived_artifact",
              "operational_log",
              "analytics_projection",
              "policy_governed_other"
            ]
          }
        },
        "required": [
          "retention_class"
        ]
      },
      "then": {
        "properties": {
          "artifact_retention_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "artifact_retention_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "artifact_retention_ref"
        ]
      },
      "then": {
        "properties": {
          "retention_class": {
            "type": "string",
            "enum": [
              "regulated_record",
              "derived_artifact",
              "operational_log",
              "analytics_projection",
              "policy_governed_other"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "investigation_class": {
            "const": "RETENTION_PRIVACY_EXCEPTION"
          }
        },
        "required": [
          "investigation_class"
        ]
      },
      "then": {
        "properties": {
          "retention_class": {
            "type": "string",
            "enum": [
              "regulated_record",
              "derived_artifact",
              "operational_log",
              "analytics_projection",
              "policy_governed_other"
            ]
          },
          "artifact_retention_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "accepted_risk_approval_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "accepted_risk_approval_ref"
        ]
      },
      "then": {
        "properties": {
          "investigation_state": {
            "const": "ACCEPTED_RISK"
          },
          "outcome": {
            "const": "ACCEPTED_RISK"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "superseded_by_investigation_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "superseded_by_investigation_id"
        ]
      },
      "then": {
        "properties": {
          "investigation_state": {
            "const": "SUPERSEDED"
          },
          "outcome": {
            "const": "SUPERSEDED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "enum": [
              "ROOT_CAUSE_CONFIRMED",
              "FALSE_POSITIVE",
              "RETRY_AUTHORIZED",
              "RECONCILIATION_REQUIRED",
              "REMEDIATION_SPAWNED"
            ]
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "properties": {
          "investigation_state": {
            "const": "RESOLVED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "ACCEPTED_RISK"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "properties": {
          "investigation_state": {
            "const": "ACCEPTED_RISK"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "SUPERSEDED"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "properties": {
          "investigation_state": {
            "const": "SUPERSEDED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "const": "CANCELLED"
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "properties": {
          "investigation_state": {
            "const": "CANCELLED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resolved_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "resolved_at"
        ]
      },
      "then": {
        "properties": {
          "investigation_state": {
            "enum": [
              "RESOLVED",
              "ACCEPTED_RISK",
              "SUPERSEDED",
              "CANCELLED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "resolution_basis_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "resolution_basis_ref"
        ]
      },
      "then": {
        "properties": {
          "investigation_state": {
            "enum": [
              "RESOLVED",
              "ACCEPTED_RISK",
              "SUPERSEDED",
              "CANCELLED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "closure_evidence_refs": {
            "minItems": 1
          }
        },
        "required": [
          "closure_evidence_refs"
        ]
      },
      "then": {
        "properties": {
          "investigation_state": {
            "enum": [
              "RESOLVED",
              "ACCEPTED_RISK",
              "SUPERSEDED",
              "CANCELLED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "investigation_state": {
            "enum": [
              "OPEN",
              "EVIDENCE_GATHERING",
              "AWAITING_EXTERNAL_INPUT",
              "IN_REVIEW"
            ]
          }
        },
        "required": [
          "investigation_state"
        ]
      },
      "then": {
        "properties": {
          "resolved_at": {
            "type": "null"
          },
          "resolution_basis_ref": {
            "type": "null"
          },
          "outcome": {
            "type": "null"
          },
          "accepted_risk_approval_ref": {
            "type": "null"
          },
          "superseded_by_investigation_id": {
            "type": "null"
          },
          "closure_evidence_refs": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "investigation_state": {
            "const": "RESOLVED"
          }
        },
        "required": [
          "investigation_state"
        ]
      },
      "then": {
        "properties": {
          "resolved_at": {
            "type": "string",
            "format": "date-time"
          },
          "resolution_basis_ref": {
            "type": "string",
            "minLength": 1
          },
          "outcome": {
            "enum": [
              "ROOT_CAUSE_CONFIRMED",
              "FALSE_POSITIVE",
              "RETRY_AUTHORIZED",
              "RECONCILIATION_REQUIRED",
              "REMEDIATION_SPAWNED"
            ]
          },
          "accepted_risk_approval_ref": {
            "type": "null"
          },
          "superseded_by_investigation_id": {
            "type": "null"
          },
          "closure_evidence_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "investigation_state": {
            "const": "ACCEPTED_RISK"
          }
        },
        "required": [
          "investigation_state"
        ]
      },
      "then": {
        "properties": {
          "resolved_at": {
            "type": "string",
            "format": "date-time"
          },
          "resolution_basis_ref": {
            "type": "string",
            "minLength": 1
          },
          "outcome": {
            "const": "ACCEPTED_RISK"
          },
          "accepted_risk_approval_ref": {
            "type": "string",
            "minLength": 1
          },
          "superseded_by_investigation_id": {
            "type": "null"
          },
          "closure_evidence_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "investigation_state": {
            "const": "SUPERSEDED"
          }
        },
        "required": [
          "investigation_state"
        ]
      },
      "then": {
        "properties": {
          "resolved_at": {
            "type": "string",
            "format": "date-time"
          },
          "resolution_basis_ref": {
            "type": "string",
            "minLength": 1
          },
          "outcome": {
            "const": "SUPERSEDED"
          },
          "accepted_risk_approval_ref": {
            "type": "null"
          },
          "superseded_by_investigation_id": {
            "type": "string",
            "minLength": 1
          },
          "closure_evidence_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "investigation_state": {
            "const": "CANCELLED"
          }
        },
        "required": [
          "investigation_state"
        ]
      },
      "then": {
        "properties": {
          "resolved_at": {
            "type": "string",
            "format": "date-time"
          },
          "resolution_basis_ref": {
            "type": "string",
            "minLength": 1
          },
          "outcome": {
            "const": "CANCELLED"
          },
          "accepted_risk_approval_ref": {
            "type": "null"
          },
          "superseded_by_investigation_id": {
            "type": "null"
          },
          "closure_evidence_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "outcome": {
            "enum": [
              "RECONCILIATION_REQUIRED",
              "REMEDIATION_SPAWNED"
            ]
          }
        },
        "required": [
          "outcome"
        ]
      },
      "then": {
        "properties": {
          "remediation_task_refs": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
