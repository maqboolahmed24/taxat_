{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/mutation_precondition_binding.schema.json",
  "title": "MutationPreconditionBinding",
  "description": "Explicit stale-view and visibility invalidation profile for mutation-capable affordances, commands, receipts, and problem envelopes.",
  "type": "object",
  "required": [
    "profile_code",
    "target_scope_classes",
    "required_guard_fields",
    "stale_guard_families",
    "requires_live_freshness",
    "invalidates_on_visibility_shift"
  ],
  "properties": {
    "profile_code": {
      "type": "string",
      "enum": [
        "MANIFEST_RENDER_FRAME",
        "MANIFEST_APPROVAL_PACK_REVIEW",
        "WORK_ITEM_STATE_MUTATION",
        "WORK_ITEM_INTERNAL_APPEND",
        "WORK_ITEM_CUSTOMER_APPEND",
        "WORK_ITEM_REQUEST_RESPONSE",
        "CLIENT_PORTAL_ROUTE_MUTATION",
        "GOVERNANCE_POLICY_MUTATION",
        "GOVERNANCE_SIMULATION_COMMIT"
      ]
    },
    "target_scope_classes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "MANIFEST",
          "WORK_ITEM",
          "GOVERNANCE"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "required_guard_fields": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "if_match_decision_bundle_hash",
          "if_match_shell_stability_token",
          "if_match_frame_epoch",
          "if_match_work_item_version",
          "if_match_internal_head_sequence",
          "if_match_customer_head_sequence",
          "if_match_request_state_version",
          "if_match_approval_pack_hash",
          "if_match_client_portal_workspace_version",
          "if_match_policy_snapshot_hash",
          "if_match_dependency_topology_hash",
          "simulation_basis_hash"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "stale_guard_families": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "DECISION_BUNDLE_HASH",
          "SHELL_STABILITY_TOKEN",
          "FRAME_EPOCH",
          "WORK_ITEM_VERSION",
          "INTERNAL_THREAD_HEAD",
          "CUSTOMER_THREAD_HEAD",
          "REQUEST_STATE_VERSION",
          "APPROVAL_PACK_HASH",
          "CLIENT_PORTAL_WORKSPACE_VERSION",
          "POLICY_SNAPSHOT_HASH",
          "DEPENDENCY_TOPOLOGY_HASH",
          "SIMULATION_BASIS_HASH",
          "MUTATION_BASIS_CONTRACT_HASH"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "requires_live_freshness": {
      "type": "boolean"
    },
    "invalidates_on_visibility_shift": {
      "type": "boolean"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "profile_code": {
            "const": "MANIFEST_RENDER_FRAME"
          }
        },
        "required": [
          "profile_code"
        ]
      },
      "then": {
        "properties": {
          "target_scope_classes": {
            "const": [
              "MANIFEST"
            ]
          },
          "required_guard_fields": {
            "const": [
              "if_match_decision_bundle_hash",
              "if_match_shell_stability_token",
              "if_match_frame_epoch"
            ]
          },
          "stale_guard_families": {
            "const": [
              "DECISION_BUNDLE_HASH",
              "SHELL_STABILITY_TOKEN",
              "FRAME_EPOCH"
            ]
          },
          "requires_live_freshness": {
            "const": true
          },
          "invalidates_on_visibility_shift": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile_code": {
            "const": "MANIFEST_APPROVAL_PACK_REVIEW"
          }
        },
        "required": [
          "profile_code"
        ]
      },
      "then": {
        "properties": {
          "target_scope_classes": {
            "const": [
              "MANIFEST"
            ]
          },
          "required_guard_fields": {
            "const": [
              "if_match_decision_bundle_hash",
              "if_match_shell_stability_token",
              "if_match_frame_epoch",
              "if_match_approval_pack_hash"
            ]
          },
          "stale_guard_families": {
            "const": [
              "DECISION_BUNDLE_HASH",
              "SHELL_STABILITY_TOKEN",
              "FRAME_EPOCH",
              "APPROVAL_PACK_HASH"
            ]
          },
          "requires_live_freshness": {
            "const": true
          },
          "invalidates_on_visibility_shift": {
            "const": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile_code": {
            "const": "WORK_ITEM_STATE_MUTATION"
          }
        },
        "required": [
          "profile_code"
        ]
      },
      "then": {
        "properties": {
          "target_scope_classes": {
            "const": [
              "WORK_ITEM"
            ]
          },
          "required_guard_fields": {
            "const": [
              "if_match_work_item_version",
              "if_match_shell_stability_token"
            ]
          },
          "stale_guard_families": {
            "const": [
              "WORK_ITEM_VERSION",
              "SHELL_STABILITY_TOKEN"
            ]
          },
          "requires_live_freshness": {
            "const": true
          },
          "invalidates_on_visibility_shift": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile_code": {
            "const": "WORK_ITEM_INTERNAL_APPEND"
          }
        },
        "required": [
          "profile_code"
        ]
      },
      "then": {
        "properties": {
          "target_scope_classes": {
            "const": [
              "WORK_ITEM"
            ]
          },
          "required_guard_fields": {
            "const": [
              "if_match_work_item_version",
              "if_match_internal_head_sequence",
              "if_match_shell_stability_token"
            ]
          },
          "stale_guard_families": {
            "const": [
              "WORK_ITEM_VERSION",
              "INTERNAL_THREAD_HEAD",
              "SHELL_STABILITY_TOKEN"
            ]
          },
          "requires_live_freshness": {
            "const": true
          },
          "invalidates_on_visibility_shift": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile_code": {
            "const": "WORK_ITEM_CUSTOMER_APPEND"
          }
        },
        "required": [
          "profile_code"
        ]
      },
      "then": {
        "properties": {
          "target_scope_classes": {
            "const": [
              "WORK_ITEM"
            ]
          },
          "required_guard_fields": {
            "const": [
              "if_match_work_item_version",
              "if_match_customer_head_sequence",
              "if_match_shell_stability_token"
            ]
          },
          "stale_guard_families": {
            "const": [
              "WORK_ITEM_VERSION",
              "CUSTOMER_THREAD_HEAD",
              "SHELL_STABILITY_TOKEN"
            ]
          },
          "requires_live_freshness": {
            "const": true
          },
          "invalidates_on_visibility_shift": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile_code": {
            "const": "WORK_ITEM_REQUEST_RESPONSE"
          }
        },
        "required": [
          "profile_code"
        ]
      },
      "then": {
        "properties": {
          "target_scope_classes": {
            "const": [
              "WORK_ITEM"
            ]
          },
          "required_guard_fields": {
            "const": [
              "if_match_work_item_version",
              "if_match_customer_head_sequence",
              "if_match_request_state_version",
              "if_match_shell_stability_token"
            ]
          },
          "stale_guard_families": {
            "const": [
              "WORK_ITEM_VERSION",
              "CUSTOMER_THREAD_HEAD",
              "REQUEST_STATE_VERSION",
              "SHELL_STABILITY_TOKEN"
            ]
          },
          "requires_live_freshness": {
            "const": true
          },
          "invalidates_on_visibility_shift": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile_code": {
            "const": "CLIENT_PORTAL_ROUTE_MUTATION"
          }
        },
        "required": [
          "profile_code"
        ]
      },
      "then": {
        "properties": {
          "target_scope_classes": {
            "const": [
              "MANIFEST",
              "WORK_ITEM"
            ]
          },
          "required_guard_fields": {
            "const": [
              "if_match_client_portal_workspace_version"
            ]
          },
          "stale_guard_families": {
            "const": [
              "CLIENT_PORTAL_WORKSPACE_VERSION"
            ]
          },
          "requires_live_freshness": {
            "const": true
          },
          "invalidates_on_visibility_shift": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile_code": {
            "const": "GOVERNANCE_POLICY_MUTATION"
          }
        },
        "required": [
          "profile_code"
        ]
      },
      "then": {
        "properties": {
          "target_scope_classes": {
            "const": [
              "GOVERNANCE"
            ]
          },
          "required_guard_fields": {
            "const": [
              "if_match_policy_snapshot_hash"
            ]
          },
          "stale_guard_families": {
            "const": [
              "POLICY_SNAPSHOT_HASH"
            ]
          },
          "requires_live_freshness": {
            "const": true
          },
          "invalidates_on_visibility_shift": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "profile_code": {
            "const": "GOVERNANCE_SIMULATION_COMMIT"
          }
        },
        "required": [
          "profile_code"
        ]
      },
      "then": {
        "properties": {
          "target_scope_classes": {
            "const": [
              "GOVERNANCE"
            ]
          },
          "required_guard_fields": {
            "const": [
              "if_match_policy_snapshot_hash",
              "if_match_dependency_topology_hash",
              "simulation_basis_hash"
            ]
          },
          "stale_guard_families": {
            "const": [
              "POLICY_SNAPSHOT_HASH",
              "DEPENDENCY_TOPOLOGY_HASH",
              "SIMULATION_BASIS_HASH",
              "MUTATION_BASIS_CONTRACT_HASH"
            ]
          },
          "requires_live_freshness": {
            "const": true
          },
          "invalidates_on_visibility_shift": {
            "const": true
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
