        "UNASSESSED",
        "IDEMPOTENT_RECOVERY_ONLY",
        "FOLLOW_UP_READ_ONLY",
        "BLOCKED_BY_RECONCILIATION",
        "BLOCKED_BY_ESCALATION",
        "CLOSED_NO_RESEND"
