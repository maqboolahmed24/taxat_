    "reconciliation_cadence_seconds": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "reconciliation_budget_state": {
      "type": "string",
      "enum": [
        "NOT_OPENED",
        "ACTIVE",
        "EXHAUSTED",
        "ESCALATED",
        "CLOSED"
      ]
    },
    "next_reconciliation_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "reconciliation_attempt_count": {
      "type": "integer",
      "minimum": 0
    },
    "reconciliation_deadline_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "reconciliation_escalated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "reconciliation_workflow_item_ref": {
