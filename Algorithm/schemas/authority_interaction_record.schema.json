      "then": {
        "properties": {
          "max_auto_reconciliation_attempts": {
            "const": 0
          },
          "reconciliation_cadence_seconds": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reconciliation_method": {
            "const": "MANUAL_ONLY"
