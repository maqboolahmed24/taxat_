{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/authority_interaction_record.schema.json",
  "title": "AuthorityInteractionRecord",
  "description": "Durable authority-exchange linkage contract. This contract freezes request lineage, mandatory send-time revalidation evidence, full response-observation history, current admissible response meaning, profile-derived reconciliation budget state, grouped reconciliation-control economics, resend-control posture, explicit authority-versus-internal truth separation, and explicit resolution or abandonment basis across the authority interaction lifecycle.",
