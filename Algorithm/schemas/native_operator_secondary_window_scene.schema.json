{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/native_operator_secondary_window_scene.schema.json",
  "title": "NativeOperatorSecondaryWindowScene",
  "description": "Machine-readable secondary-window contract for detached native macOS compare, audit, evidence, and diff workflows. This schema freezes the canonical calm-shell identity together with the native operator embodiment, parent-scene binding, secondary-window kind to source-module ownership, identity-header to summary-card to detail-body order, summary-first current-artifact posture, persisted route-stability lineage, and explicit focus handoff back to the parent object so secondary windows cannot drift into a second shell or a historical-first view.",
  "type": "object",
  "required": [
    "artifact_type",
    "scene_id",
    "tenant_id",
    "shell_family",
    "surface_embodiment",
    "secondary_window_kind",
    "source_module_code",
    "parent_scene_ref",
    "parent_backing_read_model_type",
    "parent_object_family",
    "parent_object_anchor_ref",
    "parent_focus_anchor_ref",
    "dominant_question",
    "interaction_layer",
    "cross_device_continuity_contract",
    "cache_isolation_contract",
    "native_cache_hydration_contract",
    "semantic_accessibility_contract",
    "window_surface_order",
    "artifact_affordance",
    "identity_header",
    "summary_loading",
    "focus_handoff",
    "scene_identity",
    "scene_restoration",
    "support_only_window",
    "rendered_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "NativeOperatorSecondaryWindowScene"
    },
    "scene_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "shell_family": {
      "const": "CALM_SHELL"
    },
    "surface_embodiment": {
      "const": "NATIVE_OPERATOR"
    },
    "secondary_window_kind": {
      "type": "string",
      "enum": [
        "TWIN_COMPARE",
        "DRIFT_DIFF",
        "AUDIT_FOCUS",
        "EVIDENCE_PREVIEW"
      ]
    },
    "source_module_code": {
      "type": "string",
      "enum": [
        "TWIN_PANEL",
        "DRIFT_FIELD",
        "FOCUS_LENS",
        "EVIDENCE_TIDE"
      ]
    },
    "parent_scene_ref": {
      "type": "string",
      "minLength": 1
    },
    "parent_backing_read_model_type": {
      "type": "string",
      "enum": [
        "LowNoiseExperienceFrame",
        "WorkspaceSnapshot"
      ]
    },
    "parent_object_family": {
      "type": "string",
      "enum": [
        "MANIFEST",
        "WORK_ITEM"
      ]
    },
    "parent_object_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "parent_focus_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "dominant_question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "interaction_layer": {
      "$ref": "https://taxat.dev/schemas/operator_interaction_layer.schema.json"
    },
    "cross_device_continuity_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/cross_device_continuity_contract.schema.json"
        },
        {
          "properties": {
            "continuity_scope": {
              "const": "NATIVE_SECONDARY_WINDOW"
            }
          }
        }
      ]
    },
    "cache_isolation_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/cache_isolation_contract.schema.json"
        },
        {
          "properties": {
            "cache_scope_class": {
              "const": "NATIVE_OPERATOR_SECONDARY_WINDOW_SCENE"
            }
          }
        }
      ]
    },
    "native_cache_hydration_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/native_cache_hydration_contract.schema.json"
        },
        {
          "properties": {
            "hydration_scope_class": {
              "const": "NATIVE_SECONDARY_WINDOW"
            }
          }
        }
      ]
    },
    "semantic_accessibility_contract": {
      "$ref": "https://taxat.dev/schemas/semantic_accessibility_contract.schema.json"
    },
    "window_surface_order": {
      "type": "array",
      "prefixItems": [
        {
          "const": "IDENTITY_HEADER"
        },
        {
          "const": "SUMMARY_CARD"
        },
        {
          "const": "DETAIL_BODY"
        }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "artifact_affordance": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/artifact_affordance_contract.schema.json"
        },
        {
          "properties": {
            "affordance_scope": {
              "const": "NATIVE_SECONDARY_WINDOW"
            }
          }
        }
      ]
    },
    "identity_header": {
      "$ref": "#/$defs/identityHeader"
    },
    "summary_loading": {
      "$ref": "#/$defs/summaryLoading"
    },
    "focus_handoff": {
      "$ref": "#/$defs/focusHandoff"
    },
    "scene_identity": {
      "$ref": "#/$defs/sceneIdentity"
    },
    "scene_restoration": {
      "$ref": "#/$defs/sceneRestoration"
    },
    "support_only_window": {
      "const": true
    },
    "rendered_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "identityHeader": {
      "type": "object",
      "required": [
        "parent_object_ref",
        "mounted_artifact_ref",
        "headline",
        "status_label",
        "currentness_state",
        "lineage_summary_ref"
      ],
      "properties": {
        "parent_object_ref": {
          "type": "string",
          "minLength": 1
        },
        "mounted_artifact_ref": {
          "type": "string",
          "minLength": 1
        },
        "headline": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "status_label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "currentness_state": {
          "type": "string",
          "enum": [
            "CURRENT_PRIMARY",
            "CURRENT_WITH_HISTORY_AVAILABLE",
            "HISTORICAL_CONTEXT"
          ]
        },
        "lineage_summary_ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "summaryLoading": {
      "type": "object",
      "required": [
        "summary_card_ref",
        "summary_state",
        "detail_state",
        "default_revision_posture",
        "historical_navigation_state"
      ],
      "properties": {
        "summary_card_ref": {
          "type": "string",
          "minLength": 1
        },
        "summary_state": {
          "type": "string",
          "enum": [
            "VISIBLE_LOADING_DETAIL",
            "VISIBLE_READY"
          ]
        },
        "detail_state": {
          "type": "string",
          "enum": [
            "LOADING",
            "READY"
          ]
        },
        "default_revision_posture": {
          "type": "string",
          "enum": [
            "CURRENT_ARTIFACT",
            "CURRENT_ARTIFACT_WITH_HISTORY_AVAILABLE",
            "CURRENT_VS_HISTORICAL_DIFF"
          ]
        },
        "historical_navigation_state": {
          "type": "string",
          "enum": [
            "HIDDEN_UNTIL_REQUESTED",
            "AVAILABLE_ON_DEMAND"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "detail_state": {
                "const": "LOADING"
              }
            },
            "required": [
              "detail_state"
            ]
          },
          "then": {
            "properties": {
              "summary_state": {
                "const": "VISIBLE_LOADING_DETAIL"
              },
              "historical_navigation_state": {
                "const": "HIDDEN_UNTIL_REQUESTED"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "detail_state": {
                "const": "READY"
              }
            },
            "required": [
              "detail_state"
            ]
          },
          "then": {
            "properties": {
              "summary_state": {
                "const": "VISIBLE_READY"
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "focusHandoff": {
      "type": "object",
      "required": [
        "launch_focus_anchor_ref",
        "window_focus_target",
        "close_return_focus_anchor_ref",
        "parent_focus_restore_policy"
      ],
      "properties": {
        "launch_focus_anchor_ref": {
          "type": "string",
          "minLength": 1
        },
        "window_focus_target": {
          "type": "string",
          "enum": [
            "IDENTITY_HEADER",
            "SUMMARY_CARD",
            "DETAIL_BODY"
          ]
        },
        "close_return_focus_anchor_ref": {
          "type": "string",
          "minLength": 1
        },
        "parent_focus_restore_policy": {
          "const": "RETURN_TO_PARENT_FOCUS_ANCHOR"
        }
      },
      "additionalProperties": false
    },
    "sceneIdentity": {
      "type": "object",
      "required": [
        "principal_session_lineage_ref",
        "masking_posture_fingerprint",
        "access_binding_hash_or_null",
        "schema_compatibility_ref",
        "stability_contract",
        "shell_stability_token",
        "route_key",
        "frame_epoch",
        "workspace_version_or_null",
        "manifest_id_or_null",
        "work_item_id_or_null",
        "focus_anchor_ref_or_null"
      ],
      "properties": {
        "principal_session_lineage_ref": {
          "type": "string",
          "minLength": 1
        },
        "masking_posture_fingerprint": {
          "type": "string",
          "minLength": 1
        },
        "access_binding_hash_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "schema_compatibility_ref": {
          "type": "string",
          "minLength": 1
        },
        "stability_contract": {
          "$ref": "https://taxat.dev/schemas/route_stability_contract.schema.json"
        },
        "shell_stability_token": {
          "type": "string",
          "minLength": 1
        },
        "route_key": {
          "type": "string",
          "minLength": 1
        },
        "frame_epoch": {
          "type": "integer",
          "minimum": 0
        },
        "workspace_version_or_null": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "manifest_id_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "work_item_id_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "focus_anchor_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "sceneRestoration": {
      "type": "object",
      "required": [
        "restoration_state",
        "invalid_reason_codes",
        "restoration_anchor_ref_or_null",
        "resume_token_ref_or_null",
        "focus_restoration"
      ],
      "properties": {
        "restoration_state": {
          "type": "string",
          "enum": [
            "RESTORABLE",
            "FRESH_SNAPSHOT_REQUIRED",
            "INVALIDATED"
          ]
        },
        "invalid_reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "TENANT_SWITCH",
                "PRIVILEGE_DOWNGRADE",
                "ACCESS_BINDING_CHANGE",
                "MASKING_CHANGE",
                "SESSION_REVOKED",
              "SCHEMA_INCOMPATIBLE",
              "OBJECT_GONE",
              "PARENT_WINDOW_CLOSED"
            ]
          },
          "uniqueItems": true,
          "default": []
        },
        "restoration_anchor_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "resume_token_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "focus_restoration": {
          "$ref": "https://taxat.dev/schemas/focus_restoration_contract.schema.json"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "restoration_state": {
                "const": "RESTORABLE"
              }
            },
            "required": [
              "restoration_state"
            ]
          },
          "then": {
            "properties": {
              "invalid_reason_codes": {
                "maxItems": 0
              },
              "restoration_anchor_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "resume_token_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "restoration_state": {
                "const": "FRESH_SNAPSHOT_REQUIRED"
              }
            },
            "required": [
              "restoration_state"
            ]
          },
          "then": {
            "properties": {
              "invalid_reason_codes": {
                "maxItems": 0
              },
              "restoration_anchor_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "resume_token_ref_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "restoration_state": {
                "const": "INVALIDATED"
              }
            },
            "required": [
              "restoration_state"
            ]
          },
          "then": {
            "properties": {
              "invalid_reason_codes": {
                "minItems": 1
              },
              "resume_token_ref_or_null": {
                "type": "null"
              }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "properties": {
        "interaction_layer": {
          "properties": {
            "recovery_notice_surface": {
              "const": "IDENTITY_HEADER"
            },
            "notification_surface": {
              "const": "PARENT_CONTEXT_BAR"
            },
            "artifact_preview_surface": {
              "const": "SECONDARY_WINDOW_BODY"
            }
          },
          "required": [
            "recovery_notice_surface",
            "notification_surface",
            "artifact_preview_surface"
          ]
        }
      },
      "required": [
        "interaction_layer"
      ]
    },
    {
      "if": {
        "properties": {
          "parent_backing_read_model_type": {
            "const": "LowNoiseExperienceFrame"
          }
        },
        "required": [
          "parent_backing_read_model_type"
        ]
      },
      "then": {
        "properties": {
          "parent_object_family": {
            "const": "MANIFEST"
          },
          "scene_identity": {
            "properties": {
              "workspace_version_or_null": {
                "type": "null"
              },
              "access_binding_hash_or_null": {
                "type": "null"
              },
              "manifest_id_or_null": {
                "type": "string",
                "minLength": 1
              },
              "work_item_id_or_null": {
                "type": "null"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "parent_backing_read_model_type": {
            "const": "WorkspaceSnapshot"
          }
        },
        "required": [
          "parent_backing_read_model_type"
        ]
      },
      "then": {
        "properties": {
          "parent_object_family": {
            "const": "WORK_ITEM"
          },
          "scene_identity": {
            "properties": {
              "workspace_version_or_null": {
                "type": "integer",
                "minimum": 0
              },
              "access_binding_hash_or_null": {
                "type": "string",
                "minLength": 1
              },
              "manifest_id_or_null": {
                "type": "null"
              },
              "work_item_id_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "secondary_window_kind": {
            "const": "TWIN_COMPARE"
          }
        },
        "required": [
          "secondary_window_kind"
        ]
      },
      "then": {
        "properties": {
          "source_module_code": {
            "const": "TWIN_PANEL"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "secondary_window_kind": {
            "const": "DRIFT_DIFF"
          }
        },
        "required": [
          "secondary_window_kind"
        ]
      },
      "then": {
        "properties": {
          "source_module_code": {
            "const": "DRIFT_FIELD"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "secondary_window_kind": {
            "const": "AUDIT_FOCUS"
          }
        },
        "required": [
          "secondary_window_kind"
        ]
      },
      "then": {
        "properties": {
          "source_module_code": {
            "const": "FOCUS_LENS"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "secondary_window_kind": {
            "const": "EVIDENCE_PREVIEW"
          }
        },
        "required": [
          "secondary_window_kind"
        ]
      },
      "then": {
        "properties": {
          "source_module_code": {
            "const": "EVIDENCE_TIDE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "focus_handoff": {
            "properties": {
              "window_focus_target": {
                "const": "DETAIL_BODY"
              }
            },
            "required": [
              "window_focus_target"
            ]
          }
        },
        "required": [
          "focus_handoff"
        ]
      },
      "then": {
        "properties": {
          "summary_loading": {
            "properties": {
              "detail_state": {
                "const": "READY"
              }
            },
            "required": [
              "detail_state"
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
