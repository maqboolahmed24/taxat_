{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/manifest_lineage_trace.schema.json",
  "title": "ManifestLineageTrace",
  "description": "Authoritative request-time manifest lineage explorer and reuse-decision tracer. This schema freezes the exact branch inputs, selected branch outcome, selected manifest lineage snapshot, typed candidate disqualifiers, mirror-parity state, nightly predecessor context, and audit/span refs so bundle return, sealed-manifest reuse, replay, recovery, continuation, amendment, and nightly branch decisions remain durably explainable.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "lineage_trace_id",
    "contract_version",
    "binding_scope",
    "explorer_binding_policy",
    "operator_rendering_policy",
    "mirror_consistency_policy",
    "nightly_context_policy",
    "idempotency_key",
    "request_identity_hash",
    "access_binding_hash",
    "requested_scope",
    "effective_scope",
    "mode",
    "run_kind",
    "replay_class_or_null",
    "nightly_window_key_or_null",
    "selected_branch_action",
    "selected_branch_reason_code",
    "selected_manifest_id",
    "selected_manifest_continuation_basis",
    "selected_manifest_generation",
    "root_manifest_id",
    "parent_manifest_id_or_null",
    "continuation_of_manifest_id_or_null",
    "replay_of_manifest_id_or_null",
    "supersedes_manifest_id_or_null",
    "prior_manifest_id_or_null",
    "prior_manifest_hash_at_decision_or_null",
    "prior_manifest_lifecycle_state_or_null",
    "config_inheritance_mode_or_null",
    "input_inheritance_mode_or_null",
    "returned_decision_bundle_hash_or_null",
    "candidate_evaluations",
    "mirror_consistency_state",
    "mirror_sources",
    "nightly_predecessor_batch_run_ref_or_null",
    "nightly_predecessor_manifest_id_or_null",
    "nightly_predecessor_manifest_hash_or_null",
    "nightly_context_reason_code_or_null",
    "branch_decision_audit_refs",
    "branch_decision_trace_span_refs"
  ],
  "properties": {
    "lineage_trace_id": {
      "type": "string",
      "minLength": 1
    },
    "contract_version": {
      "const": "MANIFEST_LINEAGE_TRACE_V1"
    },
    "binding_scope": {
      "const": "RUN_MANIFEST_BRANCH_SELECTION"
    },
    "explorer_binding_policy": {
      "const": "PERSIST_SELECTED_BRANCH_AND_ALL_REJECTION_BASES"
    },
    "operator_rendering_policy": {
      "const": "USE_PERSISTED_TRACE_NOT_ADJACENT_MANIFEST_INFERENCE"
    },
    "mirror_consistency_policy": {
      "const": "SELECTED_MANIFEST_LINEAGE_MIRRORS_MUST_STAY_EXACT"
    },
    "nightly_context_policy": {
      "const": "NIGHTLY_WINDOW_AND_PREDECESSOR_CONTEXT_PERSISTED_WHEN_APPLICABLE"
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "request_identity_hash": {
      "type": "string",
      "minLength": 1
    },
    "access_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "requested_scope": {
      "$ref": "#/$defs/scopeArray"
    },
    "effective_scope": {
      "$ref": "#/$defs/scopeArray"
    },
    "mode": {
      "type": "string",
      "enum": [
        "COMPLIANCE",
        "ANALYSIS"
      ]
    },
    "run_kind": {
      "type": "string",
      "enum": [
        "INTERACTIVE",
        "NIGHTLY",
        "BACKFILL",
        "REPLAY",
        "REMEDIATION",
        "AMENDMENT",
        "MIGRATION"
      ]
    },
    "replay_class_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "STANDARD_REPLAY",
        "AUDIT_REPLAY",
        "COUNTERFACTUAL_ANALYSIS",
        null
      ]
    },
    "nightly_window_key_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "selected_branch_action": {
      "type": "string",
      "enum": [
        "NEW_MANIFEST",
        "RETURN_EXISTING_BUNDLE",
        "REUSE_SEALED_MANIFEST",
        "REPLAY_CHILD",
        "RECOVERY_CHILD",
        "CONTINUATION_CHILD",
        "NEW_REQUEST_CHILD"
      ]
    },
    "selected_branch_reason_code": {
      "type": "string",
      "enum": [
        "NO_PRIOR_MANIFEST",
        "TERMINAL_IDEMPOTENT_RETRY",
        "PRESTART_SEALED_CONTEXT_REUSE",
        "REPLAY_REQUESTED_EXACT",
        "STARTED_ATTEMPT_RECOVERY",
        "POST_TERMINAL_CONTINUATION_REQUIRED",
        "REQUEST_IDENTITY_CHANGED",
        "NIGHTLY_WINDOW_ADVANCED"
      ]
    },
    "selected_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "selected_manifest_continuation_basis": {
      "type": "string",
      "enum": [
        "NEW_MANIFEST",
        "REPLAY_CHILD",
        "RECOVERY_CHILD",
        "CONTINUATION_CHILD",
        "NEW_REQUEST_CHILD"
      ]
    },
    "selected_manifest_generation": {
      "type": "integer",
      "minimum": 0
    },
    "root_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_manifest_id_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "continuation_of_manifest_id_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "replay_of_manifest_id_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "supersedes_manifest_id_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "prior_manifest_id_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "prior_manifest_hash_at_decision_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "prior_manifest_lifecycle_state_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "ALLOCATED",
        "FROZEN",
        "SEALED",
        "IN_PROGRESS",
        "COMPLETED",
        "BLOCKED",
        "FAILED",
        "SUPERSEDED",
        "REPLAY_ONLY",
        "RETIRED",
        null
      ]
    },
    "config_inheritance_mode_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "FRESH_CHILD_RESOLUTION",
        "REPLAY_EXACT",
        "RECOVERY_EXACT",
        "HISTORICAL_EXPLICIT",
        null
      ]
    },
    "input_inheritance_mode_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "FRESH_CHILD_COLLECTION",
        "REPLAY_EXACT",
        "RECOVERY_EXACT",
        "HISTORICAL_EXPLICIT",
        null
      ]
    },
    "returned_decision_bundle_hash_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "candidate_evaluations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidateEvaluation"
      },
      "minItems": 1
    },
    "mirror_consistency_state": {
      "const": "ALL_MIRRORS_IN_SYNC"
    },
    "mirror_sources": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "RUN_MANIFEST_TOP_LEVEL",
          "CONTINUATION_SET",
          "MANIFEST_BRANCH_DECISION",
          "FROZEN_EXECUTION_BINDING"
        ]
      },
      "minItems": 3,
      "uniqueItems": true
    },
    "nightly_predecessor_batch_run_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "nightly_predecessor_manifest_id_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "nightly_predecessor_manifest_hash_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "nightly_context_reason_code_or_null": {
      "type": "string",
      "enum": [
        "NOT_NIGHTLY",
        "NO_PREDECESSOR_BATCH",
        "SAME_WINDOW_REUSE",
        "WINDOW_ADVANCE_FROM_PREDECESSOR"
      ]
    },
    "branch_decision_audit_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "branch_decision_trace_span_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "run_kind": {
            "const": "NIGHTLY"
          }
        },
        "required": [
          "run_kind"
        ]
      },
      "then": {
        "properties": {
          "nightly_window_key_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "run_kind": {
            "not": {
              "const": "NIGHTLY"
            }
          }
        },
        "required": [
          "run_kind"
        ]
      },
      "then": {
        "properties": {
          "nightly_window_key_or_null": {
            "type": "null"
          },
          "nightly_predecessor_batch_run_ref_or_null": {
            "type": "null"
          },
          "nightly_predecessor_manifest_id_or_null": {
            "type": "null"
          },
          "nightly_predecessor_manifest_hash_or_null": {
            "type": "null"
          },
          "nightly_context_reason_code_or_null": {
            "const": "NOT_NIGHTLY"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "run_kind": {
            "const": "REPLAY"
          }
        },
        "required": [
          "run_kind"
        ]
      },
      "then": {
        "properties": {
          "replay_class_or_null": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_branch_action": {
            "const": "NEW_MANIFEST"
          }
        },
        "required": [
          "selected_branch_action"
        ]
      },
      "then": {
        "properties": {
          "selected_manifest_continuation_basis": {
            "const": "NEW_MANIFEST"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_branch_action": {
            "const": "RETURN_EXISTING_BUNDLE"
          }
        },
        "required": [
          "selected_branch_action"
        ]
      },
      "then": {
        "properties": {
          "returned_decision_bundle_hash_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_branch_action": {
            "const": "REPLAY_CHILD"
          }
        },
        "required": [
          "selected_branch_action"
        ]
      },
      "then": {
        "properties": {
          "selected_manifest_continuation_basis": {
            "const": "REPLAY_CHILD"
          },
          "config_inheritance_mode_or_null": {
            "const": "REPLAY_EXACT"
          },
          "input_inheritance_mode_or_null": {
            "const": "REPLAY_EXACT"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_branch_action": {
            "const": "RECOVERY_CHILD"
          }
        },
        "required": [
          "selected_branch_action"
        ]
      },
      "then": {
        "properties": {
          "selected_manifest_continuation_basis": {
            "const": "RECOVERY_CHILD"
          },
          "config_inheritance_mode_or_null": {
            "const": "RECOVERY_EXACT"
          },
          "input_inheritance_mode_or_null": {
            "const": "RECOVERY_EXACT"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_branch_action": {
            "const": "CONTINUATION_CHILD"
          }
        },
        "required": [
          "selected_branch_action"
        ]
      },
      "then": {
        "properties": {
          "selected_manifest_continuation_basis": {
            "const": "CONTINUATION_CHILD"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_branch_action": {
            "const": "NEW_REQUEST_CHILD"
          }
        },
        "required": [
          "selected_branch_action"
        ]
      },
      "then": {
        "properties": {
          "selected_manifest_continuation_basis": {
            "const": "NEW_REQUEST_CHILD"
          }
        }
      }
    }
  ],
  "$defs": {
    "scopeArray": {
      "type": "array",
      "prefixItems": [
        {
          "enum": [
            "year_end",
            "quarterly_update",
            "estimate_only"
          ]
        }
      ],
      "items": {
        "type": "string",
        "enum": [
          "year_end",
          "quarterly_update",
          "estimate_only",
          "prepare_submission",
          "submit",
          "amendment_intent",
          "amendment_submit"
        ]
      },
      "contains": {
        "enum": [
          "year_end",
          "quarterly_update",
          "estimate_only"
        ]
      },
      "minContains": 1,
      "maxContains": 1,
      "minItems": 1,
      "uniqueItems": true
    },
    "candidateEvaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_action",
        "evaluation_state",
        "compared_manifest_id_or_null",
        "compared_manifest_hash_or_null",
        "compared_manifest_lifecycle_state_or_null",
        "disqualifier_reason_codes"
      ],
      "properties": {
        "candidate_action": {
          "type": "string",
          "enum": [
            "NEW_MANIFEST",
            "RETURN_EXISTING_BUNDLE",
            "REUSE_SEALED_MANIFEST",
            "REPLAY_CHILD",
            "RECOVERY_CHILD",
            "CONTINUATION_CHILD",
            "NEW_REQUEST_CHILD"
          ]
        },
        "evaluation_state": {
          "type": "string",
          "enum": [
            "SELECTED",
            "REJECTED"
          ]
        },
        "compared_manifest_id_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "compared_manifest_hash_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "compared_manifest_lifecycle_state_or_null": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "ALLOCATED",
            "FROZEN",
            "SEALED",
            "IN_PROGRESS",
            "COMPLETED",
            "BLOCKED",
            "FAILED",
            "SUPERSEDED",
            "REPLAY_ONLY",
            "RETIRED",
            null
          ]
        },
        "disqualifier_reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "NO_PRIOR_MANIFEST",
              "REQUEST_IDENTITY_HASH_MISMATCH",
              "ACCESS_BINDING_HASH_MISMATCH",
              "REQUESTED_SCOPE_MISMATCH",
              "EFFECTIVE_SCOPE_MISMATCH",
              "MODE_MISMATCH",
              "RUN_KIND_MISMATCH",
              "REPLAY_CLASS_MISMATCH",
              "NIGHTLY_WINDOW_MISMATCH",
              "PRIOR_MANIFEST_NOT_TERMINAL",
              "PRIOR_MANIFEST_NOT_SEALED",
              "PRIOR_MANIFEST_ALREADY_STARTED",
              "PRIOR_MANIFEST_HASH_MISSING",
              "PARENT_MANIFEST_HASH_MISMATCH",
              "CONFIG_INHERITANCE_MODE_MISMATCH",
              "INPUT_INHERITANCE_MODE_MISMATCH",
              "REPLAY_NOT_REQUESTED",
              "RECOVERY_NOT_REQUIRED",
              "CONTINUATION_NOT_LEGAL",
              "REQUEST_IDENTITY_CONTINUATION_NOT_REQUIRED",
              "RETURNED_BUNDLE_NOT_AVAILABLE",
              "NIGHTLY_PREDECESSOR_CONTEXT_MISSING",
              "NIGHTLY_PREDECESSOR_BATCH_MISSING",
              "NIGHTLY_PREDECESSOR_MANIFEST_MISSING",
              "CHILD_ALLOCATION_NOT_REQUIRED"
            ]
          },
          "uniqueItems": true
        }
      }
    }
  }
}
