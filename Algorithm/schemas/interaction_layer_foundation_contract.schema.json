{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/interaction_layer_foundation_contract.schema.json",
  "title": "InteractionLayerFoundationContract",
  "description": "Shared cross-shell design-token and interaction-layer foundation. This schema makes layout-density tokens, surface-spacing tokens, responsive-compaction tokens, selector profiles, motion posture, support-surface budgeting, recovery posture, history treatment, preview posture, notification posture, secondary-window posture, and durable feedback truth explicit as one governed systems contract. It exists so operator, portal, governance, collaboration, and native embodiments cannot encode shell semantics indirectly through local theme defaults, route-local spacing forks, or platform-local behavior drift.",
  "type": "object",
  "required": [
    "contract_version",
    "shell_family",
    "design_token_binding_policy",
    "layout_density_token",
    "surface_spacing_token",
    "support_surface_spacing_token",
    "responsive_compaction_token",
    "selector_profile",
    "support_surface_policy",
    "continuity_policy",
    "recovery_surface_policy",
    "history_presentation_policy",
    "preview_surface_policy",
    "notification_surface_policy",
    "secondary_window_policy",
    "motion_profile",
    "motion_token",
    "feedback_truth_policy",
    "platform_parity_policy"
  ],
  "properties": {
    "contract_version": {
      "const": "CROSS_SHELL_INTERACTION_FOUNDATION_V1"
    },
    "shell_family": {
      "type": "string",
      "enum": [
        "CALM_SHELL",
        "CLIENT_PORTAL_SHELL",
        "GOVERNANCE_DENSITY_SHELL"
      ]
    },
    "design_token_binding_policy": {
      "const": "EXPLICIT_SEMANTIC_BINDINGS_ONLY"
    },
    "layout_density_token": {
      "type": "string",
      "enum": [
        "CALM_FOUR_SURFACE_DENSITY_V1",
        "PORTAL_COMFORTABLE_TASK_DENSITY_V1",
        "GOVERNANCE_WORKSPACE_DENSITY_V1"
      ]
    },
    "surface_spacing_token": {
      "type": "string",
      "enum": [
        "CALM_FOUR_SURFACE_SPACING_V1",
        "PORTAL_PRIMARY_STACK_SPACING_V1",
        "GOVERNANCE_CANVAS_SPACING_V1"
      ]
    },
    "support_surface_spacing_token": {
      "type": "string",
      "enum": [
        "CALM_DETAIL_DRAWER_SUPPORT_SPACING_V1",
        "PORTAL_INLINE_SUPPORT_SPACING_V1",
        "GOVERNANCE_AUXILIARY_SURFACE_SPACING_V1"
      ]
    },
    "responsive_compaction_token": {
      "type": "string",
      "enum": [
        "CALM_SUPPORT_REDOCK_V1",
        "PORTAL_STACK_BELOW_PRIMARY_V1",
        "GOVERNANCE_AUXILIARY_REDOCK_V1"
      ]
    },
    "selector_profile": {
      "type": "string",
      "enum": [
        "OPERATOR_SEMANTIC_SELECTORS_V1",
        "PORTAL_SEMANTIC_SELECTORS_V1",
        "GOVERNANCE_SEMANTIC_SELECTORS_V1"
      ]
    },
    "support_surface_policy": {
      "const": "ONE_PROMOTED_SUPPORT_SURFACE_MAX"
    },
    "continuity_policy": {
      "type": "string",
      "enum": [
        "SAME_OBJECT_SAME_SHELL_INLINE_RECOVERY",
        "SAME_SHELL_CONTEXTUAL_RETURN",
        "SAME_OBJECT_SAME_SHELL_CONTEXT_RETENTION"
      ]
    },
    "recovery_surface_policy": {
      "type": "string",
      "enum": [
        "INLINE_EXPLICIT_REBASE",
        "INLINE_REVIEW_OR_RECOVERY_NOTICE",
        "INLINE_TYPED_CONTEXTUAL_RECOVERY"
      ]
    },
    "history_presentation_policy": {
      "type": "string",
      "enum": [
        "CURRENT_PRIMARY_HISTORY_SECONDARY",
        "ACTIVE_SLICE_PRIMARY_CONTEXTUAL_HISTORY"
      ]
    },
    "preview_surface_policy": {
      "type": "string",
      "enum": [
        "DETAIL_DRAWER_OR_PARENT_BOUND_SECONDARY_WINDOW",
        "PRIMARY_CONTEXT_WITH_STACKED_SUPPORT",
        "AUXILIARY_SURFACE_CONTEXTUAL_ONLY"
      ]
    },
    "notification_surface_policy": {
      "type": "string",
      "enum": [
        "CONTEXT_BOUND_INLINE_FEEDBACK_OR_PARENT_MIRROR",
        "CONTEXT_BOUND_INLINE_FEEDBACK"
      ]
    },
    "secondary_window_policy": {
      "type": "string",
      "enum": [
        "SUPPORT_ONLY_PARENT_BOUND_CLOSE_RETURNS_FOCUS",
        "NOT_APPLICABLE"
      ]
    },
    "motion_profile": {
      "const": "SUBTLE_CAUSAL_ONLY"
    },
    "motion_token": {
      "const": "SUBTLE_CAUSAL_MOTION_V1"
    },
    "feedback_truth_policy": {
      "const": "DURABLE_RECEIPT_AND_TYPED_FAILURE_DRIVEN"
    },
    "platform_parity_policy": {
      "const": "SAME_FAMILY_REUSES_SAME_INTERACTION_GRAMMAR"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "shell_family": {
            "const": "CALM_SHELL"
          }
        }
      },
      "then": {
        "properties": {
          "layout_density_token": {
            "const": "CALM_FOUR_SURFACE_DENSITY_V1"
          },
          "surface_spacing_token": {
            "const": "CALM_FOUR_SURFACE_SPACING_V1"
          },
          "support_surface_spacing_token": {
            "const": "CALM_DETAIL_DRAWER_SUPPORT_SPACING_V1"
          },
          "responsive_compaction_token": {
            "const": "CALM_SUPPORT_REDOCK_V1"
          },
          "selector_profile": {
            "const": "OPERATOR_SEMANTIC_SELECTORS_V1"
          },
          "continuity_policy": {
            "const": "SAME_OBJECT_SAME_SHELL_INLINE_RECOVERY"
          },
          "recovery_surface_policy": {
            "const": "INLINE_EXPLICIT_REBASE"
          },
          "history_presentation_policy": {
            "const": "CURRENT_PRIMARY_HISTORY_SECONDARY"
          },
          "preview_surface_policy": {
            "const": "DETAIL_DRAWER_OR_PARENT_BOUND_SECONDARY_WINDOW"
          },
          "notification_surface_policy": {
            "const": "CONTEXT_BOUND_INLINE_FEEDBACK_OR_PARENT_MIRROR"
          },
          "secondary_window_policy": {
            "const": "SUPPORT_ONLY_PARENT_BOUND_CLOSE_RETURNS_FOCUS"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "shell_family": {
            "const": "CLIENT_PORTAL_SHELL"
          }
        }
      },
      "then": {
        "properties": {
          "layout_density_token": {
            "const": "PORTAL_COMFORTABLE_TASK_DENSITY_V1"
          },
          "surface_spacing_token": {
            "const": "PORTAL_PRIMARY_STACK_SPACING_V1"
          },
          "support_surface_spacing_token": {
            "const": "PORTAL_INLINE_SUPPORT_SPACING_V1"
          },
          "responsive_compaction_token": {
            "const": "PORTAL_STACK_BELOW_PRIMARY_V1"
          },
          "selector_profile": {
            "const": "PORTAL_SEMANTIC_SELECTORS_V1"
          },
          "continuity_policy": {
            "const": "SAME_SHELL_CONTEXTUAL_RETURN"
          },
          "recovery_surface_policy": {
            "const": "INLINE_REVIEW_OR_RECOVERY_NOTICE"
          },
          "history_presentation_policy": {
            "const": "CURRENT_PRIMARY_HISTORY_SECONDARY"
          },
          "preview_surface_policy": {
            "const": "PRIMARY_CONTEXT_WITH_STACKED_SUPPORT"
          },
          "notification_surface_policy": {
            "const": "CONTEXT_BOUND_INLINE_FEEDBACK"
          },
          "secondary_window_policy": {
            "const": "NOT_APPLICABLE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "shell_family": {
            "const": "GOVERNANCE_DENSITY_SHELL"
          }
        }
      },
      "then": {
        "properties": {
          "layout_density_token": {
            "const": "GOVERNANCE_WORKSPACE_DENSITY_V1"
          },
          "surface_spacing_token": {
            "const": "GOVERNANCE_CANVAS_SPACING_V1"
          },
          "support_surface_spacing_token": {
            "const": "GOVERNANCE_AUXILIARY_SURFACE_SPACING_V1"
          },
          "responsive_compaction_token": {
            "const": "GOVERNANCE_AUXILIARY_REDOCK_V1"
          },
          "selector_profile": {
            "const": "GOVERNANCE_SEMANTIC_SELECTORS_V1"
          },
          "continuity_policy": {
            "const": "SAME_OBJECT_SAME_SHELL_CONTEXT_RETENTION"
          },
          "recovery_surface_policy": {
            "const": "INLINE_TYPED_CONTEXTUAL_RECOVERY"
          },
          "history_presentation_policy": {
            "const": "ACTIVE_SLICE_PRIMARY_CONTEXTUAL_HISTORY"
          },
          "preview_surface_policy": {
            "const": "AUXILIARY_SURFACE_CONTEXTUAL_ONLY"
          },
          "notification_surface_policy": {
            "const": "CONTEXT_BOUND_INLINE_FEEDBACK"
          },
          "secondary_window_policy": {
            "const": "NOT_APPLICABLE"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
