{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/trust_summary.schema.json",
  "title": "TrustSummary",
  "description": "Deterministic trust-synthesis artifact. This schema freezes one manifest-scoped trust decision together with its upstream artifact lineage, scoring inputs, penalty basis, reviewer steps, and supersession state.",
  "type": "object",
  "required": [
    "trust_id",
    "manifest_id",
    "artifact_type",
    "execution_mode",
    "analysis_only",
    "non_compliance_config_refs",
    "counterfactual_basis",
    "execution_mode_boundary_contract",
    "lifecycle_state",
    "compute_result_ref",
    "parity_result_ref",
    "risk_report_ref",
    "evidence_graph_ref",
    "gate_decision_refs",
    "comparison_requirement",
    "parity_classification",
    "baseline_submission_state",
    "live_authority_progression_requested",
    "completeness_score",
    "data_quality_score",
    "parity_score",
    "graph_quality_score",
    "risk_score",
    "trust_core_score",
    "score_band",
    "cap_band",
    "trust_band",
    "trust_score",
    "trust_input_state",
    "trust_input_basis_contract",
    "trust_sensitivity_analysis_contract",
    "threshold_stability_state",
    "upstream_gate_cap",
    "trust_green_margin",
    "trust_amber_margin",
    "risk_automation_margin",
    "active_filing_critical_override_count",
    "critical_retention_limited_count",
    "unresolved_material_blocking_risk_flag",
    "unresolved_blocking_risk_flag",
    "override_penalty",
    "retention_penalty",
    "authority_uncertainty_score",
    "authority_penalty",
    "trust_level",
    "automation_level",
    "filing_readiness",
    "dominant_reason_code",
    "plain_summary",
    "decision_explainability_contract",
    "decision_constraint_codes",
    "reason_codes",
    "blocking_dependency_refs",
    "temporal_propagation_event_refs",
    "support_refs",
    "required_human_steps",
    "trust_fresh_until",
    "synthesized_at",
    "superseded_at",
    "superseded_by_trust_id",
    "contract"
  ],
  "properties": {
    "trust_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "TrustSummary"
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "COMPLIANCE",
        "ANALYSIS"
      ]
    },
    "analysis_only": {
      "type": "boolean"
    },
    "non_compliance_config_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "counterfactual_basis": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "execution_mode_boundary_contract": {
      "$ref": "https://taxat.dev/schemas/execution_mode_boundary_contract.schema.json"
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "SYNTHESIZED",
        "SUPERSEDED"
      ]
    },
    "compute_result_ref": {
      "type": "string",
      "minLength": 1
    },
    "parity_result_ref": {
      "type": "string",
      "minLength": 1
    },
    "risk_report_ref": {
      "type": "string",
      "minLength": 1
    },
    "evidence_graph_ref": {
      "type": "string",
      "minLength": 1
    },
    "gate_decision_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "comparison_requirement": {
      "type": "string",
      "enum": [
        "MANDATORY",
        "DESIRABLE",
        "NOT_REQUIRED"
      ]
    },
    "parity_classification": {
      "type": "string",
      "enum": [
        "MATCH",
        "MINOR_DIFFERENCE",
        "MATERIAL_DIFFERENCE",
        "BLOCKING_DIFFERENCE",
        "NOT_COMPARABLE"
      ]
    },
    "baseline_submission_state": {
      "type": "string",
      "enum": [
        "KNOWN_MATCHED",
        "KNOWN_FILED",
        "UNKNOWN",
        "OUT_OF_BAND_UNRECONCILED",
        "NOT_APPLICABLE"
      ]
    },
    "live_authority_progression_requested": {
      "type": "boolean"
    },
    "completeness_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "data_quality_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "parity_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "graph_quality_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "risk_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "trust_core_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "score_band": {
      "type": "string",
      "enum": [
        "RED",
        "AMBER",
        "GREEN"
      ]
    },
    "cap_band": {
      "type": "string",
      "enum": [
        "INSUFFICIENT_DATA",
        "RED",
        "AMBER",
        "GREEN"
      ]
    },
    "trust_band": {
      "type": "string",
      "enum": [
        "INSUFFICIENT_DATA",
        "RED",
        "AMBER",
        "GREEN"
      ]
    },
    "trust_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "trust_input_state": {
      "type": "string",
      "enum": [
        "ADMISSIBLE_CURRENT",
        "ADMISSIBLE_STALE",
        "INCOMPLETE",
        "CONTRADICTED"
      ]
    },
    "trust_input_basis_contract": {
      "$ref": "https://taxat.dev/schemas/trust_input_basis_contract.schema.json"
    },
    "trust_sensitivity_analysis_contract": {
      "$ref": "https://taxat.dev/schemas/trust_sensitivity_analysis_contract.schema.json"
    },
    "threshold_stability_state": {
      "type": "string",
      "enum": [
        "STABLE",
        "EDGE_REVIEW"
      ]
    },
    "upstream_gate_cap": {
      "type": "string",
      "enum": [
        "AUTO_ELIGIBLE",
        "NOTICE_ONLY",
        "REVIEW_ONLY",
        "BLOCKED"
      ]
    },
    "trust_green_margin": {
      "type": "integer"
    },
    "trust_amber_margin": {
      "type": "integer"
    },
    "risk_automation_margin": {
      "type": "integer"
    },
    "active_filing_critical_override_count": {
      "type": "integer",
      "minimum": 0
    },
    "critical_retention_limited_count": {
      "type": "integer",
      "minimum": 0
    },
    "unresolved_material_blocking_risk_flag": {
      "type": "boolean"
    },
    "unresolved_blocking_risk_flag": {
      "type": "boolean"
    },
    "override_penalty": {
      "type": "integer",
      "enum": [
        0,
        5,
        10,
        15,
        20
      ]
    },
    "retention_penalty": {
      "type": "integer",
      "enum": [
        0,
        20
      ]
    },
    "authority_uncertainty_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "authority_penalty": {
      "type": "integer",
      "minimum": 0,
      "maximum": 30
    },
    "trust_level": {
      "type": "string",
      "enum": [
        "READY",
        "REVIEW_REQUIRED",
        "BLOCKED"
      ]
    },
    "automation_level": {
      "type": "string",
      "enum": [
        "ALLOWED",
        "LIMITED",
        "BLOCKED"
      ]
    },
    "filing_readiness": {
      "type": "string",
      "enum": [
        "NOT_READY",
        "READY_REVIEW",
        "READY_TO_SUBMIT"
      ]
    },
    "dominant_reason_code": {
      "type": "string",
      "minLength": 1
    },
    "plain_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "decision_explainability_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/decision_explainability_contract.schema.json"
        },
        {
          "properties": {
            "artifact_family": {
              "const": "TRUST_SUMMARY"
            },
            "plain_text_field_name": {
              "const": "plain_summary"
            }
          }
        }
      ]
    },
    "decision_constraint_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "maxItems": 8,
      "uniqueItems": true
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true
    },
    "blocking_dependency_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "temporal_propagation_event_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "support_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "required_human_steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "trust_fresh_until": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "synthesized_at": {
      "type": "string",
      "format": "date-time"
    },
    "superseded_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "superseded_by_trust_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "execution_mode": {
            "const": "COMPLIANCE"
          }
        },
        "required": [
          "execution_mode"
        ]
      },
      "then": {
        "properties": {
          "analysis_only": {
            "const": false
          },
          "non_compliance_config_refs": {
            "maxItems": 0
          },
          "counterfactual_basis": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "execution_mode": {
            "const": "ANALYSIS"
          }
        },
        "required": [
          "execution_mode"
        ]
      },
      "then": {
        "properties": {
          "analysis_only": {
            "const": true
          },
          "reason_codes": {
            "contains": {
              "const": "TRUST_ANALYSIS_MODE_CAP"
            }
          },
          "counterfactual_basis": {
            "type": "string",
            "minLength": 1
          },
          "trust_band": {
            "enum": [
              "AMBER",
              "RED",
              "INSUFFICIENT_DATA"
            ]
          },
          "automation_level": {
            "enum": [
              "LIMITED",
              "BLOCKED"
            ]
          },
          "filing_readiness": {
            "enum": [
              "NOT_READY",
              "READY_REVIEW"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "score_band": {
            "const": "GREEN"
          }
        },
        "required": [
          "score_band"
        ]
      },
      "then": {
        "properties": {
          "trust_score": {
            "minimum": 85
          },
          "trust_green_margin": {
            "minimum": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "score_band": {
            "const": "AMBER"
          }
        },
        "required": [
          "score_band"
        ]
      },
      "then": {
        "properties": {
          "trust_score": {
            "minimum": 65,
            "maximum": 84
          },
          "trust_green_margin": {
            "maximum": -1
          },
          "trust_amber_margin": {
            "minimum": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "score_band": {
            "const": "RED"
          }
        },
        "required": [
          "score_band"
        ]
      },
      "then": {
        "properties": {
          "trust_score": {
            "maximum": 64
          },
          "trust_amber_margin": {
            "maximum": -1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cap_band": {
            "const": "INSUFFICIENT_DATA"
          }
        },
        "required": [
          "cap_band"
        ]
      },
      "then": {
        "properties": {
          "trust_band": {
            "const": "INSUFFICIENT_DATA"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cap_band": {
            "const": "RED"
          }
        },
        "required": [
          "cap_band"
        ]
      },
      "then": {
        "properties": {
          "trust_band": {
            "const": "RED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "trust_level": {
            "const": "READY"
          }
        },
        "required": [
          "trust_level"
        ]
      },
      "then": {
        "properties": {
          "decision_constraint_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "trust_level": {
            "const": "BLOCKED"
          }
        },
        "required": [
          "trust_level"
        ]
      },
      "then": {
        "properties": {
          "automation_level": {
            "const": "BLOCKED"
          },
          "filing_readiness": {
            "const": "NOT_READY"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "required_human_steps": {
            "minItems": 1
          }
        },
        "required": [
          "required_human_steps"
        ]
      },
      "then": {
        "properties": {
          "automation_level": {
            "enum": [
              "LIMITED",
              "BLOCKED"
            ]
          },
          "filing_readiness": {
            "enum": [
              "NOT_READY",
              "READY_REVIEW"
            ]
          },
          "reason_codes": {
            "contains": {
              "const": "TRUST_REQUIRED_HUMAN_STEPS"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "automation_level": {
            "const": "ALLOWED"
          }
        },
        "required": [
          "automation_level"
        ]
      },
      "then": {
        "properties": {
          "trust_band": {
            "const": "GREEN"
          },
          "trust_input_basis_contract": {
            "properties": {
              "automation_ceiling": {
                "const": "ALLOWED"
              }
            }
          },
          "trust_level": {
            "const": "READY"
          },
          "filing_readiness": {
            "const": "READY_TO_SUBMIT"
          },
          "required_human_steps": {
            "maxItems": 0
          },
          "active_filing_critical_override_count": {
            "const": 0
          },
          "critical_retention_limited_count": {
            "const": 0
          },
          "execution_mode": {
            "const": "COMPLIANCE"
          },
          "trust_input_state": {
            "const": "ADMISSIBLE_CURRENT"
          },
          "threshold_stability_state": {
            "const": "STABLE"
          },
          "risk_automation_margin": {
            "minimum": 2
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "automation_level": {
            "const": "LIMITED"
          }
        },
        "required": [
          "automation_level"
        ]
      },
      "then": {
        "properties": {
          "trust_band": {
            "const": "AMBER"
          },
          "trust_level": {
            "const": "REVIEW_REQUIRED"
          },
          "filing_readiness": {
            "const": "READY_REVIEW"
          },
          "reason_codes": {
            "contains": {
              "const": "TRUST_AUTOMATION_LIMITED"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "automation_level": {
            "const": "BLOCKED"
          }
        },
        "required": [
          "automation_level"
        ]
      },
      "then": {
        "properties": {
          "filing_readiness": {
            "const": "NOT_READY"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "filing_readiness": {
            "const": "NOT_READY"
          }
        },
        "required": [
          "filing_readiness"
        ]
      },
      "then": {
        "properties": {
          "automation_level": {
            "const": "BLOCKED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "filing_readiness": {
            "const": "READY_TO_SUBMIT"
          }
        },
        "required": [
          "filing_readiness"
        ]
      },
      "then": {
        "properties": {
          "automation_level": {
            "const": "ALLOWED"
          },
          "trust_input_basis_contract": {
            "properties": {
              "filing_readiness_ceiling": {
                "const": "READY_TO_SUBMIT"
              }
            }
          },
          "trust_band": {
            "const": "GREEN"
          },
          "trust_level": {
            "const": "READY"
          },
          "required_human_steps": {
            "maxItems": 0
          },
          "trust_input_state": {
            "const": "ADMISSIBLE_CURRENT"
          },
          "threshold_stability_state": {
            "const": "STABLE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "trust_band": {
            "const": "GREEN"
          }
        },
        "required": [
          "trust_band"
        ]
      },
      "then": {
        "properties": {
          "trust_input_basis_contract": {
            "properties": {
              "trust_input_state": {
                "const": "ADMISSIBLE_CURRENT"
              },
              "automation_ceiling": {
                "const": "ALLOWED"
              },
              "filing_readiness_ceiling": {
                "const": "READY_TO_SUBMIT"
              }
            }
          },
          "trust_level": {
            "const": "READY"
          },
          "automation_level": {
            "const": "ALLOWED"
          },
          "filing_readiness": {
            "const": "READY_TO_SUBMIT"
          },
          "trust_score": {
            "minimum": 85
          },
          "parity_classification": {
            "enum": [
              "MATCH",
              "MINOR_DIFFERENCE"
            ]
          },
          "required_human_steps": {
            "maxItems": 0
          },
          "trust_input_state": {
            "const": "ADMISSIBLE_CURRENT"
          },
          "threshold_stability_state": {
            "const": "STABLE"
          },
          "active_filing_critical_override_count": {
            "const": 0
          },
          "critical_retention_limited_count": {
            "const": 0
          },
          "unresolved_material_blocking_risk_flag": {
            "const": false
          },
          "unresolved_blocking_risk_flag": {
            "const": false
          },
          "trust_green_margin": {
            "minimum": 0
          },
          "reason_codes": {
            "contains": {
              "const": "TRUST_GREEN"
            }
          },
          "execution_mode": {
            "const": "COMPLIANCE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "trust_band": {
            "const": "AMBER"
          }
        },
        "required": [
          "trust_band"
        ]
      },
      "then": {
        "properties": {
          "trust_level": {
            "const": "REVIEW_REQUIRED"
          },
          "filing_readiness": {
            "const": "READY_REVIEW"
          },
          "automation_level": {
            "const": "LIMITED"
          },
          "trust_score": {
            "minimum": 65
          },
          "trust_amber_margin": {
            "minimum": 0
          },
          "unresolved_blocking_risk_flag": {
            "const": false
          },
          "reason_codes": {
            "contains": {
              "const": "TRUST_AMBER"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "trust_band": {
            "const": "RED"
          }
        },
        "required": [
          "trust_band"
        ]
      },
      "then": {
        "properties": {
          "trust_level": {
            "const": "BLOCKED"
          },
          "automation_level": {
            "const": "BLOCKED"
          },
          "filing_readiness": {
            "const": "NOT_READY"
          },
          "reason_codes": {
            "contains": {
              "const": "TRUST_RED"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "trust_band": {
            "const": "INSUFFICIENT_DATA"
          }
        },
        "required": [
          "trust_band"
        ]
      },
      "then": {
        "properties": {
          "trust_level": {
            "const": "BLOCKED"
          },
          "automation_level": {
            "const": "BLOCKED"
          },
          "filing_readiness": {
            "const": "NOT_READY"
          },
          "reason_codes": {
            "contains": {
              "const": "TRUST_INSUFFICIENT_DATA"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "filing_readiness": {
            "const": "READY_REVIEW"
          }
        },
        "required": [
          "filing_readiness"
        ]
      },
      "then": {
        "properties": {
          "trust_band": {
            "const": "AMBER"
          },
          "automation_level": {
            "const": "LIMITED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "SUPERSEDED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "superseded_at": {
            "type": "string",
            "format": "date-time"
