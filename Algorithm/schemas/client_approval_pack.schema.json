{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/client_approval_pack.schema.json",
  "title": "ClientApprovalPack",
  "description": "Client-facing approval and sign-off contract. This contract preserves stale-view protection, explicit approval-readiness scoring, and contained step-up semantics for client sign-off flows.",
  "type": "object",
  "required": [
    "approval_pack_id",
    "artifact_type",
    "tenant_id",
    "client_id",
    "manifest_id",
    "title",
    "summary_ref",
    "change_highlights_ref",
    "declaration_text_ref",
    "approval_pack_hash",
    "view_guard_ref",
    "stale_protection_state",
    "lifecycle_state",
    "requires_step_up",
    "viewed_at",
    "change_digest_acknowledged_at",
    "declaration_acknowledged_at",
    "acknowledged_at",
    "step_up_verified_at",
    "step_up_expires_at",
    "signed_at",
    "state_changed_at",
    "approval_readiness_score",
    "recovery_posture",
    "dominant_hazard_code",
    "supersedes_pack_ref",
    "language_contract",
    "customer_safe_projection",
    "externalization_governance_contract",
    "artifact_selection",
    "artifact_affordance"
  ],
  "properties": {
    "approval_pack_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "ClientApprovalPack"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 72
    },
    "summary_ref": {
      "type": "string",
      "minLength": 1
    },
    "change_highlights_ref": {
      "type": "string",
      "minLength": 1
    },
    "declaration_text_ref": {
      "type": "string",
      "minLength": 1
    },
    "approval_pack_hash": {
      "type": "string",
      "minLength": 1
    },
    "view_guard_ref": {
      "type": "string",
      "minLength": 1
    },
    "stale_protection_state": {
      "type": "string",
      "enum": [
        "CURRENT",
        "REBASE_REQUIRED",
        "SUPERSEDED",
        "EXPIRED"
      ]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "DRAFT",
        "READY_FOR_CLIENT",
        "VIEWED",
        "ACKNOWLEDGED",
        "STEP_UP_REQUIRED",
        "SIGNED",
        "COUNTERSIGNED",
        "EXPIRED",
        "SUPERSEDED",
        "CANCELLED"
      ]
    },
    "requires_step_up": {
      "type": "boolean"
    },
    "viewed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "change_digest_acknowledged_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "declaration_acknowledged_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "acknowledged_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "step_up_verified_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "step_up_expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "signed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "state_changed_at": {
      "type": "string",
      "format": "date-time"
    },
    "approval_readiness_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "recovery_posture": {
      "type": "string",
      "enum": [
        "NONE",
        "INLINE_RESUME",
        "RECONFIRM_INLINE",
        "STALE_REVIEW_REQUIRED",
        "STEP_UP_RETRY",
        "HARD_RESET_REQUIRED",
        "SUPPORT_REQUIRED"
      ]
    },
    "dominant_hazard_code": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "supersedes_pack_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "language_contract": {
      "$ref": "https://taxat.dev/schemas/portal_language_contract.schema.json"
    },
    "customer_safe_projection": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/customer_safe_projection_contract.schema.json"
        },
        {
          "properties": {
            "boundary_scope": {
              "const": "CLIENT_APPROVAL_PACK"
            },
            "projection_audience": {
              "const": "CLIENT_PORTAL"
            }
          }
        }
      ]
    },
    "externalization_governance_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/externalization_governance_contract.schema.json"
        },
        {
          "properties": {
            "boundary_scope": {
              "const": "CLIENT_APPROVAL_PACK"
            }
          }
        }
      ]
    },
    "artifact_selection": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/artifact_selection_contract.schema.json"
        },
        {
          "properties": {
            "selection_scope": {
              "const": "CLIENT_APPROVAL_PACK"
            }
          }
        }
      ]
    },
    "artifact_affordance": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/artifact_affordance_contract.schema.json"
        },
        {
          "properties": {
            "affordance_scope": {
              "const": "CLIENT_APPROVAL_PACK"
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "DRAFT",
              "READY_FOR_CLIENT"
            ]
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "viewed_at": {
            "type": "null"
          },
          "change_digest_acknowledged_at": {
            "type": "null"
          },
          "declaration_acknowledged_at": {
            "type": "null"
          },
          "acknowledged_at": {
            "type": "null"
          },
          "step_up_verified_at": {
            "type": "null"
          },
          "step_up_expires_at": {
            "type": "null"
          },
          "signed_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "SUPERSEDED",
              "EXPIRED",
              "CANCELLED"
            ]
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "signed_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "VIEWED",
              "ACKNOWLEDGED",
              "STEP_UP_REQUIRED",
              "SIGNED",
              "COUNTERSIGNED"
            ]
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "viewed_at": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "VIEWED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "acknowledged_at": {
            "type": "null"
          },
          "change_digest_acknowledged_at": {
            "type": "null"
          },
          "declaration_acknowledged_at": {
            "type": "null"
          },
          "signed_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "ACKNOWLEDGED",
              "STEP_UP_REQUIRED",
              "SIGNED",
              "COUNTERSIGNED"
            ]
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "change_digest_acknowledged_at": {
            "type": "string"
          },
          "declaration_acknowledged_at": {
            "type": "string"
          },
          "acknowledged_at": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "ACKNOWLEDGED",
              "STEP_UP_REQUIRED"
            ]
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "signed_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "SIGNED",
              "COUNTERSIGNED"
            ]
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "signed_at": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "CANCELLED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "viewed_at": {
            "type": "null"
          },
          "change_digest_acknowledged_at": {
            "type": "null"
          },
          "declaration_acknowledged_at": {
            "type": "null"
          },
          "acknowledged_at": {
            "type": "null"
          },
          "step_up_verified_at": {
            "type": "null"
          },
          "step_up_expires_at": {
            "type": "null"
          },
          "signed_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "STEP_UP_REQUIRED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "requires_step_up": {
            "const": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "requires_step_up": {
            "const": false
          }
        },
        "required": [
          "requires_step_up"
        ]
      },
      "then": {
        "properties": {
          "step_up_verified_at": {
            "type": "null"
          },
          "step_up_expires_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "step_up_verified_at": {
            "type": "string"
          }
        },
        "required": [
          "step_up_verified_at"
        ]
      },
      "then": {
        "properties": {
          "step_up_expires_at": {
            "type": "string"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "STEP_UP_REQUIRED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "step_up_verified_at": {
            "type": "null"
          },
          "step_up_expires_at": {
            "type": "null"
          },
          "approval_readiness_score": {
            "maximum": 84
          },
          "recovery_posture": {
            "const": "STEP_UP_RETRY"
          },
          "dominant_hazard_code": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "SIGNED",
              "COUNTERSIGNED"
            ]
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "stale_protection_state": {
            "const": "CURRENT"
          },
          "approval_readiness_score": {
            "minimum": 85
          },
          "recovery_posture": {
            "const": "NONE"
          },
          "dominant_hazard_code": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "SUPERSEDED",
              "EXPIRED"
            ]
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "approval_readiness_score": {
            "maximum": 0
          },
          "recovery_posture": {
            "const": "STALE_REVIEW_REQUIRED"
          },
          "dominant_hazard_code": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "CANCELLED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "approval_readiness_score": {
            "maximum": 24
          },
          "recovery_posture": {
            "const": "HARD_RESET_REQUIRED"
          },
          "dominant_hazard_code": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
