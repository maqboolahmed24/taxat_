{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/governance_policy_snapshot.schema.json",
  "title": "GovernancePolicySnapshot",
  "description": "Governance tenant-configuration workspace contract. This schema freezes the stale-view policy hash together with the route-stable section navigation, staged change basket, approval composition, blast-radius review, and config history posture used by the tenant policy shell.",
  "type": "object",
  "required": [
    "artifact_type",
    "snapshot_id",
    "tenant_id",
    "shell_family",
    "object_anchor_ref",
    "dominant_question",
    "settlement_state",
    "recovery_posture",
    "interaction_layer",
    "cache_isolation_contract",
    "policy_snapshot_hash",
    "environment_bindings",
    "session_security_posture",
    "step_up_rules",
    "approval_rules",
    "masking_defaults",
    "last_material_change_ref",
    "tenant_config_workspace",
    "change_basket",
    "approval_composer",
    "blast_radius_panel",
    "config_history_timeline",
    "captured_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "GovernancePolicySnapshot"
    },
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "shell_family": {
      "const": "GOVERNANCE_DENSITY_SHELL"
    },
    "object_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "dominant_question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "settlement_state": {
      "$ref": "#/$defs/settlementState"
    },
    "recovery_posture": {
      "$ref": "#/$defs/recoveryPosture"
    },
    "interaction_layer": {
      "$ref": "https://taxat.dev/schemas/governance_interaction_layer.schema.json"
    },
    "cache_isolation_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/cache_isolation_contract.schema.json"
        },
        {
          "properties": {
            "cache_scope_class": {
              "const": "GOVERNANCE_POLICY_SNAPSHOT"
            }
          }
        }
      ]
    },
    "policy_snapshot_hash": {
      "type": "string",
      "minLength": 1
    },
    "environment_bindings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/environmentBinding"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "session_security_posture": {
      "$ref": "#/$defs/sessionSecurityPosture"
    },
    "step_up_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/stepUpRule"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "approval_rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/approvalRule"
      },
      "default": [],
      "uniqueItems": true
    },
    "masking_defaults": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "last_material_change_ref": {
      "type": "string",
      "minLength": 1
    },
    "tenant_config_workspace": {
      "$ref": "#/$defs/tenantConfigWorkspace"
    },
    "change_basket": {
      "$ref": "#/$defs/changeBasket"
    },
    "approval_composer": {
      "$ref": "#/$defs/approvalComposer"
    },
    "blast_radius_panel": {
      "$ref": "#/$defs/blastRadiusPanel"
    },
    "config_history_timeline": {
      "$ref": "#/$defs/configHistoryTimeline"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "settlementState": {
      "type": "string",
      "enum": [
        "STEADY",
        "RECEIPT_PENDING",
        "FRESHENING",
        "STALE_REVIEW_REQUIRED",
        "DEGRADED_READ_ONLY",
        "RECOVERY_REQUIRED"
      ]
    },
    "recoveryPosture": {
      "type": "string",
      "enum": [
        "NONE",
        "INLINE_RECONNECT",
        "INLINE_REBASE",
        "READ_ONLY_LIMITED",
        "OBJECT_SUPERSEDED",
        "ACCESS_REBIND_REQUIRED"
      ]
    },
    "interactionLayer": {
      "type": "object",
      "required": [
        "selected_filter_chip_refs",
        "compaction_mode",
        "auxiliary_surface_presentation",
        "focus_trap_mode",
        "selection_persistence_mode",
        "preserved_context_codes"
      ],
      "properties": {
        "selected_filter_chip_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "compaction_mode": {
          "type": "string",
          "enum": [
            "WIDE",
            "AUXILIARY_DRAWER",
            "AUXILIARY_TRAY",
            "FOCUS_STACK"
          ]
        },
        "auxiliary_surface_presentation": {
          "type": "string",
          "enum": [
            "SIDECAR",
            "DRAWER",
            "INSPECTOR",
            "TRAY"
          ]
        },
        "focus_trap_mode": {
          "type": "string",
          "enum": [
            "NON_MODAL",
            "MODAL_EXPLICIT"
          ]
        },
        "selection_persistence_mode": {
          "const": "PRESERVE_WHILE_OBJECT_RESOLVES"
        },
        "preserved_context_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ACTIVE_FILTERS",
              "ACTIVE_SECTION",
              "SELECTION",
              "FOCUS_ANCHOR",
              "PROMOTED_SUPPORT_SURFACE",
              "STAGED_DIFF",
              "CHANGE_BASKET",
              "GUIDED_HANDSHAKE_STEP",
              "QUERY_SLICE"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "approvalRequirement": {
      "type": "string",
      "enum": [
        "NOT_REQUIRED",
        "SINGLE_APPROVER",
        "DUAL_APPROVER",
        "SECURITY_REVIEW",
        "CHANGE_ADVISORY_QUORUM"
      ]
    },
    "approvalRequirementNullable": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "NOT_REQUIRED",
        "SINGLE_APPROVER",
        "DUAL_APPROVER",
        "SECURITY_REVIEW",
        "CHANGE_ADVISORY_QUORUM",
        null
      ]
    },
    "sectionCode": {
      "type": "string",
      "enum": [
        "TENANT_PROFILE",
        "SECURITY_POSTURE",
        "AUTHORITY_AND_ENVIRONMENTS",
        "CONNECTOR_POLICY",
        "APPROVAL_AND_CHANGE_CONTROL",
        "NOTIFICATIONS_AND_EVIDENCE"
      ]
    },
    "environmentBinding": {
      "type": "object",
      "required": [
        "environment_ref",
        "provider_environment",
        "status"
      ],
      "properties": {
        "environment_ref": {
          "type": "string",
          "minLength": 1
        },
        "provider_environment": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "ACTIVE",
            "READ_ONLY",
            "DISABLED"
          ]
        }
      },
      "additionalProperties": false
    },
    "sessionSecurityPosture": {
      "type": "object",
      "required": [
        "browser_session_allowed",
        "native_session_allowed",
        "automation_session_allowed",
        "csrf_binding_required",
        "native_device_binding_required",
        "step_up_rotation_required"
      ],
      "properties": {
        "browser_session_allowed": {
          "type": "boolean"
        },
        "native_session_allowed": {
          "type": "boolean"
        },
        "automation_session_allowed": {
          "type": "boolean"
        },
        "csrf_binding_required": {
          "type": "boolean"
        },
        "native_device_binding_required": {
          "type": "boolean"
        },
        "step_up_rotation_required": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "stepUpRule": {
      "type": "object",
      "required": [
        "action_family",
        "required_authn_level",
        "reason_codes"
      ],
      "properties": {
        "action_family": {
          "type": "string",
          "minLength": 1
        },
        "required_authn_level": {
          "type": "string",
          "enum": [
            "BASIC",
            "MFA",
            "STEP_UP"
          ]
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "approvalRule": {
      "type": "object",
      "required": [
        "action_family",
        "approval_required",
        "approval_scope"
      ],
      "properties": {
        "action_family": {
          "type": "string",
          "minLength": 1
        },
        "approval_required": {
          "type": "boolean"
        },
        "approval_scope": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "inlinePolicyHelp": {
      "type": "object",
      "required": [
        "help_mode",
        "help_refs"
      ],
      "properties": {
        "help_mode": {
          "const": "INLINE"
        },
        "help_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "tenantConfigWorkspace": {
      "type": "object",
      "required": [
        "surface_order",
        "section_nav_order",
        "active_section_code",
        "visible_form_section_refs",
        "inline_policy_help"
      ],
      "properties": {
        "surface_order": {
          "const": [
            "SECTION_NAV",
            "CONFIG_FORM",
            "INLINE_POLICY_HELP",
            "BLAST_RADIUS_PANEL",
            "CHANGE_BASKET",
            "APPROVAL_COMPOSER",
            "CONFIG_HISTORY_TIMELINE"
          ]
        },
        "section_nav_order": {
          "const": [
            "TENANT_PROFILE",
            "SECURITY_POSTURE",
            "AUTHORITY_AND_ENVIRONMENTS",
            "CONNECTOR_POLICY",
            "APPROVAL_AND_CHANGE_CONTROL",
            "NOTIFICATIONS_AND_EVIDENCE"
          ]
        },
        "active_section_code": {
          "$ref": "#/$defs/sectionCode"
        },
        "visible_form_section_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "inline_policy_help": {
          "$ref": "#/$defs/inlinePolicyHelp"
        }
      },
      "additionalProperties": false
    },
    "stagedChange": {
      "type": "object",
      "required": [
        "change_ref",
        "field_ref",
        "current_value_label",
        "proposed_value_label",
        "effective_scope_label",
        "reason_required",
        "approval_required",
        "audit_event_families",
        "input_commit_mode"
      ],
      "properties": {
        "change_ref": {
          "type": "string",
          "minLength": 1
        },
        "field_ref": {
          "type": "string",
          "minLength": 1
        },
        "current_value_label": {
          "type": "string",
          "minLength": 1
        },
        "proposed_value_label": {
          "type": "string",
          "minLength": 1
        },
        "effective_scope_label": {
          "type": "string",
          "minLength": 1
        },
        "reason_required": {
          "type": "boolean"
        },
        "approval_required": {
          "type": "boolean"
        },
        "audit_event_families": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "input_commit_mode": {
          "const": "EXPLICIT_STAGE"
        }
      },
      "additionalProperties": false
    },
    "stagedChangeGroup": {
      "type": "object",
      "required": [
        "object_type",
        "mutation_hazard",
        "mutation_basis_contract",
        "staged_changes"
      ],
      "properties": {
        "object_type": {
          "type": "string",
          "minLength": 1
        },
        "mutation_hazard": {
          "$ref": "https://taxat.dev/schemas/governance_mutation_hazard_contract.schema.json"
        },
        "mutation_basis_contract": {
          "$ref": "https://taxat.dev/schemas/governance_mutation_basis_contract.schema.json"
        },
        "staged_changes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stagedChange"
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "changeBasket": {
      "type": "object",
      "required": [
        "basket_state",
        "simulation_atomicity",
        "submission_enabled",
        "active_simulation_basis_hash",
        "active_dependency_topology_hash",
        "active_mutation_hazard_or_null",
        "active_mutation_basis_contract_or_null",
        "step_up_pending",
        "approval_requirement",
        "bounded_safe_mutation",
        "required_approvals",
        "staged_change_groups"
      ],
      "properties": {
        "basket_state": {
          "type": "string",
          "enum": [
            "EMPTY",
            "DRAFTING",
            "READY_TO_SUBMIT",
            "STEP_UP_REQUIRED",
            "STALE_REBASE_REQUIRED",
            "RECEIPT_PENDING"
          ]
        },
        "simulation_atomicity": {
          "type": "string",
          "enum": [
            "EMPTY",
            "ATOMIC",
            "MIXED_BASIS_BLOCKED",
            "STALE_BASIS_BLOCKED"
          ]
        },
        "submission_enabled": {
          "type": "boolean"
        },
        "active_simulation_basis_hash": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "active_dependency_topology_hash": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "active_mutation_hazard_or_null": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "https://taxat.dev/schemas/governance_mutation_hazard_contract.schema.json"
            }
          ]
        },
        "active_mutation_basis_contract_or_null": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "https://taxat.dev/schemas/governance_mutation_basis_contract.schema.json"
            }
          ]
        },
        "step_up_pending": {
          "type": "boolean"
        },
        "approval_requirement": {
          "$ref": "#/$defs/approvalRequirementNullable"
        },
        "bounded_safe_mutation": {
          "type": [
            "integer",
            "null"
          ],
          "enum": [
            0,
            1,
            null
          ]
        },
        "required_approvals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "staged_change_groups": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stagedChangeGroup"
          },
          "default": []
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "simulation_atomicity": {
                "const": "EMPTY"
              }
            },
            "required": [
              "simulation_atomicity"
            ]
          },
          "then": {
            "properties": {
              "basket_state": {
                "const": "EMPTY"
              },
              "submission_enabled": {
                "const": false
              },
              "active_simulation_basis_hash": {
                "type": "null"
              },
              "active_dependency_topology_hash": {
                "type": "null"
              },
              "active_mutation_hazard_or_null": {
                "type": "null"
              },
              "active_mutation_basis_contract_or_null": {
                "type": "null"
              },
              "approval_requirement": {
                "type": "null"
              },
              "bounded_safe_mutation": {
                "type": "null"
              },
              "required_approvals": {
                "maxItems": 0
              },
              "staged_change_groups": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "simulation_atomicity": {
                "const": "ATOMIC"
              }
            },
            "required": [
              "simulation_atomicity"
            ]
          },
          "then": {
            "properties": {
              "active_simulation_basis_hash": {
                "type": "string"
              },
              "active_dependency_topology_hash": {
                "type": "string"
              },
              "active_mutation_hazard_or_null": {
                "$ref": "https://taxat.dev/schemas/governance_mutation_hazard_contract.schema.json"
              },
              "active_mutation_basis_contract_or_null": {
                "$ref": "https://taxat.dev/schemas/governance_mutation_basis_contract.schema.json"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "submission_enabled": {
                "const": true
              }
            },
            "required": [
              "submission_enabled"
            ]
          },
          "then": {
            "properties": {
              "simulation_atomicity": {
                "const": "ATOMIC"
              },
              "step_up_pending": {
                "const": false
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "step_up_pending": {
                "const": true
              }
            },
            "required": [
              "step_up_pending"
            ]
          },
          "then": {
            "properties": {
              "submission_enabled": {
                "const": false
              },
              "basket_state": {
                "const": "STEP_UP_REQUIRED"
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "approvalComposer": {
      "type": "object",
      "required": [
        "composer_state",
        "requested_approver_scope",
        "related_object_refs",
        "rationale_required",
        "rationale_ref",
        "expires_at",
        "mutation_basis_contract_or_null"
      ],
      "properties": {
        "composer_state": {
          "type": "string",
          "enum": [
            "NOT_REQUIRED",
            "DRAFT",
            "READY",
            "SUBMITTED"
          ]
        },
        "requested_approver_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "related_object_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "rationale_required": {
          "type": "boolean"
        },
        "rationale_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "expires_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "mutation_basis_contract_or_null": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "https://taxat.dev/schemas/governance_mutation_basis_contract.schema.json"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "composer_state": {
                "const": "NOT_REQUIRED"
              }
            },
            "required": [
              "composer_state"
            ]
          },
          "then": {
            "properties": {
              "requested_approver_scope": {
                "maxItems": 0
              },
              "related_object_refs": {
                "maxItems": 0
              },
              "rationale_ref": {
                "type": "null"
              },
              "expires_at": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "composer_state": {
                "const": "SUBMITTED"
              }
            },
            "required": [
              "composer_state"
            ]
          },
          "then": {
            "properties": {
              "requested_approver_scope": {
                "minItems": 1
              },
              "related_object_refs": {
                "minItems": 1
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "blastRadiusPanel": {
      "type": "object",
      "required": [
        "panel_state",
        "mutation_hazard_or_null",
        "mutation_basis_contract_or_null"
      ],
      "properties": {
        "panel_state": {
          "type": "string",
          "enum": [
            "EMPTY",
            "ACTIVE",
            "STALE"
          ]
        },
        "mutation_hazard_or_null": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "https://taxat.dev/schemas/governance_mutation_hazard_contract.schema.json"
            }
          ]
        },
        "mutation_basis_contract_or_null": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "https://taxat.dev/schemas/governance_mutation_basis_contract.schema.json"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "panel_state": {
                "const": "EMPTY"
              }
            },
            "required": [
              "panel_state"
            ]
          },
          "then": {
            "properties": {
              "mutation_hazard_or_null": {
                "type": "null"
              },
              "mutation_basis_contract_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "panel_state": {
                "const": "ACTIVE"
              }
            },
            "required": [
              "panel_state"
            ]
          },
          "then": {
            "properties": {
              "mutation_hazard_or_null": {
                "$ref": "https://taxat.dev/schemas/governance_mutation_hazard_contract.schema.json"
              },
              "mutation_basis_contract_or_null": {
                "$ref": "https://taxat.dev/schemas/governance_mutation_basis_contract.schema.json"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "panel_state": {
                "const": "STALE"
              }
            },
            "required": [
              "panel_state"
            ]
          },
          "then": {
            "properties": {
              "mutation_hazard_or_null": {
                "$ref": "https://taxat.dev/schemas/governance_mutation_hazard_contract.schema.json"
              },
