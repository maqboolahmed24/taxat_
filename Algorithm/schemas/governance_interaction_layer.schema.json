{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/governance_interaction_layer.schema.json",
  "title": "GovernanceInteractionLayer",
  "description": "Shared governance-density interaction contract. This schema is the contract boundary between server-authored governance interaction semantics and platform-specific rendering. It freezes governance-wide density rules, inventory/filter grammar, semantic selector profile, promoted support-surface policy, staged diff and change-basket continuity, export binding, keyboard/focus restoration posture, and durable receipt or typed failure driven recovery and settlement feedback while still carrying the route-specific chip echo and preserved context set. This description also names the governance_interaction_layer_v1 profile.",
  "type": "object",
  "required": [
    "foundation_contract",
    "density_profile",
    "inventory_filter_grammar",
    "support_surface_policy",
    "diff_basket_policy",
    "export_binding_policy",
    "keyboard_focus_policy",
    "selector_profile",
    "selected_filter_chip_refs",
    "compaction_mode",
    "auxiliary_surface_presentation",
    "focus_trap_mode",
    "selection_persistence_mode",
    "preserved_context_codes",
    "motion_profile",
    "feedback_truth_policy"
  ],
  "properties": {
    "foundation_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/interaction_layer_foundation_contract.schema.json"
        },
        {
          "properties": {
            "shell_family": {
              "const": "GOVERNANCE_DENSITY_SHELL"
            }
          }
        }
      ]
    },
    "density_profile": {
      "const": "GOVERNANCE_DENSITY_PROFILE_V1"
    },
    "inventory_filter_grammar": {
      "const": "CANONICAL_ROUTE_FILTER_GRAMMAR"
    },
    "support_surface_policy": {
      "const": "ONE_PROMOTED_SUPPORT_SURFACE_MAX"
    },
    "diff_basket_policy": {
      "const": "STAGED_DIFF_AND_BASKET_RETAIN_CONTEXT"
    },
    "export_binding_policy": {
      "const": "ACTIVE_FILTERED_SLICE_GOVERNS_EXPORT"
    },
    "keyboard_focus_policy": {
      "const": "RETURN_FOCUS_ANCHOR_OR_ROVING_SELECTION"
    },
    "selector_profile": {
      "const": "GOVERNANCE_SEMANTIC_SELECTORS_V1"
    },
    "selected_filter_chip_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "compaction_mode": {
      "type": "string",
      "enum": [
        "WIDE",
        "AUXILIARY_DRAWER",
        "AUXILIARY_TRAY",
        "FOCUS_STACK"
      ]
    },
    "auxiliary_surface_presentation": {
      "type": "string",
      "enum": [
        "SIDECAR",
        "DRAWER",
        "INSPECTOR",
        "TRAY"
      ]
    },
    "focus_trap_mode": {
      "type": "string",
      "enum": [
        "NON_MODAL",
        "MODAL_EXPLICIT"
      ]
    },
    "selection_persistence_mode": {
      "const": "PRESERVE_WHILE_OBJECT_RESOLVES"
    },
    "preserved_context_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "ACTIVE_FILTERS",
          "ACTIVE_SECTION",
          "SELECTION",
          "FOCUS_ANCHOR",
          "PROMOTED_SUPPORT_SURFACE",
          "STAGED_DIFF",
          "CHANGE_BASKET",
          "GUIDED_HANDSHAKE_STEP",
          "QUERY_SLICE"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "motion_profile": {
      "const": "SUBTLE_CAUSAL_ONLY"
    },
    "feedback_truth_policy": {
      "const": "DURABLE_RECEIPT_AND_TYPED_FAILURE_DRIVEN"
    }
  },
  "additionalProperties": false
}
