{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/operator_interaction_layer.schema.json",
  "title": "OperatorInteractionLayer",
  "description": "Shared operator interaction-layer contract for calm-shell, collaboration, investigation, and native operator embodiments. This schema is the contract boundary between server-authored operator interaction semantics and platform-specific rendering. It freezes mounted-content preservation, inline refresh and rebase posture, semantic selector grammar, same-shell continuity, visibility-scoped collaboration partitions, summary-first investigation posture, support-only parent-bound secondary windows, notification delivery surface, preview embodiment, current-vs-historical separation, low-noise motion, fail-closed unsafe-action posture, and durable receipt or typed failure driven recovery and settlement feedback so operator behavior cannot drift into route-wide spinners, mixed-visibility activity lanes, detached authoritative windows, or shell-local stale and pending explanations. This description also names the operator_interaction_layer_v1 profile.",
  "type": "object",
  "required": [
    "foundation_contract",
    "mounted_content_policy",
    "refresh_presentation",
    "recovery_presentation",
    "recovery_notice_surface",
    "delta_promotion_mode",
    "selector_profile",
    "shell_continuity_policy",
    "activity_partition_policy",
    "investigation_presentation_policy",
    "secondary_window_policy",
    "notification_surface",
    "artifact_preview_surface",
    "history_presentation",
    "motion_profile",
    "unsafe_action_policy",
    "feedback_truth_policy"
  ],
  "properties": {
    "foundation_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/interaction_layer_foundation_contract.schema.json"
        },
        {
          "properties": {
            "shell_family": {
              "const": "CALM_SHELL"
            }
          }
        }
      ]
    },
    "mounted_content_policy": {
      "const": "KEEP_MOUNTED_CONTENT"
    },
    "refresh_presentation": {
      "const": "INLINE_STATUS_ONLY"
    },
    "recovery_presentation": {
      "const": "INLINE_EXPLICIT_REBASE"
    },
    "recovery_notice_surface": {
      "type": "string",
      "enum": [
        "CONTEXT_BAR",
        "IDENTITY_HEADER"
      ]
    },
    "delta_promotion_mode": {
      "const": "COALESCE_BEFORE_PROMOTION"
    },
    "selector_profile": {
      "const": "OPERATOR_SEMANTIC_SELECTORS_V1"
    },
    "shell_continuity_policy": {
      "const": "SAME_OBJECT_SAME_SHELL_INLINE_RECOVERY"
    },
    "activity_partition_policy": {
      "const": "VISIBILITY_SCOPED_LANES_WITH_CURRENT_FIRST_ARTIFACTS"
    },
    "investigation_presentation_policy": {
      "const": "SUMMARY_FIRST_PLAIN_LANGUAGE_MODULES"
    },
    "secondary_window_policy": {
      "const": "SUPPORT_ONLY_PARENT_BOUND_CLOSE_RETURNS_FOCUS"
    },
    "notification_surface": {
      "type": "string",
      "enum": [
        "CONTEXT_BAR",
        "CONTEXT_BAR_WITH_SYSTEM_MIRROR",
        "PARENT_CONTEXT_BAR"
      ]
    },
    "artifact_preview_surface": {
      "type": "string",
      "enum": [
        "DETAIL_DRAWER",
        "SECONDARY_WINDOW_BODY"
      ]
    },
    "history_presentation": {
      "const": "CURRENT_PRIMARY_HISTORY_SECONDARY"
    },
    "motion_profile": {
      "const": "SUBTLE_CAUSAL_ONLY"
    },
    "unsafe_action_policy": {
      "const": "FAIL_CLOSED_DURING_DEGRADED_OR_RECOVERY"
    },
    "feedback_truth_policy": {
      "const": "DURABLE_RECEIPT_AND_TYPED_FAILURE_DRIVEN"
    }
  },
  "additionalProperties": false
}
