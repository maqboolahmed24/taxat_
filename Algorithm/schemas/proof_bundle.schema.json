{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/proof_bundle.schema.json",
  "title": "ProofBundle",
  "description": "Deterministic filing-proof bundle. This schema freezes decisive path selection, rejected competing paths, contradiction posture, replay recipe, and render bindings for one filing-capable target.",
  "type": "object",
  "required": [
    "artifact_type",
    "proof_bundle_id",
    "manifest_id",
    "manifest_refs",
    "partition_contract",
    "graph_ref",
    "target_ref",
    "target_class",
    "bundle_purpose",
    "lifecycle_state",
    "support_state",
    "admissibility_state",
    "closure_state",
    "proof_closure_contract",
    "primary_path_ref",
    "decisive_path_refs",
    "rejected_path_refs",
    "rejected_path_entries",
    "decisive_evidence_refs",
    "authority_basis_refs",
    "config_basis_refs",
    "contradiction_refs",
    "stale_reason_codes",
    "staleness_dependency_refs",
    "temporal_propagation_event_refs",
    "lineage_boundary_refs",
    "decisive_lineage_boundary_refs",
    "replay_recipe",
    "render_refs",
    "limitation_notes",
    "retention_limited_explainability_contract",
    "retention_binding",
    "bundle_hash",
    "superseded_by_bundle_ref",
    "generated_at",
    "contract"
  ],
  "properties": {
    "artifact_type": {
      "const": "ProofBundle"
    },
    "proof_bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "partition_contract": {
      "$ref": "./provenance_partition_contract.schema.json"
    },
    "graph_ref": {
      "type": "string",
      "minLength": 1
    },
    "target_ref": {
      "type": "string",
      "minLength": 1
    },
    "target_class": {
      "type": "string",
      "enum": [
        "FIGURE",
        "TOTAL",
        "FILING_FIELD",
        "DECISION",
        "LEGAL_STATE"
      ]
    },
    "bundle_purpose": {
      "type": "string",
      "enum": [
        "FILING_DEFENCE",
        "GATE_EXPLANATION",
        "LEGAL_STATE_PROOF",
        "DRIFT_JUSTIFICATION",
        "RETENTION_LIMITATION"
      ]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "GENERATED",
        "LIMITED",
        "STALE",
        "SUPERSEDED"
      ]
    },
    "support_state": {
      "type": "string",
      "enum": [
        "SUPPORTED",
        "PARTIALLY_SUPPORTED",
        "UNSUPPORTED",
        "CONTRADICTED",
        "STALE"
      ]
    },
    "admissibility_state": {
      "type": "string",
      "enum": [
        "ADMISSIBLE",
        "LIMITED",
        "INADMISSIBLE"
      ]
    },
    "closure_state": {
      "type": "string",
      "enum": [
        "CLOSED",
        "OPEN"
      ]
    },
    "proof_closure_contract": {
      "$ref": "./proof_closure_contract.schema.json"
    },
    "primary_path_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "decisive_path_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "rejected_path_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "rejected_path_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path_ref",
          "path_rank",
          "rejection_class",
          "rejection_reason_codes"
        ],
        "properties": {
          "path_ref": {
            "type": "string",
            "minLength": 1
          },
          "path_rank": {
            "type": "integer",
            "minimum": 2
          },
          "rejection_class": {
            "type": "string",
            "enum": [
              "WEAKER_SUPPORT",
              "CONTRADICTS_PRIMARY",
              "SILENT_LIMITATION_AMBIGUITY",
              "STALE_OR_SUPERSEDED",
              "REPLAY_CLOSURE_FAILURE",
              "AUTHORITY_CLOSURE_FAILURE"
            ]
          },
          "rejection_reason_codes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "decisive_evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "authority_basis_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "config_basis_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "contradiction_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "stale_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "staleness_dependency_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "temporal_propagation_event_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "lineage_boundary_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "decisive_lineage_boundary_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "replay_recipe": {
      "type": "object",
      "required": [
        "manifest_refs",
        "required_artifact_refs",
        "deterministic_order_basis",
        "replayable",
        "path_ref_order",
        "lineage_boundary_refs"
      ],
      "properties": {
        "manifest_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "required_artifact_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "deterministic_order_basis": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "replayable": {
          "type": "boolean"
        },
        "path_ref_order": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "lineage_boundary_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "render_refs": {
      "type": "object",
      "required": [
        "operator_render_ref",
        "reviewer_render_ref",
        "filing_artifact_ref",
        "explanation_status"
      ],
      "properties": {
        "operator_render_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "reviewer_render_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "filing_artifact_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "explanation_status": {
          "type": "string",
          "enum": [
            "AVAILABLE",
            "LIMITED",
            "FAILED"
          ]
        }
      },
      "additionalProperties": false
    },
    "limitation_notes": {
      "type": "array",
      "items": {
        "$ref": "https://taxat.dev/schemas/enquiry_pack.schema.json#/$defs/limitationNote"
      },
      "default": []
    },
    "retention_limited_explainability_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/retention_limited_explainability_contract.schema.json"
        },
        {
          "properties": {
            "boundary_scope": {
              "const": "PROOF_BUNDLE"
            },
            "surface_role": {
              "const": "FILING_PROOF_ARTIFACT"
            },
            "surface_specific_binding_policy": {
              "const": "PROOF_BUNDLE_RETAINS_DECISIVE_LIMITATION_AND_RETENTION_BINDING"
            }
          }
        }
      ]
    },
    "retention_binding": {
      "type": "object",
      "required": [
        "retention_tag_ref",
        "limitation_behavior",
        "minimum_available_until"
      ],
      "properties": {
        "retention_tag_ref": {
          "type": "string",
          "minLength": 1
        },
        "limitation_behavior": {
          "type": "string",
          "enum": [
            "FULL",
            "LIMITED",
            "TOMBSTONED",
            "PSEUDONYMISED"
          ]
        },
        "minimum_available_until": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "bundle_hash": {
      "type": "string",
      "minLength": 1
    },
    "superseded_by_bundle_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "closure_state": {
            "const": "CLOSED"
          }
        },
        "required": [
          "closure_state"
        ]
      },
      "then": {
        "properties": {
          "primary_path_ref": {
            "type": "string",
            "minLength": 1
          },
          "decisive_path_refs": {
            "minItems": 1
          },
          "replay_recipe": {
            "properties": {
              "path_ref_order": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "primary_path_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "primary_path_ref"
        ]
      },
      "then": {
        "properties": {
          "closure_state": {
            "const": "CLOSED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "support_state": {
            "const": "SUPPORTED"
          }
        },
        "required": [
          "support_state"
        ]
      },
      "then": {
        "properties": {
          "admissibility_state": {
            "const": "ADMISSIBLE"
          },
          "closure_state": {
            "const": "CLOSED"
          },
          "replay_recipe": {
            "properties": {
              "replayable": {
                "const": true
              }
            }
          },
          "proof_closure_contract": {
            "properties": {
              "support_closed": {
                "const": true
              },
              "authority_closed": {
                "const": true
              },
              "contradiction_isolated": {
                "const": true
              },
              "replay_closed": {
                "const": true
              },
              "silent_limitation_ambiguity_present": {
                "const": false
              },
              "current_decisive_anchor_present": {
                "const": true
              },
              "staleness_invalidated": {
                "const": false
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "support_state": {
            "const": "CONTRADICTED"
          }
        },
        "required": [
          "support_state"
        ]
      },
      "then": {
        "properties": {
          "closure_state": {
            "const": "OPEN"
          },
          "contradiction_refs": {
            "minItems": 1
          },
          "proof_closure_contract": {
            "properties": {
              "contradiction_isolated": {
                "const": false
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "contradiction_refs": {
            "minItems": 1
          }
        },
        "required": [
          "contradiction_refs"
        ]
      },
      "then": {
        "properties": {
          "support_state": {
            "const": "CONTRADICTED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "support_state": {
            "const": "PARTIALLY_SUPPORTED"
          }
        },
        "required": [
          "support_state"
        ]
      },
      "then": {
        "properties": {
          "admissibility_state": {
            "const": "LIMITED"
          },
          "closure_state": {
            "const": "CLOSED"
          },
          "replay_recipe": {
            "properties": {
              "replayable": {
                "const": true
              }
            }
          },
          "proof_closure_contract": {
            "properties": {
              "support_closed": {
                "const": true
              },
              "authority_closed": {
                "const": true
              },
              "contradiction_isolated": {
                "const": true
              },
              "replay_closed": {
                "const": true
              },
              "silent_limitation_ambiguity_present": {
                "const": false
              },
              "current_decisive_anchor_present": {
                "const": true
              },
              "staleness_invalidated": {
                "const": false
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "support_state": {
            "const": "UNSUPPORTED"
          }
        },
        "required": [
          "support_state"
        ]
      },
      "then": {
        "properties": {
          "closure_state": {
            "const": "OPEN"
          },
          "primary_path_ref": {
            "type": "null"
          },
          "decisive_path_refs": {
            "maxItems": 0
          },
          "rejected_path_refs": {
            "maxItems": 0
          },
          "rejected_path_entries": {
            "maxItems": 0
          },
          "replay_recipe": {
            "properties": {
              "path_ref_order": {
                "maxItems": 0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "stale_reason_codes": {
            "minItems": 1
          }
        },
        "required": [
          "stale_reason_codes"
        ]
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "support_state": {
                "const": "STALE"
              }
            },
            "required": [
              "support_state"
            ]
          },
          {
            "properties": {
              "lifecycle_state": {
                "const": "STALE"
              }
            },
            "required": [
              "lifecycle_state"
            ]
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "support_state": {
            "const": "STALE"
          }
        },
        "required": [
          "support_state"
        ]
      },
      "then": {
        "properties": {
          "closure_state": {
            "const": "OPEN"
          },
          "stale_reason_codes": {
            "minItems": 1
          },
          "staleness_dependency_refs": {
            "minItems": 1
          },
          "proof_closure_contract": {
            "properties": {
              "staleness_invalidated": {
                "const": true
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "SUPERSEDED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "superseded_by_bundle_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "superseded_by_bundle_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "superseded_by_bundle_ref"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "const": "SUPERSEDED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "STALE"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "stale_reason_codes": {
            "minItems": 1
          },
          "staleness_dependency_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "stale_reason_codes": {
            "maxItems": 0
          }
        },
        "required": [
          "stale_reason_codes"
        ]
      },
      "then": {
        "properties": {
          "staleness_dependency_refs": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "support_state": {
            "enum": [
              "SUPPORTED",
              "PARTIALLY_SUPPORTED",
              "CONTRADICTED",
              "STALE"
            ]
          }
        },
        "required": [
          "support_state"
        ]
      },
      "then": {
        "properties": {
          "primary_path_ref": {
            "type": "string",
            "minLength": 1
          },
          "decisive_path_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "manifest_refs": {
            "minItems": 2
          }
        },
        "required": [
          "manifest_refs"
        ]
      },
      "then": {
        "properties": {
          "lineage_boundary_refs": {
            "minItems": 1
          },
          "replay_recipe": {
            "properties": {
              "lineage_boundary_refs": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lineage_boundary_refs": {
            "minItems": 1
          }
        },
        "required": [
          "lineage_boundary_refs"
        ]
      },
      "then": {
        "properties": {
          "manifest_refs": {
            "minItems": 2
          },
          "replay_recipe": {
            "properties": {
              "lineage_boundary_refs": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "render_refs": {
            "properties": {
              "explanation_status": {
                "const": "AVAILABLE"
              }
            },
            "required": [
              "explanation_status"
            ]
          }
        },
        "required": [
          "render_refs"
        ]
      },
      "then": {
        "properties": {
          "retention_binding": {
            "properties": {
              "limitation_behavior": {
                "const": "FULL"
              }
            }
          },
          "limitation_notes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "render_refs": {
            "properties": {
              "explanation_status": {
                "enum": [
                  "LIMITED",
                  "FAILED"
                ]
              }
            },
            "required": [
              "explanation_status"
            ]
          }
        },
        "required": [
          "render_refs"
        ]
      },
      "then": {
        "properties": {
          "limitation_notes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "retention_binding": {
            "properties": {
              "limitation_behavior": {
                "enum": [
                  "LIMITED",
                  "TOMBSTONED",
                  "PSEUDONYMISED"
                ]
              }
            },
            "required": [
              "limitation_behavior"
            ]
          }
        },
        "required": [
          "retention_binding"
        ]
      },
      "then": {
        "properties": {
          "render_refs": {
            "properties": {
              "explanation_status": {
                "enum": [
                  "LIMITED",
                  "FAILED"
                ]
              }
            },
            "required": [
              "explanation_status"
            ]
          },
          "limitation_notes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decisive_lineage_boundary_refs": {
            "minItems": 1
          }
        },
        "required": [
          "decisive_lineage_boundary_refs"
        ]
      },
      "then": {
        "properties": {
          "lineage_boundary_refs": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
