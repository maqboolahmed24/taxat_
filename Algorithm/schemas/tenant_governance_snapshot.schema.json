{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/tenant_governance_snapshot.schema.json",
  "title": "TenantGovernanceSnapshot",
  "description": "Governance Overview read-side projection for the Admin/Governance Console. This is a control-plane UX contract only; it must never be treated as mutation-side truth. The snapshot freezes one dominant question, settlement posture, one promoted worklist, and one explicit support-sidecar mode.",
  "type": "object",
  "required": [
    "snapshot_id",
    "artifact_type",
    "tenant_id",
    "shell_family",
    "object_anchor_ref",
    "environment_ref",
    "policy_snapshot_hash",
    "dominant_question",
    "dominance_contract",
    "state_taxonomy_contract",
    "cross_device_continuity_contract",
    "cache_isolation_contract",
    "semantic_accessibility_contract",
    "settlement_state",
    "recovery_posture",
    "interaction_layer",
    "primary_queue_code",
    "primary_worklist_ref",
    "active_filters",
    "selected_canvas_object_ref",
    "focus_anchor_ref",
    "pending_approval_count",
    "risky_configuration_drift_count",
    "expiring_authority_link_count",
    "retention_exception_count",
    "pending_approval_worklist_ref",
    "configuration_drift_worklist_ref",
    "authority_link_risk_worklist_ref",
    "retention_exception_worklist_ref",
    "audit_hotspot_worklist_ref",
    "pending_change_worklist_ref",
    "attention_summary",
    "risk_ledger_entries",
    "support_region_state",
    "authority_link_risk_refs",
    "retention_exception_refs",
    "audit_hotspot_refs",
    "recent_change_refs",
    "pending_change_refs",
    "updated_at"
  ],
  "properties": {
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "TenantGovernanceSnapshot"
    },
    "shell_family": {
      "const": "GOVERNANCE_DENSITY_SHELL"
    },
    "object_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "environment_ref": {
      "type": "string",
      "minLength": 1
    },
    "policy_snapshot_hash": {
      "type": "string",
      "minLength": 1
    },
    "dominant_question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "dominance_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/shell_dominance_contract.schema.json"
        },
        {
          "properties": {
            "dominant_question_surface_code": {
              "const": "ATTENTION_SUMMARY"
            },
            "dominant_action_surface_code": {
              "const": "ATTENTION_SUMMARY"
            },
            "supplemental_queue_policy": {
              "const": "SECONDARY_TO_PRIMARY_ACTION"
            },
            "promoted_support_surface_code_or_null": {
              "enum": [
                "AUDIT_SIDECAR",
                "BLAST_RADIUS_PANEL",
                "DIFF_PANEL",
                "EXPORT_ELIGIBILITY_PANEL",
                "APPROVAL_PANEL",
                null
              ]
            }
          }
        }
      ]
    },
    "state_taxonomy_contract": {
      "$ref": "https://taxat.dev/schemas/shell_state_taxonomy_contract.schema.json"
    },
    "cross_device_continuity_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/cross_device_continuity_contract.schema.json"
        },
        {
          "properties": {
            "continuity_scope": {
              "const": "GOVERNANCE_ROUTE"
            }
          }
        }
      ]
    },
    "cache_isolation_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/cache_isolation_contract.schema.json"
        },
        {
          "properties": {
            "cache_scope_class": {
              "const": "TENANT_GOVERNANCE_SNAPSHOT"
            }
          }
        }
      ]
    },
    "semantic_accessibility_contract": {
      "$ref": "https://taxat.dev/schemas/semantic_accessibility_contract.schema.json"
    },
    "settlement_state": {
      "$ref": "#/$defs/settlementState"
    },
    "recovery_posture": {
      "$ref": "#/$defs/recoveryPosture"
    },
    "interaction_layer": {
      "$ref": "https://taxat.dev/schemas/governance_interaction_layer.schema.json"
    },
    "primary_queue_code": {
      "type": "string",
      "enum": [
        "PENDING_APPROVALS",
        "CONFIGURATION_DRIFT",
        "AUTHORITY_LINK_RISKS",
        "RETENTION_EXCEPTIONS",
        "AUDIT_HOTSPOTS"
      ]
    },
    "primary_worklist_ref": {
      "type": "string",
      "minLength": 1
    },
    "active_filters": {
      "$ref": "#/$defs/activeFilters"
    },
    "selected_canvas_object_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "focus_anchor_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "pending_approval_count": {
      "type": "integer",
      "minimum": 0
    },
    "risky_configuration_drift_count": {
      "type": "integer",
      "minimum": 0
    },
    "expiring_authority_link_count": {
      "type": "integer",
      "minimum": 0
    },
    "retention_exception_count": {
      "type": "integer",
      "minimum": 0
    },
    "pending_approval_worklist_ref": {
      "type": "string",
      "minLength": 1
    },
    "configuration_drift_worklist_ref": {
      "type": "string",
      "minLength": 1
    },
    "authority_link_risk_worklist_ref": {
      "type": "string",
      "minLength": 1
    },
    "retention_exception_worklist_ref": {
      "type": "string",
      "minLength": 1
    },
    "audit_hotspot_worklist_ref": {
      "type": "string",
      "minLength": 1
    },
    "pending_change_worklist_ref": {
      "type": "string",
      "minLength": 1
    },
    "attention_summary": {
      "$ref": "#/$defs/attentionSummary"
    },
    "risk_ledger_entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/riskLedgerEntry"
      },
      "minItems": 5,
      "maxItems": 5
    },
    "support_region_state": {
      "$ref": "#/$defs/supportRegionState"
    },
    "authority_link_risk_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "maxItems": 6,
      "uniqueItems": true
    },
    "retention_exception_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "maxItems": 6,
      "uniqueItems": true
    },
    "audit_hotspot_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "maxItems": 12,
      "uniqueItems": true
    },
    "recent_change_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "maxItems": 20,
      "uniqueItems": true
    },
    "pending_change_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "maxItems": 12,
      "uniqueItems": true
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "settlementState": {
      "type": "string",
      "enum": [
        "STEADY",
        "RECEIPT_PENDING",
        "FRESHENING",
        "STALE_REVIEW_REQUIRED",
        "DEGRADED_READ_ONLY",
        "RECOVERY_REQUIRED"
      ]
    },
    "recoveryPosture": {
      "type": "string",
      "enum": [
        "NONE",
        "INLINE_RECONNECT",
        "INLINE_REBASE",
        "READ_ONLY_LIMITED",
        "OBJECT_SUPERSEDED",
        "ACCESS_REBIND_REQUIRED"
      ]
    },
    "interactionLayer": {
      "type": "object",
      "required": [
        "selected_filter_chip_refs",
        "compaction_mode",
        "auxiliary_surface_presentation",
        "focus_trap_mode",
        "selection_persistence_mode",
        "preserved_context_codes"
      ],
      "properties": {
        "selected_filter_chip_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "compaction_mode": {
          "type": "string",
          "enum": [
            "WIDE",
            "AUXILIARY_DRAWER",
            "AUXILIARY_TRAY",
            "FOCUS_STACK"
          ]
        },
        "auxiliary_surface_presentation": {
          "type": "string",
          "enum": [
            "SIDECAR",
            "DRAWER",
            "INSPECTOR",
            "TRAY"
          ]
        },
        "focus_trap_mode": {
          "type": "string",
          "enum": [
            "NON_MODAL",
            "MODAL_EXPLICIT"
          ]
        },
        "selection_persistence_mode": {
          "const": "PRESERVE_WHILE_OBJECT_RESOLVES"
        },
        "preserved_context_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ACTIVE_FILTERS",
              "ACTIVE_SECTION",
              "SELECTION",
              "FOCUS_ANCHOR",
              "PROMOTED_SUPPORT_SURFACE",
              "STAGED_DIFF",
              "CHANGE_BASKET",
              "GUIDED_HANDSHAKE_STEP",
              "QUERY_SLICE"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "attentionSummary": {
      "type": "object",
      "required": [
        "attention_family",
        "headline",
        "supporting_text",
        "primary_worklist_ref",
        "primary_action_label",
        "why_now_label",
        "affected_scope_label",
        "next_legal_action_label",
        "secondary_issue_count"
      ],
      "properties": {
        "attention_family": {
          "type": "string",
          "enum": [
            "CALM",
            "PENDING_APPROVALS",
            "CONFIGURATION_DRIFT",
            "AUTHORITY_LINK_RISK",
            "RETENTION_EXCEPTION",
            "AUDIT_HOTSPOT"
          ]
        },
        "headline": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "supporting_text": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 160
        },
        "primary_worklist_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "primary_action_label": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 40
        },
        "why_now_label": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 80
        },
        "affected_scope_label": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 96
        },
        "next_legal_action_label": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 40
        },
        "secondary_issue_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "attention_family": {
                "const": "CALM"
              }
            },
            "required": [
              "attention_family"
            ]
          },
          "then": {
            "properties": {
              "primary_worklist_ref": {
                "type": "null"
              },
              "primary_action_label": {
                "type": "null"
              },
              "why_now_label": {
                "type": "null"
              },
              "affected_scope_label": {
                "type": "null"
              },
              "next_legal_action_label": {
                "type": "null"
              },
              "secondary_issue_count": {
                "const": 0
              }
            }
          },
          "else": {
            "properties": {
              "primary_worklist_ref": {
                "type": "string",
                "minLength": 1
              },
              "primary_action_label": {
                "type": "string",
                "minLength": 1
              },
              "why_now_label": {
                "type": "string",
                "minLength": 1
              },
              "affected_scope_label": {
                "type": "string",
                "minLength": 1
              },
              "next_legal_action_label": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "riskLedgerEntry": {
      "type": "object",
      "required": [
        "queue_code",
        "headline",
        "open_count",
        "worklist_ref",
        "affected_scope_label",
        "next_action_label"
      ],
      "properties": {
        "queue_code": {
          "type": "string",
          "enum": [
            "PENDING_APPROVALS",
            "CONFIGURATION_DRIFT",
            "AUTHORITY_LINK_RISKS",
            "RETENTION_EXCEPTIONS",
            "AUDIT_HOTSPOTS"
          ]
        },
        "headline": {
          "type": "string",
          "minLength": 1,
          "maxLength": 72
        },
        "open_count": {
          "type": "integer",
          "minimum": 0
        },
        "worklist_ref": {
          "type": "string",
          "minLength": 1
        },
        "affected_scope_label": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 96
        },
        "next_action_label": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 40
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "open_count": {
                "const": 0
              }
            },
            "required": [
              "open_count"
            ]
          },
          "then": {
            "properties": {
              "affected_scope_label": {
                "type": "null"
              },
              "next_action_label": {
                "type": "null"
              }
            }
          },
          "else": {
            "properties": {
              "affected_scope_label": {
                "type": "string",
                "minLength": 1
              },
              "next_action_label": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "activeFilters": {
      "type": "object",
      "required": [
        "environment_ref",
        "client_refs",
        "principal_classes",
        "risk_families",
        "change_states"
      ],
      "properties": {
        "environment_ref": {
          "type": "string",
          "minLength": 1
        },
        "client_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "principal_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "HUMAN",
              "SERVICE",
              "EXTERNAL"
            ]
          },
          "default": [],
          "uniqueItems": true
        },
        "risk_families": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "PENDING_APPROVALS",
              "CONFIGURATION_DRIFT",
              "AUTHORITY_LINK_RISKS",
              "RETENTION_EXCEPTIONS",
              "AUDIT_HOTSPOTS"
            ]
          },
          "default": [],
          "uniqueItems": true
        },
        "change_states": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "supportRegionState": {
      "type": "object",
      "required": [
        "mode",
        "selected_object_ref",
        "reason_code"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "NONE",
            "AUDIT",
            "BLAST_RADIUS",
            "DIFF",
            "EXPORT_ELIGIBILITY",
            "APPROVAL"
          ]
        },
        "selected_object_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "reason_code": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "maxLength": 80
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "selected_object_ref": {
                "type": "string"
              }
            },
            "required": [
              "selected_object_ref"
            ]
          },
          "then": {
            "properties": {
              "mode": {
                "not": {
                  "const": "NONE"
                }
              },
              "reason_code": {
                "type": "string",
                "minLength": 1,
                "maxLength": 80
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "reason_code": {
                "type": "string"
              }
            },
            "required": [
              "reason_code"
            ]
          },
          "then": {
            "properties": {
              "mode": {
                "not": {
                  "const": "NONE"
                }
              },
              "selected_object_ref": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "const": "NONE"
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "properties": {
              "selected_object_ref": {
                "type": "null"
              },
              "reason_code": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "mode": {
                "enum": [
                  "AUDIT",
                  "BLAST_RADIUS",
                  "DIFF",
                  "EXPORT_ELIGIBILITY",
                  "APPROVAL"
                ]
              }
            },
            "required": [
              "mode"
            ]
          },
          "then": {
            "properties": {
              "selected_object_ref": {
                "type": "string",
                "minLength": 1
              },
              "reason_code": {
                "type": "string",
                "minLength": 1,
                "maxLength": 80
              }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "recovery_posture": {
            "const": "NONE"
          }
        },
        "required": [
          "recovery_posture"
        ]
      },
      "then": {
        "properties": {
          "settlement_state": {
            "not": {
              "const": "RECOVERY_REQUIRED"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "settlement_state": {
            "const": "RECOVERY_REQUIRED"
          }
        },
        "required": [
          "settlement_state"
        ]
      },
      "then": {
        "properties": {
          "recovery_posture": {
            "not": {
              "const": "NONE"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "pending_approval_count": {
            "const": 0
          },
          "risky_configuration_drift_count": {
            "const": 0
          },
          "expiring_authority_link_count": {
            "const": 0
          },
          "retention_exception_count": {
            "const": 0
          },
          "audit_hotspot_refs": {
            "maxItems": 0
          }
        },
        "required": [
          "pending_approval_count",
          "risky_configuration_drift_count",
          "expiring_authority_link_count",
          "retention_exception_count",
          "audit_hotspot_refs"
        ]
      },
      "then": {
        "properties": {
          "attention_summary": {
            "type": "object",
            "properties": {
              "attention_family": {
                "const": "CALM"
              }
            },
            "required": [
              "attention_family"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "focus_anchor_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "focus_anchor_ref"
        ]
      },
      "then": {
        "properties": {
          "selected_canvas_object_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "support_region_state": {
            "type": "object",
            "properties": {
              "selected_object_ref": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "selected_object_ref"
            ]
          }
        },
        "required": [
          "support_region_state"
        ]
      },
      "then": {
        "properties": {
          "selected_canvas_object_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "expiring_authority_link_count": {
            "const": 0
          }
        },
        "required": [
          "expiring_authority_link_count"
        ]
      },
      "then": {
        "properties": {
          "authority_link_risk_refs": {
            "maxItems": 0
          }
        }
      },
      "else": {
        "properties": {
          "authority_link_risk_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "retention_exception_count": {
            "const": 0
          }
        },
        "required": [
          "retention_exception_count"
        ]
      },
      "then": {
        "properties": {
          "retention_exception_refs": {
            "maxItems": 0
          }
        }
      },
      "else": {
        "properties": {
          "retention_exception_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "attention_summary": {
            "type": "object",
            "properties": {
              "attention_family": {
                "const": "CALM"
              }
            },
            "required": [
              "attention_family"
            ]
          }
        },
        "required": [
          "attention_summary"
        ]
      },
      "then": {
        "properties": {
          "pending_approval_count": {
            "const": 0
          },
          "risky_configuration_drift_count": {
            "const": 0
          },
          "expiring_authority_link_count": {
            "const": 0
          },
          "retention_exception_count": {
            "const": 0
          },
