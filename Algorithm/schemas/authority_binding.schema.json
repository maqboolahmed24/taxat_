{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/authority_binding.schema.json",
  "title": "AuthorityBinding",
  "description": "Resolved authority-binding contract for a single executable authority operation. This contract freezes tenant/client identity, delegation and partition scope, token and link health posture, executable access-policy binding, and step-up or approval evidence used at preflight and send-time revalidation.",
  "type": "object",
  "required": [
    "artifact_type",
    "authority_binding_id",
    "tenant_id",
    "client_id",
    "manifest_id",
    "principal_context_ref",
    "authorization_decision_ref",
    "authority_link_ref",
    "delegation_grant_ref",
    "delegation_state",
    "authority_link_state",
    "partition_scope_refs",
    "token_binding_ref",
    "binding_lineage_ref",
    "token_version_ref",
    "subject_ref",
    "acting_party_ref",
    "authority_scope",
    "provider_environment",
    "provider_api_version",
    "access_binding_hash",
    "policy_snapshot_hash",
    "token_client_binding_state",
    "binding_health",
    "last_validated_at",
    "expires_at",
    "blocked_reason_codes",
    "authority_layer_boundary",
    "step_up_state",
    "step_up_evidence_ref",
    "approval_state",
    "approval_ref",
    "binding_resolved_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "AuthorityBinding"
    },
    "authority_binding_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "principal_context_ref": {
      "type": "string",
      "minLength": 1
    },
    "authorization_decision_ref": {
      "type": "string",
      "minLength": 1
    },
    "authority_link_ref": {
      "type": "string",
      "minLength": 1
    },
    "delegation_grant_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "delegation_state": {
      "type": "string",
      "enum": [
        "NOT_REQUIRED",
        "SATISFIED",
        "LIMITED",
        "MISSING",
        "EXPIRED",
        "UNKNOWN"
      ]
    },
    "authority_link_state": {
      "type": "string",
      "enum": [
        "UNLINKED",
        "LINK_INITIATED",
        "AUTHORISED_ACTIVE",
        "AUTHORISED_LIMITED",
        "TOKEN_INVALID",
        "REVOKED",
        "EXPIRED",
        "SUPERSEDED"
      ]
    },
    "partition_scope_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "token_binding_ref": {
      "type": "string",
      "minLength": 1
    },
    "binding_lineage_ref": {
      "type": "string",
      "minLength": 1
    },
    "token_version_ref": {
      "type": "string",
      "minLength": 1
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "acting_party_ref": {
      "type": "string",
      "minLength": 1
    },
    "authority_scope": {
      "type": "string",
      "minLength": 1
    },
    "provider_environment": {
      "type": "string",
      "minLength": 1
    },
    "provider_api_version": {
      "type": "string",
      "minLength": 1
    },
    "access_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "policy_snapshot_hash": {
      "type": "string",
      "minLength": 1
    },
    "token_client_binding_state": {
      "type": "string",
      "enum": [
        "BOUND",
        "MISMATCH",
        "UNVERIFIED"
      ]
    },
    "binding_health": {
      "type": "string",
      "enum": [
        "HEALTHY",
        "LIMITED_SCOPE",
        "EXPIRING_SOON",
        "TOKEN_INVALID",
        "CLIENT_BINDING_MISMATCH",
        "DELEGATION_GAP",
        "ENVIRONMENT_DRIFT",
        "REVOKED",
        "EXPIRED",
        "UNKNOWN"
      ]
    },
    "last_validated_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "blocked_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "authority_layer_boundary": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/authority_layer_boundary_contract.schema.json"
        },
        {
          "type": "object",
          "properties": {
            "binding_scope_class": {
              "const": "AUTHORITY_BINDING"
            },
            "integration_capability": {
              "const": "AUTHORITY_INTEGRATED"
            }
          }
        }
      ]
    },
    "step_up_state": {
      "type": "string",
      "enum": [
        "NOT_REQUIRED",
        "SATISFIED"
      ]
    },
    "step_up_evidence_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "approval_state": {
      "type": "string",
      "enum": [
        "NOT_REQUIRED",
        "SATISFIED"
      ]
    },
    "approval_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "binding_resolved_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "token_client_binding_state": {
            "const": "MISMATCH"
          }
        },
        "required": [
          "token_client_binding_state"
        ]
      },
      "then": {
        "properties": {
          "binding_health": {
            "const": "CLIENT_BINDING_MISMATCH"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "binding_health": {
            "const": "CLIENT_BINDING_MISMATCH"
          }
        },
        "required": [
          "binding_health"
        ]
      },
      "then": {
        "properties": {
          "token_client_binding_state": {
            "const": "MISMATCH"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "binding_health": {
            "enum": [
              "HEALTHY",
              "EXPIRING_SOON"
            ]
          }
        },
        "required": [
          "binding_health"
        ]
      },
      "then": {
        "properties": {
          "token_client_binding_state": {
            "const": "BOUND"
          },
          "delegation_state": {
            "enum": [
              "NOT_REQUIRED",
              "SATISFIED"
            ]
          },
          "authority_link_state": {
            "const": "AUTHORISED_ACTIVE"
          },
          "blocked_reason_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "delegation_state": {
            "const": "NOT_REQUIRED"
          }
        },
        "required": [
          "delegation_state"
        ]
      },
      "then": {
        "properties": {
          "delegation_grant_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "delegation_state": {
            "enum": [
              "SATISFIED",
              "LIMITED",
              "EXPIRED"
            ]
          }
        },
        "required": [
          "delegation_state"
        ]
      },
      "then": {
        "properties": {
          "delegation_grant_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "binding_health": {
            "not": {
              "enum": [
                "HEALTHY",
                "EXPIRING_SOON"
              ]
            }
          }
        },
        "required": [
          "binding_health"
        ]
      },
      "then": {
        "properties": {
          "blocked_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "delegation_state": {
            "enum": [
              "MISSING",
              "EXPIRED"
            ]
          }
        },
        "required": [
          "delegation_state"
        ]
      },
      "then": {
        "properties": {
          "binding_health": {
            "const": "DELEGATION_GAP"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "binding_health": {
            "const": "DELEGATION_GAP"
          }
        },
        "required": [
          "binding_health"
        ]
      },
      "then": {
        "properties": {
          "delegation_state": {
            "enum": [
              "MISSING",
              "EXPIRED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "delegation_state": {
            "const": "LIMITED"
          }
        },
        "required": [
          "delegation_state"
        ]
      },
      "then": {
        "properties": {
          "binding_health": {
            "const": "LIMITED_SCOPE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "binding_health": {
            "enum": [
              "EXPIRING_SOON",
              "EXPIRED"
            ]
          }
        },
        "required": [
          "binding_health"
        ]
      },
      "then": {
        "properties": {
          "expires_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_link_state": {
            "const": "AUTHORISED_LIMITED"
          }
        },
        "required": [
          "authority_link_state"
        ]
      },
      "then": {
        "properties": {
          "binding_health": {
            "const": "LIMITED_SCOPE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_link_state": {
            "const": "TOKEN_INVALID"
          }
        },
        "required": [
          "authority_link_state"
        ]
      },
      "then": {
        "properties": {
          "binding_health": {
            "const": "TOKEN_INVALID"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_link_state": {
            "const": "REVOKED"
          }
        },
        "required": [
          "authority_link_state"
        ]
      },
      "then": {
        "properties": {
          "binding_health": {
            "const": "REVOKED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authority_link_state": {
            "const": "EXPIRED"
          }
        },
        "required": [
          "authority_link_state"
        ]
      },
      "then": {
        "properties": {
          "binding_health": {
            "const": "EXPIRED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "step_up_state": {
            "const": "SATISFIED"
          }
        },
        "required": [
          "step_up_state"
        ]
      },
      "then": {
        "properties": {
          "step_up_evidence_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "else": {
        "properties": {
          "step_up_evidence_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "approval_state": {
            "const": "SATISFIED"
          }
        },
        "required": [
          "approval_state"
        ]
      },
      "then": {
        "properties": {
          "approval_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "else": {
        "properties": {
          "approval_ref": {
            "type": "null"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
