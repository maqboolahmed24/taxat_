{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/release_verification_manifest_assembly_contract.schema.json",
  "title": "ReleaseVerificationManifestAssemblyContract",
  "description": "Deterministic release-verification manifest assembly contract. This schema freezes the exact gate-result and admissibility evidence set, companion release evidence, canonical gate order, candidate and schema-compatibility binding, and decision posture used to assemble one ReleaseVerificationManifest.",
  "type": "object",
  "required": [
    "contract_version",
    "assembly_contract_hash",
    "candidate_identity_hash",
    "compatibility_gate_hash",
    "gate_order_policy",
    "evidence_source_policy",
    "admissibility_derivation_policy",
    "companion_evidence_policy",
    "decision_posture_policy",
    "supersession_policy",
    "enabled_provider_profile_refs",
    "executed_test_run_identifiers",
    "gate_bindings",
    "migration_mode",
    "migration_plan_ref_or_null",
    "migration_ledger_refs",
    "supported_client_window_ref",
    "canary_summary_ref_or_null",
    "deterministic_golden_pack_ref_or_null",
    "restore_drill_ref_or_null",
    "restore_checkpoint_ref_or_null",
    "client_compatibility_matrix_ref_or_null",
    "decision_state",
    "approval_ref_or_null",
    "deployment_release_ref_or_null",
    "superseded_by_verification_manifest_ref_or_null"
  ],
  "properties": {
    "contract_version": {
      "const": "RELEASE_VERIFICATION_MANIFEST_ASSEMBLY_V1"
    },
    "assembly_contract_hash": {
      "type": "string",
      "minLength": 1
    },
    "candidate_identity_hash": {
      "type": "string",
      "minLength": 1
    },
    "compatibility_gate_hash": {
      "type": "string",
      "minLength": 1
    },
    "gate_order_policy": {
      "const": "CANONICAL_BLOCKING_GATE_ORDER_V1"
    },
    "evidence_source_policy": {
      "const": "FIRST_CLASS_RESULT_AND_ADMISSIBILITY_ARTIFACTS_ONLY"
    },
    "admissibility_derivation_policy": {
      "const": "GREEN_REQUIRES_ADMISSIBLE_UNQUARANTINED_UNWAIVED_EVIDENCE"
    },
    "companion_evidence_policy": {
      "const": "GREEN_SUPPORTING_GATES_REQUIRE_COMPANION_EVIDENCE_REFS"
    },
    "decision_posture_policy": {
      "const": "APPROVAL_AND_SUPERSESSION_REQUIRE_EXPLICIT_DECISION_LINEAGE"
    },
    "supersession_policy": {
      "const": "NEW_MANIFEST_SUPERSEDES_OLD_MANIFEST_EXPLICITLY_NO_POST_HOC_REWRITE"
    },
    "enabled_provider_profile_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "executed_test_run_identifiers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "gate_bindings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/gateBinding"
      },
      "minItems": 11,
      "maxItems": 11
    },
    "migration_mode": {
      "type": "string",
      "enum": [
        "NO_MIGRATION",
        "MIGRATION_REQUIRED"
      ]
    },
    "migration_plan_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "migration_ledger_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "supported_client_window_ref": {
      "type": "string",
      "minLength": 1
    },
    "canary_summary_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "deterministic_golden_pack_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "restore_drill_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "restore_checkpoint_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "client_compatibility_matrix_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "decision_state": {
      "type": "string",
      "enum": [
        "PENDING",
        "BLOCKED",
        "APPROVED",
        "SUPERSEDED"
      ]
    },
    "approval_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "deployment_release_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "superseded_by_verification_manifest_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  },
  "$defs": {
    "gateBinding": {
      "type": "object",
      "required": [
        "gate_name",
        "suite_family",
        "candidate_identity_hash",
        "compatibility_gate_hash_or_null",
        "authority_sandbox_coverage_hash_or_null",
        "result_ref",
        "admissibility_ref",
        "status",
        "admissibility_state",
        "quarantine_state",
        "manual_waiver_state",
        "executed_at"
      ],
      "properties": {
        "gate_name": {
          "type": "string",
          "enum": [
            "schema_compatibility",
            "deterministic_and_state_machine",
            "northbound_api",
            "authority_sandbox",
            "operator_client",
            "security",
            "performance_and_canary",
            "restore_drill",
            "migration_verification",
            "supply_chain",
            "suite_admissibility"
          ]
        },
        "suite_family": {
          "type": "string",
          "enum": [
            "SCHEMA_COMPATIBILITY",
            "DETERMINISTIC_AND_STATE_MACHINE",
            "NORTHBOUND_API",
            "AUTHORITY_SANDBOX",
            "OPERATOR_CLIENT",
            "SECURITY",
            "PERFORMANCE_AND_CANARY",
            "RESTORE_DRILL",
            "MIGRATION_VERIFICATION",
            "SUPPLY_CHAIN",
            "SUITE_ADMISSIBILITY"
          ]
        },
        "candidate_identity_hash": {
          "type": "string",
          "minLength": 1
        },
        "compatibility_gate_hash_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "authority_sandbox_coverage_hash_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "result_ref": {
          "type": "string",
          "minLength": 1
        },
        "admissibility_ref": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "GREEN",
            "RED"
          ]
        },
        "admissibility_state": {
          "type": "string",
          "enum": [
            "ADMISSIBLE",
            "INADMISSIBLE"
          ]
        },
        "quarantine_state": {
          "type": "string",
          "enum": [
            "NONE",
            "QUARANTINED"
          ]
        },
        "manual_waiver_state": {
          "type": "string",
          "enum": [
            "NONE",
            "WAIVED"
          ]
        },
        "executed_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "gate_name": {
                "const": "schema_compatibility"
              }
            },
            "required": [
              "gate_name"
            ]
          },
          "then": {
            "properties": {
              "suite_family": {
                "const": "SCHEMA_COMPATIBILITY"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "gate_name": {
                "const": "deterministic_and_state_machine"
              }
            },
            "required": [
              "gate_name"
            ]
          },
          "then": {
            "properties": {
              "suite_family": {
                "const": "DETERMINISTIC_AND_STATE_MACHINE"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "gate_name": {
                "const": "northbound_api"
              }
            },
            "required": [
              "gate_name"
            ]
          },
          "then": {
            "properties": {
              "suite_family": {
                "const": "NORTHBOUND_API"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "gate_name": {
                "const": "authority_sandbox"
              }
            },
            "required": [
              "gate_name"
            ]
          },
          "then": {
            "properties": {
              "suite_family": {
                "const": "AUTHORITY_SANDBOX"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "gate_name": {
                "const": "operator_client"
              }
            },
            "required": [
              "gate_name"
            ]
          },
          "then": {
            "properties": {
              "suite_family": {
                "const": "OPERATOR_CLIENT"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "gate_name": {
                "const": "security"
              }
            },
            "required": [
              "gate_name"
            ]
          },
          "then": {
            "properties": {
              "suite_family": {
                "const": "SECURITY"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "gate_name": {
                "const": "performance_and_canary"
              }
            },
            "required": [
              "gate_name"
            ]
          },
          "then": {
            "properties": {
              "suite_family": {
                "const": "PERFORMANCE_AND_CANARY"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "gate_name": {
                "const": "restore_drill"
              }
            },
            "required": [
              "gate_name"
            ]
          },
          "then": {
            "properties": {
              "suite_family": {
                "const": "RESTORE_DRILL"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "gate_name": {
                "const": "migration_verification"
              }
            },
            "required": [
              "gate_name"
            ]
          },
          "then": {
            "properties": {
              "suite_family": {
                "const": "MIGRATION_VERIFICATION"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "gate_name": {
                "const": "supply_chain"
              }
            },
            "required": [
              "gate_name"
            ]
          },
          "then": {
            "properties": {
              "suite_family": {
                "const": "SUPPLY_CHAIN"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "gate_name": {
                "const": "suite_admissibility"
              }
            },
            "required": [
              "gate_name"
            ]
          },
          "then": {
            "properties": {
              "suite_family": {
                "const": "SUITE_ADMISSIBILITY"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "suite_family": {
                "const": "AUTHORITY_SANDBOX"
              }
            },
            "required": [
              "suite_family"
            ]
          },
          "then": {
            "properties": {
              "authority_sandbox_coverage_hash_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "else": {
            "properties": {
              "authority_sandbox_coverage_hash_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "suite_family": {
                "enum": [
                  "SCHEMA_COMPATIBILITY",
                  "MIGRATION_VERIFICATION",
                  "OPERATOR_CLIENT"
                ]
              }
            },
            "required": [
              "suite_family"
            ]
          },
          "then": {
            "properties": {
              "compatibility_gate_hash_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "else": {
            "properties": {
              "compatibility_gate_hash_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "GREEN"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "admissibility_state": {
                "const": "ADMISSIBLE"
              },
              "quarantine_state": {
                "const": "NONE"
              },
              "manual_waiver_state": {
                "const": "NONE"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "quarantine_state": {
                "const": "QUARANTINED"
              }
            },
            "required": [
              "quarantine_state"
            ]
          },
          "then": {
            "properties": {
              "status": {
                "const": "RED"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "manual_waiver_state": {
                "const": "WAIVED"
              }
            },
            "required": [
              "manual_waiver_state"
            ]
          },
          "then": {
            "properties": {
              "status": {
                "const": "RED"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "admissibility_state": {
                "const": "INADMISSIBLE"
              }
            },
            "required": [
              "admissibility_state"
            ]
          },
          "then": {
            "properties": {
              "status": {
                "const": "RED"
              }
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "gate_bindings": {
            "contains": {
              "type": "object",
              "properties": {
                "gate_name": {
                  "const": "deterministic_and_state_machine"
                },
                "status": {
                  "const": "GREEN"
                }
              },
              "required": [
                "gate_name",
                "status"
              ]
            }
          }
        },
        "required": [
          "gate_bindings"
        ]
      },
      "then": {
        "properties": {
          "deterministic_golden_pack_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "deterministic_golden_pack_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "deterministic_golden_pack_ref_or_null"
        ]
      },
      "then": {
        "properties": {
          "gate_bindings": {
            "contains": {
              "type": "object",
              "properties": {
                "gate_name": {
                  "const": "deterministic_and_state_machine"
                },
                "status": {
                  "const": "GREEN"
                }
              },
              "required": [
                "gate_name",
                "status"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "migration_mode": {
            "const": "NO_MIGRATION"
          }
        },
        "required": [
          "migration_mode"
        ]
      },
      "then": {
        "properties": {
          "migration_plan_ref_or_null": {
            "type": "null"
          },
          "migration_ledger_refs": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "migration_mode": {
            "const": "MIGRATION_REQUIRED"
          }
        },
        "required": [
          "migration_mode"
        ]
      },
      "then": {
        "properties": {
          "migration_plan_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "migration_ledger_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "restore_drill_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "restore_drill_ref_or_null"
        ]
      },
      "then": {
        "properties": {
          "restore_checkpoint_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "restore_checkpoint_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "restore_checkpoint_ref_or_null"
        ]
      },
      "then": {
        "properties": {
          "restore_drill_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "approval_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "approval_ref_or_null"
        ]
      },
      "then": {
        "properties": {
          "decision_state": {
            "const": "APPROVED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "deployment_release_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "deployment_release_ref_or_null"
        ]
      },
      "then": {
        "properties": {
          "decision_state": {
            "const": "APPROVED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "superseded_by_verification_manifest_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "superseded_by_verification_manifest_ref_or_null"
        ]
      },
      "then": {
        "properties": {
          "decision_state": {
            "const": "SUPERSEDED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision_state": {
            "const": "APPROVED"
          }
        },
        "required": [
          "decision_state"
        ]
      },
      "then": {
        "properties": {
          "approval_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "deployment_release_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "superseded_by_verification_manifest_ref_or_null": {
            "type": "null"
          },
          "canary_summary_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "deterministic_golden_pack_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "restore_drill_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "restore_checkpoint_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "client_compatibility_matrix_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision_state": {
            "enum": [
              "PENDING",
              "BLOCKED"
            ]
          }
        },
        "required": [
          "decision_state"
        ]
      },
      "then": {
        "properties": {
          "approval_ref_or_null": {
            "type": "null"
          },
          "deployment_release_ref_or_null": {
            "type": "null"
          },
          "superseded_by_verification_manifest_ref_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision_state": {
            "const": "SUPERSEDED"
          }
        },
        "required": [
          "decision_state"
        ]
      },
      "then": {
        "properties": {
          "superseded_by_verification_manifest_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
