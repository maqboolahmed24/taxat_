{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/twin_portfolio_summary.schema.json",
  "title": "TwinPortfolioSummary",
  "description": "Portfolio-level twin aggregation contract. This schema freezes aggregate twin counts and top-ranked twins/mismatches for a selected portfolio scope so operators do not have to expand every manifest-level twin to know what matters first.",
  "type": "object",
  "required": [
    "artifact_type",
    "twin_portfolio_summary_id",
    "tenant_id",
    "scope_ref",
    "generated_at",
    "total_twin_count",
    "ready_count",
    "review_required_count",
    "waiting_on_authority_count",
    "reconciliation_required_count",
    "blocked_count",
    "stale_twin_count",
    "out_of_band_twin_count",
    "highest_attention_rank",
    "top_twin_refs",
    "top_mismatch_refs"
  ],
  "properties": {
    "artifact_type": {
      "const": "TwinPortfolioSummary"
    },
    "twin_portfolio_summary_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "scope_ref": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "total_twin_count": {
      "type": "integer",
      "minimum": 0
    },
    "ready_count": {
      "type": "integer",
      "minimum": 0
    },
    "review_required_count": {
      "type": "integer",
      "minimum": 0
    },
    "waiting_on_authority_count": {
      "type": "integer",
      "minimum": 0
    },
    "reconciliation_required_count": {
      "type": "integer",
      "minimum": 0
    },
    "blocked_count": {
      "type": "integer",
      "minimum": 0
    },
    "stale_twin_count": {
      "type": "integer",
      "minimum": 0
    },
    "out_of_band_twin_count": {
      "type": "integer",
      "minimum": 0
    },
    "highest_attention_rank": {
      "type": "integer",
      "minimum": 0
    },
    "top_twin_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "top_mismatch_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "total_twin_count": {
            "const": 0
          }
        },
        "required": [
          "total_twin_count"
        ]
      },
      "then": {
        "properties": {
          "ready_count": {
            "const": 0
          },
          "review_required_count": {
            "const": 0
          },
          "waiting_on_authority_count": {
            "const": 0
          },
          "reconciliation_required_count": {
            "const": 0
          },
          "blocked_count": {
            "const": 0
          },
          "stale_twin_count": {
            "const": 0
          },
          "out_of_band_twin_count": {
            "const": 0
          },
          "highest_attention_rank": {
            "const": 0
          },
          "top_twin_refs": {
            "maxItems": 0
          },
          "top_mismatch_refs": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "total_twin_count": {
            "minimum": 1
          }
        },
        "required": [
          "total_twin_count"
        ]
      },
      "then": {
        "properties": {
          "highest_attention_rank": {
            "minimum": 1
          },
          "top_twin_refs": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
