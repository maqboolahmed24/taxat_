{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/build_artifact.schema.json",
  "title": "BuildArtifact",
  "description": "Signed release-build contract. This schema freezes build digest, SBOM, provenance, signature, and desktop notarization posture for a shippable artifact.",
  "type": "object",
  "required": [
    "build_id",
    "vcs_ref",
    "artifact_digest",
    "sbom_ref",
    "provenance_ref",
    "signature_ref",
    "artifact_registry_ref",
    "release_channel",
    "build_time",
    "distribution_targets",
    "desktop_notarization_ref",
    "hardened_runtime_attestation_ref"
  ],
  "properties": {
    "build_id": {
      "type": "string",
      "minLength": 1
    },
    "vcs_ref": {
      "type": "string",
      "minLength": 1
    },
    "artifact_digest": {
      "type": "string",
      "minLength": 1
    },
    "sbom_ref": {
      "type": "string",
      "minLength": 1
    },
    "provenance_ref": {
      "type": "string",
      "minLength": 1
    },
    "signature_ref": {
      "type": "string",
      "minLength": 1
    },
    "artifact_registry_ref": {
      "type": "string",
      "minLength": 1
    },
    "release_channel": {
      "type": "string",
      "minLength": 1
    },
    "build_time": {
      "type": "string",
      "format": "date-time"
    },
    "distribution_targets": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "SERVER",
          "WEB_OPERATOR_SHELL",
          "MACOS_DESKTOP"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "desktop_notarization_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "hardened_runtime_attestation_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "distribution_targets": {
            "contains": {
              "const": "MACOS_DESKTOP"
            }
          }
        },
        "required": [
          "distribution_targets"
        ]
      },
      "then": {
        "properties": {
          "desktop_notarization_ref": {
            "type": "string",
            "minLength": 1
          },
          "hardened_runtime_attestation_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "else": {
        "properties": {
          "desktop_notarization_ref": {
            "type": "null"
          },
          "hardened_runtime_attestation_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "desktop_notarization_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "desktop_notarization_ref"
        ]
      },
      "then": {
        "properties": {
          "distribution_targets": {
            "contains": {
              "const": "MACOS_DESKTOP"
            },
            "minContains": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "hardened_runtime_attestation_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "hardened_runtime_attestation_ref"
        ]
      },
      "then": {
        "properties": {
          "distribution_targets": {
            "contains": {
              "const": "MACOS_DESKTOP"
            },
            "minContains": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
