{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/cross_device_continuity_contract.schema.json",
  "title": "CrossDeviceContinuityContract",
  "description": "Shared same-object continuity and restoration contract for route-visible shell and native scene embodiments. This schema freezes the governed object anchor, active route or scene identity, explicit parent return binding, compatibility scope hashes, allowed device embodiments, and the authoritative cross-device continuity policies so resize, deep-link open, cache hydration, and native restoration cannot reopen a different shell, broader visibility, or guessed action posture for the same object.",
  "type": "object",
  "required": [
    "contract_version",
    "continuity_scope",
    "canonical_object_ref",
    "shell_family",
    "route_identity_ref",
    "parent_context_ref_or_null",
    "focus_anchor_ref_or_null",
    "return_focus_anchor_ref_or_null",
    "dominant_action_state_or_null",
    "stability_guard_hash_or_null",
    "access_scope_hash_or_null",
    "masking_scope_fingerprint_or_null",
    "session_scope_ref_or_null",
    "visibility_cache_partition_key_or_null",
    "allowed_embodiments",
    "same_object_policy",
    "same_shell_policy",
    "narrow_layout_policy",
    "deep_link_return_policy",
    "action_posture_policy",
    "hydration_compatibility_policy",
    "compatibility_basis_class",
    "restoration_mode_policy",
    "secondary_window_policy",
    "supported_invalidation_reason_codes"
  ],
  "properties": {
    "contract_version": {
      "const": "CROSS_DEVICE_CONTINUITY_V1"
    },
    "continuity_scope": {
      "type": "string",
      "enum": [
        "MANIFEST_ROUTE",
        "WORKSPACE_ROUTE",
        "CLIENT_PORTAL_ROUTE",
        "WORK_ITEM_NOTIFICATION",
        "NATIVE_PRIMARY_SCENE",
        "NATIVE_SECONDARY_WINDOW",
        "GOVERNANCE_ROUTE"
      ]
    },
    "canonical_object_ref": {
      "type": "string",
      "minLength": 1
    },
    "shell_family": {
      "type": "string",
      "enum": [
        "CALM_SHELL",
        "CLIENT_PORTAL_SHELL",
        "GOVERNANCE_DENSITY_SHELL"
      ]
    },
    "route_identity_ref": {
      "type": "string",
      "minLength": 1
    },
    "parent_context_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "focus_anchor_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "return_focus_anchor_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "dominant_action_state_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "ACTION_AVAILABLE",
        "NO_SAFE_ACTION",
        null
      ]
    },
    "stability_guard_hash_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "access_scope_hash_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "masking_scope_fingerprint_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "session_scope_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "visibility_cache_partition_key_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "allowed_embodiments": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "BROWSER_WIDE",
          "BROWSER_NARROW_STACKED",
          "NATIVE_PRIMARY_SCENE",
          "NATIVE_SUPPORT_WINDOW"
        ]
      },
      "minItems": 2,
      "uniqueItems": true
    },
    "same_object_policy": {
      "const": "PRESERVE_EXACT_OBJECT_OR_EXPLICIT_LAWFUL_FALLBACK"
    },
    "same_shell_policy": {
      "const": "PRESERVE_SAME_SHELL_FAMILY"
    },
    "narrow_layout_policy": {
      "type": "string",
      "enum": [
        "STACK_WITHIN_SAME_SHELL",
        "NOT_APPLICABLE"
      ]
    },
    "deep_link_return_policy": {
      "const": "EXPLICIT_PARENT_CONTEXT_AND_FOCUS"
    },
    "action_posture_policy": {
      "const": "DOMINANCE_AND_SETTLEMENT_SERVER_AUTHORED_ONLY"
    },
    "hydration_compatibility_policy": {
      "const": "TENANT_ACCESS_MASKING_AND_SESSION_BOUND"
    },
    "compatibility_basis_class": {
      "type": "string",
      "enum": [
        "ROUTE_GUARD_ONLY",
        "ROUTE_GUARD_AND_VISIBILITY",
        "VISIBILITY_ONLY",
        "SESSION_MASKING_AND_ROUTE_GUARD",
        "SESSION_MASKING_AND_PARENT_SCENE"
      ]
    },
    "restoration_mode_policy": {
      "const": "EXPLICIT_CARRY_FORWARD_OR_REBASE_ONLY"
    },
    "secondary_window_policy": {
      "type": "string",
      "enum": [
        "NOT_APPLICABLE",
        "SUPPORT_ONLY_PARENT_BOUND"
      ]
    },
    "supported_invalidation_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "TENANT_SWITCH",
          "PRIVILEGE_DOWNGRADE",
          "ACCESS_BINDING_CHANGE",
          "MASKING_CHANGE",
          "VIEW_GUARD_CHANGE",
          "SESSION_REVOKED",
          "SCHEMA_INCOMPATIBLE",
          "OBJECT_GONE",
          "PARENT_WINDOW_CLOSED",
          "POLICY_SNAPSHOT_CHANGE"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "parent_context_ref_or_null": {
            "type": "null"
          }
        },
        "required": [
          "parent_context_ref_or_null"
        ]
      },
      "then": {
        "properties": {
          "return_focus_anchor_ref_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "parent_context_ref_or_null": {
            "type": "string"
          }
        },
        "required": [
          "parent_context_ref_or_null"
        ]
      },
      "then": {
        "properties": {
          "return_focus_anchor_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "continuity_scope": {
            "const": "WORK_ITEM_NOTIFICATION"
          }
        },
        "required": [
          "continuity_scope"
        ]
      },
      "then": {
        "properties": {
          "dominant_action_state_or_null": {
            "type": "null"
          },
          "narrow_layout_policy": {
            "const": "NOT_APPLICABLE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "continuity_scope": {
            "enum": [
              "NATIVE_PRIMARY_SCENE",
              "NATIVE_SECONDARY_WINDOW"
            ]
          }
        },
        "required": [
          "continuity_scope"
        ]
      },
      "then": {
        "properties": {
          "narrow_layout_policy": {
            "const": "NOT_APPLICABLE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "continuity_scope": {
            "const": "NATIVE_SECONDARY_WINDOW"
          }
        },
        "required": [
          "continuity_scope"
        ]
      },
      "then": {
        "properties": {
          "secondary_window_policy": {
            "const": "SUPPORT_ONLY_PARENT_BOUND"
          },
          "dominant_action_state_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "continuity_scope": {
            "enum": [
              "MANIFEST_ROUTE",
              "GOVERNANCE_ROUTE"
            ]
          }
        },
        "required": [
          "continuity_scope"
        ]
      },
      "then": {
        "properties": {
          "compatibility_basis_class": {
            "const": "ROUTE_GUARD_ONLY"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "compatibility_basis_class": {
            "const": "ROUTE_GUARD_ONLY"
          }
        },
        "required": [
          "compatibility_basis_class"
        ]
      },
      "then": {
        "properties": {
          "stability_guard_hash_or_null": {
            "type": "string",
            "minLength": 1
          },
          "access_scope_hash_or_null": {
            "type": "null"
          },
          "masking_scope_fingerprint_or_null": {
            "type": "null"
          },
          "session_scope_ref_or_null": {
            "type": "null"
          },
          "visibility_cache_partition_key_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "compatibility_basis_class": {
            "const": "ROUTE_GUARD_AND_VISIBILITY"
          }
        },
        "required": [
          "compatibility_basis_class"
        ]
      },
      "then": {
        "properties": {
          "stability_guard_hash_or_null": {
            "type": "string",
            "minLength": 1
          },
          "access_scope_hash_or_null": {
            "type": "string",
            "minLength": 1
          },
          "masking_scope_fingerprint_or_null": {
            "type": "string",
            "minLength": 1
          },
          "session_scope_ref_or_null": {
            "type": "null"
          },
          "visibility_cache_partition_key_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "compatibility_basis_class": {
            "const": "VISIBILITY_ONLY"
          }
        },
        "required": [
          "compatibility_basis_class"
        ]
      },
      "then": {
        "properties": {
          "stability_guard_hash_or_null": {
            "type": "null"
          },
          "access_scope_hash_or_null": {
            "type": "string",
            "minLength": 1
          },
          "masking_scope_fingerprint_or_null": {
            "type": "string",
            "minLength": 1
          },
          "session_scope_ref_or_null": {
            "type": "null"
          },
          "visibility_cache_partition_key_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "compatibility_basis_class": {
            "enum": [
              "SESSION_MASKING_AND_ROUTE_GUARD",
              "SESSION_MASKING_AND_PARENT_SCENE"
            ]
          }
        },
        "required": [
          "compatibility_basis_class"
        ]
      },
      "then": {
        "properties": {
          "stability_guard_hash_or_null": {
            "type": "string",
            "minLength": 1
          },
          "access_scope_hash_or_null": {
            "type": [
              "string",
              "null"
            ],
            "minLength": 1
          },
          "masking_scope_fingerprint_or_null": {
            "type": "string",
            "minLength": 1
          },
          "session_scope_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "visibility_cache_partition_key_or_null": {
            "type": "null"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
