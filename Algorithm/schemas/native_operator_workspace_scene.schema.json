{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/native_operator_workspace_scene.schema.json",
  "title": "NativeOperatorWorkspaceScene",
  "description": "Machine-readable primary-window contract for the signed macOS operator shell. This schema freezes the canonical calm-shell identity together with the native operator embodiment, the three-region native workspace layout, mounted object-family continuity, support-only inspector detachment, restoration invalidation posture, explicit keyboard focus or shortcut vocabulary, and persisted route-stability lineage so native scene behavior cannot drift from the shared shell law.",
  "type": "object",
  "required": [
    "artifact_type",
    "scene_id",
    "tenant_id",
    "shell_family",
    "surface_embodiment",
    "backing_read_model_type",
    "backing_read_model_ref",
    "object_family",
    "object_anchor_ref",
    "dominant_question",
    "dominance_contract",
    "state_taxonomy_contract",
    "cross_device_continuity_contract",
    "cache_isolation_contract",
    "native_cache_hydration_contract",
    "semantic_accessibility_contract",
    "settlement_state",
    "recovery_posture",
    "interaction_layer",
    "surface_order",
    "leading_sidebar",
    "primary_canvas",
    "trailing_inspector",
    "scene_identity",
    "scene_restoration",
    "shortcut_posture",
    "rendered_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "NativeOperatorWorkspaceScene"
    },
    "scene_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "shell_family": {
      "const": "CALM_SHELL"
    },
    "surface_embodiment": {
      "const": "NATIVE_OPERATOR"
    },
    "backing_read_model_type": {
      "type": "string",
      "enum": [
        "LowNoiseExperienceFrame",
        "WorkspaceSnapshot"
      ]
    },
    "backing_read_model_ref": {
      "type": "string",
      "minLength": 1
    },
    "object_family": {
      "type": "string",
      "enum": [
        "MANIFEST",
        "WORK_ITEM"
      ]
    },
    "object_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "dominant_question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "dominance_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/shell_dominance_contract.schema.json"
        },
        {
          "properties": {
            "dominant_question_surface_code": {
              "const": "PRIMARY_CANVAS"
            },
            "dominant_action_surface_code": {
              "const": "ACTION_STRIP"
            },
            "supplemental_queue_policy": {
              "const": "NOT_APPLICABLE"
            },
            "promoted_support_surface_code_or_null": {
              "enum": [
                "TRAILING_INSPECTOR",
                null
              ]
            }
          }
        }
      ]
    },
    "state_taxonomy_contract": {
      "$ref": "https://taxat.dev/schemas/shell_state_taxonomy_contract.schema.json"
    },
    "cross_device_continuity_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/cross_device_continuity_contract.schema.json"
        },
        {
          "properties": {
            "continuity_scope": {
              "const": "NATIVE_PRIMARY_SCENE"
            }
          }
        }
      ]
    },
    "cache_isolation_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/cache_isolation_contract.schema.json"
        },
        {
          "properties": {
            "cache_scope_class": {
              "const": "NATIVE_OPERATOR_WORKSPACE_SCENE"
            }
          }
        }
      ]
    },
    "native_cache_hydration_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/native_cache_hydration_contract.schema.json"
        },
        {
          "properties": {
            "hydration_scope_class": {
              "const": "NATIVE_PRIMARY_SCENE"
            }
          }
        }
      ]
    },
    "semantic_accessibility_contract": {
      "$ref": "https://taxat.dev/schemas/semantic_accessibility_contract.schema.json"
    },
    "settlement_state": {
      "$ref": "#/$defs/settlementState"
    },
    "recovery_posture": {
      "$ref": "#/$defs/recoveryPosture"
    },
    "interaction_layer": {
      "$ref": "https://taxat.dev/schemas/operator_interaction_layer.schema.json"
    },
    "surface_order": {
      "type": "array",
      "prefixItems": [
        {
          "const": "LEADING_SIDEBAR"
        },
        {
          "const": "PRIMARY_CANVAS"
        },
        {
          "const": "TRAILING_INSPECTOR"
        }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "leading_sidebar": {
      "$ref": "#/$defs/leadingSidebar"
    },
    "primary_canvas": {
      "$ref": "#/$defs/primaryCanvas"
    },
    "trailing_inspector": {
      "$ref": "#/$defs/trailingInspector"
    },
    "scene_identity": {
      "$ref": "#/$defs/sceneIdentity"
    },
    "scene_restoration": {
      "$ref": "#/$defs/sceneRestoration"
    },
    "shortcut_posture": {
      "$ref": "#/$defs/shortcutPosture"
    },
    "rendered_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "settlementState": {
      "type": "string",
      "enum": [
        "STEADY",
        "RECEIPT_PENDING",
        "FRESHENING",
        "STALE_REVIEW_REQUIRED",
        "DEGRADED_READ_ONLY",
        "RECOVERY_REQUIRED"
      ]
    },
    "recoveryPosture": {
      "type": "string",
      "enum": [
        "NONE",
        "INLINE_RECONNECT",
        "INLINE_REBASE",
        "READ_ONLY_LIMITED",
        "OBJECT_SUPERSEDED",
        "ACCESS_REBIND_REQUIRED"
      ]
    },
    "detailSurfaceCode": {
      "type": "string",
      "enum": [
        "CONTEXT_BAR",
        "DECISION_SUMMARY",
        "ACTION_STRIP",
        "DETAIL_DRAWER"
      ]
    },
    "leadingSidebar": {
      "type": "object",
      "required": [
        "selection_family",
        "sidebar_collapse_state",
        "selected_object_ref",
        "selected_focus_anchor_ref_or_null"
      ],
      "properties": {
        "selection_family": {
          "type": "string",
          "enum": [
            "MANIFEST_QUEUE",
            "WORK_QUEUE"
          ]
        },
        "sidebar_collapse_state": {
          "type": "string",
          "enum": [
            "EXPANDED",
            "ICON_RAIL",
            "HIDDEN"
          ]
        },
        "selected_object_ref": {
          "type": "string",
          "minLength": 1
        },
        "selected_focus_anchor_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "primaryCanvas": {
      "type": "object",
      "required": [
        "surface_order",
        "authoritative_action_surface_code",
        "mounted_object_ref",
        "focused_surface_code_or_null"
      ],
      "properties": {
        "surface_order": {
          "type": "array",
          "prefixItems": [
            {
              "const": "CONTEXT_BAR"
            },
            {
              "const": "DECISION_SUMMARY"
            },
            {
              "const": "ACTION_STRIP"
            },
            {
              "const": "DETAIL_DRAWER"
            }
          ],
          "items": false,
          "minItems": 4,
          "maxItems": 4
        },
        "authoritative_action_surface_code": {
          "const": "ACTION_STRIP"
        },
        "mounted_object_ref": {
          "type": "string",
          "minLength": 1
        },
        "focused_surface_code_or_null": {
          "anyOf": [
            {
              "$ref": "#/$defs/detailSurfaceCode"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "trailingInspector": {
      "type": "object",
      "required": [
        "presentation_mode",
        "support_surface_code",
        "bound_object_ref_or_null",
        "focus_anchor_ref_or_null",
        "detached_scene_ref_or_null",
        "authoritative_action_strip_present"
      ],
      "properties": {
        "presentation_mode": {
          "type": "string",
          "enum": [
            "DOCKED",
            "COLLAPSED",
            "DETACHED"
          ]
        },
        "support_surface_code": {
          "const": "DETAIL_DRAWER"
        },
        "bound_object_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "focus_anchor_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "detached_scene_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "authoritative_action_strip_present": {
          "const": false
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "presentation_mode": {
                "const": "COLLAPSED"
              }
            },
            "required": [
              "presentation_mode"
            ]
          },
          "then": {
            "properties": {
              "bound_object_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "focus_anchor_ref_or_null": {
                "type": "null"
              },
              "detached_scene_ref_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "presentation_mode": {
                "const": "DOCKED"
              }
            },
            "required": [
              "presentation_mode"
            ]
          },
          "then": {
            "properties": {
              "bound_object_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "detached_scene_ref_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "presentation_mode": {
                "const": "DETACHED"
              }
            },
            "required": [
              "presentation_mode"
            ]
          },
          "then": {
            "properties": {
              "bound_object_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "detached_scene_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "sceneIdentity": {
      "type": "object",
      "required": [
        "principal_session_lineage_ref",
        "masking_posture_fingerprint",
        "access_binding_hash_or_null",
        "schema_compatibility_ref",
        "stability_contract",
        "shell_stability_token",
        "route_key",
        "frame_epoch",
        "workspace_version_or_null",
        "manifest_id_or_null",
        "work_item_id_or_null",
        "focus_anchor_ref_or_null"
      ],
      "properties": {
        "principal_session_lineage_ref": {
          "type": "string",
          "minLength": 1
        },
        "masking_posture_fingerprint": {
          "type": "string",
          "minLength": 1
        },
        "access_binding_hash_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "schema_compatibility_ref": {
          "type": "string",
          "minLength": 1
        },
        "stability_contract": {
          "$ref": "https://taxat.dev/schemas/route_stability_contract.schema.json"
        },
        "shell_stability_token": {
          "type": "string",
          "minLength": 1
        },
        "route_key": {
          "type": "string",
          "minLength": 1
        },
        "frame_epoch": {
          "type": "integer",
          "minimum": 0
        },
        "workspace_version_or_null": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0
        },
        "manifest_id_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "work_item_id_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "focus_anchor_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "sceneRestoration": {
      "type": "object",
      "required": [
        "restoration_state",
        "invalid_reason_codes",
        "restoration_anchor_ref_or_null",
        "resume_token_ref_or_null",
        "focus_restoration"
      ],
      "properties": {
        "restoration_state": {
          "type": "string",
          "enum": [
            "RESTORABLE",
            "FRESH_SNAPSHOT_REQUIRED",
            "INVALIDATED"
          ]
        },
        "invalid_reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "TENANT_SWITCH",
                "PRIVILEGE_DOWNGRADE",
                "ACCESS_BINDING_CHANGE",
                "MASKING_CHANGE",
                "SESSION_REVOKED",
              "SCHEMA_INCOMPATIBLE",
              "OBJECT_GONE"
            ]
          },
          "uniqueItems": true,
          "default": []
        },
        "restoration_anchor_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "resume_token_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "focus_restoration": {
          "$ref": "https://taxat.dev/schemas/focus_restoration_contract.schema.json"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "restoration_state": {
                "const": "RESTORABLE"
              }
            },
            "required": [
              "restoration_state"
            ]
          },
          "then": {
            "properties": {
              "invalid_reason_codes": {
                "maxItems": 0
              },
              "restoration_anchor_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "resume_token_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "restoration_state": {
                "const": "FRESH_SNAPSHOT_REQUIRED"
              }
            },
            "required": [
              "restoration_state"
            ]
          },
          "then": {
            "properties": {
              "invalid_reason_codes": {
                "maxItems": 0
              },
              "restoration_anchor_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "resume_token_ref_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "restoration_state": {
                "const": "INVALIDATED"
              }
            },
            "required": [
              "restoration_state"
            ]
          },
          "then": {
            "properties": {
              "invalid_reason_codes": {
                "minItems": 1
              },
              "resume_token_ref_or_null": {
                "type": "null"
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "shortcutPosture": {
      "type": "object",
      "required": [
        "available_shortcut_codes",
        "focused_region",
        "menu_command_surface_state",
        "focus_restore_policy"
      ],
      "properties": {
        "available_shortcut_codes": {
          "type": "array",
          "prefixItems": [
            {
              "const": "TOGGLE_SIDEBAR"
            },
            {
              "const": "TOGGLE_INSPECTOR"
            },
            {
              "const": "DETACH_INSPECTOR"
            },
            {
              "const": "FOCUS_SIDEBAR"
            },
            {
              "const": "FOCUS_PRIMARY_CANVAS"
            },
            {
              "const": "FOCUS_INSPECTOR"
            },
            {
              "const": "REFRESH_CURRENT_SCENE"
            }
          ],
          "items": false,
          "minItems": 7,
          "maxItems": 7
        },
        "focused_region": {
          "type": "string",
          "enum": [
            "LEADING_SIDEBAR",
            "PRIMARY_CANVAS",
            "TRAILING_INSPECTOR",
            "DETACHED_INSPECTOR"
          ]
        },
        "menu_command_surface_state": {
          "const": "PRIMARY_ACTIONS_VISIBLE_AND_MIRRORED"
        },
        "focus_restore_policy": {
          "const": "RETURN_TO_LAST_OBJECT_ANCHOR"
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "properties": {
        "interaction_layer": {
          "properties": {
            "recovery_notice_surface": {
              "const": "CONTEXT_BAR"
            },
            "notification_surface": {
              "const": "CONTEXT_BAR_WITH_SYSTEM_MIRROR"
            },
            "artifact_preview_surface": {
              "const": "SECONDARY_WINDOW_BODY"
            }
          },
          "required": [
            "recovery_notice_surface",
            "notification_surface",
            "artifact_preview_surface"
          ]
        }
      },
      "required": [
        "interaction_layer"
      ]
    },
    {
      "if": {
        "properties": {
          "backing_read_model_type": {
            "const": "LowNoiseExperienceFrame"
          }
        },
        "required": [
          "backing_read_model_type"
        ]
      },
      "then": {
        "properties": {
          "object_family": {
            "const": "MANIFEST"
          },
          "leading_sidebar": {
            "properties": {
              "selection_family": {
                "const": "MANIFEST_QUEUE"
              }
            }
          },
          "scene_identity": {
            "properties": {
              "workspace_version_or_null": {
                "type": "null"
              },
              "access_binding_hash_or_null": {
                "type": "null"
              },
              "manifest_id_or_null": {
                "type": "string",
                "minLength": 1
              },
              "work_item_id_or_null": {
                "type": "null"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "backing_read_model_type": {
            "const": "WorkspaceSnapshot"
          }
        },
        "required": [
          "backing_read_model_type"
        ]
      },
      "then": {
        "properties": {
          "object_family": {
            "const": "WORK_ITEM"
          },
          "leading_sidebar": {
            "properties": {
              "selection_family": {
                "const": "WORK_QUEUE"
              }
            }
          },
          "scene_identity": {
            "properties": {
              "workspace_version_or_null": {
                "type": "integer",
                "minimum": 0
              },
              "access_binding_hash_or_null": {
                "type": "string",
                "minLength": 1
              },
              "manifest_id_or_null": {
                "type": "null"
              },
              "work_item_id_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "shortcut_posture": {
            "properties": {
              "focused_region": {
                "const": "TRAILING_INSPECTOR"
              }
            }
          }
        },
        "required": [
          "shortcut_posture"
        ]
      },
      "then": {
        "properties": {
          "trailing_inspector": {
            "properties": {
              "presentation_mode": {
                "const": "DOCKED"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "shortcut_posture": {
            "properties": {
              "focused_region": {
                "const": "DETACHED_INSPECTOR"
              }
            }
          }
        },
        "required": [
          "shortcut_posture"
        ]
      },
      "then": {
        "properties": {
          "trailing_inspector": {
            "properties": {
              "presentation_mode": {
                "const": "DETACHED"
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
