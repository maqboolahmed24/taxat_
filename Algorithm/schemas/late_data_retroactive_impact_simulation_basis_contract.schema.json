{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/late_data_retroactive_impact_simulation_basis_contract.schema.json",
  "title": "LateDataRetroactiveImpactSimulationBasisContract",
  "description": "Frozen historical late-data simulation basis. This schema binds one replay-only counterfactual simulator to exact persisted late-data, baseline, proof, and submission lineage so retroactive widening, trust invalidation, and proof staleness can be explored without mutating prior legal state or reclassifying history from live reads.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "basis_contract_hash",
    "execution_mode_boundary_hash",
    "source_manifest_id",
    "source_manifest_hash",
    "source_execution_basis_hash",
    "source_collection_boundary_ref",
    "source_source_window_ref",
    "source_input_freeze_ref",
    "source_cutoff_at",
    "source_baseline_envelope_ref",
    "source_baseline_effective_at",
    "source_active_exact_scope_key",
    "covered_scope_refs",
    "covered_submission_refs",
    "source_late_data_policy_refs",
    "source_late_data_monitor_ref",
    "source_late_data_finding_refs",
    "source_temporal_propagation_event_refs",
    "source_retroactive_impact_ref_or_null",
    "source_filing_case_ref_or_null",
    "source_proof_bundle_refs",
    "source_evidence_graph_ref_or_null",
    "required_temporal_classes",
    "required_outcome_classes",
    "truth_source_policy",
    "historical_reuse_policy",
    "scope_widening_policy",
    "trust_invalidation_policy",
    "proof_staleness_policy",
    "historical_mutation_policy",
    "simulation_case_policy"
  ],
  "properties": {
    "contract_version": {
      "const": "LATE_DATA_RETROACTIVE_IMPACT_SIMULATION_BASIS_V1"
    },
    "basis_contract_hash": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode_boundary_hash": {
      "type": "string",
      "minLength": 1
    },
    "source_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "source_manifest_hash": {
      "type": "string",
      "minLength": 1
    },
    "source_execution_basis_hash": {
      "type": "string",
      "minLength": 1
    },
    "source_collection_boundary_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_source_window_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_input_freeze_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_cutoff_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_baseline_envelope_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_baseline_effective_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_active_exact_scope_key": {
      "type": "string",
      "minLength": 1
    },
    "covered_scope_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "covered_submission_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "source_late_data_policy_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "source_late_data_monitor_ref": {
      "type": "string",
      "minLength": 1
    },
    "source_late_data_finding_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "source_temporal_propagation_event_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "source_retroactive_impact_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "source_filing_case_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "source_proof_bundle_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "source_evidence_graph_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "required_temporal_classes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/temporalClass"
      },
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true
    },
    "required_outcome_classes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/outcomeClass"
      },
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true
    },
    "truth_source_policy": {
      "const": "PERSISTED_LATE_DATA_BASELINE_AND_PROOF_ARTIFACTS_ONLY"
    },
    "historical_reuse_policy": {
      "const": "NO_FRESH_RECLASSIFICATION_OR_CONNECTOR_RESCAN"
    },
    "scope_widening_policy": {
      "const": "ONLY_DECLARED_COVERED_SCOPE_AND_SUBMISSION_CHAIN_REFS"
    },
    "trust_invalidation_policy": {
      "const": "POST_SEAL_MATERIAL_OR_UNPROVED_REQUIRES_RECALC"
    },
    "proof_staleness_policy": {
      "const": "DECISIVE_PATH_TOUCH_REQUIRES_STALE_PROOF"
    },
    "historical_mutation_policy": {
      "const": "NO_IN_PLACE_MUTATION_OF_PRIOR_LEGAL_STATE"
    },
    "simulation_case_policy": {
      "const": "CANONICAL_FIVE_TEMPORAL_CLASSES_AND_OUTCOME_CLASSES_REQUIRED"
    }
  },
  "$defs": {
    "temporalClass": {
      "type": "string",
      "enum": [
        "PRE_CUTOFF_PREEXISTING_LATE_ARRIVAL",
        "POST_CUTOFF_DISCOVERY_PRE_BASELINE_FACT",
        "AUTHORITY_POSTING_LAG",
        "TRUE_POST_BASELINE_EVENT",
        "TEMPORALLY_UNPROVED"
      ]
    },
    "outcomeClass": {
      "type": "string",
      "enum": [
        "CURRENT_ONLY",
        "EXPLANATION_ONLY",
        "AMENDMENT_TRIGGERING",
        "REPLAY_TRIGGERING",
        "REVIEW_BLOCKED"
      ]
    }
  },
  "allOf": [
    {
      "properties": {
        "required_temporal_classes": {
          "contains": {
            "const": "PRE_CUTOFF_PREEXISTING_LATE_ARRIVAL"
          }
        }
      }
    },
    {
      "properties": {
        "required_temporal_classes": {
          "contains": {
            "const": "POST_CUTOFF_DISCOVERY_PRE_BASELINE_FACT"
          }
        }
      }
    },
    {
      "properties": {
        "required_temporal_classes": {
          "contains": {
            "const": "AUTHORITY_POSTING_LAG"
          }
        }
      }
    },
    {
      "properties": {
        "required_temporal_classes": {
          "contains": {
            "const": "TRUE_POST_BASELINE_EVENT"
          }
        }
      }
    },
    {
      "properties": {
        "required_temporal_classes": {
          "contains": {
            "const": "TEMPORALLY_UNPROVED"
          }
        }
      }
    },
    {
      "properties": {
        "required_outcome_classes": {
          "contains": {
            "const": "CURRENT_ONLY"
          }
        }
      }
    },
    {
      "properties": {
        "required_outcome_classes": {
          "contains": {
            "const": "EXPLANATION_ONLY"
          }
        }
      }
    },
    {
      "properties": {
        "required_outcome_classes": {
          "contains": {
            "const": "AMENDMENT_TRIGGERING"
          }
        }
      }
    },
    {
      "properties": {
        "required_outcome_classes": {
          "contains": {
            "const": "REPLAY_TRIGGERING"
          }
        }
      }
    },
    {
      "properties": {
        "required_outcome_classes": {
          "contains": {
            "const": "REVIEW_BLOCKED"
          }
        }
      }
    }
  ]
}
