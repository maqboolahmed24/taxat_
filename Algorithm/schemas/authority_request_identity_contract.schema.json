    "authority_binding_ref": {
      "type": "string",
      "minLength": 1
    },
    "authority_link_ref": {
      "type": "string",
      "minLength": 1
    },
    "delegation_grant_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "acting_party_ref": {
      "type": "string",
      "minLength": 1
    },
    "token_binding_ref": {
      "type": "string",
      "minLength": 1
    },
    "binding_lineage_ref": {
      "type": "string",
      "minLength": 1
    },
    "business_partition_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
