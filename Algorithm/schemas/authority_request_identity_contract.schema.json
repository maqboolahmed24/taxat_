      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "basis_type_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "request_body_hash": {
      "type": "string",
      "minLength": 1
    },
    "duplicate_meaning_key": {
      "type": "string",
      "minLength": 1
    },
    "request_hash": {
