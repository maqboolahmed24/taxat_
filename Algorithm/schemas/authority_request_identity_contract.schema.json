{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/authority_request_identity_contract.schema.json",
  "title": "AuthorityRequestIdentityContract",
  "description": "Grouped sealed authority request identity. This contract preserves the exact manifest-bound request identity, canonical transport identity, binding lineage, request_identity_hash semantics, and duplicate_bucket_key semantics so downstream records never reconstruct request sameness from neighboring artifacts.",
  "type": "object",
  "required": [
    "contract_version",
    "binding_scope_class",
    "request_id",
    "tenant_id",
    "client_id",
    "manifest_id",
    "manifest_hash",
    "execution_basis_hash",
    "attempt_lineage_manifest_id",
    "operation_id",
    "authority_name",
    "authority_product_profile",
    "provider_environment",
    "authority_scope",
    "operation_family",
    "operation_profile",
    "provider_api_version",
    "http_method",
    "canonical_path",
    "canonical_query",
    "header_profile_refs",
    "identity_profile_version",
    "identity_namespace_hash",
    "normalized_obligation_ref",
    "normalized_basis_type",
    "obligation_ref_or_null",
    "basis_type_or_null",
    "request_body_hash",
    "duplicate_meaning_key",
    "request_hash",
    "idempotency_key",
    "access_binding_hash",
    "policy_snapshot_hash",
    "authority_binding_ref",
    "authority_link_ref",
    "delegation_grant_ref_or_null",
    "subject_ref",
    "acting_party_ref",
    "token_binding_ref",
    "binding_lineage_ref",
    "business_partition_refs"
  ],
  "properties": {
    "contract_version": {
      "const": "AUTHORITY_REQUEST_IDENTITY_CONTRACT_V1"
    },
    "binding_scope_class": {
      "type": "string",
      "enum": [
        "AUTHORITY_REQUEST_ENVELOPE",
        "AUTHORITY_INTERACTION_RECORD",
        "SUBMISSION_RECORD"
      ]
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_hash": {
      "type": "string",
      "minLength": 1
    },
    "execution_basis_hash": {
      "type": "string",
      "minLength": 1
    },
    "attempt_lineage_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "operation_id": {
      "type": "string",
      "minLength": 1
    },
    "authority_name": {
      "type": "string",
      "minLength": 1
    },
    "authority_product_profile": {
      "type": "string",
      "minLength": 1
    },
    "provider_environment": {
      "type": "string",
      "minLength": 1
    },
    "authority_scope": {
      "type": "string",
      "minLength": 1
    },
    "operation_family": {
      "type": "string",
      "minLength": 1
    },
    "operation_profile": {
      "type": "string",
      "minLength": 1
    },
    "provider_api_version": {
      "type": "string",
      "minLength": 1
    },
    "http_method": {
      "type": "string",
      "enum": [
        "GET",
        "POST",
        "PUT",
        "PATCH",
        "DELETE"
      ]
    },
    "canonical_path": {
      "type": "string",
      "minLength": 1
    },
    "canonical_query": {
      "type": "string"
    },
    "header_profile_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "identity_profile_version": {
      "const": "AUTHORITY_REQUEST_IDENTITY_V2"
    },
    "identity_namespace_hash": {
