{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/manifest_branch_decision_contract.schema.json",
  "title": "ManifestBranchDecisionContract",
  "description": "Authoritative manifest branch-selection contract. This schema freezes the exact request identity, selected branch action, prior-manifest reuse or child-allocation basis, and the persisted continuation lineage chosen by orchestration so idempotent return, sealed-manifest reuse, replay, recovery, continuation, and fresh-manifest allocation cannot be reinterpreted later.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "branch_action",
    "branch_reason_code",
    "idempotency_key",
    "request_identity_hash",
    "access_binding_hash",
    "requested_scope",
    "effective_scope",
    "mode",
    "run_kind",
    "replay_class_or_null",
    "nightly_window_key_or_null",
    "prior_manifest_id_or_null",
    "prior_manifest_hash_at_decision_or_null",
    "prior_manifest_lifecycle_state_or_null",
    "selected_manifest_id",
    "selected_manifest_continuation_basis",
    "root_manifest_id",
    "parent_manifest_id_or_null",
    "continuation_of_manifest_id_or_null",
    "replay_of_manifest_id_or_null",
    "supersedes_manifest_id_or_null",
    "selected_manifest_generation",
    "config_inheritance_mode_or_null",
    "input_inheritance_mode_or_null",
    "returned_decision_bundle_hash_or_null"
  ],
  "properties": {
    "branch_action": {
      "type": "string",
      "enum": [
        "NEW_MANIFEST",
        "RETURN_EXISTING_BUNDLE",
        "REUSE_SEALED_MANIFEST",
        "REPLAY_CHILD",
        "RECOVERY_CHILD",
        "CONTINUATION_CHILD",
        "NEW_REQUEST_CHILD"
      ]
    },
    "branch_reason_code": {
      "type": "string",
      "enum": [
        "NO_PRIOR_MANIFEST",
        "TERMINAL_IDEMPOTENT_RETRY",
        "PRESTART_SEALED_CONTEXT_REUSE",
        "REPLAY_REQUESTED_EXACT",
        "STARTED_ATTEMPT_RECOVERY",
        "POST_TERMINAL_CONTINUATION_REQUIRED",
        "REQUEST_IDENTITY_CHANGED",
        "NIGHTLY_WINDOW_ADVANCED"
      ]
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "request_identity_hash": {
      "type": "string",
      "minLength": 1
    },
    "access_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "requested_scope": {
      "$ref": "#/$defs/scopeArray"
    },
    "effective_scope": {
      "$ref": "#/$defs/scopeArray"
    },
    "mode": {
      "type": "string",
      "enum": [
        "COMPLIANCE",
        "ANALYSIS"
      ]
    },
    "run_kind": {
      "type": "string",
      "enum": [
        "INTERACTIVE",
        "NIGHTLY",
        "BACKFILL",
        "REPLAY",
        "REMEDIATION",
        "AMENDMENT",
        "MIGRATION"
      ]
    },
    "replay_class_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "STANDARD_REPLAY",
        "AUDIT_REPLAY",
        "COUNTERFACTUAL_ANALYSIS",
        null
      ]
    },
    "nightly_window_key_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "prior_manifest_id_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "prior_manifest_hash_at_decision_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "prior_manifest_lifecycle_state_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "ALLOCATED",
        "FROZEN",
        "SEALED",
        "IN_PROGRESS",
        "COMPLETED",
        "BLOCKED",
        "FAILED",
        "SUPERSEDED",
        "REPLAY_ONLY",
        "RETIRED",
        null
      ]
    },
    "selected_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "selected_manifest_continuation_basis": {
      "type": "string",
      "enum": [
        "NEW_MANIFEST",
        "REPLAY_CHILD",
        "RECOVERY_CHILD",
        "CONTINUATION_CHILD",
        "NEW_REQUEST_CHILD"
      ]
    },
    "root_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_manifest_id_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "continuation_of_manifest_id_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "replay_of_manifest_id_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "supersedes_manifest_id_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "selected_manifest_generation": {
      "type": "integer",
      "minimum": 0
    },
    "config_inheritance_mode_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "FRESH_CHILD_RESOLUTION",
        "REPLAY_EXACT",
        "RECOVERY_EXACT",
        "HISTORICAL_EXPLICIT",
        null
      ]
    },
    "input_inheritance_mode_or_null": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "FRESH_CHILD_COLLECTION",
        "REPLAY_EXACT",
        "RECOVERY_EXACT",
        "HISTORICAL_EXPLICIT",
        null
      ]
    },
    "returned_decision_bundle_hash_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "run_kind": {
            "const": "NIGHTLY"
          }
        },
        "required": [
          "run_kind"
        ]
      },
      "then": {
        "properties": {
          "nightly_window_key_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "run_kind": {
            "not": {
              "const": "NIGHTLY"
            }
          }
        },
        "required": [
          "run_kind"
        ]
      },
      "then": {
        "properties": {
          "nightly_window_key_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "run_kind": {
            "const": "REPLAY"
          }
        },
        "required": [
          "run_kind"
        ]
      },
      "then": {
        "properties": {
          "replay_class_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "run_kind": {
            "not": {
              "const": "REPLAY"
            }
          }
        },
        "required": [
          "run_kind"
        ]
      },
      "then": {
        "properties": {
          "replay_class_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "prior_manifest_id_or_null": {
            "type": "string"
          }
        },
        "required": [
          "prior_manifest_id_or_null"
        ]
      },
      "then": {
        "properties": {
          "prior_manifest_hash_at_decision_or_null": {
            "type": "string",
            "minLength": 1
          },
          "prior_manifest_lifecycle_state_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "prior_manifest_hash_at_decision_or_null": {
            "type": "string"
          }
        },
        "required": [
          "prior_manifest_hash_at_decision_or_null"
        ]
      },
      "then": {
        "properties": {
          "prior_manifest_id_or_null": {
            "type": "string",
            "minLength": 1
          },
          "prior_manifest_lifecycle_state_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "prior_manifest_lifecycle_state_or_null": {
            "type": "string"
          }
        },
        "required": [
          "prior_manifest_lifecycle_state_or_null"
        ]
      },
      "then": {
        "properties": {
          "prior_manifest_id_or_null": {
            "type": "string",
            "minLength": 1
          },
          "prior_manifest_hash_at_decision_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "returned_decision_bundle_hash_or_null": {
            "type": "string"
          }
        },
        "required": [
          "returned_decision_bundle_hash_or_null"
        ]
      },
      "then": {
        "properties": {
          "branch_action": {
            "const": "RETURN_EXISTING_BUNDLE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_manifest_continuation_basis": {
            "const": "NEW_MANIFEST"
          }
        },
        "required": [
          "selected_manifest_continuation_basis"
        ]
      },
      "then": {
        "properties": {
          "selected_manifest_generation": {
            "const": 0
          },
          "root_manifest_id": {
            "type": "string",
            "minLength": 1
          },
          "parent_manifest_id_or_null": {
            "type": "null"
          },
          "continuation_of_manifest_id_or_null": {
            "type": "null"
          },
          "replay_of_manifest_id_or_null": {
            "type": "null"
          },
          "supersedes_manifest_id_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_manifest_continuation_basis": {
            "enum": [
              "REPLAY_CHILD",
              "RECOVERY_CHILD",
              "CONTINUATION_CHILD",
              "NEW_REQUEST_CHILD"
            ]
          }
        },
        "required": [
          "selected_manifest_continuation_basis"
        ]
      },
      "then": {
        "properties": {
          "selected_manifest_generation": {
            "minimum": 1
          },
          "parent_manifest_id_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "selected_manifest_continuation_basis": {
            "const": "REPLAY_CHILD"
          }
        },
        "required": [
          "selected_manifest_continuation_basis"
        ]
      },
      "then": {
        "properties": {
          "replay_of_manifest_id_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "branch_action": {
            "const": "NEW_MANIFEST"
          }
        },
        "required": [
          "branch_action"
        ]
      },
      "then": {
        "properties": {
          "branch_reason_code": {
            "const": "NO_PRIOR_MANIFEST"
          },
          "selected_manifest_continuation_basis": {
            "const": "NEW_MANIFEST"
          },
          "prior_manifest_id_or_null": {
            "type": "null"
          },
          "prior_manifest_hash_at_decision_or_null": {
            "type": "null"
          },
          "prior_manifest_lifecycle_state_or_null": {
            "type": "null"
          },
          "config_inheritance_mode_or_null": {
            "type": "null"
          },
          "input_inheritance_mode_or_null": {
            "type": "null"
          },
          "returned_decision_bundle_hash_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "branch_action": {
            "const": "RETURN_EXISTING_BUNDLE"
          }
        },
        "required": [
          "branch_action"
        ]
      },
      "then": {
        "properties": {
          "branch_reason_code": {
            "const": "TERMINAL_IDEMPOTENT_RETRY"
          },
          "prior_manifest_id_or_null": {
            "type": "string",
            "minLength": 1
          },
          "prior_manifest_hash_at_decision_or_null": {
            "type": "string",
            "minLength": 1
          },
          "prior_manifest_lifecycle_state_or_null": {
            "enum": [
              "COMPLETED",
              "BLOCKED",
              "FAILED",
              "SUPERSEDED",
              "REPLAY_ONLY",
              "RETIRED"
            ]
          },
          "config_inheritance_mode_or_null": {
            "type": "null"
          },
          "input_inheritance_mode_or_null": {
            "type": "null"
          },
          "returned_decision_bundle_hash_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "branch_action": {
            "const": "REUSE_SEALED_MANIFEST"
          }
        },
        "required": [
          "branch_action"
        ]
      },
      "then": {
        "properties": {
          "branch_reason_code": {
            "const": "PRESTART_SEALED_CONTEXT_REUSE"
          },
          "prior_manifest_id_or_null": {
            "type": "string",
            "minLength": 1
          },
          "prior_manifest_hash_at_decision_or_null": {
            "type": "string",
            "minLength": 1
          },
          "prior_manifest_lifecycle_state_or_null": {
            "const": "SEALED"
          },
          "config_inheritance_mode_or_null": {
            "type": "null"
          },
          "input_inheritance_mode_or_null": {
            "type": "null"
          },
          "returned_decision_bundle_hash_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "branch_action": {
            "const": "REPLAY_CHILD"
          }
        },
        "required": [
          "branch_action"
        ]
      },
      "then": {
        "properties": {
          "branch_reason_code": {
            "const": "REPLAY_REQUESTED_EXACT"
          },
          "selected_manifest_continuation_basis": {
            "const": "REPLAY_CHILD"
          },
          "prior_manifest_id_or_null": {
            "type": "string",
            "minLength": 1
          },
          "prior_manifest_hash_at_decision_or_null": {
            "type": "string",
            "minLength": 1
          },
          "config_inheritance_mode_or_null": {
            "const": "REPLAY_EXACT"
          },
          "input_inheritance_mode_or_null": {
            "const": "REPLAY_EXACT"
          },
          "returned_decision_bundle_hash_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "branch_action": {
            "const": "RECOVERY_CHILD"
          }
        },
        "required": [
          "branch_action"
        ]
      },
      "then": {
        "properties": {
          "branch_reason_code": {
            "const": "STARTED_ATTEMPT_RECOVERY"
          },
          "selected_manifest_continuation_basis": {
            "const": "RECOVERY_CHILD"
          },
          "prior_manifest_id_or_null": {
            "type": "string",
            "minLength": 1
          },
          "prior_manifest_hash_at_decision_or_null": {
            "type": "string",
            "minLength": 1
          },
          "config_inheritance_mode_or_null": {
            "const": "RECOVERY_EXACT"
          },
          "input_inheritance_mode_or_null": {
            "const": "RECOVERY_EXACT"
          },
          "returned_decision_bundle_hash_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "branch_action": {
            "const": "CONTINUATION_CHILD"
          }
        },
        "required": [
          "branch_action"
        ]
      },
      "then": {
        "properties": {
          "selected_manifest_continuation_basis": {
            "const": "CONTINUATION_CHILD"
          },
          "branch_reason_code": {
            "enum": [
              "POST_TERMINAL_CONTINUATION_REQUIRED",
              "NIGHTLY_WINDOW_ADVANCED"
            ]
          },
          "prior_manifest_id_or_null": {
            "type": "string",
            "minLength": 1
          },
          "prior_manifest_hash_at_decision_or_null": {
            "type": "string",
            "minLength": 1
          },
          "config_inheritance_mode_or_null": {
            "enum": [
              "FRESH_CHILD_RESOLUTION",
              "HISTORICAL_EXPLICIT"
            ]
          },
          "input_inheritance_mode_or_null": {
            "enum": [
              "FRESH_CHILD_COLLECTION",
              "HISTORICAL_EXPLICIT"
            ]
          },
          "returned_decision_bundle_hash_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "branch_action": {
            "const": "NEW_REQUEST_CHILD"
          }
        },
        "required": [
          "branch_action"
        ]
      },
      "then": {
        "properties": {
          "branch_reason_code": {
            "const": "REQUEST_IDENTITY_CHANGED"
          },
          "selected_manifest_continuation_basis": {
            "const": "NEW_REQUEST_CHILD"
          },
          "prior_manifest_id_or_null": {
            "type": "string",
            "minLength": 1
          },
          "prior_manifest_hash_at_decision_or_null": {
            "type": "string",
            "minLength": 1
          },
          "config_inheritance_mode_or_null": {
            "enum": [
              "FRESH_CHILD_RESOLUTION",
              "HISTORICAL_EXPLICIT"
            ]
          },
          "input_inheritance_mode_or_null": {
            "enum": [
              "FRESH_CHILD_COLLECTION",
              "HISTORICAL_EXPLICIT"
            ]
          },
          "returned_decision_bundle_hash_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "branch_action": {
            "const": "CONTINUATION_CHILD"
          },
          "run_kind": {
            "not": {
              "const": "NIGHTLY"
            }
          }
        },
        "required": [
          "branch_action",
          "run_kind"
        ]
      },
      "then": {
        "properties": {
          "branch_reason_code": {
            "const": "POST_TERMINAL_CONTINUATION_REQUIRED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "branch_action": {
            "const": "CONTINUATION_CHILD"
          },
          "run_kind": {
            "const": "NIGHTLY"
          }
        },
        "required": [
          "branch_action",
          "run_kind"
        ]
      },
      "then": {
        "properties": {
          "branch_reason_code": {
            "const": "NIGHTLY_WINDOW_ADVANCED"
          }
        }
      }
    }
  ],
  "$defs": {
    "scopeArray": {
      "type": "array",
      "prefixItems": [
        {
          "enum": [
            "year_end",
            "quarterly_update",
            "estimate_only"
          ]
        }
      ],
      "items": {
        "type": "string",
        "enum": [
          "year_end",
          "quarterly_update",
          "estimate_only",
          "prepare_submission",
          "submit",
          "amendment_intent",
          "amendment_submit"
        ]
      },
      "contains": {
        "enum": [
          "year_end",
          "quarterly_update",
          "estimate_only"
        ]
      },
      "minContains": 1,
      "maxContains": 1,
      "minItems": 1,
      "uniqueItems": true,
      "allOf": [
        {
          "not": {
            "allOf": [
              {
                "contains": {
                  "const": "amendment_intent"
                }
              },
              {
                "contains": {
                  "const": "amendment_submit"
                }
              }
            ]
          }
        },
        {
          "not": {
            "allOf": [
              {
                "contains": {
                  "const": "estimate_only"
                }
              },
              {
                "contains": {
                  "enum": [
                    "prepare_submission",
                    "submit",
                    "amendment_intent",
                    "amendment_submit"
                  ]
                }
              }
            ]
          }
        },
        {
          "not": {
            "allOf": [
              {
                "contains": {
                  "const": "amendment_intent"
                }
              },
              {
                "contains": {
                  "enum": [
                    "prepare_submission",
                    "submit"
                  ]
                }
              }
            ]
          }
        },
        {
          "not": {
            "allOf": [
              {
                "contains": {
                  "const": "amendment_submit"
                }
              },
              {
                "contains": {
                  "enum": [
                    "prepare_submission",
                    "submit"
                  ]
                }
              }
            ]
          }
        },
        {
          "not": {
            "allOf": [
              {
                "contains": {
                  "const": "amendment_intent"
                }
              },
              {
                "not": {
                  "contains": {
                    "const": "year_end"
                  }
                }
              }
            ]
          }
        },
        {
          "not": {
            "allOf": [
              {
                "contains": {
                  "const": "amendment_submit"
                }
              },
              {
                "not": {
                  "contains": {
                    "const": "year_end"
                  }
                }
              }
            ]
          }
        },
        {
          "if": {
            "contains": {
              "const": "submit"
            }
          },
          "then": {
            "contains": {
              "const": "prepare_submission"
            }
          }
        }
      ]
    }
  },
  "additionalProperties": false
}
