{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/authority_ingress_receipt.schema.json",
  "title": "AuthorityIngressReceipt",
  "description": "Authenticated provider-ingress checkpoint contract. This schema freezes channel authentication, deterministic delivery dedupe identity, request-lineage correlation, quarantine posture, and explicit authority-versus-internal truth separation before any authority-side payload may mutate legal state.",
  "type": "object",
  "required": [
    "artifact_type",
    "ingress_receipt_id",
    "provider_environment",
    "provider_profile_ref",
    "ingress_channel_class",
    "provider_delivery_ref",
    "response_body_ref",
    "response_body_hash",
    "ingress_channel_metadata_hash",
    "delivery_dedupe_key",
    "authority_reference",
    "request_hash",
    "idempotency_key",
    "identity_namespace_hash",
    "duplicate_meaning_key",
    "bound_interaction_ref",
    "authority_truth_contract",
    "correlation_status",
    "authenticated_channel_state",
    "authority_ingress_proof_contract",
    "authority_ingress_correlation_contract",
    "receipt_state",
    "received_at",
    "persisted_at",
    "quarantined_at",
    "quarantine_reason_codes",
    "canonical_ingress_receipt_ref",
    "reconciliation_owner_ref",
    "normalized_response_ref",
    "audit_event_refs"
  ],
  "properties": {
    "artifact_type": {
      "const": "AuthorityIngressReceipt"
    },
    "ingress_receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "provider_environment": {
      "type": "string",
      "minLength": 1
    },
    "provider_profile_ref": {
      "type": "string",
      "minLength": 1
    },
    "ingress_channel_class": {
      "type": "string",
      "enum": [
        "CALLBACK",
        "POLL_RESULT",
        "INBOX_DELIVERY",
        "WORKER_OBSERVED",
        "GATEWAY_RECOVERED"
      ]
    },
    "provider_delivery_ref": {
      "type": "string",
      "minLength": 1
    },
    "response_body_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "response_body_hash": {
      "type": "string",
      "minLength": 1
    },
    "ingress_channel_metadata_hash": {
      "type": "string",
      "minLength": 1
    },
    "delivery_dedupe_key": {
      "type": "string",
      "minLength": 1
    },
    "authority_reference": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "request_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "idempotency_key": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "identity_namespace_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "duplicate_meaning_key": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "bound_interaction_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "authority_truth_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/authority_truth_contract.schema.json"
        },
        {
          "properties": {
            "boundary_scope": {
              "const": "AUTHORITY_INGRESS_RECEIPT"
            },
            "truth_surface_role": {
              "const": "AUTHORITY_INGRESS_CHECKPOINT"
            },
            "surface_specific_binding_policy": {
              "const": "INGRESS_RECEIPT_MUST_NOT_DECIDE_TRUTH_UNTIL_BOUND"
            }
          }
        }
      ]
    },
    "correlation_status": {
      "type": "string",
      "enum": [
        "BOUND",
        "BOUND_WITH_AUTHORITY_REFERENCE_ONLY",
        "AMBIGUOUS",
        "UNBOUND"
      ]
    },
    "authenticated_channel_state": {
      "type": "string",
      "enum": [
        "AUTHENTICATED",
        "FAILED"
      ]
    },
    "authority_ingress_proof_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/authority_ingress_proof_contract.schema.json"
        },
        {
          "properties": {
            "binding_scope_class": {
              "const": "AUTHORITY_INGRESS_RECEIPT"
            }
          }
        }
      ]
    },
    "authority_ingress_correlation_contract": {
      "$ref": "https://taxat.dev/schemas/authority_ingress_correlation_contract.schema.json"
    },
    "receipt_state": {
      "type": "string",
      "enum": [
        "PERSISTED",
        "NORMALIZED",
        "QUARANTINED",
        "DUPLICATE_SUPPRESSED"
      ]
    },
    "received_at": {
      "type": "string",
      "format": "date-time"
    },
    "persisted_at": {
      "type": "string",
      "format": "date-time"
    },
    "quarantined_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "quarantine_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "canonical_ingress_receipt_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "reconciliation_owner_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "normalized_response_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "audit_event_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "response_body_hash": {
            "const": "<NONE>"
          }
        },
        "required": [
          "response_body_hash"
        ]
      },
      "then": {
        "properties": {
          "response_body_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "response_body_ref": {
            "type": "null"
          }
        },
        "required": [
          "response_body_ref"
        ]
      },
      "then": {
        "properties": {
          "response_body_hash": {
            "const": "<NONE>"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "correlation_status": {
            "const": "BOUND"
          }
        },
        "required": [
          "correlation_status"
        ]
      },
      "then": {
        "properties": {
          "authority_reference": {
            "type": "string",
            "minLength": 1
          },
          "request_hash": {
            "type": "string",
            "minLength": 1
          },
          "idempotency_key": {
            "type": "string",
            "minLength": 1
          },
          "identity_namespace_hash": {
            "type": "string",
            "minLength": 1
          },
          "duplicate_meaning_key": {
            "type": "string",
            "minLength": 1
          },
          "bound_interaction_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "else": {
        "properties": {
          "bound_interaction_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "correlation_status": {
            "const": "BOUND_WITH_AUTHORITY_REFERENCE_ONLY"
          }
        },
        "required": [
          "correlation_status"
        ]
      },
      "then": {
        "properties": {
          "authority_reference": {
            "type": "string",
            "minLength": 1
          },
          "request_hash": {
            "type": "null"
          },
          "idempotency_key": {
            "type": "null"
          },
          "identity_namespace_hash": {
            "type": "null"
          },
          "duplicate_meaning_key": {
            "type": "null"
          },
          "bound_interaction_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "correlation_status": {
            "enum": [
              "BOUND_WITH_AUTHORITY_REFERENCE_ONLY",
              "AMBIGUOUS",
              "UNBOUND"
            ]
          }
        },
        "required": [
          "correlation_status"
        ]
      },
      "then": {
        "properties": {
          "receipt_state": {
            "enum": [
              "QUARANTINED",
              "DUPLICATE_SUPPRESSED"
            ]
          },
          "normalized_response_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "authenticated_channel_state": {
            "const": "FAILED"
          }
        },
        "required": [
          "authenticated_channel_state"
        ]
      },
      "then": {
        "properties": {
          "receipt_state": {
            "const": "QUARANTINED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "correlation_status": {
            "enum": [
              "BOUND_WITH_AUTHORITY_REFERENCE_ONLY",
              "AMBIGUOUS",
              "UNBOUND"
            ]
          }
        },
        "required": [
          "correlation_status"
        ]
      },
      "then": {
        "properties": {
          "receipt_state": {
            "enum": [
              "QUARANTINED",
              "DUPLICATE_SUPPRESSED"
            ]
          },
          "normalized_response_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "receipt_state": {
            "const": "PERSISTED"
          }
        },
        "required": [
          "receipt_state"
        ]
      },
      "then": {
        "properties": {
          "quarantined_at": {
            "type": "null"
          },
          "quarantine_reason_codes": {
            "maxItems": 0
          },
          "canonical_ingress_receipt_ref": {
            "type": "null"
          },
          "reconciliation_owner_ref": {
            "type": "null"
          },
          "normalized_response_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "receipt_state": {
            "const": "NORMALIZED"
          }
        },
        "required": [
          "receipt_state"
        ]
      },
      "then": {
        "properties": {
          "authenticated_channel_state": {
            "const": "AUTHENTICATED"
          },
          "correlation_status": {
            "const": "BOUND"
          },
          "authority_reference": {
            "type": "string",
            "minLength": 1
          },
          "request_hash": {
            "type": "string",
            "minLength": 1
          },
          "idempotency_key": {
            "type": "string",
            "minLength": 1
          },
          "identity_namespace_hash": {
            "type": "string",
            "minLength": 1
          },
          "duplicate_meaning_key": {
            "type": "string",
            "minLength": 1
          },
          "canonical_ingress_receipt_ref": {
            "type": "null"
          },
          "reconciliation_owner_ref": {
            "type": "null"
          },
          "quarantined_at": {
            "type": "null"
          },
          "quarantine_reason_codes": {
            "maxItems": 0
          },
          "normalized_response_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "receipt_state": {
            "const": "QUARANTINED"
          }
        },
        "required": [
          "receipt_state"
        ]
      },
      "then": {
        "properties": {
          "quarantined_at": {
            "type": "string",
            "format": "date-time"
          },
          "quarantine_reason_codes": {
            "minItems": 1
          },
          "canonical_ingress_receipt_ref": {
            "type": "null"
          },
          "reconciliation_owner_ref": {
            "type": "string",
            "minLength": 1
          },
          "normalized_response_ref": {
            "type": "null"
          },
          "audit_event_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "receipt_state": {
            "const": "DUPLICATE_SUPPRESSED"
          }
        },
        "required": [
          "receipt_state"
        ]
      },
      "then": {
        "properties": {
          "authenticated_channel_state": {
            "const": "AUTHENTICATED"
          },
          "quarantined_at": {
            "type": "null"
          },
          "quarantine_reason_codes": {
            "maxItems": 0
          },
          "canonical_ingress_receipt_ref": {
            "type": "string",
            "minLength": 1
          },
          "reconciliation_owner_ref": {
            "type": "null"
          },
          "normalized_response_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "normalized_response_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "normalized_response_ref"
        ]
      },
      "then": {
        "properties": {
          "receipt_state": {
            "const": "NORMALIZED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "canonical_ingress_receipt_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "canonical_ingress_receipt_ref"
        ]
      },
      "then": {
        "properties": {
          "receipt_state": {
            "const": "DUPLICATE_SUPPRESSED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "reconciliation_owner_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "reconciliation_owner_ref"
        ]
      },
      "then": {
        "properties": {
          "receipt_state": {
            "const": "QUARANTINED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "quarantined_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "quarantined_at"
        ]
      },
      "then": {
        "properties": {
          "receipt_state": {
            "const": "QUARANTINED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "quarantine_reason_codes": {
            "minItems": 1
          }
        },
        "required": [
          "quarantine_reason_codes"
        ]
      },
      "then": {
        "properties": {
          "receipt_state": {
            "const": "QUARANTINED"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
