{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/authority_link_inventory_item.schema.json",
  "title": "AuthorityLinkInventoryItem",
  "description": "Governance authority-links workspace contract for the Admin/Governance Console. This schema freezes the selected-link anchor, guided handshake stepper, binding-health timeline, handshake history, affected-operation drill-down, and preflight checklist so the route cannot degrade into a raw credential form or a generic event log.",
  "type": "object",
  "required": [
    "artifact_type",
    "tenant_id",
    "shell_family",
    "object_anchor_ref",
    "dominant_question",
    "settlement_state",
    "recovery_posture",
    "interaction_layer",
    "authority_link_id",
    "client_id",
    "authority_scope",
    "provider_environment",
    "lifecycle_state",
    "binding_health",
    "delegation_state",
    "token_client_binding_state",
    "last_validated_at",
    "focus_anchor_ref",
    "externalization_governance_contract",
    "authority_link_workspace",
    "guided_handshake_stepper",
    "binding_health_timeline",
    "handshake_history",
    "affected_operation_list",
    "preflight_checklist",
    "affected_operation_counts"
  ],
  "properties": {
    "artifact_type": {
      "const": "AuthorityLinkInventoryItem"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "shell_family": {
      "const": "GOVERNANCE_DENSITY_SHELL"
    },
    "object_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "dominant_question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "settlement_state": {
      "$ref": "#/$defs/settlementState"
    },
    "recovery_posture": {
      "$ref": "#/$defs/recoveryPosture"
    },
    "interaction_layer": {
      "$ref": "https://taxat.dev/schemas/governance_interaction_layer.schema.json"
    },
    "authority_link_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "authority_scope": {
      "type": "string",
      "minLength": 1
    },
    "provider_environment": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_state": {
      "$ref": "#/$defs/lifecycleState"
    },
    "binding_health": {
      "$ref": "#/$defs/bindingHealth"
    },
    "delegation_state": {
      "$ref": "#/$defs/delegationState"
    },
    "token_client_binding_state": {
      "$ref": "#/$defs/tokenClientBindingState"
    },
    "last_validated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "expires_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "blocked_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "focus_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "externalization_governance_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/externalization_governance_contract.schema.json"
        },
        {
          "properties": {
            "boundary_scope": {
              "const": "AUTHORITY_LINK_HANDOFF"
            }
          }
        }
      ]
    },
    "authority_link_workspace": {
      "$ref": "#/$defs/authorityLinkWorkspace"
    },
    "guided_handshake_stepper": {
      "$ref": "#/$defs/guidedHandshakeStepper"
    },
    "binding_health_timeline": {
      "$ref": "#/$defs/bindingHealthTimeline"
    },
    "handshake_history": {
      "$ref": "#/$defs/handshakeHistory"
    },
    "affected_operation_list": {
      "$ref": "#/$defs/affectedOperationList"
    },
    "preflight_checklist": {
      "$ref": "#/$defs/preflightChecklist"
    },
    "affected_operation_counts": {
      "$ref": "#/$defs/affectedOperationCounts"
    }
  },
  "$defs": {
    "settlementState": {
      "type": "string",
      "enum": [
        "STEADY",
        "RECEIPT_PENDING",
        "FRESHENING",
        "STALE_REVIEW_REQUIRED",
        "DEGRADED_READ_ONLY",
        "RECOVERY_REQUIRED"
      ]
    },
    "recoveryPosture": {
      "type": "string",
      "enum": [
        "NONE",
        "INLINE_RECONNECT",
        "INLINE_REBASE",
        "READ_ONLY_LIMITED",
        "OBJECT_SUPERSEDED",
        "ACCESS_REBIND_REQUIRED"
      ]
    },
    "interactionLayer": {
      "type": "object",
      "required": [
        "selected_filter_chip_refs",
        "compaction_mode",
        "auxiliary_surface_presentation",
        "focus_trap_mode",
        "selection_persistence_mode",
        "preserved_context_codes"
      ],
      "properties": {
        "selected_filter_chip_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "compaction_mode": {
          "type": "string",
          "enum": [
            "WIDE",
            "AUXILIARY_DRAWER",
            "AUXILIARY_TRAY",
            "FOCUS_STACK"
          ]
        },
        "auxiliary_surface_presentation": {
          "type": "string",
          "enum": [
            "SIDECAR",
            "DRAWER",
            "INSPECTOR",
            "TRAY"
          ]
        },
        "focus_trap_mode": {
          "type": "string",
          "enum": [
            "NON_MODAL",
            "MODAL_EXPLICIT"
          ]
        },
        "selection_persistence_mode": {
          "const": "PRESERVE_WHILE_OBJECT_RESOLVES"
        },
        "preserved_context_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ACTIVE_FILTERS",
              "ACTIVE_SECTION",
              "SELECTION",
              "FOCUS_ANCHOR",
              "PROMOTED_SUPPORT_SURFACE",
              "STAGED_DIFF",
              "CHANGE_BASKET",
              "GUIDED_HANDSHAKE_STEP",
              "QUERY_SLICE"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "lifecycleState": {
      "type": "string",
      "enum": [
        "UNLINKED",
        "LINK_INITIATED",
        "AUTHORISED_ACTIVE",
        "AUTHORISED_LIMITED",
        "TOKEN_INVALID",
        "REVOKED",
        "EXPIRED"
      ]
    },
    "bindingHealth": {
      "type": "string",
      "enum": [
        "HEALTHY",
        "LIMITED_SCOPE",
        "EXPIRING_SOON",
        "TOKEN_INVALID",
        "CLIENT_BINDING_MISMATCH",
        "DELEGATION_GAP",
        "ENVIRONMENT_DRIFT",
        "REVOKED",
        "EXPIRED",
        "UNLINKED",
        "UNKNOWN"
      ]
    },
    "delegationState": {
      "type": "string",
      "enum": [
        "SATISFIED",
        "LIMITED",
        "MISSING",
        "EXPIRED",
        "UNKNOWN"
      ]
    },
    "tokenClientBindingState": {
      "type": "string",
      "enum": [
        "BOUND",
        "MISMATCH",
        "UNVERIFIED"
      ]
    },
    "guidedFlowMode": {
      "type": "string",
      "enum": [
        "DETAILS",
        "LINK",
        "RELINK",
        "UNLINK_REVIEW"
      ]
    },
    "expiryRiskBand": {
      "type": "string",
      "enum": [
        "NONE",
        "EXPIRING_30_DAYS",
        "EXPIRING_14_DAYS",
        "EXPIRING_7_DAYS",
        "EXPIRED"
      ]
    },
    "handshakeFlowState": {
      "type": "string",
      "enum": [
        "NOT_STARTED",
        "IN_PROGRESS",
        "HANDOFF_PENDING",
        "VALIDATION_PENDING",
        "LINKED",
        "BLOCKED"
      ]
    },
    "handshakeStepCode": {
      "type": "string",
      "enum": [
        "SELECT_AUTHORITY",
        "CONFIRM_CLIENT_SCOPE",
        "RUN_PREFLIGHT_CHECKS",
        "AUTHORISE_EXTERNAL_HANDOFF",
        "VALIDATE_BINDING"
      ]
    },
    "handshakeAttemptState": {
      "type": "string",
      "enum": [
        "NONE_RECORDED",
        "COMPLETED",
        "FAILED",
        "ABANDONED",
        "EXPIRED",
        "PENDING_RETURN"
      ]
    },
    "preflightCheckCode": {
      "type": "string",
      "enum": [
        "AUTHORITY_SCOPE",
        "CLIENT_BINDING",
        "DELEGATION_COVERAGE",
        "PROVIDER_ENVIRONMENT",
        "TOKEN_FRESHNESS"
      ]
    },
    "preflightCheckState": {
      "type": "string",
      "enum": [
        "PASS",
        "WARNING",
        "BLOCKED",
        "NOT_RUN"
      ]
    },
    "authorityLinkWorkspace": {
      "type": "object",
      "required": [
        "surface_order",
        "active_filters",
        "selected_authority_link_ref",
        "detail_module_order",
        "guided_flow_mode",
        "promoted_support_surface",
        "prominent_issue_ref_or_null"
      ],
      "properties": {
        "surface_order": {
          "const": [
            "INVENTORY_RAIL",
            "WORKSPACE_CANVAS",
            "AUDIT_SIDECAR"
          ]
        },
        "active_filters": {
          "$ref": "#/$defs/authorityLinkWorkspaceFilters"
        },
        "selected_authority_link_ref": {
          "type": "string",
          "minLength": 1
        },
        "detail_module_order": {
          "const": [
            "AuthorityLinkIdentityCard",
            "BindingHealthTimeline",
            "HandshakeHistory",
            "AffectedOperationList",
            "PreflightChecklist"
          ]
        },
        "guided_flow_mode": {
          "$ref": "#/$defs/guidedFlowMode"
        },
        "promoted_support_surface": {
          "const": "AUDIT_SIDECAR"
        },
        "prominent_issue_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "authorityLinkWorkspaceFilters": {
      "type": "object",
      "required": [
        "authority_scopes",
        "client_refs",
        "provider_environments",
        "lifecycle_states",
        "binding_health_states",
        "expiry_risk_bands"
      ],
      "properties": {
        "authority_scopes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "client_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "provider_environments": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "lifecycle_states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lifecycleState"
          },
          "default": [],
          "uniqueItems": true
        },
        "binding_health_states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/bindingHealth"
          },
          "default": [],
          "uniqueItems": true
        },
        "expiry_risk_bands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/expiryRiskBand"
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "guidedHandshakeStepper": {
      "type": "object",
      "required": [
        "flow_state",
        "step_order",
        "current_step_code",
        "completed_step_codes",
        "credential_capture_mode",
        "external_handoff_ref_or_null",
        "preflight_blocking_check_refs"
      ],
      "properties": {
        "flow_state": {
          "$ref": "#/$defs/handshakeFlowState"
        },
        "step_order": {
          "const": [
            "SELECT_AUTHORITY",
            "CONFIRM_CLIENT_SCOPE",
            "RUN_PREFLIGHT_CHECKS",
            "AUTHORISE_EXTERNAL_HANDOFF",
            "VALIDATE_BINDING"
          ]
        },
        "current_step_code": {
          "$ref": "#/$defs/handshakeStepCode"
        },
        "completed_step_codes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/handshakeStepCode"
          },
          "default": [],
          "uniqueItems": true
        },
        "credential_capture_mode": {
          "const": "GUIDED_HANDSHAKE_ONLY"
        },
        "external_handoff_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "preflight_blocking_check_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "bindingHealthTimeline": {
      "type": "object",
      "required": [
        "current_binding_health",
        "current_delegation_state",
        "current_token_client_binding_state",
        "promoted_issue_ref_or_null",
        "event_refs",
        "next_validation_due_at_or_null"
      ],
      "properties": {
        "current_binding_health": {
          "$ref": "#/$defs/bindingHealth"
        },
        "current_delegation_state": {
          "$ref": "#/$defs/delegationState"
        },
        "current_token_client_binding_state": {
          "$ref": "#/$defs/tokenClientBindingState"
        },
        "promoted_issue_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "event_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "next_validation_due_at_or_null": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "handshakeHistory": {
      "type": "object",
      "required": [
        "attempt_refs",
        "selected_attempt_ref_or_null",
        "latest_attempt_state",
        "latest_failure_ref_or_null"
      ],
      "properties": {
        "attempt_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "selected_attempt_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "latest_attempt_state": {
          "$ref": "#/$defs/handshakeAttemptState"
        },
        "latest_failure_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "affectedOperationList": {
      "type": "object",
      "required": [
        "section_order",
        "preflight_refs",
        "submission_refs",
        "reconciliation_refs",
        "amendment_refs",
        "primary_blocked_operation_ref_or_null"
      ],
      "properties": {
        "section_order": {
          "const": [
            "PREFLIGHT",
            "SUBMISSION",
            "RECONCILIATION",
            "AMENDMENT"
          ]
        },
        "preflight_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "submission_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "reconciliation_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "amendment_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "primary_blocked_operation_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "preflightChecklist": {
      "type": "object",
      "required": [
        "check_order",
        "checks",
        "blocking_check_refs",
        "last_run_at_or_null"
      ],
      "properties": {
        "check_order": {
          "const": [
            "AUTHORITY_SCOPE",
            "CLIENT_BINDING",
            "DELEGATION_COVERAGE",
            "PROVIDER_ENVIRONMENT",
            "TOKEN_FRESHNESS"
          ]
        },
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/preflightCheck"
          },
          "minItems": 5,
          "maxItems": 5
        },
        "blocking_check_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "last_run_at_or_null": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "preflightCheck": {
      "type": "object",
      "required": [
        "check_ref",
        "check_code",
        "check_state",
        "reason_refs"
      ],
      "properties": {
        "check_ref": {
          "type": "string",
          "minLength": 1
        },
        "check_code": {
          "$ref": "#/$defs/preflightCheckCode"
        },
        "check_state": {
          "$ref": "#/$defs/preflightCheckState"
        },
        "reason_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "affectedOperationCounts": {
      "type": "object",
      "required": [
        "preflight_count",
        "submission_count",
        "reconciliation_count",
        "amendment_count"
      ],
      "properties": {
        "preflight_count": {
          "type": "integer",
          "minimum": 0
        },
        "submission_count": {
          "type": "integer",
          "minimum": 0
        },
        "reconciliation_count": {
          "type": "integer",
          "minimum": 0
        },
        "amendment_count": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "settlement_state": {
            "const": "RECOVERY_REQUIRED"
          }
        },
        "required": [
          "settlement_state"
        ]
      },
      "then": {
        "properties": {
          "recovery_posture": {
            "not": {
              "const": "NONE"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "token_client_binding_state": {
            "const": "MISMATCH"
          }
        },
        "required": [
          "token_client_binding_state"
        ]
      },
      "then": {
        "properties": {
          "binding_health": {
            "const": "CLIENT_BINDING_MISMATCH"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "TOKEN_INVALID"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "binding_health": {
            "const": "TOKEN_INVALID"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "UNLINKED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "binding_health": {
            "const": "UNLINKED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "REVOKED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "binding_health": {
            "const": "REVOKED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "EXPIRED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "binding_health": {
            "const": "EXPIRED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "binding_health": {
            "enum": [
              "CLIENT_BINDING_MISMATCH",
              "DELEGATION_GAP",
              "ENVIRONMENT_DRIFT",
              "TOKEN_INVALID",
              "REVOKED",
              "EXPIRED"
            ]
          }
        },
        "required": [
          "binding_health"
        ]
      },
      "then": {
        "properties": {
          "authority_link_workspace": {
            "properties": {
              "prominent_issue_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "binding_health_timeline": {
            "properties": {
              "promoted_issue_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "guided_handshake_stepper": {
            "properties": {
              "flow_state": {
                "const": "NOT_STARTED"
              }
            },
            "required": [
              "flow_state"
            ]
          }
        },
        "required": [
          "guided_handshake_stepper"
        ]
      },
      "then": {
        "properties": {
          "guided_handshake_stepper": {
            "properties": {
              "current_step_code": {
                "const": "SELECT_AUTHORITY"
              },
              "completed_step_codes": {
                "maxItems": 0
              },
              "external_handoff_ref_or_null": {
                "type": "null"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "guided_handshake_stepper": {
            "properties": {
              "flow_state": {
                "const": "HANDOFF_PENDING"
              }
            },
            "required": [
              "flow_state"
            ]
          }
        },
        "required": [
          "guided_handshake_stepper"
        ]
      },
      "then": {
        "properties": {
          "guided_handshake_stepper": {
            "properties": {
              "current_step_code": {
                "const": "AUTHORISE_EXTERNAL_HANDOFF"
              },
