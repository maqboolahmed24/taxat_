{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/provenance_path.schema.json",
  "title": "ProvenancePath",
  "description": "Critical provenance-path contract. This schema freezes path class, admissibility, ranking basis, and retention or inference limitations for one explanation path.",
  "type": "object",
  "required": [
    "path_id",
    "graph_id",
    "manifest_id",
    "manifest_refs",
    "partition_contract",
    "target_ref",
    "path_class",
    "path_role",
    "admissibility_state",
    "node_refs",
    "edge_refs",
    "weakest_support_confidence",
    "inferred_decisive_segment_present",
    "retention_limited_segment_count",
    "tombstoned_segment_count",
    "limitation_codes",
    "ranking_basis",
    "lineage_boundary_refs",
    "decisive_lineage_boundary_refs",
    "hop_count",
    "generated_at",
    "closure_state",
    "replayable",
    "path_hash",
    "anchor_ref",
    "anchor_class",
    "decisive_edge_refs",
    "contradiction_refs",
    "stale_segment_count"
  ],
  "properties": {
    "path_id": {
      "type": "string",
      "minLength": 1
    },
    "graph_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "partition_contract": {
      "$ref": "./provenance_partition_contract.schema.json"
    },
    "target_ref": {
      "type": "string",
      "minLength": 1
    },
    "path_class": {
      "type": "string",
      "enum": [
        "PATH_DERIVATION",
        "PATH_EVIDENCE_SUPPORT",
        "PATH_AUDIT_PROOF",
        "PATH_AUTHORITY_STATE",
        "PATH_PARITY_EXPLANATION",
        "PATH_TRUST_EXPLANATION",
        "PATH_DRIFT_BASELINE",
        "PATH_AMENDMENT_JUSTIFICATION",
        "PATH_REMEDIATION_CHAIN",
        "PATH_CONTINUATION_LINEAGE",
        "PATH_RETENTION_LIMITATION",
        "PATH_FILING_PROOF"
      ]
    },
    "path_role": {
      "type": "string",
      "enum": [
        "PRIMARY",
        "ALTERNATIVE"
      ]
    },
    "admissibility_state": {
      "type": "string",
      "enum": [
        "ADMISSIBLE",
        "LIMITED",
        "INADMISSIBLE"
      ]
    },
    "node_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 2,
      "uniqueItems": true
    },
    "edge_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "weakest_support_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "inferred_decisive_segment_present": {
      "type": "boolean"
    },
    "retention_limited_segment_count": {
      "type": "integer",
      "minimum": 0
    },
    "tombstoned_segment_count": {
      "type": "integer",
      "minimum": 0
    },
    "limitation_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "ranking_basis": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/rankingBasisItem"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "lineage_boundary_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "decisive_lineage_boundary_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "hop_count": {
      "type": "integer",
      "minimum": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "closure_state": {
      "type": "string",
      "enum": [
        "CLOSED",
        "OPEN"
      ]
    },
    "replayable": {
      "type": "boolean"
    },
    "path_hash": {
      "type": "string",
      "minLength": 1
    },
    "anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "anchor_class": {
      "type": "string",
      "enum": [
        "EVIDENCE_ITEM",
        "SOURCE_RECORD",
        "AUTHORITY_RESPONSE",
        "AUDIT_EVENT",
        "CONFIG_FREEZE"
      ]
    },
    "decisive_edge_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "contradiction_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "stale_segment_count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "rankingBasisItem": {
      "type": "object",
      "required": [
        "criterion",
        "rank_order",
        "basis_value"
      ],
      "properties": {
        "criterion": {
          "type": "string",
          "enum": [
            "CONTRADICTION_FREE",
            "LEGAL_STATE_PREREQUISITES",
            "WEAKEST_SEGMENT_CONFIDENCE",
            "UNRESOLVED_LIMITATION_COUNT",
            "STALE_SEGMENT_COUNT",
            "RETENTION_TOMBSTONE_COUNT",
            "HOP_COUNT",
            "LEXICAL_PATH_ID"
          ]
        },
        "rank_order": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7
        },
        "basis_value": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "admissibility_state": {
            "const": "ADMISSIBLE"
          }
        },
        "required": [
          "admissibility_state"
        ]
      },
      "then": {
        "properties": {
          "inferred_decisive_segment_present": {
            "const": false
          },
          "retention_limited_segment_count": {
            "const": 0
          },
          "tombstoned_segment_count": {
            "const": 0
          },
          "limitation_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "inferred_decisive_segment_present": {
            "const": true
          }
        },
        "required": [
          "inferred_decisive_segment_present"
        ]
      },
      "then": {
        "properties": {
          "admissibility_state": {
            "enum": [
              "LIMITED",
              "INADMISSIBLE"
            ]
          },
          "limitation_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "retention_limited_segment_count": {
            "minimum": 1
          }
        },
        "required": [
          "retention_limited_segment_count"
        ]
      },
      "then": {
        "properties": {
          "admissibility_state": {
            "enum": [
              "LIMITED",
              "INADMISSIBLE"
            ]
          },
          "limitation_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "tombstoned_segment_count": {
            "minimum": 1
          }
        },
        "required": [
          "tombstoned_segment_count"
        ]
      },
      "then": {
        "properties": {
          "admissibility_state": {
            "enum": [
              "LIMITED",
              "INADMISSIBLE"
            ]
          },
          "limitation_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "closure_state": {
            "const": "CLOSED"
          }
        },
        "required": [
          "closure_state"
        ]
      },
      "then": {
        "properties": {
          "anchor_ref": {
            "type": "string",
            "minLength": 1
          },
          "decisive_edge_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "replayable": {
            "const": false
          }
        },
        "required": [
          "replayable"
        ]
      },
      "then": {
        "properties": {
          "admissibility_state": {
            "enum": [
              "LIMITED",
              "INADMISSIBLE"
            ]
          },
          "limitation_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "stale_segment_count": {
            "minimum": 1
          }
        },
        "required": [
          "stale_segment_count"
        ]
      },
      "then": {
        "properties": {
          "admissibility_state": {
            "enum": [
              "LIMITED",
              "INADMISSIBLE"
            ]
          },
          "limitation_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "path_role": {
            "const": "PRIMARY"
          }
        },
        "required": [
          "path_role"
        ]
      },
      "then": {
        "properties": {
          "ranking_basis": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "path_class": {
            "const": "PATH_RETENTION_LIMITATION"
          }
        },
        "required": [
          "path_class"
        ]
      },
      "then": {
        "properties": {
          "limitation_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "manifest_refs": {
            "minItems": 2
          }
        },
        "required": [
          "manifest_refs"
        ]
      },
      "then": {
        "properties": {
          "lineage_boundary_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lineage_boundary_refs": {
            "minItems": 1
          }
        },
        "required": [
          "lineage_boundary_refs"
        ]
      },
      "then": {
        "properties": {
          "manifest_refs": {
            "minItems": 2
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decisive_lineage_boundary_refs": {
            "minItems": 1
          }
        },
        "required": [
          "decisive_lineage_boundary_refs"
        ]
      },
      "then": {
        "properties": {
          "lineage_boundary_refs": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
