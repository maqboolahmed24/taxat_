{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/config_freeze.schema.json",
  "title": "ConfigFreeze",
  "type": "object",
  "required": [
    "config_freeze_id",
    "manifest_id",
    "artifact_type",
    "entries",
    "config_freeze_hash",
    "approval_snapshot_ref",
    "materiality_profile_ref",
    "amendment_materiality_profile_ref",
    "retention_profile_ref",
    "provider_contract_profile_ref",
    "workflow_policy_ref",
    "override_policy_ref",
    "masking_export_policy_ref",
    "canonicalization_rules_ref",
    "connector_mapping_rules_ref",
    "parity_threshold_profile_ref",
    "trust_threshold_profile_ref",
    "risk_threshold_profile_ref",
    "evidence_confidence_policy_ref",
    "computation_rules_ref",
    "required_config_types_present"
  ],
  "properties": {
    "config_freeze_id": {
      "type": "string"
    },
    "manifest_id": {
      "type": "string"
    },
    "artifact_type": {
      "const": "ConfigFreeze"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/configEntry"
      }
    },
    "config_freeze_hash": {
      "type": "string"
    },
    "approval_snapshot_ref": {
      "type": "string"
    },
    "materiality_profile_ref": {
      "type": "string"
    },
    "amendment_materiality_profile_ref": {
      "type": "string"
    },
    "retention_profile_ref": {
      "type": "string"
    },
    "provider_contract_profile_ref": {
      "type": "string"
    },
    "workflow_policy_ref": {
      "type": "string"
    },
    "override_policy_ref": {
      "type": "string"
    },
    "masking_export_policy_ref": {
      "type": "string"
    },
    "canonicalization_rules_ref": {
      "type": "string"
    },
    "connector_mapping_rules_ref": {
      "type": "string"
    },
    "parity_threshold_profile_ref": {
      "type": "string"
    },
    "trust_threshold_profile_ref": {
      "type": "string"
    },
    "risk_threshold_profile_ref": {
      "type": "string"
    },
    "evidence_confidence_policy_ref": {
      "type": "string"
    },
    "computation_rules_ref": {
      "type": "string"
    },
    "required_config_types_present": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "COMPUTATION_RULES",
          "PARITY_THRESHOLDS",
          "TRUST_THRESHOLDS",
          "RISK_THRESHOLDS",
          "WORKFLOW_POLICY",
          "OVERRIDE_POLICY",
          "RETENTION_POLICY",
          "EVIDENCE_CONFIDENCE_POLICY",
          "CANONICALIZATION_RULES",
          "CONNECTOR_MAPPING_RULES",
          "PROVIDER_CONTRACT_PROFILE",
          "MATERIALITY_PROFILE",
          "AMENDMENT_MATERIALITY_PROFILE",
          "MASKING_EXPORT_POLICY"
        ]
      },
      "uniqueItems": true,
      "minItems": 14
    }
  },
  "$defs": {
    "configEntry": {
      "type": "object",
      "required": [
        "config_type",
        "version_id",
        "content_hash",
        "status_at_freeze",
        "effective_scope",
        "effective_from",
        "effective_to",
        "ccr_id",
        "test_suite_refs",
        "provider_api_version",
        "provider_schema_version",
        "environment_allowlist",
        "compatibility_class",
        "superseded_by_version_id"
      ],
      "properties": {
        "config_type": {
          "type": "string"
        },
        "version_id": {
          "type": "string"
        },
        "content_hash": {
          "type": "string"
        },
        "status_at_freeze": {
          "type": "string",
          "enum": [
            "DRAFT",
            "CANDIDATE",
            "VERIFIED",
            "APPROVED",
            "DEPRECATED",
            "REVOKED"
          ]
        },
        "effective_scope": {
          "type": ["string", "null"]
        },
        "effective_from": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "effective_to": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "ccr_id": {
          "type": ["string", "null"]
        },
        "test_suite_refs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "provider_api_version": {
          "type": ["string", "null"]
        },
        "provider_schema_version": {
          "type": ["string", "null"]
        },
        "environment_allowlist": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "compatibility_class": {
          "type": ["string", "null"]
        },
        "superseded_by_version_id": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
