{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/config_freeze.schema.json",
  "title": "ConfigFreeze",
  "type": "object",
  "required": [
    "config_freeze_id",
    "manifest_id",
    "artifact_type",
    "entries",
    "config_freeze_hash",
    "schema_bundle_hash",
    "feature_flag_snapshot_hash",
    "config_surface_hash",
    "config_completeness_state",
    "config_resolution_basis",
    "source_config_freeze_ref",
    "source_config_freeze_hash",
    "source_config_surface_hash",
    "config_consumption_mode",
    "approval_snapshot_ref",
    "materiality_profile_ref",
    "amendment_materiality_profile_ref",
    "retention_profile_ref",
    "provider_contract_profile_ref",
    "workflow_policy_ref",
    "override_policy_ref",
    "masking_export_policy_ref",
    "canonicalization_rules_ref",
    "connector_mapping_rules_ref",
    "parity_threshold_profile_ref",
    "trust_threshold_profile_ref",
    "risk_threshold_profile_ref",
    "evidence_confidence_policy_ref",
    "computation_rules_ref",
    "required_config_types_present"
  ],
  "properties": {
    "config_freeze_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "ConfigFreeze"
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/configEntry"
      },
      "minItems": 14,
      "allOf": [
        {
          "contains": {
            "type": "object",
            "properties": {
              "config_type": {
                "const": "COMPUTATION_RULES"
              }
            },
            "required": [
              "config_type"
            ]
          },
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "config_type": {
                "const": "PARITY_THRESHOLDS"
              }
            },
            "required": [
              "config_type"
            ]
          },
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "config_type": {
                "const": "TRUST_THRESHOLDS"
              }
            },
            "required": [
              "config_type"
            ]
          },
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "config_type": {
                "const": "RISK_THRESHOLDS"
              }
            },
            "required": [
              "config_type"
            ]
          },
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "config_type": {
                "const": "WORKFLOW_POLICY"
              }
            },
            "required": [
              "config_type"
            ]
          },
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "config_type": {
                "const": "OVERRIDE_POLICY"
              }
            },
            "required": [
              "config_type"
            ]
          },
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "config_type": {
                "const": "RETENTION_POLICY"
              }
            },
            "required": [
              "config_type"
            ]
          },
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "config_type": {
                "const": "EVIDENCE_CONFIDENCE_POLICY"
              }
            },
            "required": [
              "config_type"
            ]
          },
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "config_type": {
                "const": "CANONICALIZATION_RULES"
              }
            },
            "required": [
              "config_type"
            ]
          },
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "config_type": {
                "const": "CONNECTOR_MAPPING_RULES"
              }
            },
            "required": [
              "config_type"
            ]
          },
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "config_type": {
                "const": "PROVIDER_CONTRACT_PROFILE"
              }
            },
            "required": [
              "config_type"
            ]
          },
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "config_type": {
                "const": "MATERIALITY_PROFILE"
              }
            },
            "required": [
              "config_type"
            ]
          },
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "config_type": {
                "const": "AMENDMENT_MATERIALITY_PROFILE"
              }
            },
            "required": [
              "config_type"
            ]
          },
          "maxContains": 1
        },
        {
          "contains": {
            "type": "object",
            "properties": {
              "config_type": {
                "const": "MASKING_EXPORT_POLICY"
              }
            },
            "required": [
              "config_type"
            ]
          },
          "maxContains": 1
        }
      ],
      "uniqueItems": true
    },
    "config_freeze_hash": {
      "type": "string",
      "minLength": 1
    },
    "schema_bundle_hash": {
      "type": "string",
      "minLength": 1
    },
    "feature_flag_snapshot_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "config_surface_hash": {
      "type": "string",
      "minLength": 1
    },
    "config_completeness_state": {
      "const": "COMPLETE_REQUIRED_CONFIG_SET"
    },
    "config_resolution_basis": {
      "type": "string",
      "enum": [
        "DIRECT_REQUEST_RESOLUTION",
        "REPLAY_EXACT_REUSE",
        "RECOVERY_EXACT_REUSE",
        "HISTORICAL_EXPLICIT_REUSE"
      ]
    },
    "source_config_freeze_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "source_config_freeze_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "source_config_surface_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "config_consumption_mode": {
      "const": "FROZEN_CONFIG_ONLY"
    },
    "approval_snapshot_ref": {
      "type": "string",
      "minLength": 1
    },
    "materiality_profile_ref": {
      "type": "string",
      "minLength": 1
    },
    "amendment_materiality_profile_ref": {
      "type": "string",
      "minLength": 1
    },
    "retention_profile_ref": {
      "type": "string",
      "minLength": 1
    },
    "provider_contract_profile_ref": {
      "type": "string",
      "minLength": 1
    },
    "workflow_policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "override_policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "masking_export_policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "canonicalization_rules_ref": {
      "type": "string",
      "minLength": 1
    },
    "connector_mapping_rules_ref": {
      "type": "string",
      "minLength": 1
    },
    "parity_threshold_profile_ref": {
      "type": "string",
      "minLength": 1
    },
    "trust_threshold_profile_ref": {
      "type": "string",
      "minLength": 1
    },
    "risk_threshold_profile_ref": {
      "type": "string",
      "minLength": 1
    },
    "evidence_confidence_policy_ref": {
      "type": "string",
      "minLength": 1
    },
    "computation_rules_ref": {
      "type": "string",
      "minLength": 1
    },
    "required_config_types_present": {
      "type": "array",
      "const": [
        "COMPUTATION_RULES",
        "PARITY_THRESHOLDS",
        "TRUST_THRESHOLDS",
        "RISK_THRESHOLDS",
        "WORKFLOW_POLICY",
        "OVERRIDE_POLICY",
        "RETENTION_POLICY",
        "EVIDENCE_CONFIDENCE_POLICY",
        "CANONICALIZATION_RULES",
        "CONNECTOR_MAPPING_RULES",
        "PROVIDER_CONTRACT_PROFILE",
        "MATERIALITY_PROFILE",
        "AMENDMENT_MATERIALITY_PROFILE",
        "MASKING_EXPORT_POLICY"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "config_resolution_basis": {
            "const": "DIRECT_REQUEST_RESOLUTION"
          }
        },
        "required": [
          "config_resolution_basis"
        ]
      },
      "then": {
        "properties": {
          "source_config_freeze_ref": {
            "type": "null"
          },
          "source_config_freeze_hash": {
            "type": "null"
          },
          "source_config_surface_hash": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "config_resolution_basis": {
            "enum": [
              "REPLAY_EXACT_REUSE",
              "RECOVERY_EXACT_REUSE",
              "HISTORICAL_EXPLICIT_REUSE"
            ]
          }
        },
        "required": [
          "config_resolution_basis"
        ]
      },
      "then": {
        "properties": {
          "source_config_freeze_ref": {
            "type": "string",
            "minLength": 1
          },
          "source_config_freeze_hash": {
            "type": "string",
            "minLength": 1
          },
          "source_config_surface_hash": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ],
  "$defs": {
    "configEntry": {
      "type": "object",
      "required": [
        "config_type",
        "version_id",
        "content_hash",
        "status_at_freeze",
        "effective_scope",
        "effective_from",
        "effective_to",
        "ccr_id",
        "test_suite_refs",
        "provider_api_version",
        "provider_schema_version",
        "environment_allowlist",
        "compatibility_class",
        "superseded_by_version_id"
      ],
      "properties": {
        "config_type": {
          "type": "string",
          "minLength": 1
        },
        "version_id": {
          "type": "string",
          "minLength": 1
        },
        "content_hash": {
          "type": "string",
          "minLength": 1
        },
        "status_at_freeze": {
          "type": "string",
          "enum": [
            "DRAFT",
            "CANDIDATE",
            "VERIFIED",
            "APPROVED",
            "DEPRECATED",
            "REVOKED"
          ]
        },
        "effective_scope": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "effective_from": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "effective_to": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "ccr_id": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "test_suite_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "provider_api_version": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "provider_schema_version": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "environment_allowlist": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "compatibility_class": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "superseded_by_version_id": {
          "type": ["string", "null"],
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "anyOf": [
              {
                "properties": {
                  "provider_api_version": {
                    "type": "string"
                  }
                },
                "required": [
                  "provider_api_version"
                ]
              },
              {
                "properties": {
                  "provider_schema_version": {
                    "type": "string"
                  }
                },
                "required": [
                  "provider_schema_version"
                ]
              }
            ]
          },
          "then": {
            "properties": {
              "provider_api_version": {
                "type": "string",
                "minLength": 1
              },
              "provider_schema_version": {
                "type": "string",
                "minLength": 1
              },
              "environment_allowlist": {
                "minItems": 1
              }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
