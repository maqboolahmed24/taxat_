{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/audit_investigation_frame.schema.json",
  "title": "AuditInvestigationFrame",
  "description": "Governance audit and investigations workspace contract for the Admin/Governance Console. This read-side schema freezes selected-event continuity, object-neighborhood reconstruction, summary-first diff inspection, and active-slice export eligibility so the route does not degrade into a raw-JSON or detached-export view.",
  "type": "object",
  "required": [
    "frame_id",
    "artifact_type",
    "tenant_id",
    "shell_family",
    "object_anchor_ref",
    "dominant_question",
    "query_contract_code",
    "query_anchor_ref",
    "ordering_basis",
    "settlement_state",
    "recovery_posture",
    "interaction_layer",
    "focus_anchor_ref",
    "ordered_event_refs",
    "supporting_trace_span_refs",
    "supporting_log_record_refs",
    "correlation_keys",
    "integrity_chain_posture",
    "export_posture",
    "externalization_governance_contract",
    "active_filters",
    "audit_workspace",
    "audit_tape",
    "object_neighborhood",
    "event_diff_inspector",
    "export_eligibility_panel",
    "object_neighborhood_refs",
    "updated_at"
  ],
  "properties": {
    "frame_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "AuditInvestigationFrame"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "shell_family": {
      "const": "GOVERNANCE_DENSITY_SHELL"
    },
    "object_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "dominant_question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "query_contract_code": {
      "type": "string",
      "enum": [
        "AUDIT_TRAIL",
        "RUN_TIMELINE",
        "NIGHTLY_BATCH_TIMELINE",
        "FILING_EVIDENCE_LEDGER",
        "PRIVACY_ACTION_LEDGER"
      ]
    },
    "query_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "ordering_basis": {
      "type": "string",
      "enum": [
        "AUDIT_STREAM_SEQUENCE",
        "RECORDED_AT_THEN_STREAM_SEQUENCE"
      ]
    },
    "settlement_state": {
      "$ref": "#/$defs/settlementState"
    },
    "recovery_posture": {
      "$ref": "#/$defs/recoveryPosture"
    },
    "interaction_layer": {
      "$ref": "https://taxat.dev/schemas/governance_interaction_layer.schema.json"
    },
    "focus_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "ordered_event_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "supporting_trace_span_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "supporting_log_record_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "correlation_keys": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "integrity_chain_posture": {
      "type": "string",
      "enum": [
        "VERIFIED",
        "PARTIAL_GAP",
        "BROKEN",
        "PENDING_REBUILD"
      ]
    },
    "export_posture": {
      "$ref": "#/$defs/exportPosture"
    },
    "externalization_governance_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/externalization_governance_contract.schema.json"
        },
        {
          "properties": {
            "boundary_scope": {
              "const": "AUDIT_INVESTIGATION_FRAME"
            }
          }
        }
      ]
    },
    "active_filters": {
      "$ref": "#/$defs/activeFilters"
    },
    "audit_workspace": {
      "$ref": "#/$defs/auditWorkspace"
    },
    "audit_tape": {
      "$ref": "#/$defs/auditTape"
    },
    "object_neighborhood": {
      "$ref": "#/$defs/objectNeighborhood"
    },
    "event_diff_inspector": {
      "$ref": "#/$defs/eventDiffInspector"
    },
    "export_eligibility_panel": {
      "$ref": "#/$defs/exportEligibilityPanel"
    },
    "object_neighborhood_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "next_cursor": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "settlementState": {
      "type": "string",
      "enum": [
        "STEADY",
        "RECEIPT_PENDING",
        "FRESHENING",
        "STALE_REVIEW_REQUIRED",
        "DEGRADED_READ_ONLY",
        "RECOVERY_REQUIRED"
      ]
    },
    "recoveryPosture": {
      "type": "string",
      "enum": [
        "NONE",
        "INLINE_RECONNECT",
        "INLINE_REBASE",
        "READ_ONLY_LIMITED",
        "OBJECT_SUPERSEDED",
        "ACCESS_REBIND_REQUIRED"
      ]
    },
    "interactionLayer": {
      "type": "object",
      "required": [
        "selected_filter_chip_refs",
        "compaction_mode",
        "auxiliary_surface_presentation",
        "focus_trap_mode",
        "selection_persistence_mode",
        "preserved_context_codes"
      ],
      "properties": {
        "selected_filter_chip_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "compaction_mode": {
          "type": "string",
          "enum": [
            "WIDE",
            "AUXILIARY_DRAWER",
            "AUXILIARY_TRAY",
            "FOCUS_STACK"
          ]
        },
        "auxiliary_surface_presentation": {
          "type": "string",
          "enum": [
            "SIDECAR",
            "DRAWER",
            "INSPECTOR",
            "TRAY"
          ]
        },
        "focus_trap_mode": {
          "type": "string",
          "enum": [
            "NON_MODAL",
            "MODAL_EXPLICIT"
          ]
        },
        "selection_persistence_mode": {
          "const": "PRESERVE_WHILE_OBJECT_RESOLVES"
        },
        "preserved_context_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ACTIVE_FILTERS",
              "ACTIVE_SECTION",
              "SELECTION",
              "FOCUS_ANCHOR",
              "PROMOTED_SUPPORT_SURFACE",
              "STAGED_DIFF",
              "CHANGE_BASKET",
              "GUIDED_HANDSHAKE_STEP",
              "QUERY_SLICE"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "workspaceMode": {
      "type": "string",
      "enum": [
        "EVENT_TIMELINE",
        "OBJECT_TIMELINE",
        "CORRELATION_TRACE"
      ]
    },
    "promotedSupportSurface": {
      "type": "string",
      "enum": [
        "AUDIT_SIDECAR",
        "EXPORT_ELIGIBILITY_PANEL"
      ]
    },
    "timelineMode": {
      "type": "string",
      "enum": [
        "APPEND_ONLY"
      ]
    },
    "neighborhoodMode": {
      "type": "string",
      "enum": [
        "UPSTREAM_DOWNSTREAM"
      ]
    },
    "eventDiffPanelMode": {
      "type": "string",
      "enum": [
        "CHANGE_NUCLEI",
        "MASKED_CHANGE_NUCLEI",
        "LIMITATION_NOTICE"
      ]
    },
    "rawPayloadPosture": {
      "type": "string",
      "enum": [
        "SUMMARY_FIRST"
      ]
    },
    "exportPanelMode": {
      "type": "string",
      "enum": [
        "FULL_EXPORT_READY",
        "MASKED_EXPORT_ONLY",
        "APPROVAL_GATE",
        "DENIED_NOTICE"
      ]
    },
    "invocationPosture": {
      "type": "string",
      "enum": [
        "ACTIVE_FILTERED_SLICE"
      ]
    },
    "exportPosture": {
      "type": "object",
      "required": [
        "state",
        "reason_codes"
      ],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "FULL_ALLOWED",
            "MASKED_ONLY",
            "APPROVAL_REQUIRED",
            "DENIED"
          ]
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "enum": [
                  "MASKED_ONLY",
                  "APPROVAL_REQUIRED",
                  "DENIED"
                ]
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "reason_codes": {
                "minItems": 1
              }
            }
          },
          "else": {
            "properties": {
              "reason_codes": {
                "maxItems": 0
              }
            }
          }
        }
      ]
    },
    "activeFilters": {
      "type": "object",
      "required": [
        "actor_refs",
        "event_families",
        "client_refs",
        "manifest_refs",
        "authority_operation_refs",
        "object_refs",
        "window_from",
        "window_to"
      ],
      "properties": {
        "actor_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "event_families": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "client_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "manifest_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "authority_operation_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "object_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "window_from": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "window_to": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "auditWorkspace": {
      "type": "object",
      "required": [
        "surface_order",
        "workspace_mode",
        "active_filters",
        "selected_event_ref",
        "selected_object_ref_or_null",
        "promoted_support_surface"
      ],
      "properties": {
        "surface_order": {
          "const": [
            "INVENTORY_RAIL",
            "WORKSPACE_CANVAS",
            "EVENT_DIFF_INSPECTOR",
            "AUDIT_SIDECAR"
          ]
        },
        "workspace_mode": {
          "$ref": "#/$defs/workspaceMode"
        },
        "active_filters": {
          "$ref": "#/$defs/activeFilters"
        },
        "selected_event_ref": {
          "type": "string",
          "minLength": 1
        },
        "selected_object_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "promoted_support_surface": {
          "$ref": "#/$defs/promotedSupportSurface"
        }
      },
      "additionalProperties": false
    },
    "auditTapeRow": {
      "type": "object",
      "required": [
        "event_ref",
        "family_ref",
        "actor_or_service_ref_or_null",
        "primary_object_ref_or_null",
        "diff_available"
      ],
      "properties": {
        "event_ref": {
          "type": "string",
          "minLength": 1
        },
        "family_ref": {
          "type": "string",
          "minLength": 1
        },
        "actor_or_service_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "primary_object_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "diff_available": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "auditTape": {
      "type": "object",
      "required": [
        "timeline_mode",
        "rows",
        "selected_event_ref"
      ],
      "properties": {
        "timeline_mode": {
          "$ref": "#/$defs/timelineMode"
        },
        "rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/auditTapeRow"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "selected_event_ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "objectNeighborhood": {
      "type": "object",
      "required": [
        "neighborhood_mode",
        "object_refs",
        "selected_object_ref_or_null",
        "upstream_event_refs",
        "selected_event_ref",
        "downstream_event_refs"
      ],
      "properties": {
        "neighborhood_mode": {
          "$ref": "#/$defs/neighborhoodMode"
        },
        "object_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "selected_object_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "upstream_event_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "selected_event_ref": {
          "type": "string",
          "minLength": 1
        },
        "downstream_event_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "anyOf": [
            {
              "properties": {
                "upstream_event_refs": {
                  "minItems": 1
                }
              }
            },
            {
              "properties": {
                "downstream_event_refs": {
                  "minItems": 1
                }
              }
            }
          ]
        }
      ],
      "additionalProperties": false
    },
    "eventDiffInspector": {
      "type": "object",
      "required": [
        "panel_mode",
        "baseline_event_ref_or_null",
        "comparison_event_ref_or_null",
        "summary_ref_or_null",
        "changed_field_refs",
        "raw_payload_posture"
      ],
      "properties": {
        "panel_mode": {
          "$ref": "#/$defs/eventDiffPanelMode"
        },
        "baseline_event_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "comparison_event_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "summary_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "changed_field_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "raw_payload_posture": {
          "$ref": "#/$defs/rawPayloadPosture"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "panel_mode": {
                "enum": [
                  "CHANGE_NUCLEI",
                  "MASKED_CHANGE_NUCLEI"
                ]
              }
            },
            "required": [
              "panel_mode"
            ]
          },
          "then": {
            "properties": {
              "baseline_event_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "comparison_event_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "summary_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "changed_field_refs": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "panel_mode": {
                "const": "LIMITATION_NOTICE"
              }
            },
            "required": [
              "panel_mode"
            ]
          },
          "then": {
            "properties": {
              "baseline_event_ref_or_null": {
                "type": "null"
              },
              "comparison_event_ref_or_null": {
                "type": "null"
              },
              "summary_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "changed_field_refs": {
                "maxItems": 0
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "exportEligibilityPanel": {
      "type": "object",
      "required": [
        "panel_mode",
        "state",
        "reason_codes",
        "active_slice_scope_ref",
        "masked_preview_ref_or_null",
        "approval_requirement_ref_or_null",
        "invocation_posture"
      ],
      "properties": {
        "panel_mode": {
          "$ref": "#/$defs/exportPanelMode"
        },
        "state": {
          "type": "string",
          "enum": [
            "FULL_ALLOWED",
            "MASKED_ONLY",
            "APPROVAL_REQUIRED",
            "DENIED"
          ]
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "active_slice_scope_ref": {
          "type": "string",
          "minLength": 1
        },
        "masked_preview_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "approval_requirement_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "invocation_posture": {
          "$ref": "#/$defs/invocationPosture"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "state": {
                "const": "FULL_ALLOWED"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "panel_mode": {
                "const": "FULL_EXPORT_READY"
              },
              "reason_codes": {
                "maxItems": 0
              },
              "masked_preview_ref_or_null": {
                "type": "null"
              },
              "approval_requirement_ref_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "MASKED_ONLY"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "panel_mode": {
                "const": "MASKED_EXPORT_ONLY"
              },
              "reason_codes": {
                "minItems": 1
              },
              "masked_preview_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "approval_requirement_ref_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "APPROVAL_REQUIRED"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "panel_mode": {
                "const": "APPROVAL_GATE"
              },
              "reason_codes": {
                "minItems": 1
              },
              "masked_preview_ref_or_null": {
                "type": "null"
              },
              "approval_requirement_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "DENIED"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "panel_mode": {
                "const": "DENIED_NOTICE"
              },
              "reason_codes": {
                "minItems": 1
              },
              "masked_preview_ref_or_null": {
                "type": "null"
              },
              "approval_requirement_ref_or_null": {
                "type": "null"
              }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "settlement_state": {
            "const": "RECOVERY_REQUIRED"
          }
        },
        "required": [
          "settlement_state"
        ]
      },
      "then": {
        "properties": {
          "recovery_posture": {
            "not": {
              "const": "NONE"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "query_contract_code": {
            "const": "AUDIT_TRAIL"
          }
        },
        "required": [
          "query_contract_code"
        ]
      },
      "then": {
        "properties": {
          "ordering_basis": {
            "const": "AUDIT_STREAM_SEQUENCE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "query_contract_code": {
            "enum": [
              "RUN_TIMELINE",
              "NIGHTLY_BATCH_TIMELINE",
              "FILING_EVIDENCE_LEDGER",
              "PRIVACY_ACTION_LEDGER"
            ]
          }
        },
        "required": [
          "query_contract_code"
        ]
      },
      "then": {
        "properties": {
          "ordering_basis": {
            "const": "RECORDED_AT_THEN_STREAM_SEQUENCE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "query_contract_code": {
            "enum": [
              "RUN_TIMELINE",
              "NIGHTLY_BATCH_TIMELINE"
            ]
          }
        },
        "required": [
          "query_contract_code"
        ]
      },
      "then": {
