{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/semantic_accessibility_regression_pack.schema.json",
  "title": "SemanticAccessibilityRegressionPack",
  "description": "Deterministic cross-shell semantic selector and accessibility regression artifact. This schema freezes the Playwright and XCUITest case inventory, exact semantic-contract bindings, identifier parity, landmark and heading assertions, keyboard and screen-reader critical paths, reduced-motion parity, live-update announcement rules, and support-surface accessibility rules used to prove that governed shells keep the same machine-readable meaning through responsive and recovery transitions.",
  "type": "object",
  "required": [
    "contract_version",
    "pack_id",
    "deterministic_seed",
    "suite_profile",
    "run_mode",
    "modality_policy",
    "identifier_binding_policy",
    "landmark_heading_policy",
    "live_update_announcement_policy",
    "support_surface_policy",
    "transition_stability_policy",
    "return_path_policy",
    "cases"
  ],
  "properties": {
    "contract_version": {
      "const": "SEMANTIC_ACCESSIBILITY_REGRESSION_PACK_V1"
    },
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "deterministic_seed": {
      "type": "integer",
      "minimum": 0
    },
    "suite_profile": {
      "const": "CROSS_SHELL_SEMANTIC_ACCESSIBILITY_AND_ASSISTIVE_TECH_MATRIX"
    },
    "run_mode": {
      "const": "DETERMINISTIC_SEEDED_ENUMERATION"
    },
    "modality_policy": {
      "const": "EVERY_CASE_COVERS_KEYBOARD_SCREEN_READER_AND_REDUCED_MOTION"
    },
    "identifier_binding_policy": {
      "const": "AUTOMATION_IDENTIFIERS_MUST_EQUAL_SEMANTIC_ANCHOR_REFS"
    },
    "landmark_heading_policy": {
      "const": "LANDMARKS_AND_HEADINGS_MIRROR_VISIBLE_SHELL_STRUCTURE"
    },
    "live_update_announcement_policy": {
      "const": "DECISIVE_CHANGE_ANNOUNCED_WITHOUT_NOISE_OR_FOCUS_THEFT"
    },
    "support_surface_policy": {
      "const": "PROMOTED_SUPPORT_AND_DETAIL_SURFACES_REMAIN_NON_MODAL_AND_ESCAPABLE"
    },
    "transition_stability_policy": {
      "const": "RESPONSIVE_REBASE_RECONNECT_AND_COLLAPSE_KEEP_SEMANTIC_ANCHORS_STABLE"
    },
    "return_path_policy": {
      "const": "RETURN_PATH_CONTROLS_REMAIN_ADDRESSABLE_ACROSS_CONTEXTUAL_AND_SECONDARY_FLOWS"
    },
    "cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/regressionCase"
      },
      "minItems": 6,
      "uniqueItems": true
    }
  },
  "$defs": {
    "surfaceType": {
      "type": "string",
      "enum": [
        "LowNoiseExperienceFrame",
        "WorkspaceSnapshot",
        "ClientPortalWorkspace",
        "TenantGovernanceSnapshot",
        "NativeOperatorWorkspaceScene",
        "NativeOperatorSecondaryWindowScene"
      ]
    },
    "shellFamily": {
      "type": "string",
      "enum": [
        "CALM_SHELL",
        "CLIENT_PORTAL_SHELL",
        "GOVERNANCE_DENSITY_SHELL"
      ]
    },
    "selectorProfile": {
      "type": "string",
      "enum": [
        "OPERATOR_SEMANTIC_SELECTORS_V1",
        "PORTAL_SEMANTIC_SELECTORS_V1",
        "GOVERNANCE_SEMANTIC_SELECTORS_V1"
      ]
    },
    "automationHarness": {
      "type": "string",
      "enum": [
        "PLAYWRIGHT",
        "XCUITEST"
      ]
    },
    "modality": {
      "type": "string",
      "enum": [
        "KEYBOARD_ONLY",
        "SCREEN_READER",
        "REDUCED_MOTION"
      ]
    },
    "transitionClass": {
      "type": "string",
      "enum": [
        "RESPONSIVE_RESTACK",
        "REBASE",
        "RECONNECT",
        "SUPPORT_REGION_COLLAPSE",
        "LIVE_UPDATE",
        "SECONDARY_WINDOW_RETURN"
      ]
    },
    "announcementMode": {
      "type": "string",
      "enum": [
        "POLITE",
        "ASSERTIVE"
      ]
    },
    "anchorBinding": {
      "type": "object",
      "required": [
        "anchor_code",
        "semantic_anchor_ref",
        "browser_identifier_or_null",
        "native_identifier_or_null",
        "heading_level_or_null",
        "landmark_role_or_null"
      ],
      "properties": {
        "anchor_code": {
          "type": "string",
          "minLength": 1
        },
        "semantic_anchor_ref": {
          "type": "string",
          "minLength": 1
        },
        "browser_identifier_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "native_identifier_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "heading_level_or_null": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1,
          "maximum": 6
        },
        "landmark_role_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "regressionCase": {
      "type": "object",
      "required": [
        "case_id",
        "surface_type",
        "shell_family",
        "selector_profile",
        "automation_harness",
        "covered_modalities",
        "transition_classes",
        "required_anchor_codes",
        "semantic_focus_order",
        "announced_change_kinds",
        "anchor_bindings",
        "landmark_anchor_codes_in_order",
        "heading_anchor_codes_in_order",
        "focus_entry_anchor_ref",
        "keyboard_path_anchor_refs",
        "screen_reader_anchor_codes_in_order",
        "live_update_change_kind_or_null",
        "live_region_mode_or_null",
        "live_update_focus_theft_detected",
        "excessive_live_noise_detected",
        "support_surface_kind_or_null",
        "support_surface_keyboard_reachable",
        "support_surface_keyboard_dismissible",
        "support_surface_modal_trap_detected",
        "return_path_anchor_code_or_null",
        "reduced_motion_semantics_preserved",
        "reduced_motion_recovery_story_matches_default"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "surface_type": {
          "$ref": "#/$defs/surfaceType"
        },
        "shell_family": {
          "$ref": "#/$defs/shellFamily"
        },
        "selector_profile": {
          "$ref": "#/$defs/selectorProfile"
        },
        "automation_harness": {
          "$ref": "#/$defs/automationHarness"
        },
        "covered_modalities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/modality"
          },
          "minItems": 3,
          "uniqueItems": true
        },
        "transition_classes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transitionClass"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "required_anchor_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 6,
          "uniqueItems": true
        },
        "semantic_focus_order": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 2,
          "uniqueItems": true
        },
        "announced_change_kinds": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "anchor_bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/anchorBinding"
          },
          "minItems": 6,
          "uniqueItems": true
        },
        "landmark_anchor_codes_in_order": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 3,
          "uniqueItems": true
        },
        "heading_anchor_codes_in_order": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "focus_entry_anchor_ref": {
          "type": "string",
          "minLength": 1
        },
        "keyboard_path_anchor_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 3,
          "uniqueItems": true
        },
        "screen_reader_anchor_codes_in_order": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 3,
          "uniqueItems": true
        },
        "live_update_change_kind_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "live_region_mode_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "live_update_focus_theft_detected": {
          "type": "boolean"
        },
        "excessive_live_noise_detected": {
          "type": "boolean"
        },
        "support_surface_kind_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "support_surface_keyboard_reachable": {
          "type": "boolean"
        },
        "support_surface_keyboard_dismissible": {
          "type": "boolean"
        },
        "support_surface_modal_trap_detected": {
          "type": "boolean"
        },
        "return_path_anchor_code_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "reduced_motion_semantics_preserved": {
          "type": "boolean"
        },
        "reduced_motion_recovery_story_matches_default": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
