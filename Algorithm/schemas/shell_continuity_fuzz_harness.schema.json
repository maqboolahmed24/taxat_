{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/shell_continuity_fuzz_harness.schema.json",
  "title": "ShellContinuityFuzzHarness",
  "description": "Deterministic same-object same-shell perturbation harness. This schema freezes the perturbation matrix, invariant set, shrink strategy, and browser/native continuity case snapshots used to prove that lawful reconnect, rebase, resize, catch-up, and restoration flows preserve shell meaning rather than silently remounting a different route or object.",
  "type": "object",
  "required": [
    "contract_version",
    "harness_id",
    "deterministic_seed",
    "suite_profile",
    "run_mode",
    "shrink_policy",
    "coverage_policy",
    "continuity_invariant_policy",
    "inline_recovery_policy",
    "action_meaning_policy",
    "native_return_policy",
    "cases"
  ],
  "properties": {
    "contract_version": {
      "const": "SHELL_CONTINUITY_FUZZ_HARNESS_V1"
    },
    "harness_id": {
      "type": "string",
      "minLength": 1
    },
    "deterministic_seed": {
      "type": "integer",
      "minimum": 0
    },
    "suite_profile": {
      "const": "SAME_OBJECT_SAME_SHELL_PERTURBATION_MATRIX"
    },
    "run_mode": {
      "const": "DETERMINISTIC_SEEDED_ENUMERATION"
    },
    "shrink_policy": {
      "const": "REMOVE_NONESSENTIAL_PERTURBATIONS_KEEP_FIRST_BREAK"
    },
    "coverage_policy": {
      "const": "BROWSER_AND_NATIVE_COVERAGE_REQUIRED"
    },
    "continuity_invariant_policy": {
      "const": "SHELL_ROUTE_OBJECT_QUESTION_MODULE_FOCUS_STABLE_WHEN_LAWFUL"
    },
    "inline_recovery_policy": {
      "const": "INLINE_TYPED_RECOVERY_INSTEAD_OF_SILENT_REMOUNT"
    },
    "action_meaning_policy": {
      "const": "DOMINANT_MEANING_STABLE_WITHOUT_TRUTH_CHANGE"
    },
    "native_return_policy": {
      "const": "SECONDARY_AND_RESTORED_SCENES_RETURN_TO_PARENT_ANCHOR"
    },
    "cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fuzzCase"
      },
      "minItems": 5,
      "uniqueItems": true
    }
  },
  "$defs": {
    "surfaceType": {
      "type": "string",
      "enum": [
        "LowNoiseExperienceFrame",
        "WorkspaceSnapshot",
        "ClientPortalWorkspace",
        "TenantGovernanceSnapshot",
        "NativeOperatorWorkspaceScene",
        "NativeOperatorSecondaryWindowScene"
      ]
    },
    "continuityScope": {
      "type": "string",
      "enum": [
        "MANIFEST_ROUTE",
        "WORKSPACE_ROUTE",
        "CLIENT_PORTAL_ROUTE",
        "GOVERNANCE_ROUTE",
        "NATIVE_PRIMARY_SCENE",
        "NATIVE_SECONDARY_WINDOW"
      ]
    },
    "shellFamily": {
      "type": "string",
      "enum": [
        "CALM_SHELL",
        "CLIENT_PORTAL_SHELL",
        "GOVERNANCE_DENSITY_SHELL"
      ]
    },
    "perturbation": {
      "type": "string",
      "enum": [
        "REBASE",
        "RECONNECT",
        "RESIZE_WIDE_TO_NARROW",
        "RESIZE_NARROW_TO_WIDE",
        "RESPONSIVE_COLLAPSE",
        "STREAM_CATCH_UP",
        "FRAME_EPOCH_ADVANCE",
        "NATIVE_SCENE_RESTORE",
        "SECONDARY_WINDOW_RESTORE"
      ]
    },
    "assertedInvariant": {
      "type": "string",
      "enum": [
        "SHELL_FAMILY",
        "ROUTE_IDENTITY",
        "OBJECT_ANCHOR",
        "DOMINANT_QUESTION",
        "SETTLEMENT_STATE",
        "ACTIVE_CONTEXT",
        "FOCUS_ANCHOR",
        "RETURN_FOCUS_ANCHOR",
        "DOMINANT_MEANING"
      ]
    },
    "stateSnapshot": {
      "type": "object",
      "required": [
        "route_identity_ref",
        "canonical_object_ref",
        "shell_family",
        "dominant_question",
        "dominant_meaning_ref_or_null",
        "settlement_state_or_null",
        "recovery_posture_or_null",
        "active_context_ref_or_null",
        "focus_anchor_ref_or_null",
        "return_focus_anchor_ref_or_null"
      ],
      "properties": {
        "route_identity_ref": {
          "type": "string",
          "minLength": 1
        },
        "canonical_object_ref": {
          "type": "string",
          "minLength": 1
        },
        "shell_family": {
          "$ref": "#/$defs/shellFamily"
        },
        "dominant_question": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "dominant_meaning_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "settlement_state_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "recovery_posture_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "active_context_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "focus_anchor_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "return_focus_anchor_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "fuzzCase": {
      "type": "object",
      "required": [
        "case_id",
        "surface_type",
        "continuity_scope",
        "shell_family",
        "truth_change_detected",
        "perturbations",
        "shrink_sequence",
        "expected_outcome",
        "expected_inline_recovery_reason_or_null",
        "asserted_invariants",
        "pre_state",
        "post_state"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "surface_type": {
          "$ref": "#/$defs/surfaceType"
        },
        "continuity_scope": {
          "$ref": "#/$defs/continuityScope"
        },
        "shell_family": {
          "$ref": "#/$defs/shellFamily"
        },
        "truth_change_detected": {
          "type": "boolean"
        },
        "perturbations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/perturbation"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "shrink_sequence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/perturbation"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "expected_outcome": {
          "type": "string",
          "enum": [
            "PRESERVED",
            "INLINE_RECOVERY"
          ]
        },
        "expected_inline_recovery_reason_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "asserted_invariants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/assertedInvariant"
          },
          "minItems": 7,
          "uniqueItems": true
        },
        "pre_state": {
          "$ref": "#/$defs/stateSnapshot"
        },
        "post_state": {
          "$ref": "#/$defs/stateSnapshot"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "expected_outcome": {
                "const": "PRESERVED"
              }
            },
            "required": [
              "expected_outcome"
            ]
          },
          "then": {
            "properties": {
              "expected_inline_recovery_reason_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "expected_outcome": {
                "const": "INLINE_RECOVERY"
              }
            },
            "required": [
              "expected_outcome"
            ]
          },
          "then": {
            "properties": {
              "expected_inline_recovery_reason_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
