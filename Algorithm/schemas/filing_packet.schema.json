{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/filing_packet.schema.json",
  "title": "FilingPacket",
  "description": "Authoritative filing-packet contract. This schema freezes packet bytes, calculation lineage, packet-local approval and declaration acknowledgement posture, notice resolution, and filing-gate promotion state so submission legality is carried by the packet itself.",
  "type": "object",
  "required": [
    "artifact_type",
    "packet_id",
    "manifest_id",
    "execution_mode_boundary_contract",
    "lifecycle_state",
    "state_transition_contract",
    "payload_ref",
    "payload_hash",
    "manifest_binding_hash",
    "declared_basis",
    "disclaimers",
    "calculation_basis_ref",
    "authority_calculation_ref",
    "readiness_context_ref",
    "user_confirmation_ref",
    "controlling_proof_bundle_ref",
    "proof_closure_state",
    "approval_state",
    "declared_basis_ack_state",
    "notice_step_refs",
    "notice_resolution_ref",
    "filing_gate_ref",
    "created_at",
    "approved_at",
    "submitted_at",
    "voided_at",
    "superseded_at",
    "state_changed_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "FilingPacket"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode_boundary_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/execution_mode_boundary_contract.schema.json"
        },
        {
          "properties": {
            "execution_posture": {
              "const": "LIVE_COMPLIANCE"
            },
            "legal_effect_boundary": {
              "const": "COMPLIANCE_CAPABLE"
            }
          }
        }
      ]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "DRAFT",
        "PREPARED",
        "APPROVED_TO_SUBMIT",
        "SUBMITTED",
        "VOID",
        "SUPERSEDED"
      ]
    },
    "state_transition_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/state_transition_contract.schema.json"
        },
        {
          "properties": {
            "object_family": {
              "const": "FILING_PACKET"
            },
            "machine_code": {
              "const": "FILING_PACKET_LIFECYCLE_V1"
            },
            "state_field_name": {
              "const": "lifecycle_state"
            }
          }
        }
      ]
    },
    "payload_ref": {
      "type": "string",
      "minLength": 1
    },
    "payload_hash": {
      "type": "string",
      "minLength": 1
    },
    "manifest_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "declared_basis": {
      "type": "string",
      "minLength": 1
    },
    "disclaimers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "maxItems": 12,
      "uniqueItems": true
    },
    "calculation_basis_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "authority_calculation_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "readiness_context_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "user_confirmation_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "controlling_proof_bundle_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "proof_closure_state": {
      "type": "string",
      "enum": [
        "NOT_APPLICABLE",
        "OPEN",
        "CLOSED"
      ]
    },
    "approval_state": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "NOT_REQUIRED",
        "SATISFIED",
        "REQUIRED_PENDING",
        "UNSATISFIABLE",
        "DENIED",
        null
      ]
    },
    "declared_basis_ack_state": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "NOT_APPLICABLE",
        "NOT_REQUIRED",
        "SATISFIED",
        "REQUIRED_PENDING",
        "UNSATISFIABLE",
        null
      ]
    },
    "notice_step_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "maxItems": 8,
      "uniqueItems": true
    },
    "notice_resolution_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "filing_gate_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "approved_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "submitted_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "voided_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "superseded_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "state_changed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "anyOf": [
          {
            "properties": {
              "calculation_basis_ref": {
                "type": "string"
              }
            },
            "required": [
              "calculation_basis_ref"
            ]
          },
          {
            "properties": {
              "authority_calculation_ref": {
                "type": "string"
              }
            },
            "required": [
              "authority_calculation_ref"
            ]
          },
          {
            "properties": {
              "user_confirmation_ref": {
                "type": "string"
              }
            },
            "required": [
              "user_confirmation_ref"
            ]
          }
        ]
      },
      "then": {
        "properties": {
          "readiness_context_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "controlling_proof_bundle_ref": {
            "type": "null"
          }
        },
        "required": [
          "controlling_proof_bundle_ref"
        ]
      },
      "then": {
        "properties": {
          "proof_closure_state": {
            "const": "NOT_APPLICABLE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "proof_closure_state": {
            "enum": [
              "OPEN",
              "CLOSED"
            ]
          }
        },
        "required": [
          "proof_closure_state"
        ]
      },
      "then": {
        "properties": {
          "controlling_proof_bundle_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "notice_resolution_ref": {
            "type": "string"
          }
        },
        "required": [
          "notice_resolution_ref"
        ]
      },
      "then": {
        "properties": {
          "notice_step_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "notice_step_refs": {
            "maxItems": 0
          }
        },
        "required": [
          "notice_step_refs"
        ]
      },
      "then": {
        "properties": {
          "notice_resolution_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "approval_state": {
            "type": "null"
          }
        },
        "required": [
          "approval_state"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "const": "DRAFT"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "declared_basis_ack_state": {
            "type": "null"
          }
        },
        "required": [
          "declared_basis_ack_state"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "const": "DRAFT"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "DRAFT"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "approval_state": {
            "type": "null"
          },
          "declared_basis_ack_state": {
            "type": "null"
          },
          "notice_step_refs": {
            "maxItems": 0
          },
          "notice_resolution_ref": {
            "type": "null"
          },
          "filing_gate_ref": {
            "type": "null"
          },
          "approved_at": {
            "type": "null"
          },
          "submitted_at": {
            "type": "null"
          },
          "voided_at": {
            "type": "null"
          },
          "superseded_at": {
            "type": "null"
          },
          "controlling_proof_bundle_ref": {
            "type": "null"
          },
          "proof_closure_state": {
            "const": "NOT_APPLICABLE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "PREPARED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "approval_state": {
            "type": "string"
          },
          "declared_basis_ack_state": {
            "type": "string"
          },
          "approved_at": {
            "type": "null"
          },
          "submitted_at": {
            "type": "null"
          },
          "voided_at": {
            "type": "null"
          },
          "superseded_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "APPROVED_TO_SUBMIT"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "approval_state": {
            "enum": [
              "NOT_REQUIRED",
              "SATISFIED"
            ]
          },
          "declared_basis_ack_state": {
            "enum": [
              "NOT_REQUIRED",
              "SATISFIED"
            ]
          },
          "controlling_proof_bundle_ref": {
            "type": "string",
            "minLength": 1
          },
          "proof_closure_state": {
            "const": "CLOSED"
          },
          "filing_gate_ref": {
            "type": "string",
            "minLength": 1
          },
          "approved_at": {
            "type": "string",
            "format": "date-time"
          },
          "submitted_at": {
            "type": "null"
          },
          "voided_at": {
            "type": "null"
          },
          "superseded_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "allOf": [
          {
            "properties": {
              "lifecycle_state": {
                "enum": [
                  "APPROVED_TO_SUBMIT",
                  "SUBMITTED"
                ]
              }
            },
            "required": [
              "lifecycle_state"
            ]
          },
          {
            "properties": {
              "notice_step_refs": {
                "minItems": 1
              }
            },
            "required": [
              "notice_step_refs"
            ]
          }
        ]
      },
      "then": {
        "properties": {
          "notice_resolution_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "SUBMITTED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "approval_state": {
            "enum": [
              "NOT_REQUIRED",
              "SATISFIED"
            ]
          },
          "declared_basis_ack_state": {
            "enum": [
              "NOT_REQUIRED",
              "SATISFIED"
            ]
          },
          "controlling_proof_bundle_ref": {
            "type": "string",
            "minLength": 1
          },
          "proof_closure_state": {
            "const": "CLOSED"
          },
          "filing_gate_ref": {
            "type": "string",
            "minLength": 1
          },
          "approved_at": {
            "type": "string",
            "format": "date-time"
          },
          "submitted_at": {
            "type": "string",
            "format": "date-time"
          },
          "voided_at": {
            "type": "null"
          },
          "superseded_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "VOID"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "approved_at": {
            "type": "null"
          },
          "submitted_at": {
            "type": "null"
          },
          "voided_at": {
            "type": "string",
            "format": "date-time"
          },
          "superseded_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "SUPERSEDED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "approved_at": {
            "type": "null"
          },
          "submitted_at": {
            "type": "null"
          },
          "voided_at": {
            "type": "null"
          },
          "superseded_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
