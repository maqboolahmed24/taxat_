{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/normalization_context.schema.json",
  "title": "NormalizationContext",
  "type": "object",
  "required": [
    "normalization_context_id",
    "manifest_id",
    "artifact_type",
    "mapping_rules_ref",
    "evidence_rules_ref",
    "promotion_rules_ref",
    "normalization_rules_ref",
    "transformation_version_set",
    "normalization_context_hash",
    "produced_at",
    "contract"
  ],
  "properties": {
    "normalization_context_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "const": "NormalizationContext"
    },
    "mapping_rules_ref": {
      "type": "string",
      "minLength": 1
    },
    "evidence_rules_ref": {
      "type": "string",
      "minLength": 1
    },
    "promotion_rules_ref": {
      "type": "string",
      "minLength": 1
    },
    "normalization_rules_ref": {
      "type": "string",
      "minLength": 1
    },
    "transformation_version_set": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "normalization_context_hash": {
      "type": "string",
      "minLength": 1
    },
    "produced_at": {
      "type": "string",
      "format": "date-time"
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "additionalProperties": false
}
