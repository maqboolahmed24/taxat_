{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/role_template_matrix.schema.json",
  "title": "RoleTemplateMatrix",
  "description": "Governance role-template matrix read-side projection for the access route. This schema freezes the policy snapshot basis, role version hash, grouped matrix layout, selected-cell continuity, role-editor pending-change posture, and simulator linkage so inline refresh does not discard the selected role cell or stale-view basis.",
  "type": "object",
  "required": [
    "artifact_type",
    "tenant_id",
    "shell_family",
    "object_anchor_ref",
    "dominant_question",
    "settlement_state",
    "recovery_posture",
    "interaction_layer",
    "cache_isolation_contract",
    "role_id",
    "role_label",
    "policy_snapshot_hash",
    "version_hash",
    "focus_anchor_ref",
    "role_matrix_workspace",
    "matrix_rows",
    "matrix_columns",
    "matrix_cells",
    "selected_action_detail",
    "captured_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "RoleTemplateMatrix"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "shell_family": {
      "const": "GOVERNANCE_DENSITY_SHELL"
    },
    "object_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "dominant_question": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "settlement_state": {
      "$ref": "#/$defs/settlementState"
    },
    "recovery_posture": {
      "$ref": "#/$defs/recoveryPosture"
    },
    "interaction_layer": {
      "$ref": "https://taxat.dev/schemas/governance_interaction_layer.schema.json"
    },
    "cache_isolation_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/cache_isolation_contract.schema.json"
        },
        {
          "properties": {
            "cache_scope_class": {
              "const": "ROLE_TEMPLATE_MATRIX"
            }
          }
        }
      ]
    },
    "role_id": {
      "type": "string",
      "minLength": 1
    },
    "role_label": {
      "type": "string",
      "minLength": 1
    },
    "policy_snapshot_hash": {
      "type": "string",
      "minLength": 1
    },
    "version_hash": {
      "type": "string",
      "minLength": 1
    },
    "focus_anchor_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "role_matrix_workspace": {
      "$ref": "#/$defs/roleMatrixWorkspace"
    },
    "matrix_rows": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/matrixRow"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "matrix_columns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/matrixColumn"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "matrix_cells": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/matrixCell"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "selected_action_detail": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/selectedActionDetail"
        }
      ]
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "settlementState": {
      "type": "string",
      "enum": [
        "STEADY",
        "RECEIPT_PENDING",
        "FRESHENING",
        "STALE_REVIEW_REQUIRED",
        "DEGRADED_READ_ONLY",
        "RECOVERY_REQUIRED"
      ]
    },
    "recoveryPosture": {
      "type": "string",
      "enum": [
        "NONE",
        "INLINE_RECONNECT",
        "INLINE_REBASE",
        "READ_ONLY_LIMITED",
        "OBJECT_SUPERSEDED",
        "ACCESS_REBIND_REQUIRED"
      ]
    },
    "interactionLayer": {
      "type": "object",
      "required": [
        "selected_filter_chip_refs",
        "compaction_mode",
        "auxiliary_surface_presentation",
        "focus_trap_mode",
        "selection_persistence_mode",
        "preserved_context_codes"
      ],
      "properties": {
        "selected_filter_chip_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "compaction_mode": {
          "type": "string",
          "enum": [
            "WIDE",
            "AUXILIARY_DRAWER",
            "AUXILIARY_TRAY",
            "FOCUS_STACK"
          ]
        },
        "auxiliary_surface_presentation": {
          "type": "string",
          "enum": [
            "SIDECAR",
            "DRAWER",
            "INSPECTOR",
            "TRAY"
          ]
        },
        "focus_trap_mode": {
          "type": "string",
          "enum": [
            "NON_MODAL",
            "MODAL_EXPLICIT"
          ]
        },
        "selection_persistence_mode": {
          "const": "PRESERVE_WHILE_OBJECT_RESOLVES"
        },
        "preserved_context_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "ACTIVE_FILTERS",
              "ACTIVE_SECTION",
              "SELECTION",
              "FOCUS_ANCHOR",
              "PROMOTED_SUPPORT_SURFACE",
              "STAGED_DIFF",
              "CHANGE_BASKET",
              "GUIDED_HANDSHAKE_STEP",
              "QUERY_SLICE"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "matrixDecision": {
      "type": "string",
      "enum": [
        "ALLOW",
        "ALLOW_MASKED",
        "REQUIRE_STEP_UP",
        "REQUIRE_APPROVAL",
        "DENY"
      ]
    },
    "activeFilters": {
      "type": "object",
      "required": [
        "resource_classes",
        "action_families",
        "decision_outcomes"
      ],
      "properties": {
        "resource_classes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "action_families": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "decision_outcomes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/matrixDecision"
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "roleMatrixWorkspace": {
      "type": "object",
      "required": [
        "surface_order",
        "active_filters",
        "selected_role_template_ref",
        "selected_cell_ref",
        "grid_navigation_model",
        "inspector_state",
        "promoted_support_surface",
        "latest_simulation_ref",
        "role_editor_pending_change_refs"
      ],
      "properties": {
        "surface_order": {
          "const": [
            "PRINCIPAL_DIRECTORY",
            "WORKSPACE_CANVAS",
            "ACCESS_INSPECTOR",
            "AUTHORITY_CHAIN_PANEL",
            "POLICY_SIMULATOR"
          ]
        },
        "active_filters": {
          "$ref": "#/$defs/activeFilters"
        },
        "selected_role_template_ref": {
          "type": "string",
          "minLength": 1
        },
        "selected_cell_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "grid_navigation_model": {
          "const": "ROW_COLUMN_ROVING_TABINDEX"
        },
        "inspector_state": {
          "type": "string",
          "enum": [
            "HIDDEN",
            "CELL_SELECTED",
            "ROLE_EDITING"
          ]
        },
        "promoted_support_surface": {
          "type": "string",
          "enum": [
            "AUDIT_SIDECAR",
            "POLICY_SIMULATOR"
          ]
        },
        "latest_simulation_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "role_editor_pending_change_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "matrixRow": {
      "type": "object",
      "required": [
        "resource_class",
        "row_label",
        "cell_refs"
      ],
      "properties": {
        "resource_class": {
          "type": "string",
          "minLength": 1
        },
        "row_label": {
          "type": "string",
          "minLength": 1
        },
        "cell_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "matrixColumn": {
      "type": "object",
      "required": [
        "action_family",
        "column_label"
      ],
      "properties": {
        "action_family": {
          "type": "string",
          "minLength": 1
        },
        "column_label": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "cellDetailCore": {
      "type": "object",
      "required": [
        "cell_ref",
        "resource_class",
        "action_family",
        "decision",
        "reason_codes",
        "effective_scope",
        "masking_rules",
        "required_approvals",
        "required_authn_level",
        "policy_path_ref",
        "pending_change_ref_or_null"
      ],
      "properties": {
        "cell_ref": {
          "type": "string",
          "minLength": 1
        },
        "resource_class": {
          "type": "string",
          "minLength": 1
        },
        "action_family": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "$ref": "#/$defs/matrixDecision"
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "effective_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "masking_rules": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "required_approvals": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "required_authn_level": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "BASIC",
            "MFA",
            "STEP_UP",
            null
          ]
        },
        "policy_path_ref": {
          "type": "string",
          "minLength": 1
        },
        "pending_change_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "decision": {
                "const": "DENY"
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "effective_scope": {
                "maxItems": 0
              },
              "masking_rules": {
                "maxItems": 0
              },
              "required_approvals": {
                "maxItems": 0
              },
              "required_authn_level": {
                "const": null
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "not": {
                  "const": "DENY"
                }
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "effective_scope": {
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "const": "ALLOW_MASKED"
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "masking_rules": {
                "minItems": 1
              },
              "required_approvals": {
                "maxItems": 0
              },
              "required_authn_level": {
                "const": null
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "enum": [
                  "ALLOW",
                  "REQUIRE_STEP_UP",
                  "REQUIRE_APPROVAL"
                ]
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "masking_rules": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "const": "REQUIRE_APPROVAL"
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "required_approvals": {
                "minItems": 1
              },
              "required_authn_level": {
                "const": null
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "enum": [
                  "ALLOW",
                  "ALLOW_MASKED",
                  "DENY"
                ]
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "required_approvals": {
                "maxItems": 0
              },
              "required_authn_level": {
                "const": null
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "const": "REQUIRE_STEP_UP"
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "required_authn_level": {
                "enum": [
                  "MFA",
                  "STEP_UP"
                ]
              },
              "required_approvals": {
                "maxItems": 0
              }
            }
          }
        }
      ]
    },
    "matrixCell": {
      "$ref": "#/$defs/cellDetailCore"
    },
    "selectedActionDetail": {
      "allOf": [
        {
          "$ref": "#/$defs/cellDetailCore"
        },
        {
          "type": "object",
          "required": [
            "panel_mode"
          ],
          "properties": {
            "panel_mode": {
              "const": "ACCESS_INSPECTOR"
            }
          }
        }
      ]
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "settlement_state": {
            "const": "RECOVERY_REQUIRED"
          }
        },
        "required": [
          "settlement_state"
        ]
      },
      "then": {
        "properties": {
          "recovery_posture": {
            "not": {
              "const": "NONE"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "role_matrix_workspace": {
            "properties": {
              "selected_cell_ref": {
                "type": "string"
              }
            },
            "required": [
              "selected_cell_ref"
            ]
          }
        },
        "required": [
          "role_matrix_workspace"
        ]
      },
      "then": {
        "properties": {
          "focus_anchor_ref": {
            "type": "string",
            "minLength": 1
          },
          "selected_action_detail": {
            "type": "object"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "role_matrix_workspace": {
            "properties": {
              "inspector_state": {
                "const": "HIDDEN"
              }
            },
            "required": [
              "inspector_state"
            ]
          }
        },
        "required": [
          "role_matrix_workspace"
        ]
      },
      "then": {
        "properties": {
          "focus_anchor_ref": {
            "type": "null"
          },
          "selected_action_detail": {
            "type": "null"
          },
          "role_matrix_workspace": {
            "properties": {
              "selected_cell_ref": {
                "type": "null"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "role_matrix_workspace": {
            "properties": {
              "latest_simulation_ref": {
                "type": "string"
              }
            },
            "required": [
              "latest_simulation_ref"
            ]
          }
        },
        "required": [
          "role_matrix_workspace"
        ]
      },
      "then": {
        "properties": {
          "role_matrix_workspace": {
            "properties": {
              "promoted_support_surface": {
                "const": "POLICY_SIMULATOR"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "role_matrix_workspace": {
            "properties": {
              "role_editor_pending_change_refs": {
                "minItems": 1
              }
            },
            "required": [
              "role_editor_pending_change_refs"
            ]
          }
        },
        "required": [
          "role_matrix_workspace"
        ]
      },
      "then": {
        "properties": {
          "role_matrix_workspace": {
            "properties": {
              "inspector_state": {
                "const": "ROLE_EDITING"
              }
            }
          }
        }
      }
    }
  ]
}
