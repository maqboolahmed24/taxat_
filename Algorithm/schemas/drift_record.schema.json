{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/drift_record.schema.json",
  "title": "DriftRecord",
  "description": "Post-baseline drift-classification contract. This schema freezes exact-scope baseline selection, delta planes, retroactive impact, supersession posture, and amendment or review semantics for one manifest comparison.",
  "type": "object",
  "required": [
    "artifact_type",
    "drift_id",
    "manifest_id",
    "baseline_ref",
    "baseline_envelope_ref",
    "baseline_manifest_id",
    "comparison_manifest_id",
    "baseline_type",
    "baseline_scope_refs",
    "drift_scope_refs",
    "active_exact_scope_key",
    "baseline_basis_ref",
    "authority_basis_refs",
    "drift_scope",
    "difference_classes",
    "field_deltas",
    "money_profile",
    "plane_pressures",
    "tax_delta_abs",
    "tax_delta_rel",
    "drift_pressure",
    "amendment_pressure",
    "critical_field_delta_count",
    "cause_codes",
    "materiality_profile_ref",
    "materiality_class",
    "lifecycle_state",
    "amendment_recommendation",
    "amendment_eligibility_contract",
    "amendment_window_context_ref",
    "retroactive_impact_ref",
    "late_data_indicator_refs",
    "source_contradiction_state",
    "review_state",
    "escalation_state",
    "recommendation_cap",
    "automation_cap",
    "lineage_boundary_refs",
    "basis_limitations",
    "supersedes_drift_id",
    "superseded_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "DriftRecord"
    },
    "drift_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "baseline_ref": {
      "type": "string",
      "minLength": 1
    },
    "baseline_envelope_ref": {
      "type": "string",
      "minLength": 1
    },
    "baseline_manifest_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "comparison_manifest_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "baseline_type": {
      "type": "string",
      "enum": [
        "WORKING",
        "FILED",
        "AMENDED",
        "AUTHORITY_CORRECTED",
        "OUT_OF_BAND"
      ]
    },
    "baseline_scope_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "drift_scope_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "active_exact_scope_key": {
      "type": "string",
      "minLength": 1
    },
    "baseline_basis_ref": {
      "type": "string",
      "minLength": 1
    },
    "authority_basis_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "drift_scope": {
      "type": "string",
      "enum": [
        "RECORD_LAYER",
        "ADJUSTMENT_LAYER",
        "AUTHORITY_LAYER",
        "DECLARATION_LAYER",
        "EXPLANATION_LAYER",
        "RETENTION_LIMITED_LAYER"
      ]
    },
    "difference_classes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "FACT_STATE",
          "TOTAL_STATE",
          "FILING_STATE",
          "AUTHORITY_STATE",
          "EXPLANATION_STATE"
        ]
      },
      "default": [],
      "uniqueItems": true
    },
    "field_deltas": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fieldDelta"
      },
      "default": [],
      "uniqueItems": true
    },
    "money_profile": {
      "$ref": "./schema_bundle.schema.json#/$defs/moneyProfile"
    },
    "plane_pressures": {
      "$ref": "#/$defs/planePressures"
    },
    "tax_delta_abs": {
      "$ref": "./schema_bundle.schema.json#/$defs/moneyValue"
    },
    "tax_delta_rel": {
      "type": "number",
      "minimum": 0
    },
    "drift_pressure": {
      "type": "number",
      "minimum": 0
    },
    "amendment_pressure": {
      "type": "number",
      "minimum": 0
    },
    "critical_field_delta_count": {
      "type": "integer",
      "minimum": 0
    },
    "cause_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "LATE_SOURCE_ARRIVAL",
          "SOURCE_CORRECTION",
          "CATEGORY_RECLASSIFICATION",
          "PARTITION_REALLOCATION",
          "RULE_OR_CONFIG_DIFFERENCE",
          "AUTHORITY_REFERENCE_CHANGE",
          "AUTHORITY_CORRECTION",
          "OUT_OF_BAND_FILING_DISCOVERED",
          "OVERRIDE_CHANGE",
          "RETENTION_LIMITED_HISTORY",
          "PREVIOUS_EXTRACTION_ERROR",
          "CALCULATION_PATH_CHANGE"
        ]
      },
      "default": [],
      "uniqueItems": true
    },
    "materiality_profile_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "materiality_class": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "NO_CHANGE",
        "EXPLANATION_ONLY",
        "BENIGN_DRIFT",
        "MATERIAL_REVIEW",
        "AMENDMENT_REQUIRED",
        null
      ]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "NOT_ASSESSED",
        "NO_CHANGE",
        "EXPLANATION_ONLY",
        "BENIGN_DRIFT",
        "MATERIAL_REVIEW",
        "REVIEW_REQUIRED",
        "AMENDMENT_REQUIRED",
        "RESOLVED",
        "SUPERSEDED"
      ]
    },
    "amendment_recommendation": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "NO_ACTION",
        "EXPLAIN_ONLY",
        "REVIEW_ONLY",
        "RECONCILE_FIRST",
        "PREPARE_AMENDMENT",
        "SUBMIT_AMENDMENT",
        null
      ]
    },
    "amendment_eligibility_contract": {
      "$ref": "https://taxat.dev/schemas/amendment_eligibility_contract.schema.json"
    },
    "amendment_window_context_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "retroactive_impact_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "late_data_indicator_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "source_contradiction_state": {
      "type": "string",
      "enum": [
        "NONE",
        "CONTRADICTORY_EVIDENCE",
        "CONTRADICTORY_AUTHORITY",
        "CONTRADICTORY_SCOPE"
      ]
    },
    "review_state": {
      "type": "string",
      "enum": [
        "NONE",
        "REVIEW_OPEN",
        "REVIEW_RESOLVED"
      ]
    },
    "escalation_state": {
      "type": "string",
      "enum": [
        "NONE",
        "OPERATOR_REVIEW",
        "COMPLIANCE_ESCALATION",
        "AUTHORITY_RECONCILIATION"
      ]
    },
    "recommendation_cap": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "automation_cap": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "lineage_boundary_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "basis_limitations": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "supersedes_drift_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "superseded_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "$defs": {
    "fieldDelta": {
      "type": "object",
      "required": [
        "field_code",
        "field_delta_abs",
        "field_delta_rel",
        "critical"
      ],
      "properties": {
        "field_code": {
          "type": "string",
          "minLength": 1
        },
        "field_delta_abs": {
          "$ref": "./schema_bundle.schema.json#/$defs/moneyValue"
        },
        "field_delta_rel": {
          "type": "number",
          "minimum": 0
        },
        "critical": {
          "type": "boolean"
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "planePressures": {
      "type": "object",
      "required": [
        "fact",
        "total",
        "filing",
        "authority",
        "explanation"
      ],
      "properties": {
        "fact": {
          "type": "number",
          "minimum": 0
        },
        "total": {
          "type": "number",
          "minimum": 0
        },
        "filing": {
          "type": "number",
          "minimum": 0
        },
        "authority": {
          "type": "number",
          "minimum": 0
        },
        "explanation": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "NOT_ASSESSED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "field_deltas": {
            "maxItems": 0
          },
          "tax_delta_abs": {
            "const": 0
          },
          "tax_delta_rel": {
            "const": 0
          },
          "drift_pressure": {
            "const": 0
          },
          "amendment_pressure": {
            "const": 0
          },
          "critical_field_delta_count": {
            "const": 0
          },
          "cause_codes": {
            "maxItems": 0
          },
          "materiality_profile_ref": {
            "type": "null"
          },
          "materiality_class": {
            "type": "null"
          },
          "amendment_recommendation": {
            "type": "null"
          },
          "amendment_window_context_ref": {
            "type": "null"
          },
          "difference_classes": {
            "maxItems": 0
          },
          "retroactive_impact_ref": {
            "type": "null"
          },
          "supersedes_drift_id": {
            "type": "null"
          },
          "superseded_at": {
            "type": "null"
          },
          "plane_pressures": {
            "type": "object",
            "properties": {
              "fact": {
                "const": 0
              },
              "total": {
                "const": 0
              },
              "filing": {
                "const": 0
              },
              "authority": {
                "const": 0
              },
              "explanation": {
                "const": 0
              }
            },
            "required": [
              "fact",
              "total",
              "filing",
              "authority",
              "explanation"
            ]
          },
          "tax_delta_abs": {
            "pattern": "^0+(\\.0+)?$"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "NO_CHANGE"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "materiality_class": {
            "const": "NO_CHANGE"
          },
          "amendment_recommendation": {
            "const": "NO_ACTION"
          },
          "tax_delta_abs": {
            "const": 0
          },
          "tax_delta_rel": {
            "const": 0
          },
          "critical_field_delta_count": {
            "const": 0
          },
          "field_deltas": {
            "maxItems": 0
          },
          "difference_classes": {
            "maxItems": 0
          },
          "plane_pressures": {
            "type": "object",
            "properties": {
              "fact": {
                "const": 0
              },
              "total": {
                "const": 0
              },
              "filing": {
                "const": 0
              },
              "authority": {
                "const": 0
              },
              "explanation": {
                "const": 0
              }
            },
            "required": [
              "fact",
              "total",
              "filing",
              "authority",
              "explanation"
            ]
          },
          "tax_delta_abs": {
            "pattern": "^0+(\\.0+)?$"
          },
          "retroactive_impact_ref": {
            "type": "null"
          },
          "supersedes_drift_id": {
            "type": "null"
          },
          "superseded_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "EXPLANATION_ONLY"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "materiality_class": {
            "const": "EXPLANATION_ONLY"
          },
          "amendment_recommendation": {
            "const": "EXPLAIN_ONLY"
          },
          "difference_classes": {
            "contains": {
              "const": "EXPLANATION_STATE"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "BENIGN_DRIFT"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "materiality_class": {
            "const": "BENIGN_DRIFT"
          },
          "amendment_recommendation": {
            "enum": [
              "REVIEW_ONLY",
              "RECONCILE_FIRST"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "MATERIAL_REVIEW"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "materiality_class": {
            "const": "MATERIAL_REVIEW"
          },
          "amendment_recommendation": {
            "enum": [
              "REVIEW_ONLY",
              "RECONCILE_FIRST"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "REVIEW_REQUIRED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "materiality_class": {
            "const": "MATERIAL_REVIEW"
          },
          "amendment_recommendation": {
            "enum": [
              "REVIEW_ONLY",
              "RECONCILE_FIRST"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "REVIEW_REQUIRED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "review_state": {
            "const": "REVIEW_OPEN"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "AMENDMENT_REQUIRED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "materiality_class": {
            "const": "AMENDMENT_REQUIRED"
          },
          "amendment_recommendation": {
            "enum": [
              "PREPARE_AMENDMENT",
              "SUBMIT_AMENDMENT",
              "RECONCILE_FIRST"
            ]
          },
          "amendment_window_context_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "RESOLVED",
              "SUPERSEDED"
            ]
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "review_state": {
            "enum": [
              "NONE",
              "REVIEW_RESOLVED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "RESOLVED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "materiality_class": {
            "enum": [
              "EXPLANATION_ONLY",
              "BENIGN_DRIFT",
              "MATERIAL_REVIEW",
              "AMENDMENT_REQUIRED"
            ]
          },
          "amendment_recommendation": {
            "enum": [
              "EXPLAIN_ONLY",
              "REVIEW_ONLY",
              "RECONCILE_FIRST",
              "PREPARE_AMENDMENT",
              "SUBMIT_AMENDMENT"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "SUPERSEDED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "superseded_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "not": {
              "enum": [
                "NOT_ASSESSED",
                "NO_CHANGE"
              ]
            }
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "cause_codes": {
            "minItems": 1
          },
          "materiality_profile_ref": {
            "type": "string",
            "minLength": 1
          },
          "difference_classes": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
