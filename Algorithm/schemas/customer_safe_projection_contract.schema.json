{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/customer_safe_projection_contract.schema.json",
  "title": "CustomerSafeProjectionContract",
  "description": "Shared customer-safe projection boundary contract. This schema freezes the customer-safe trust boundary for portal routes, contextual collaboration detail, visibility-scoped collaboration activity and attachment reads, customer-visible workspace stream delivery, customer-visible notifications, and customer-facing document, approval, onboarding, and timeline payloads so staff-only workflow posture cannot leak through hidden fields, cache drift, cosmetic preview toggles, or same-object reopen flows. The masking_basis_hash-equivalent boundary is carried through the frozen masking posture fingerprint.",
  "type": "object",
  "required": [
    "contract_version",
    "boundary_scope",
    "projection_audience",
    "shell_family",
    "access_binding_hash",
    "masking_posture_fingerprint",
    "visibility_cache_partition_key",
    "status_derivation_policy",
    "staff_field_dependency_policy",
    "plain_language_status_policy",
    "plain_language_action_policy",
    "limitation_notice_policy",
    "recovery_explanation_policy",
    "artifact_history_policy",
    "hidden_activity_policy",
    "module_projection_policy",
    "attachment_visibility_policy",
    "live_update_visibility_policy",
    "draft_placeholder_policy",
    "notification_navigation_policy",
    "export_visibility_policy",
    "blocked_staff_signal_classes"
  ],
  "properties": {
    "contract_version": {
      "const": "CUSTOMER_SAFE_PROJECTION_V1"
    },
    "boundary_scope": {
      "type": "string",
      "enum": [
        "CLIENT_PORTAL_WORKSPACE",
        "CUSTOMER_REQUEST_LIST",
        "COLLABORATION_ACTIVITY_SLICE",
        "COLLABORATION_ATTACHMENT_SLICE",
        "WORKSPACE_STREAM_EVENT",
        "CLIENT_DOCUMENT_REQUEST",
        "CLIENT_APPROVAL_PACK",
        "CLIENT_ONBOARDING_JOURNEY",
        "CLIENT_TIMELINE_EVENT",
        "WORKSPACE_CUSTOMER_REQUEST",
        "WORK_ITEM_NOTIFICATION"
      ]
    },
    "projection_audience": {
      "type": "string",
      "enum": [
        "CLIENT_PORTAL",
        "CUSTOMER_COLLABORATION"
      ]
    },
    "shell_family": {
      "const": "CLIENT_PORTAL_SHELL"
    },
    "access_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "masking_posture_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "visibility_cache_partition_key": {
      "type": "string",
      "minLength": 1
    },
    "status_derivation_policy": {
      "const": "CUSTOMER_SAFE_BLOCKS_ONLY"
    },
    "staff_field_dependency_policy": {
      "const": "EXCLUDE_STAFF_FIELDS_AT_PROJECTION_SOURCE"
    },
    "plain_language_status_policy": {
      "const": "CUSTOMER_SAFE_STATUS_VOCABULARY_ONLY"
    },
    "plain_language_action_policy": {
      "const": "CUSTOMER_SAFE_ACTION_VOCABULARY_ONLY"
    },
    "limitation_notice_policy": {
      "const": "EXPLICIT_CUSTOMER_SAFE_NOTICE_REQUIRED"
    },
    "recovery_explanation_policy": {
      "const": "EXPLICIT_CUSTOMER_SAFE_RECOVERY_NOTICE_REQUIRED"
    },
    "artifact_history_policy": {
      "const": "CURRENT_VERSUS_HISTORY_EXPLICIT"
    },
    "hidden_activity_policy": {
      "const": "NO_HIDDEN_ACTIVITY_DERIVATION"
    },
    "module_projection_policy": {
      "const": "CUSTOMER_SAFE_MODULES_AND_METADATA_ONLY"
    },
    "attachment_visibility_policy": {
      "const": "CUSTOMER_VISIBLE_ATTACHMENTS_ONLY"
    },
    "live_update_visibility_policy": {
      "const": "INTERNAL_ONLY_DELTA_EXCLUSION_REQUIRED"
    },
    "draft_placeholder_policy": {
      "const": "CUSTOMER_SAFE_PROJECTIONS_EXCLUDE_INTERNAL_DRAFTS"
    },
    "notification_navigation_policy": {
      "const": "PORTAL_SAME_SHELL_AND_VISIBILITY_ONLY"
    },
    "export_visibility_policy": {
      "const": "CUSTOMER_VISIBLE_EXPORTS_ONLY"
    },
    "blocked_staff_signal_classes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/blockedSignalClass"
      },
      "minItems": 10,
      "maxItems": 10,
      "uniqueItems": true
    }
  },
  "$defs": {
    "blockedSignalClass": {
      "type": "string",
      "enum": [
        "ASSIGNMENT_STATE",
        "ESCALATION_LOGIC",
        "RAW_GATE_STATE",
        "STAFF_REASON_CODES",
        "AUDIT_LINEAGE",
        "INTERNAL_ACTIVITY",
        "INTERNAL_ATTACHMENTS",
        "INTERNAL_PARTICIPANTS",
        "INTERNAL_COUNTS",
        "STAFF_ROUTE_CONTEXT"
      ]
    }
  },
  "additionalProperties": false
}
