{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/portal_language_contract.schema.json",
  "title": "PortalLanguageContract",
  "description": "Shared portal language and copy-budget contract. This schema freezes client-safe literal task language, the one-dominant-question and one-primary-action rule, the one-promoted-support-region subordination rule, role-filtered copy publication, explicit due-label grammar, current-primary-history-secondary wording, governed direct-text or text-ref serialization, the banned internal vocabulary families, and the first-view copy budgets that keep Home, Documents, Approvals, Onboarding, request-list, and contextual request-detail routes calm and trustworthy.",
  "type": "object",
  "required": [
    "contract_code",
    "plain_language_policy",
    "copy_serialization_policy",
    "dominance_policy",
    "support_subordination_policy",
    "role_filter_policy",
    "due_label_policy",
    "history_language_policy",
    "settlement_language_policy",
    "forbidden_term_families",
    "copy_budget"
  ],
  "properties": {
    "contract_code": {
      "const": "PORTAL_LANGUAGE_CONTRACT_V1"
    },
    "plain_language_policy": {
      "const": "CLIENT_SAFE_LITERAL_TASK_LANGUAGE"
    },
    "copy_serialization_policy": {
      "const": "DIRECT_TEXT_OR_GOVERNED_TEXT_REF_ONLY"
    },
    "dominance_policy": {
      "const": "ONE_DOMINANT_QUESTION_AND_ONE_PRIMARY_ACTION"
    },
    "support_subordination_policy": {
      "const": "ONE_PROMOTED_SUPPORT_REGION_SUBORDINATE_TO_TASK"
    },
    "role_filter_policy": {
      "const": "ROLE_FILTER_BEFORE_COPY_PUBLICATION"
    },
    "due_label_policy": {
      "const": "EXPLICIT_DUE_DATE_OR_NO_DEADLINE"
    },
    "history_language_policy": {
      "const": "CURRENT_PRIMARY_HISTORY_EXPLICIT"
    },
    "settlement_language_policy": {
      "const": "PENDING_AND_SETTLED_EXPLICIT"
    },
    "forbidden_term_families": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "GATE_LANGUAGE",
          "MANIFEST_LANGUAGE",
          "STALE_OR_REBASE_JARGON",
          "OVERRIDE_LANGUAGE",
          "AUDIT_LANGUAGE",
          "ESCALATION_LANGUAGE",
          "ASSIGNMENT_LANGUAGE",
          "STAFF_ROLE_LANGUAGE",
          "WORKFLOW_LANGUAGE",
          "INTERNAL_ONLY_LANGUAGE"
        ]
      },
      "minItems": 10,
      "maxItems": 10,
      "uniqueItems": true,
      "const": [
        "GATE_LANGUAGE",
        "MANIFEST_LANGUAGE",
        "STALE_OR_REBASE_JARGON",
        "OVERRIDE_LANGUAGE",
        "AUDIT_LANGUAGE",
        "ESCALATION_LANGUAGE",
        "ASSIGNMENT_LANGUAGE",
        "STAFF_ROLE_LANGUAGE",
        "WORKFLOW_LANGUAGE",
        "INTERNAL_ONLY_LANGUAGE"
      ]
    },
    "copy_budget": {
      "type": "object",
      "required": [
        "dominant_question_max_chars",
        "reassurance_line_max_chars",
        "status_headline_max_chars",
        "status_supporting_text_max_chars",
        "status_due_label_max_chars",
        "action_label_max_chars",
        "task_label_max_chars",
        "task_description_max_chars",
        "limitation_headline_max_chars",
        "limitation_detail_max_chars",
        "request_title_max_chars",
        "request_why_label_max_chars",
        "request_due_label_max_chars",
        "request_help_text_max_chars",
        "approval_title_max_chars",
        "approval_summary_max_chars",
        "approval_change_digest_max_chars",
        "approval_receipt_next_step_max_chars",
        "onboarding_step_label_max_chars",
        "help_headline_max_chars",
        "help_option_label_max_chars",
        "timeline_headline_max_chars",
        "timeline_detail_max_chars",
        "request_row_title_max_chars",
        "request_row_status_label_max_chars",
        "request_row_due_label_max_chars",
        "request_row_action_label_max_chars",
        "request_row_no_safe_action_max_chars",
        "request_detail_status_max_chars",
        "home_first_view_char_budget",
        "documents_first_view_char_budget",
        "approvals_first_view_char_budget",
        "onboarding_first_view_char_budget",
        "help_first_view_char_budget",
        "request_detail_first_view_char_budget"
      ],
      "properties": {
        "dominant_question_max_chars": {
          "const": 120
        },
        "reassurance_line_max_chars": {
          "const": 120
        },
        "status_headline_max_chars": {
          "const": 96
        },
        "status_supporting_text_max_chars": {
          "const": 180
        },
        "status_due_label_max_chars": {
          "const": 48
        },
        "action_label_max_chars": {
          "const": 36
        },
        "task_label_max_chars": {
          "const": 72
        },
        "task_description_max_chars": {
          "const": 180
        },
        "limitation_headline_max_chars": {
          "const": 120
        },
        "limitation_detail_max_chars": {
          "const": 180
        },
        "request_title_max_chars": {
          "const": 72
        },
        "request_why_label_max_chars": {
          "const": 120
        },
        "request_due_label_max_chars": {
          "const": 64
        },
        "request_help_text_max_chars": {
          "const": 180
        },
        "approval_title_max_chars": {
          "const": 72
        },
        "approval_summary_max_chars": {
          "const": 180
        },
        "approval_change_digest_max_chars": {
          "const": 180
        },
        "approval_receipt_next_step_max_chars": {
          "const": 96
        },
        "onboarding_step_label_max_chars": {
          "const": 64
        },
        "help_headline_max_chars": {
          "const": 96
        },
        "help_option_label_max_chars": {
          "const": 40
        },
        "timeline_headline_max_chars": {
          "const": 120
        },
        "timeline_detail_max_chars": {
          "const": 180
        },
        "request_row_title_max_chars": {
          "const": 72
        },
        "request_row_status_label_max_chars": {
          "const": 48
        },
        "request_row_due_label_max_chars": {
          "const": 64
        },
        "request_row_action_label_max_chars": {
          "const": 36
        },
        "request_row_no_safe_action_max_chars": {
          "const": 120
        },
        "request_detail_status_max_chars": {
          "const": 120
        },
        "home_first_view_char_budget": {
          "const": 520
        },
        "documents_first_view_char_budget": {
          "const": 560
        },
        "approvals_first_view_char_budget": {
          "const": 560
        },
        "onboarding_first_view_char_budget": {
          "const": 480
        },
        "help_first_view_char_budget": {
          "const": 420
        },
        "request_detail_first_view_char_budget": {
          "const": 460
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
