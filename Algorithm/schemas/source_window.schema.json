{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/source_window.schema.json",
  "title": "SourceWindow",
  "type": "object",
  "required": [
    "source_window_id",
    "manifest_id",
    "artifact_type",
    "collection_started_at",
    "collection_completed_at",
    "read_cutoff_at",
    "contract"
  ],
  "properties": {
    "source_window_id": {
      "type": "string"
    },
    "manifest_id": {
      "type": "string"
    },
    "artifact_type": {
      "const": "SourceWindow"
    },
    "collection_started_at": {
      "type": "string",
      "format": "date-time"
    },
    "collection_completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "read_cutoff_at": {
      "type": "string",
      "format": "date-time"
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "additionalProperties": false
}
