{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/amendment_case.schema.json",
  "title": "AmendmentCase",
  "description": "Exact-scope amendment-chain contract. This schema freezes lifecycle, baseline, retroactive impact, readiness freshness, and deterministic same-scope supersession for one amendment lineage head or historical case.",
  "type": "object",
  "required": [
    "artifact_type",
    "amendment_case_id",
    "filing_case_id",
    "client_id",
    "period",
    "current_manifest_ref",
    "execution_mode_boundary_contract",
    "scope_key",
    "lifecycle_state",
    "baseline_ref",
    "baseline_envelope_ref",
    "baseline_frozen_hash",
    "drift_ref",
    "retroactive_impact_ref",
    "retroactive_impact_hash",
    "current_bundle_ref",
    "supersedes_amendment_case_id",
    "active_chain_key",
    "intent_ref",
    "amendment_window_ref",
    "amendment_window_evaluation_hash",
    "authority_operation_profile_ref",
    "calculation_request_ref",
    "calculation_id",
    "calculation_type",
    "calculation_hash",
    "calculation_basis_ref",
    "user_confirmation_ref",
    "readiness_context_ref",
    "amendment_eligibility_contract",
    "freshness_state",
    "freshness_invalidation_reason_codes",
    "temporal_propagation_event_refs",
    "review_state",
    "escalation_state",
    "validation_outcome",
    "superseded_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "AmendmentCase"
    },
    "amendment_case_id": {
      "type": "string",
      "minLength": 1
    },
    "filing_case_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "period": {
      "type": "string",
      "minLength": 1
    },
    "current_manifest_ref": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode_boundary_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/execution_mode_boundary_contract.schema.json"
        },
        {
          "properties": {
            "execution_posture": {
              "const": "LIVE_COMPLIANCE"
            },
            "legal_effect_boundary": {
              "const": "COMPLIANCE_CAPABLE"
            }
          }
        }
      ]
    },
    "scope_key": {
      "type": "string",
      "minLength": 1
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "NOT_ELIGIBLE",
        "RECONCILE_REQUIRED",
        "ELIGIBLE",
        "INTENT_REQUIRED",
        "INTENT_SUBMITTED",
        "READY_TO_AMEND",
        "AMEND_SUBMITTED",
        "AMEND_PENDING",
        "AMEND_CONFIRMED",
        "AMEND_REJECTED",
        "WINDOW_CLOSED",
        "SUPERSEDED"
      ]
    },
    "baseline_ref": {
      "type": "string",
      "minLength": 1
    },
    "baseline_envelope_ref": {
      "type": "string",
      "minLength": 1
    },
    "baseline_frozen_hash": {
      "type": "string",
      "minLength": 1
    },
    "drift_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "retroactive_impact_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "retroactive_impact_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "current_bundle_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "supersedes_amendment_case_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "active_chain_key": {
      "type": "string",
      "minLength": 1
    },
    "intent_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "amendment_window_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "amendment_window_evaluation_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "authority_operation_profile_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "calculation_request_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "calculation_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "calculation_type": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "intent-to-amend",
        "confirm-amendment",
        null
      ]
    },
    "calculation_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "calculation_basis_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "user_confirmation_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "readiness_context_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "amendment_eligibility_contract": {
      "$ref": "https://taxat.dev/schemas/amendment_eligibility_contract.schema.json"
    },
    "freshness_state": {
      "type": "string",
      "enum": [
        "NOT_APPLICABLE",
        "FRESH",
        "STALE"
      ]
    },
    "freshness_invalidation_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "temporal_propagation_event_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "review_state": {
      "type": "string",
      "enum": [
        "NONE",
        "REVIEW_OPEN",
        "REVIEW_RESOLVED"
      ]
    },
    "escalation_state": {
      "type": "string",
      "enum": [
        "NONE",
        "OPERATOR_REVIEW",
        "COMPLIANCE_ESCALATION",
        "AUTHORITY_RECONCILIATION"
      ]
    },
    "validation_outcome": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "PASS",
        "PASS_WITH_NOTICE",
        "MANUAL_REVIEW",
        "OVERRIDABLE_BLOCK",
        "HARD_BLOCK",
        null
      ]
    },
    "superseded_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "INTENT_SUBMITTED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "calculation_request_ref": {
            "type": "string",
            "minLength": 1
          },
          "calculation_id": {
            "type": "string",
            "minLength": 1
          },
          "readiness_context_ref": {
            "type": "string",
            "minLength": 1
          },
          "authority_operation_profile_ref": {
            "type": "string",
            "minLength": 1
          },
          "calculation_type": {
            "const": "intent-to-amend"
          },
          "validation_outcome": {
            "type": "string",
            "enum": [
              "PASS",
              "PASS_WITH_NOTICE",
              "MANUAL_REVIEW",
              "OVERRIDABLE_BLOCK",
              "HARD_BLOCK"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "READY_TO_AMEND"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "calculation_request_ref": {
            "type": "string",
            "minLength": 1
          },
          "calculation_id": {
            "type": "string",
            "minLength": 1
          },
          "calculation_hash": {
            "type": "string",
            "minLength": 1
          },
          "calculation_basis_ref": {
            "type": "string",
            "minLength": 1
          },
          "retroactive_impact_ref": {
            "type": "string",
            "minLength": 1
          },
          "retroactive_impact_hash": {
            "type": "string",
            "minLength": 1
          },
          "user_confirmation_ref": {
            "type": "string",
            "minLength": 1
          },
          "readiness_context_ref": {
            "type": "string",
            "minLength": 1
          },
          "amendment_window_ref": {
            "type": "string",
            "minLength": 1
          },
          "amendment_window_evaluation_hash": {
            "type": "string",
            "minLength": 1
          },
          "authority_operation_profile_ref": {
            "type": "string",
            "minLength": 1
          },
          "calculation_type": {
            "const": "intent-to-amend"
          },
          "freshness_state": {
            "const": "FRESH"
          },
          "validation_outcome": {
            "enum": [
              "PASS",
              "PASS_WITH_NOTICE"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "retroactive_impact_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "retroactive_impact_ref"
        ]
      },
      "then": {
        "properties": {
          "retroactive_impact_hash": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "retroactive_impact_hash": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "retroactive_impact_hash"
        ]
      },
      "then": {
        "properties": {
          "retroactive_impact_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "amendment_window_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "amendment_window_ref"
        ]
      },
      "then": {
        "properties": {
          "amendment_window_evaluation_hash": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "amendment_window_evaluation_hash": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "amendment_window_evaluation_hash"
        ]
      },
      "then": {
        "properties": {
          "amendment_window_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "freshness_state": {
            "const": "STALE"
          }
        },
        "required": [
          "freshness_state"
        ]
      },
      "then": {
        "properties": {
          "freshness_invalidation_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "freshness_state": {
            "enum": [
              "NOT_APPLICABLE",
              "FRESH"
            ]
          }
        },
        "required": [
          "freshness_state"
        ]
      },
      "then": {
        "properties": {
          "freshness_invalidation_reason_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "freshness_invalidation_reason_codes": {
            "minItems": 1
          }
        },
        "required": [
          "freshness_invalidation_reason_codes"
        ]
      },
      "then": {
        "properties": {
          "freshness_state": {
            "const": "STALE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "AMEND_SUBMITTED",
              "AMEND_PENDING",
              "AMEND_CONFIRMED",
              "AMEND_REJECTED"
            ]
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "current_bundle_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "SUPERSEDED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "superseded_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "current_bundle_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "current_bundle_ref"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "READY_TO_AMEND",
              "AMEND_SUBMITTED",
              "AMEND_PENDING",
              "AMEND_CONFIRMED",
              "AMEND_REJECTED"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "superseded_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "superseded_at"
        ]
      },
      "then": {
        "properties": {
          "lifecycle_state": {
            "const": "SUPERSEDED"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
