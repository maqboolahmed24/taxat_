{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/experience_cursor.schema.json",
  "title": "ExperienceCursor",
  "description": "Reconnect-safe experience-stream cursor contract. This contract freezes resume-token binding, route and shell lineage, the current and replacement route-stability contracts, rebase semantics, and expiry/revocation behavior for manifest-scoped streams.",
  "type": "object",
  "required": [
    "artifact_type",
    "cursor_scope_class",
    "cursor_id",
    "tenant_id",
    "principal_ref",
    "principal_class",
    "manifest_id",
    "shell_route_key",
    "shell_stability_token",
    "session_ref",
    "session_binding_hash",
    "access_binding_hash",
    "frame_epoch",
    "last_ack_sequence",
    "last_published_sequence",
    "latest_snapshot_ref",
    "resume_token_hash",
    "stream_recovery_contract",
    "native_cache_hydration_contract",
    "truth_boundary_contract",
    "stability_contract",
    "replacement_stability_contract_or_null",
    "cursor_state",
    "masking_posture_hash",
    "schema_compatibility_ref",
    "replacement_snapshot_ref",
    "invalidation_reason_code",
    "invalidated_at",
    "last_seen_at",
    "expires_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "ExperienceCursor"
    },
    "cursor_scope_class": {
      "const": "MANIFEST_EXPERIENCE"
    },
    "cursor_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "principal_ref": {
      "type": "string",
      "minLength": 1
    },
    "principal_class": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "shell_route_key": {
      "type": "string",
      "minLength": 1
    },
    "shell_stability_token": {
      "type": "string",
      "minLength": 1
    },
    "session_ref": {
      "type": "string",
      "minLength": 1
    },
    "session_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "access_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "frame_epoch": {
      "type": "integer",
      "minimum": 0
    },
    "last_ack_sequence": {
      "type": "integer",
      "minimum": 0
    },
    "last_published_sequence": {
      "type": "integer",
      "minimum": 0
    },
    "latest_snapshot_ref": {
      "type": "string",
      "minLength": 1
    },
    "resume_token_hash": {
      "type": "string",
      "minLength": 1
    },
    "stream_recovery_contract": {
      "$ref": "https://taxat.dev/schemas/stream_recovery_contract.schema.json"
    },
    "native_cache_hydration_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/native_cache_hydration_contract.schema.json"
        },
        {
          "properties": {
            "hydration_scope_class": {
              "const": "EXPERIENCE_CURSOR"
            }
          }
        }
      ]
    },
    "truth_boundary_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/command_truth_boundary_contract.schema.json"
        },
        {
          "properties": {
            "artifact_role": {
              "const": "READ_SIDE_PROJECTION"
            },
            "authoritative_record_families": {
              "const": [
                "RUN_MANIFEST",
                "GATE_DECISION_RECORD",
                "WORKFLOW_ITEM",
                "AUTHORITY_INTERACTION_RECORD",
                "AUDIT_EVENT"
              ]
            },
            "observable_projection_families": {
              "const": []
            }
          }
        }
      ]
    },
    "stability_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/route_stability_contract.schema.json"
        },
        {
          "properties": {
            "route_scope_class": {
              "const": "MANIFEST_EXPERIENCE"
            },
            "guard_vector_components": {
              "properties": {
                "decision_bundle_hash_or_null": {
                  "type": "string",
                  "minLength": 1
                },
                "shell_stability_token_or_null": {
                  "type": "string",
                  "minLength": 1
                },
                "frame_epoch_or_null": {
                  "type": "integer",
                  "minimum": 0
                },
                "work_item_version_or_null": {
                  "type": "null"
                },
                "customer_thread_head_or_null": {
                  "type": "null"
                },
                "internal_thread_head_or_null": {
                  "type": "null"
                },
                "request_state_version_or_null": {
                  "type": "null"
                },
                "client_portal_workspace_version_or_null": {
                  "type": "null"
                },
                "view_guard_ref_or_null": {
                  "type": "null"
                }
              }
            },
            "last_published_sequence_or_null": {
              "type": "integer",
              "minimum": 0
            },
            "resume_capability": {
              "const": "STREAM_RESUMABLE"
            }
          }
        }
      ]
    },
    "replacement_stability_contract_or_null": {
      "anyOf": [
        {
          "allOf": [
            {
              "$ref": "https://taxat.dev/schemas/route_stability_contract.schema.json"
            },
            {
              "properties": {
                "route_scope_class": {
                  "const": "MANIFEST_EXPERIENCE"
                },
                "guard_vector_components": {
                  "properties": {
                    "decision_bundle_hash_or_null": {
                      "type": "string",
                      "minLength": 1
                    },
                    "shell_stability_token_or_null": {
                      "type": "string",
                      "minLength": 1
                    },
                    "frame_epoch_or_null": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "work_item_version_or_null": {
                      "type": "null"
                    },
                    "customer_thread_head_or_null": {
                      "type": "null"
                    },
                    "internal_thread_head_or_null": {
                      "type": "null"
                    },
                    "request_state_version_or_null": {
                      "type": "null"
                    },
                    "client_portal_workspace_version_or_null": {
                      "type": "null"
                    },
                    "view_guard_ref_or_null": {
                      "type": "null"
                    }
                  }
                },
                "last_published_sequence_or_null": {
                  "type": "integer",
                  "minimum": 0
                },
                "resume_capability": {
                  "const": "STREAM_RESUMABLE"
                }
              }
            }
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "cursor_state": {
      "type": "string",
      "enum": [
        "LIVE",
        "REBASED",
        "CLOSED",
        "REVOKED",
        "EXPIRED"
      ]
    },
    "masking_posture_hash": {
      "type": "string",
      "minLength": 1
    },
    "schema_compatibility_ref": {
      "type": "string",
      "minLength": 1
    },
    "replacement_snapshot_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "invalidation_reason_code": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "FRAME_EPOCH_ADVANCED",
        "HISTORY_COMPACTED",
        "SHELL_STABILITY_CHANGED",
        "SESSION_REVOKED",
        "SESSION_BINDING_CHANGED",
        "ACCESS_BINDING_CHANGED",
        "MASKING_POSTURE_CHANGED",
        "SCHEMA_INCOMPATIBLE",
        "TENANT_SWITCHED",
        "PRINCIPAL_CLASS_CHANGED",
        "CURSOR_TTL_ELAPSED",
        "CLIENT_CLOSED",
        null
      ]
    },
    "invalidated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "last_seen_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "replacement_snapshot_ref": {
            "type": "string"
          }
        },
        "required": [
          "replacement_snapshot_ref"
        ]
      },
      "then": {
        "properties": {
          "cursor_state": {
            "const": "REBASED"
          },
          "replacement_stability_contract_or_null": {
            "$ref": "https://taxat.dev/schemas/route_stability_contract.schema.json"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "replacement_snapshot_ref": {
            "type": "null"
          }
        },
        "required": [
          "replacement_snapshot_ref"
        ]
      },
      "then": {
        "properties": {
          "replacement_stability_contract_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "invalidation_reason_code": {
            "type": "null"
          }
        },
        "required": [
          "invalidation_reason_code"
        ]
      },
      "then": {
        "properties": {
          "cursor_state": {
            "const": "LIVE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "invalidation_reason_code": {
            "enum": [
              "FRAME_EPOCH_ADVANCED",
              "HISTORY_COMPACTED",
              "SHELL_STABILITY_CHANGED"
            ]
          }
        },
        "required": [
          "invalidation_reason_code"
        ]
      },
      "then": {
        "properties": {
          "cursor_state": {
            "const": "REBASED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "invalidation_reason_code": {
            "enum": [
              "SESSION_REVOKED",
              "SESSION_BINDING_CHANGED",
              "ACCESS_BINDING_CHANGED",
              "MASKING_POSTURE_CHANGED",
              "SCHEMA_INCOMPATIBLE",
              "TENANT_SWITCHED",
              "PRINCIPAL_CLASS_CHANGED"
            ]
          }
        },
        "required": [
          "invalidation_reason_code"
        ]
      },
      "then": {
        "properties": {
          "cursor_state": {
            "const": "REVOKED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "invalidation_reason_code": {
            "const": "CURSOR_TTL_ELAPSED"
          }
        },
        "required": [
          "invalidation_reason_code"
        ]
      },
      "then": {
        "properties": {
          "cursor_state": {
            "const": "EXPIRED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "invalidation_reason_code": {
            "const": "CLIENT_CLOSED"
          }
        },
        "required": [
          "invalidation_reason_code"
        ]
      },
      "then": {
        "properties": {
          "cursor_state": {
            "const": "CLOSED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cursor_state": {
            "const": "LIVE"
          }
        },
        "required": [
          "cursor_state"
        ]
      },
      "then": {
        "properties": {
          "replacement_snapshot_ref": {
            "type": "null"
          },
          "invalidation_reason_code": {
            "type": "null"
          },
          "invalidated_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cursor_state": {
            "const": "REBASED"
          }
        },
        "required": [
          "cursor_state"
        ]
      },
      "then": {
        "properties": {
          "replacement_snapshot_ref": {
            "type": "string",
            "minLength": 1
          },
          "invalidation_reason_code": {
            "type": "string",
            "enum": [
              "FRAME_EPOCH_ADVANCED",
              "HISTORY_COMPACTED",
              "SHELL_STABILITY_CHANGED"
            ]
          },
          "invalidated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cursor_state": {
            "const": "REVOKED"
          }
        },
        "required": [
          "cursor_state"
        ]
      },
      "then": {
        "properties": {
          "replacement_snapshot_ref": {
            "type": "null"
          },
          "invalidation_reason_code": {
            "type": "string",
            "enum": [
              "SESSION_REVOKED",
              "SESSION_BINDING_CHANGED",
              "ACCESS_BINDING_CHANGED",
              "MASKING_POSTURE_CHANGED",
              "SCHEMA_INCOMPATIBLE",
              "TENANT_SWITCHED",
              "PRINCIPAL_CLASS_CHANGED"
            ]
          },
          "invalidated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cursor_state": {
            "const": "EXPIRED"
          }
        },
        "required": [
          "cursor_state"
        ]
      },
      "then": {
        "properties": {
          "replacement_snapshot_ref": {
            "type": "null"
          },
          "invalidation_reason_code": {
            "const": "CURSOR_TTL_ELAPSED"
          },
          "invalidated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cursor_state": {
            "const": "CLOSED"
          }
        },
        "required": [
          "cursor_state"
        ]
      },
      "then": {
        "properties": {
          "replacement_snapshot_ref": {
            "type": "null"
          },
          "invalidation_reason_code": {
            "const": "CLIENT_CLOSED"
          },
          "invalidated_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
