{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/failure_resolution_contract.schema.json",
  "title": "FailureResolutionContract",
  "description": "Shared failure-to-remediation governance contract. This schema freezes the cross-object lifecycle law that every material failure must become a durable operational object with explicit ownership, one lawful next path, retry gating, accepted-risk controls, and evidence-backed closure.",
  "type": "object",
  "required": [
    "contract_version",
    "lifecycle_role",
    "role_specific_binding_policy",
    "material_failure_policy",
    "ownership_policy",
    "next_action_policy",
    "retry_policy",
    "closure_policy",
    "accepted_risk_policy",
    "linkage_policy"
  ],
  "properties": {
    "contract_version": {
      "const": "FAILURE_RESOLUTION_V1"
    },
    "lifecycle_role": {
      "type": "string",
      "enum": [
        "ERROR_RECORD",
        "REMEDIATION_TASK",
        "COMPENSATION_RECORD",
        "FAILURE_INVESTIGATION",
        "ACCEPTED_RISK_APPROVAL"
      ]
    },
    "role_specific_binding_policy": {
      "type": "string",
      "enum": [
        "ERROR_RETAINS_OWNER_NEXT_ACTION_AND_CHILD_LINKS",
        "TASK_CLOSURE_DECLARES_EFFECT_ON_ERROR",
        "COMPENSATION_RETAINS_OWNER_VERIFICATION_AND_CLOSURE",
        "INVESTIGATION_CLOSURE_RETAINS_OUTCOME_AND_EVIDENCE",
        "APPROVAL_RETAINS_SCOPE_EXPIRY_AND_AUTHORIZATION_BASIS"
      ]
    },
    "material_failure_policy": {
      "const": "NO_MATERIAL_FAILURE_WITHOUT_DURABLE_OBJECT"
    },
    "ownership_policy": {
      "const": "OWNER_TYPE_AND_REF_OR_EXPLICIT_SYSTEM_OWNER_REQUIRED"
    },
    "next_action_policy": {
      "const": "OPEN_FAILURES_REQUIRE_ONE_LAWFUL_NEXT_PATH"
    },
    "retry_policy": {
      "const": "RETRY_CLASS_BUDGET_AND_PRECONDITIONS_BIND_EXECUTION"
    },
    "closure_policy": {
      "const": "TERMINAL_OR_COMPLETED_STATES_REQUIRE_BASIS_EVIDENCE_AND_AUDIT"
    },
    "accepted_risk_policy": {
      "const": "ACCEPTED_RISK_REQUIRES_APPROVAL_EXPIRY_AND_BOUNDED_SCOPE"
    },
    "linkage_policy": {
      "const": "ERROR_TASK_COMPENSATION_INVESTIGATION_APPROVAL_LINKS_MUST_STAY_COHERENT"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "lifecycle_role": {
            "const": "ERROR_RECORD"
          }
        },
        "required": [
          "lifecycle_role"
        ]
      },
      "then": {
        "properties": {
          "role_specific_binding_policy": {
            "const": "ERROR_RETAINS_OWNER_NEXT_ACTION_AND_CHILD_LINKS"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_role": {
            "const": "REMEDIATION_TASK"
          }
        },
        "required": [
          "lifecycle_role"
        ]
      },
      "then": {
        "properties": {
          "role_specific_binding_policy": {
            "const": "TASK_CLOSURE_DECLARES_EFFECT_ON_ERROR"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_role": {
            "const": "COMPENSATION_RECORD"
          }
        },
        "required": [
          "lifecycle_role"
        ]
      },
      "then": {
        "properties": {
          "role_specific_binding_policy": {
            "const": "COMPENSATION_RETAINS_OWNER_VERIFICATION_AND_CLOSURE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_role": {
            "const": "FAILURE_INVESTIGATION"
          }
        },
        "required": [
          "lifecycle_role"
        ]
      },
      "then": {
        "properties": {
          "role_specific_binding_policy": {
            "const": "INVESTIGATION_CLOSURE_RETAINS_OUTCOME_AND_EVIDENCE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_role": {
            "const": "ACCEPTED_RISK_APPROVAL"
          }
        },
        "required": [
          "lifecycle_role"
        ]
      },
      "then": {
        "properties": {
          "role_specific_binding_policy": {
            "const": "APPROVAL_RETAINS_SCOPE_EXPIRY_AND_AUTHORIZATION_BASIS"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
