{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/provenance_partition_contract.schema.json",
  "title": "ProvenancePartitionContract",
  "description": "Shared provenance partition contract. This schema freezes the tenant, client, executable scope, and cross-manifest traversal posture that every durable provenance artifact must preserve so replay and enquiry never depend on ambient caller context.",
  "type": "object",
  "required": [
    "contract_version",
    "tenant_id",
    "client_id",
    "partition_scope_refs",
    "period_scope_ref_or_null",
    "cross_manifest_traversal_policy",
    "scope_widening_policy"
  ],
  "properties": {
    "contract_version": {
      "const": "PROVENANCE_PARTITION_V1"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "partition_scope_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "period_scope_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "cross_manifest_traversal_policy": {
      "const": "EXPLICIT_BOUNDARY_EDGES_ONLY"
    },
    "scope_widening_policy": {
      "const": "NO_TENANT_CLIENT_OR_SCOPE_WIDENING"
    }
  },
  "additionalProperties": false
}
