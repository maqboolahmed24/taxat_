{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/authority_operation.schema.json",
  "title": "AuthorityOperation",
  "description": "Sealed authority-operation intent contract. This schema freezes tenant/client scope, continuation lineage, provider target, executable scope, and obligation or basis context before an external authority exchange can occur.",
  "type": "object",
  "required": [
    "artifact_type",
    "operation_id",
    "tenant_id",
    "client_id",
    "manifest_id",
    "manifest_hash",
    "execution_basis_hash",
    "attempt_lineage_manifest_id",
    "operation_family",
    "authority_name",
    "authority_product_profile",
    "operation_profile_ref",
    "provider_environment",
    "provider_api_version",
    "authority_scope",
    "requested_scope",
    "runtime_scope",
    "scope_execution_binding",
    "access_binding_hash",
    "policy_snapshot_hash",
    "authority_binding_ref",
    "authority_link_ref",
    "delegation_grant_ref",
    "binding_lineage_ref",
    "token_binding_ref",
    "subject_ref",
    "acting_party_ref",
    "business_partitions",
    "period",
    "target_obligation_ref",
    "basis_type",
    "authority_layer_boundary",
    "contract"
  ],
  "properties": {
    "artifact_type": {
      "const": "AuthorityOperation"
    },
    "operation_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_hash": {
      "type": "string",
      "minLength": 1
    },
    "execution_basis_hash": {
      "type": "string",
      "minLength": 1
    },
    "attempt_lineage_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "operation_family": {
      "type": "string",
      "enum": [
        "AUTH_READ_REFERENCE",
        "AUTH_READ_OBLIGATIONS",
        "AUTH_READ_CALCULATION",
        "AUTH_CREATE_OR_AMEND_DATA",
        "AUTH_DELETE_DATA",
        "AUTH_TRIGGER_CALCULATION",
        "AUTH_SUBMIT_FINAL_DECLARATION",
        "AUTH_SUBMIT_PERIODIC_UPDATE",
        "AUTH_SUBMIT_POST_FINALISATION_AMENDMENT",
        "AUTH_RECONCILE_STATUS"
      ]
    },
    "authority_name": {
      "type": "string",
      "minLength": 1
    },
    "authority_product_profile": {
      "type": "string",
      "minLength": 1
    },
    "operation_profile_ref": {
      "type": "string",
      "minLength": 1
    },
    "provider_environment": {
      "type": "string",
      "minLength": 1
    },
    "provider_api_version": {
      "type": "string",
      "minLength": 1
    },
    "authority_scope": {
      "type": "string",
      "minLength": 1
    },
    "requested_scope": {
      "$ref": "#/$defs/scopeArray"
    },
    "runtime_scope": {
      "$ref": "#/$defs/scopeArray"
    },
    "scope_execution_binding": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/scope_execution_binding.schema.json"
        },
        {
          "type": "object",
          "properties": {
            "binding_scope_class": {
              "const": "AUTHORITY_OPERATION"
            }
          }
        }
      ]
    },
    "access_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "policy_snapshot_hash": {
      "type": "string",
      "minLength": 1
    },
    "authority_binding_ref": {
      "type": "string",
      "minLength": 1
    },
    "authority_link_ref": {
      "type": "string",
      "minLength": 1
    },
    "delegation_grant_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "binding_lineage_ref": {
      "type": "string",
      "minLength": 1
    },
    "token_binding_ref": {
      "type": "string",
      "minLength": 1
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "acting_party_ref": {
      "type": "string",
      "minLength": 1
    },
    "business_partitions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "period": {
      "type": "string",
      "minLength": 1
    },
    "target_obligation_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "basis_type": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "authority_layer_boundary": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/authority_layer_boundary_contract.schema.json"
        },
        {
          "type": "object",
          "properties": {
            "binding_scope_class": {
              "const": "AUTHORITY_OPERATION"
            },
            "integration_capability": {
              "const": "AUTHORITY_INTEGRATED"
            }
          }
        }
      ]
    },
    "contract": {
      "$ref": "./schema_bundle.schema.json#/$defs/artifactContract"
    }
  },
  "$defs": {
    "scopeArray": {
      "type": "array",
      "prefixItems": [
        {
          "enum": [
            "year_end",
            "quarterly_update",
            "estimate_only"
          ]
        }
      ],
      "items": {
        "type": "string",
        "enum": [
          "year_end",
          "quarterly_update",
          "estimate_only",
          "prepare_submission",
          "submit",
          "amendment_intent",
          "amendment_submit"
        ]
      },
      "contains": {
        "enum": [
          "year_end",
          "quarterly_update",
          "estimate_only"
        ]
      },
      "minContains": 1,
      "maxContains": 1,
      "minItems": 1,
      "uniqueItems": true,
      "allOf": [
        {
          "not": {
            "allOf": [
              {
                "contains": {
                  "const": "amendment_intent"
                }
              },
              {
                "contains": {
                  "const": "amendment_submit"
                }
              }
            ]
          }
        },
        {
          "not": {
            "allOf": [
              {
                "contains": {
                  "const": "estimate_only"
                }
              },
              {
                "contains": {
                  "enum": [
                    "prepare_submission",
                    "submit",
                    "amendment_intent",
                    "amendment_submit"
                  ]
                }
              }
            ]
          }
        },
        {
          "not": {
            "allOf": [
              {
                "contains": {
                  "const": "amendment_intent"
                }
              },
              {
                "contains": {
                  "enum": [
                    "prepare_submission",
                    "submit"
                  ]
                }
              }
            ]
          }
        },
        {
          "not": {
            "allOf": [
              {
                "contains": {
                  "const": "amendment_submit"
                }
              },
              {
                "contains": {
                  "enum": [
                    "prepare_submission",
                    "submit"
                  ]
                }
              }
            ]
          }
        },
        {
          "not": {
            "allOf": [
              {
                "contains": {
                  "const": "amendment_intent"
                }
              },
              {
                "not": {
                  "contains": {
                    "const": "year_end"
                  }
                }
              }
            ]
          }
        },
        {
          "not": {
            "allOf": [
              {
                "contains": {
                  "const": "amendment_submit"
                }
              },
              {
                "not": {
                  "contains": {
                    "const": "year_end"
                  }
                }
              }
            ]
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "runtime_scope": {
            "contains": {
              "const": "year_end"
            }
          }
        },
        "required": [
          "runtime_scope"
        ]
      },
      "then": {
        "properties": {
          "requested_scope": {
            "contains": {
              "const": "year_end"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "runtime_scope": {
            "contains": {
              "const": "quarterly_update"
            }
          }
        },
        "required": [
          "runtime_scope"
        ]
      },
      "then": {
        "properties": {
          "requested_scope": {
            "contains": {
              "const": "quarterly_update"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "runtime_scope": {
            "contains": {
              "const": "estimate_only"
            }
          }
        },
        "required": [
          "runtime_scope"
        ]
      },
      "then": {
        "properties": {
          "requested_scope": {
            "contains": {
              "const": "estimate_only"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "runtime_scope": {
            "contains": {
              "const": "prepare_submission"
            }
          }
        },
        "required": [
          "runtime_scope"
        ]
      },
      "then": {
        "properties": {
          "requested_scope": {
            "contains": {
              "const": "prepare_submission"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "runtime_scope": {
            "contains": {
              "const": "submit"
            }
          }
        },
        "required": [
          "runtime_scope"
        ]
      },
      "then": {
        "properties": {
          "requested_scope": {
            "contains": {
              "const": "submit"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "runtime_scope": {
            "contains": {
              "const": "amendment_intent"
            }
          }
        },
        "required": [
          "runtime_scope"
        ]
      },
      "then": {
        "properties": {
          "requested_scope": {
            "contains": {
              "const": "amendment_intent"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "runtime_scope": {
            "contains": {
              "const": "amendment_submit"
            }
          }
        },
        "required": [
          "runtime_scope"
        ]
      },
      "then": {
        "properties": {
          "requested_scope": {
            "contains": {
              "const": "amendment_submit"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation_family": {
            "enum": [
              "AUTH_CREATE_OR_AMEND_DATA",
              "AUTH_DELETE_DATA",
              "AUTH_TRIGGER_CALCULATION",
              "AUTH_SUBMIT_FINAL_DECLARATION",
              "AUTH_SUBMIT_PERIODIC_UPDATE",
              "AUTH_SUBMIT_POST_FINALISATION_AMENDMENT"
            ]
          }
        },
        "required": [
          "operation_family"
        ]
      },
      "then": {
        "properties": {
          "business_partitions": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation_family": {
            "enum": [
              "AUTH_READ_REFERENCE",
              "AUTH_READ_OBLIGATIONS",
              "AUTH_READ_CALCULATION",
              "AUTH_TRIGGER_CALCULATION",
              "AUTH_RECONCILE_STATUS"
            ]
          }
        },
        "required": [
          "operation_family"
        ]
      },
      "then": {
        "properties": {
          "runtime_scope": {
            "not": {
              "contains": {
                "enum": [
                  "submit",
                  "amendment_submit"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation_family": {
            "const": "AUTH_SUBMIT_PERIODIC_UPDATE"
          }
        },
        "required": [
          "operation_family"
        ]
      },
      "then": {
        "properties": {
          "runtime_scope": {
            "allOf": [
              {
                "contains": {
                  "const": "quarterly_update"
                }
              },
              {
                "contains": {
                  "const": "submit"
                }
              }
            ]
          },
          "target_obligation_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation_family": {
            "const": "AUTH_SUBMIT_FINAL_DECLARATION"
          }
        },
        "required": [
          "operation_family"
        ]
      },
      "then": {
        "properties": {
          "runtime_scope": {
            "allOf": [
              {
                "contains": {
                  "const": "year_end"
                }
              },
              {
                "contains": {
                  "const": "submit"
                }
              }
            ]
          },
          "basis_type": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation_family": {
            "const": "AUTH_SUBMIT_POST_FINALISATION_AMENDMENT"
          }
        },
        "required": [
          "operation_family"
        ]
      },
      "then": {
        "properties": {
          "runtime_scope": {
            "allOf": [
              {
                "contains": {
                  "const": "year_end"
                }
              },
              {
                "contains": {
                  "const": "amendment_submit"
                }
              }
            ]
          },
          "basis_type": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation_family": {
            "const": "AUTH_TRIGGER_CALCULATION"
          }
        },
        "required": [
          "operation_family"
        ]
      },
      "then": {
        "properties": {
          "runtime_scope": {
            "anyOf": [
              {
                "contains": {
                  "const": "prepare_submission"
                }
              },
              {
                "contains": {
                  "const": "amendment_intent"
                }
              }
            ]
          },
          "basis_type": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
