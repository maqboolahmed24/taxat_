{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/workspace_stream_event.schema.json",
  "title": "WorkspaceStreamEvent",
  "description": "Typed collaboration-workspace stream event contract. This schema freezes shell ownership, mounted object anchor, route-scoped ordering, visibility-bound session posture, one authoritative route-stability contract, and the one authoritative payload ref carried on each workspace stream event.",
  "type": "object",
  "required": [
    "artifact_type",
    "stream_scope_class",
    "item_id",
    "shell_family",
    "object_anchor_ref",
    "workspace_route_key",
    "session_visibility_class",
    "workspace_sequence",
    "frame_epoch",
    "workspace_version",
    "shell_stability_token",
    "access_binding_hash",
    "masking_posture_fingerprint",
    "resume_token",
    "stream_recovery_contract",
    "stability_contract",
    "visibility_partition",
    "customer_safe_projection",
    "event_type",
    "queue_projection_or_null",
    "snapshot_ref",
    "delta_ref",
    "activity_ref",
    "audit_ref",
    "notification_ref",
    "occurred_at"
  ],
  "properties": {
    "artifact_type": {
      "const": "WorkspaceStreamEvent"
    },
    "stream_scope_class": {
      "const": "WORKSPACE"
    },
    "item_id": {
      "type": "string",
      "minLength": 1
    },
    "shell_family": {
      "type": "string",
      "enum": [
        "CALM_SHELL",
        "CLIENT_PORTAL_SHELL"
      ]
    },
    "object_anchor_ref": {
      "type": "string",
      "minLength": 1
    },
    "workspace_route_key": {
      "type": "string",
      "minLength": 1
    },
    "session_visibility_class": {
      "type": "string",
      "enum": [
        "STAFF_FULL",
        "CUSTOMER_VISIBLE"
      ]
    },
    "workspace_sequence": {
      "type": "integer",
      "minimum": 0
    },
    "frame_epoch": {
      "type": "integer",
      "minimum": 0
    },
    "workspace_version": {
      "type": "integer",
      "minimum": 0
    },
    "shell_stability_token": {
      "type": "string",
      "minLength": 1
    },
    "access_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "masking_posture_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "resume_token": {
      "type": "string",
      "minLength": 1
    },
    "stream_recovery_contract": {
      "$ref": "https://taxat.dev/schemas/stream_recovery_contract.schema.json"
    },
    "stability_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/route_stability_contract.schema.json"
        },
        {
          "properties": {
            "route_scope_class": {
              "const": "WORKSPACE"
            },
            "guard_vector_components": {
              "properties": {
                "decision_bundle_hash_or_null": {
                  "type": "null"
                },
                "shell_stability_token_or_null": {
                  "type": "string",
                  "minLength": 1
                },
                "frame_epoch_or_null": {
                  "type": "integer",
                  "minimum": 0
                },
                "work_item_version_or_null": {
                  "type": "integer",
                  "minimum": 0
                },
                "customer_thread_head_or_null": {
                  "type": "integer",
                  "minimum": 0
                },
                "internal_thread_head_or_null": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 0
                },
                "request_state_version_or_null": {
                  "type": [
                    "integer",
                    "null"
                  ],
                  "minimum": 1
                },
                "client_portal_workspace_version_or_null": {
                  "type": "null"
                },
                "view_guard_ref_or_null": {
                  "type": "null"
                }
              }
            },
            "last_published_sequence_or_null": {
              "type": "integer",
              "minimum": 0
            },
            "resume_capability": {
              "const": "STREAM_RESUMABLE"
            }
          }
        }
      ]
    },
    "visibility_partition": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/visibility_partition_contract.schema.json"
        },
        {
          "properties": {
            "partition_scope": {
              "const": "WORKSPACE_STREAM_EVENT"
            }
          }
        }
      ]
    },
    "customer_safe_projection": {
      "anyOf": [
        {
          "allOf": [
            {
              "$ref": "https://taxat.dev/schemas/customer_safe_projection_contract.schema.json"
            },
            {
              "properties": {
                "boundary_scope": {
                  "const": "WORKSPACE_STREAM_EVENT"
                },
                "projection_audience": {
                  "const": "CUSTOMER_COLLABORATION"
                }
              }
            }
          ]
        },
        {
          "type": "null"
        }
      ]
    },
    "event_type": {
      "type": "string",
      "enum": [
        "workspace.delta",
        "workspace.snapshot",
        "activity.appended",
        "audit.appended",
        "notification.badge",
        "heartbeat"
      ]
    },
    "queue_projection_or_null": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "allOf": [
            {
              "$ref": "https://taxat.dev/schemas/collaboration_queue_projection_contract.schema.json"
            },
            {
              "properties": {
                "projection_scope": {
                  "const": "WORKSPACE_STREAM_EVENT"
                }
              }
            }
          ]
        }
      ]
    },
    "snapshot_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "delta_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "activity_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "audit_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "notification_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "session_visibility_class": {
            "const": "STAFF_FULL"
          }
        },
        "required": [
          "session_visibility_class"
        ]
      },
      "then": {
        "properties": {
          "shell_family": {
            "const": "CALM_SHELL"
          },
          "customer_safe_projection": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "session_visibility_class": {
            "const": "CUSTOMER_VISIBLE"
          }
        },
        "required": [
          "session_visibility_class"
        ]
      },
      "then": {
        "properties": {
          "shell_family": {
            "const": "CLIENT_PORTAL_SHELL"
          },
          "customer_safe_projection": {
            "type": "object"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "workspace.delta"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "queue_projection_or_null": {
            "allOf": [
              {
                "$ref": "https://taxat.dev/schemas/collaboration_queue_projection_contract.schema.json"
              },
              {
                "properties": {
                  "projection_scope": {
                    "const": "WORKSPACE_STREAM_EVENT"
                  }
                }
              }
            ]
          },
          "snapshot_ref": {
            "type": "null"
          },
          "delta_ref": {
            "type": "string",
            "minLength": 1
          },
          "activity_ref": {
            "type": "null"
          },
          "audit_ref": {
            "type": "null"
          },
          "notification_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "workspace.snapshot"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "queue_projection_or_null": {
            "type": "null"
          },
          "snapshot_ref": {
            "type": "string",
            "minLength": 1
          },
          "delta_ref": {
            "type": "null"
          },
          "activity_ref": {
            "type": "null"
          },
          "audit_ref": {
            "type": "null"
          },
          "notification_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "activity.appended"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "queue_projection_or_null": {
            "allOf": [
              {
                "$ref": "https://taxat.dev/schemas/collaboration_queue_projection_contract.schema.json"
              },
              {
                "properties": {
                  "projection_scope": {
                    "const": "WORKSPACE_STREAM_EVENT"
                  }
                }
              }
            ]
          },
          "snapshot_ref": {
            "type": "null"
          },
          "delta_ref": {
            "type": "null"
          },
          "activity_ref": {
            "type": "string",
            "minLength": 1
          },
          "audit_ref": {
            "type": "null"
          },
          "notification_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "audit.appended"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "queue_projection_or_null": {
            "type": "null"
          },
          "snapshot_ref": {
            "type": "null"
          },
          "delta_ref": {
            "type": "null"
          },
          "activity_ref": {
            "type": "null"
          },
          "audit_ref": {
            "type": "string",
            "minLength": 1
          },
          "notification_ref": {
            "type": "null"
          },
          "session_visibility_class": {
            "const": "STAFF_FULL"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "notification.badge"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "queue_projection_or_null": {
            "allOf": [
              {
                "$ref": "https://taxat.dev/schemas/collaboration_queue_projection_contract.schema.json"
              },
              {
                "properties": {
                  "projection_scope": {
                    "const": "WORKSPACE_STREAM_EVENT"
                  }
                }
              }
            ]
          },
          "snapshot_ref": {
            "type": "null"
          },
          "delta_ref": {
            "type": "null"
          },
          "activity_ref": {
            "type": "null"
          },
          "audit_ref": {
            "type": "null"
          },
          "notification_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "heartbeat"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "queue_projection_or_null": {
            "type": "null"
          },
          "snapshot_ref": {
            "type": "null"
          },
          "delta_ref": {
            "type": "null"
          },
          "activity_ref": {
            "type": "null"
          },
          "audit_ref": {
            "type": "null"
          },
          "notification_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "snapshot_ref": {
            "type": "string"
          }
        },
        "required": [
          "snapshot_ref"
        ]
      },
      "then": {
        "properties": {
          "event_type": {
            "const": "workspace.snapshot"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "delta_ref": {
            "type": "string"
          }
        },
        "required": [
          "delta_ref"
        ]
      },
      "then": {
        "properties": {
          "event_type": {
            "const": "workspace.delta"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "activity_ref": {
            "type": "string"
          }
        },
        "required": [
          "activity_ref"
        ]
      },
      "then": {
        "properties": {
          "event_type": {
            "const": "activity.appended"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "audit_ref": {
            "type": "string"
          }
        },
        "required": [
          "audit_ref"
        ]
      },
      "then": {
        "properties": {
          "event_type": {
            "const": "audit.appended"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "notification_ref": {
            "type": "string"
          }
        },
        "required": [
          "notification_ref"
        ]
      },
      "then": {
        "properties": {
          "event_type": {
            "const": "notification.badge"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "session_visibility_class": {
            "const": "CUSTOMER_VISIBLE"
          }
        },
        "required": [
          "session_visibility_class"
        ]
      },
      "then": {
        "properties": {
          "event_type": {
            "not": {
              "const": "audit.appended"
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
