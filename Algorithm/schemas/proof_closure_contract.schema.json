{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/proof_closure_contract.schema.json",
  "title": "ProofClosureContract",
  "description": "Deterministic proof-closure contract for filing-capable targets and proof bundles. This schema freezes the closure factors, path-selection profile, and explicit failure reasons so admissibility, contradiction isolation, staleness, and replay closure are backend-authored rather than inferred from visualization state.",
  "type": "object",
  "required": [
    "closure_profile_code",
    "path_ranking_profile_code",
    "support_closed",
    "authority_closed",
    "contradiction_isolated",
    "replay_closed",
    "silent_limitation_ambiguity_present",
    "current_decisive_anchor_present",
    "staleness_invalidated",
    "closure_failure_reason_codes"
  ],
  "properties": {
    "closure_profile_code": {
      "const": "PROOF_CLOSURE_V1"
    },
    "path_ranking_profile_code": {
      "const": "PROOF_PATH_SELECTION_V1"
    },
    "support_closed": {
      "type": "boolean"
    },
    "authority_closed": {
      "type": "boolean"
    },
    "contradiction_isolated": {
      "type": "boolean"
    },
    "replay_closed": {
      "type": "boolean"
    },
    "silent_limitation_ambiguity_present": {
      "type": "boolean"
    },
    "current_decisive_anchor_present": {
      "type": "boolean"
    },
    "staleness_invalidated": {
      "type": "boolean"
    },
    "closure_failure_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "anyOf": [
          {
            "properties": {
              "support_closed": {
                "const": false
              }
            },
            "required": [
              "support_closed"
            ]
          },
          {
            "properties": {
              "authority_closed": {
                "const": false
              }
            },
            "required": [
              "authority_closed"
            ]
          },
          {
            "properties": {
              "contradiction_isolated": {
                "const": false
              }
            },
            "required": [
              "contradiction_isolated"
            ]
          },
          {
            "properties": {
              "replay_closed": {
                "const": false
              }
            },
            "required": [
              "replay_closed"
            ]
          },
          {
            "properties": {
              "silent_limitation_ambiguity_present": {
                "const": true
              }
            },
            "required": [
              "silent_limitation_ambiguity_present"
            ]
          },
          {
            "properties": {
              "current_decisive_anchor_present": {
                "const": false
              }
            },
            "required": [
              "current_decisive_anchor_present"
            ]
          },
          {
            "properties": {
              "staleness_invalidated": {
                "const": true
              }
            },
            "required": [
              "staleness_invalidated"
            ]
          }
        ]
      },
      "then": {
        "properties": {
          "closure_failure_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "allOf": [
          {
            "properties": {
              "support_closed": {
                "const": true
              }
            },
            "required": [
              "support_closed"
            ]
          },
          {
            "properties": {
              "authority_closed": {
                "const": true
              }
            },
            "required": [
              "authority_closed"
            ]
          },
          {
            "properties": {
              "contradiction_isolated": {
                "const": true
              }
            },
            "required": [
              "contradiction_isolated"
            ]
          },
          {
            "properties": {
              "replay_closed": {
                "const": true
              }
            },
            "required": [
              "replay_closed"
            ]
          },
          {
            "properties": {
              "silent_limitation_ambiguity_present": {
                "const": false
              }
            },
            "required": [
              "silent_limitation_ambiguity_present"
            ]
          },
          {
            "properties": {
              "current_decisive_anchor_present": {
                "const": true
              }
            },
            "required": [
              "current_decisive_anchor_present"
            ]
          },
          {
            "properties": {
              "staleness_invalidated": {
                "const": false
              }
            },
            "required": [
              "staleness_invalidated"
            ]
          }
        ]
      },
      "then": {
        "properties": {
          "closure_failure_reason_codes": {
            "maxItems": 0
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
