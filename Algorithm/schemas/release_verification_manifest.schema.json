{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/release_verification_manifest.schema.json",
  "title": "ReleaseVerificationManifest",
  "description": "Promotion-evidence contract. This schema binds blocking release gates to the exact candidate identity, suite families, waiver and quarantine posture, migration evidence, restore checkpoint, and approval or supersession outcome used for a deployment decision.",
  "type": "object",
  "required": [
    "verification_manifest_id",
    "candidate_environment_ref",
    "build_artifact_ref",
    "artifact_digest",
    "candidate_identity_hash",
    "candidate_identity_contract",
    "manifest_assembly_contract",
    "schema_bundle_hash",
    "schema_reader_window_contract",
    "schema_bundle_compatibility_gate_contract",
    "config_bundle_hash",
    "migration_mode",
    "migration_plan_ref",
    "enabled_provider_profile_refs",
    "executed_test_run_identifiers",
    "blocking_gates",
    "migration_ledger_refs",
    "canary_summary_ref",
    "deterministic_golden_pack_ref",
    "restore_drill_ref",
    "restore_checkpoint_ref",
    "supported_client_window_ref",
    "client_compatibility_matrix_ref",
    "decision_state",
    "state_transition_contract",
    "approval_ref",
    "deployment_release_ref",
    "superseded_by_verification_manifest_ref",
    "decision_changed_at",
    "created_at"
  ],
  "properties": {
    "verification_manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "candidate_environment_ref": {
      "type": "string",
      "minLength": 1
    },
    "build_artifact_ref": {
      "type": "string",
      "minLength": 1
    },
    "artifact_digest": {
      "type": "string",
      "minLength": 1
    },
    "candidate_identity_hash": {
      "type": "string",
      "minLength": 1
    },
    "candidate_identity_contract": {
      "$ref": "https://taxat.dev/schemas/release_candidate_identity_contract.schema.json"
    },
    "manifest_assembly_contract": {
      "$ref": "https://taxat.dev/schemas/release_verification_manifest_assembly_contract.schema.json"
    },
    "schema_bundle_hash": {
      "type": "string",
      "minLength": 1
    },
    "schema_reader_window_contract": {
      "$ref": "https://taxat.dev/schemas/schema_reader_window_contract.schema.json"
    },
    "schema_bundle_compatibility_gate_contract": {
      "$ref": "https://taxat.dev/schemas/schema_bundle_compatibility_gate_contract.schema.json"
    },
    "config_bundle_hash": {
      "type": "string",
      "minLength": 1
    },
    "migration_mode": {
      "type": "string",
      "enum": [
        "NO_MIGRATION",
        "MIGRATION_REQUIRED"
      ]
    },
    "migration_plan_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "enabled_provider_profile_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "executed_test_run_identifiers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "blocking_gates": {
      "type": "object",
      "required": [
        "schema_compatibility",
        "deterministic_and_state_machine",
        "northbound_api",
        "authority_sandbox",
        "operator_client",
        "security",
        "performance_and_canary",
        "restore_drill",
        "migration_verification",
        "supply_chain",
        "suite_admissibility"
      ],
      "properties": {
        "schema_compatibility": {
          "allOf": [
            {
              "$ref": "#/$defs/gateResult"
            },
            {
              "type": "object",
              "properties": {
                "suite_family": {
                  "const": "SCHEMA_COMPATIBILITY"
                }
              }
            }
          ]
        },
        "deterministic_and_state_machine": {
          "allOf": [
            {
              "$ref": "#/$defs/gateResult"
            },
            {
              "type": "object",
              "properties": {
                "suite_family": {
                  "const": "DETERMINISTIC_AND_STATE_MACHINE"
                }
              }
            }
          ]
        },
        "northbound_api": {
          "allOf": [
            {
              "$ref": "#/$defs/gateResult"
            },
            {
              "type": "object",
              "properties": {
                "suite_family": {
                  "const": "NORTHBOUND_API"
                }
              }
            }
          ]
        },
        "authority_sandbox": {
          "allOf": [
            {
              "$ref": "#/$defs/gateResult"
            },
            {
              "type": "object",
              "properties": {
                "suite_family": {
                  "const": "AUTHORITY_SANDBOX"
                }
              }
            }
          ]
        },
        "operator_client": {
          "allOf": [
            {
              "$ref": "#/$defs/gateResult"
            },
            {
              "type": "object",
              "properties": {
                "suite_family": {
                  "const": "OPERATOR_CLIENT"
                }
              }
            }
          ]
        },
        "security": {
          "allOf": [
            {
              "$ref": "#/$defs/gateResult"
            },
            {
              "type": "object",
              "properties": {
                "suite_family": {
                  "const": "SECURITY"
                }
              }
            }
          ]
        },
        "performance_and_canary": {
          "allOf": [
            {
              "$ref": "#/$defs/gateResult"
            },
            {
              "type": "object",
              "properties": {
                "suite_family": {
                  "const": "PERFORMANCE_AND_CANARY"
                }
              }
            }
          ]
        },
        "restore_drill": {
          "allOf": [
            {
              "$ref": "#/$defs/gateResult"
            },
            {
              "type": "object",
              "properties": {
                "suite_family": {
                  "const": "RESTORE_DRILL"
                }
              }
            }
          ]
        },
        "migration_verification": {
          "allOf": [
            {
              "$ref": "#/$defs/gateResult"
            },
            {
              "type": "object",
              "properties": {
                "suite_family": {
                  "const": "MIGRATION_VERIFICATION"
                }
              }
            }
          ]
        },
        "supply_chain": {
          "allOf": [
            {
              "$ref": "#/$defs/gateResult"
            },
            {
              "type": "object",
              "properties": {
                "suite_family": {
                  "const": "SUPPLY_CHAIN"
                }
              }
            }
          ]
        },
        "suite_admissibility": {
          "allOf": [
            {
              "$ref": "#/$defs/gateResult"
            },
            {
              "type": "object",
              "properties": {
                "suite_family": {
                  "const": "SUITE_ADMISSIBILITY"
                }
              }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "migration_ledger_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "canary_summary_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "deterministic_golden_pack_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "restore_drill_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "restore_checkpoint_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "supported_client_window_ref": {
      "type": "string",
      "minLength": 1
    },
    "client_compatibility_matrix_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "decision_state": {
      "type": "string",
      "enum": [
        "PENDING",
        "BLOCKED",
        "APPROVED",
        "SUPERSEDED"
      ]
    },
    "state_transition_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/state_transition_contract.schema.json"
        },
        {
          "properties": {
            "object_family": {
              "const": "RELEASE_VERIFICATION_MANIFEST"
            },
            "machine_code": {
              "const": "RELEASE_VERIFICATION_MANIFEST_DECISION_V1"
            },
            "state_field_name": {
              "const": "decision_state"
            }
          }
        }
      ]
    },
    "approval_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "deployment_release_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "superseded_by_verification_manifest_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "decision_changed_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "gateResult": {
      "type": "object",
      "required": [
        "suite_family",
        "candidate_identity_hash",
        "compatibility_gate_hash_or_null",
        "authority_sandbox_coverage_hash_or_null",
        "result_ref",
        "admissibility_ref",
        "status",
        "admissibility_state",
        "quarantine_state",
        "manual_waiver_state",
        "executed_at"
      ],
      "properties": {
        "suite_family": {
          "type": "string",
          "enum": [
            "SCHEMA_COMPATIBILITY",
            "DETERMINISTIC_AND_STATE_MACHINE",
            "NORTHBOUND_API",
            "AUTHORITY_SANDBOX",
            "OPERATOR_CLIENT",
            "SECURITY",
            "PERFORMANCE_AND_CANARY",
            "RESTORE_DRILL",
            "MIGRATION_VERIFICATION",
            "SUPPLY_CHAIN",
            "SUITE_ADMISSIBILITY"
          ]
        },
        "candidate_identity_hash": {
          "type": "string",
          "minLength": 1
        },
        "compatibility_gate_hash_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "authority_sandbox_coverage_hash_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "result_ref": {
          "type": "string",
          "minLength": 1
        },
        "admissibility_ref": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "GREEN",
            "RED"
          ]
        },
        "admissibility_state": {
          "type": "string",
          "enum": [
            "ADMISSIBLE",
            "INADMISSIBLE"
          ]
        },
        "quarantine_state": {
          "type": "string",
          "enum": [
            "NONE",
            "QUARANTINED"
          ]
        },
        "manual_waiver_state": {
          "type": "string",
          "enum": [
            "NONE",
            "WAIVED"
          ]
        },
        "executed_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "suite_family": {
                "enum": [
                  "SCHEMA_COMPATIBILITY",
                  "MIGRATION_VERIFICATION",
                  "OPERATOR_CLIENT"
                ]
              }
            },
            "required": [
              "suite_family"
            ]
          },
          "then": {
            "properties": {
              "compatibility_gate_hash_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "else": {
            "properties": {
              "compatibility_gate_hash_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "suite_family": {
                "const": "AUTHORITY_SANDBOX"
              }
            },
            "required": [
              "suite_family"
            ]
          },
          "then": {
            "properties": {
              "authority_sandbox_coverage_hash_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "else": {
            "properties": {
              "authority_sandbox_coverage_hash_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "GREEN"
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "admissibility_state": {
                "const": "ADMISSIBLE"
              },
              "quarantine_state": {
                "const": "NONE"
              },
              "manual_waiver_state": {
                "const": "NONE"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "quarantine_state": {
                "const": "QUARANTINED"
              }
            },
            "required": [
              "quarantine_state"
            ]
          },
          "then": {
            "properties": {
              "status": {
                "const": "RED"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "manual_waiver_state": {
                "const": "WAIVED"
              }
            },
            "required": [
              "manual_waiver_state"
            ]
          },
          "then": {
            "properties": {
              "status": {
                "const": "RED"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "admissibility_state": {
                "const": "INADMISSIBLE"
              }
            },
            "required": [
              "admissibility_state"
            ]
          },
          "then": {
            "properties": {
              "status": {
                "const": "RED"
              }
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "blocking_gates": {
            "type": "object",
            "properties": {
              "deterministic_and_state_machine": {
                "type": "object",
                "properties": {
                  "status": {
                    "const": "GREEN"
                  }
                },
                "required": [
                  "status"
                ]
              }
            },
            "required": [
              "deterministic_and_state_machine"
            ]
          }
        },
        "required": [
          "blocking_gates"
        ]
      },
      "then": {
        "properties": {
          "deterministic_golden_pack_ref": {
            "type": "string",
            "minLength": 1
          },
          "manifest_assembly_contract": {
            "type": "object",
            "properties": {
              "deterministic_golden_pack_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "deterministic_golden_pack_ref_or_null"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "deterministic_golden_pack_ref": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "deterministic_golden_pack_ref"
        ]
      },
      "then": {
        "properties": {
          "blocking_gates": {
            "type": "object",
            "properties": {
              "deterministic_and_state_machine": {
                "type": "object",
                "properties": {
                  "status": {
                    "const": "GREEN"
                  }
                },
                "required": [
                  "status"
                ]
              }
            },
            "required": [
              "deterministic_and_state_machine"
            ]
          },
          "manifest_assembly_contract": {
            "type": "object",
            "properties": {
              "deterministic_golden_pack_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "deterministic_golden_pack_ref_or_null"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "migration_mode": {
            "const": "NO_MIGRATION"
          }
        },
        "required": [
          "migration_mode"
        ]
      },
      "then": {
        "properties": {
          "migration_plan_ref": {
            "type": "null"
          },
          "migration_ledger_refs": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "migration_mode": {
            "const": "MIGRATION_REQUIRED"
          }
        },
        "required": [
          "migration_mode"
        ]
      },
      "then": {
        "properties": {
          "migration_plan_ref": {
            "type": "string",
            "minLength": 1
          },
          "migration_ledger_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "migration_plan_ref": {
            "type": "null"
          }
        },
        "required": [
          "migration_plan_ref"
        ]
      },
      "then": {
        "properties": {
          "migration_mode": {
            "const": "NO_MIGRATION"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "migration_ledger_refs": {
            "minItems": 1
          }
        },
        "required": [
          "migration_ledger_refs"
        ]
      },
      "then": {
        "properties": {
          "migration_mode": {
            "const": "MIGRATION_REQUIRED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "migration_ledger_refs": {
            "maxItems": 0
          }
        },
        "required": [
          "migration_ledger_refs"
        ]
      },
      "then": {
        "properties": {
          "migration_mode": {
            "const": "NO_MIGRATION"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision_state": {
            "const": "APPROVED"
          }
        },
        "required": [
          "decision_state"
        ]
      },
      "then": {
        "properties": {
          "approval_ref": {
            "type": "string",
            "minLength": 1
          },
          "deployment_release_ref": {
            "type": "string",
            "minLength": 1
          },
          "superseded_by_verification_manifest_ref": {
            "type": "null"
          },
          "restore_drill_ref": {
            "type": "string",
            "minLength": 1
          },
          "restore_checkpoint_ref": {
            "type": "string",
            "minLength": 1
          },
          "canary_summary_ref": {
            "type": "string",
            "minLength": 1
          },
          "deterministic_golden_pack_ref": {
            "type": "string",
            "minLength": 1
          },
          "client_compatibility_matrix_ref": {
            "type": "string",
            "minLength": 1
          },
          "manifest_assembly_contract": {
            "type": "object",
            "properties": {
              "decision_state": {
                "const": "APPROVED"
              },
              "approval_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "deployment_release_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "deterministic_golden_pack_ref_or_null": {
                "type": "string",
                "minLength": 1
              },
              "superseded_by_verification_manifest_ref_or_null": {
                "type": "null"
              }
            },
            "required": [
              "decision_state",
              "approval_ref_or_null",
              "deployment_release_ref_or_null",
              "deterministic_golden_pack_ref_or_null",
              "superseded_by_verification_manifest_ref_or_null"
            ]
          },
          "schema_bundle_compatibility_gate_contract": {
            "properties": {
              "historical_manifest_guard_state": {
                "const": "PROTECTED"
              },
              "replay_restore_guard_state": {
                "const": "PROTECTED"
              }
            },
            "required": [
              "historical_manifest_guard_state",
              "replay_restore_guard_state"
            ]
          },
          "blocking_gates": {
            "type": "object",
            "properties": {
              "schema_compatibility": {
                "type": "object",
                "properties": {
                  "compatibility_gate_hash_or_null": {
                    "type": "string",
                    "minLength": 1
                  },
                  "status": {
                    "const": "GREEN"
                  },
                  "admissibility_state": {
                    "const": "ADMISSIBLE"
                  },
                  "quarantine_state": {
                    "const": "NONE"
                  },
                  "manual_waiver_state": {
                    "const": "NONE"
                  }
                }
              },
              "deterministic_and_state_machine": {
                "type": "object",
                "properties": {
                  "status": {
                    "const": "GREEN"
                  },
                  "admissibility_state": {
                    "const": "ADMISSIBLE"
                  },
                  "quarantine_state": {
                    "const": "NONE"
                  },
                  "manual_waiver_state": {
                    "const": "NONE"
                  }
                }
              },
              "northbound_api": {
                "type": "object",
                "properties": {
                  "status": {
                    "const": "GREEN"
                  },
                  "admissibility_state": {
                    "const": "ADMISSIBLE"
                  },
                  "quarantine_state": {
                    "const": "NONE"
                  },
                  "manual_waiver_state": {
                    "const": "NONE"
                  }
                }
              },
              "authority_sandbox": {
                "type": "object",
                "properties": {
                  "status": {
                    "const": "GREEN"
                  },
                  "admissibility_state": {
                    "const": "ADMISSIBLE"
                  },
                  "quarantine_state": {
                    "const": "NONE"
                  },
                  "manual_waiver_state": {
                    "const": "NONE"
                  }
                }
              },
              "operator_client": {
                "type": "object",
                "properties": {
                  "compatibility_gate_hash_or_null": {
                    "type": "string",
                    "minLength": 1
                  },
                  "status": {
                    "const": "GREEN"
                  },
                  "admissibility_state": {
                    "const": "ADMISSIBLE"
                  },
                  "quarantine_state": {
                    "const": "NONE"
                  },
                  "manual_waiver_state": {
                    "const": "NONE"
                  }
                }
              },
              "security": {
                "type": "object",
                "properties": {
                  "status": {
                    "const": "GREEN"
                  },
                  "admissibility_state": {
                    "const": "ADMISSIBLE"
                  },
                  "quarantine_state": {
                    "const": "NONE"
                  },
                  "manual_waiver_state": {
                    "const": "NONE"
                  }
                }
              },
              "performance_and_canary": {
                "type": "object",
                "properties": {
                  "status": {
                    "const": "GREEN"
                  },
                  "admissibility_state": {
                    "const": "ADMISSIBLE"
                  },
                  "quarantine_state": {
                    "const": "NONE"
                  },
                  "manual_waiver_state": {
                    "const": "NONE"
                  }
                }
