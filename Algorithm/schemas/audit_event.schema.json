{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/audit_event.schema.json",
  "title": "AuditEvent",
  "description": "Append-only audit evidence contract for compliance-significant events. This contract freezes event family vocabulary, stream ordering semantics, and minimum correlation posture.",
  "type": "object",
  "required": [
    "audit_event_id",
    "event_type",
    "event_time",
    "recorded_at",
    "audit_stream_ref",
    "stream_sequence",
    "tenant_id",
    "client_id",
    "manifest_id",
    "actor_ref",
    "service_ref",
    "object_refs",
    "reason_codes",
    "event_payload_hash",
    "prev_event_hash",
    "visibility_class",
    "retention_class",
    "signature_ref",
    "correlation_context",
    "retention_limited_explainability_contract",
    "retained_context"
  ],
  "properties": {
    "audit_event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "type": "string",
      "enum": [
        "PrincipalAuthenticated",
        "StepUpRequired",
        "StepUpSatisfied",
        "AuthorityLinked",
        "AuthorityRelinked",
        "AuthorityBindingMismatchDetected",
        "AccessScopeBound",
        "ExistingDecisionBundleReturned",
        "ManifestContextReused",
        "ContinuationChildAllocated",
        "ConfigInheritanceResolved",
        "ManifestAllocated",
        "ManifestFrozen",
        "ManifestSealed",
        "RunStarted",
        "RunStartClaimRejected",
        "ManifestFailed",
        "ManifestBlocked",
        "ManifestCompleted",
        "ManifestSuperseded",
        "NightlyBatchAllocated",
        "NightlyPortfolioSelected",
        "NightlyClientExecutionDispatched",
        "NightlyClientExecutionDeferred",
        "NightlyClientExecutionSkipped",
        "NightlyClientExecutionEscalated",
        "NightlyBatchShardClaimed",
        "NightlyBatchShardReclaimed",
        "NightlyBatchQuiesced",
        "NightlyBatchCompleted",
        "NightlyBatchAbandoned",
        "OperatorMorningDigestPublished",
        "SourceCollectionStarted",
        "SourceCollectionCompleted",
        "SnapshotBuilt",
        "SnapshotValidated",
        "FactPromoted",
        "ConflictRecorded",
        "GateEvaluated",
        "ComputeCompleted",
        "ParityEvaluated",
        "TrustSynthesized",
        "GraphBuilt",
        "TwinBuilt",
        "WorkflowOpened",
        "WorkflowResolved",
        "OverrideRequested",
        "OverrideApproved",
        "OverrideRejected",
        "OverrideExpired",
        "FilingPacketPrepared",
        "SubmissionAttempted",
        "AuthorityOperationPlanned",
        "AuthorityRequestBuilt",
        "AuthorityRequestSent",
        "AuthorityResponseReceived",
        "AuthorityStatusNormalized",
        "AuthorityReconciliationAttempted",
        "AuthorityReconciliationResolved",
        "SubmissionReconciled",
        "SubmissionConfirmed",
        "SubmissionRejected",
        "SubmissionUnknown",
        "OutOfBandStateObserved",
        "BaselineSelected",
        "AmendmentWindowEvaluated",
        "DriftDetected",
        "DriftClassified",
        "DriftRetroactiveImpactAnalyzed",
        "DriftSuperseded",
        "AmendmentEligibilityEvaluated",
        "AmendmentFreshnessInvalidated",
        "IntentToAmendTriggered",
        "IntentToAmendValidated",
        "AmendmentBundlePrepared",
        "AmendmentSubmitted",
        "AmendmentConfirmed",
        "AuthorityCorrectionObserved",
        "AuthorityAcceptedStateInternallySuperseded",
        "DriftReviewEscalated",
        "RetentionApplied",
        "RetentionLimited",
        "LegalHoldApplied",
        "LegalHoldReleased",
        "ErasureRequested",
        "ErasureCompleted",
        "SensitiveViewOpened",
        "MaskedExportProduced",
        "BuildAttested",
        "ReleaseCanaryStarted",
        "ReleasePromoted",
        "ReleaseRolledBack",
        "SchemaMigrationPlanned",
        "SchemaMigrationApplied",
        "SchemaMigrationVerified",
        "SecretRotated",
        "BackupCreated",
        "RestoreDrillExecuted",
        "DisasterRecoveryFailedOver",
        "DisasterRecoveryFailedBack",
        "ErrorRecorded",
        "RemediationOpened",
        "RemediationCompleted",
        "CompensationApplied",
        "CompensationVerified",
        "ReplayPreflightValidated",
        "ReplayBasisCorruptionDetected",
        "FrozenPostSealBasisLoaded",
        "HistoricalAuthorityBasisReused",
        "HistoricalLateDataBasisReused",
        "ReplayOutcomeCompared",
        "ReplayAttested"
      ]
    },
    "event_time": {
      "type": "string",
      "format": "date-time"
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    },
    "audit_stream_ref": {
      "type": "string",
      "minLength": 1
    },
    "stream_sequence": {
      "type": "integer",
      "minimum": 0
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "manifest_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "actor_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "service_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "object_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "event_payload_hash": {
      "type": "string",
      "minLength": 1
    },
    "prev_event_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "visibility_class": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "retention_class": {
      "type": "string",
      "minLength": 1
    },
    "signature_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "correlation_context": {
      "$ref": "./telemetry_resource.schema.json#/$defs/correlationContext"
    },
    "retention_limited_explainability_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/retention_limited_explainability_contract.schema.json"
        },
        {
          "properties": {
            "boundary_scope": {
              "const": "AUDIT_EVENT"
            },
            "surface_role": {
              "const": "AUDIT_RECONSTRUCTION_EVIDENCE"
            },
            "surface_specific_binding_policy": {
              "const": "AUDIT_EVENT_RETAINS_MINIMUM_RECONSTRUCTION_CONTEXT_AFTER_PAYLOAD_EXPIRY"
            }
          }
        }
      ]
    },
    "retained_context": {
      "type": "object",
      "required": [
        "payload_availability_state",
        "audit_sufficiency_state",
        "payload_expiry_at_or_null",
        "lineage_refs",
        "limitation_reason_codes"
      ],
      "properties": {
        "payload_availability_state": {
          "type": "string",
          "enum": [
            "FULL",
            "HASH_ONLY",
            "TOMBSTONED",
            "ERASED"
          ]
        },
        "audit_sufficiency_state": {
          "type": "string",
          "enum": [
            "SUFFICIENT",
            "LIMITED"
          ]
        },
        "payload_expiry_at_or_null": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "lineage_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "limitation_reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "retained_context": {
            "properties": {
              "payload_availability_state": {
                "const": "FULL"
              }
            },
            "required": [
              "payload_availability_state"
            ]
          }
        },
        "required": [
          "retained_context"
        ]
      },
      "then": {
        "properties": {
          "retained_context": {
            "properties": {
              "audit_sufficiency_state": {
                "const": "SUFFICIENT"
              },
              "payload_expiry_at_or_null": {
                "type": "null"
              },
              "limitation_reason_codes": {
                "maxItems": 0
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "retained_context": {
            "properties": {
              "payload_availability_state": {
                "enum": [
                  "HASH_ONLY",
                  "TOMBSTONED",
                  "ERASED"
                ]
              }
            },
            "required": [
              "payload_availability_state"
            ]
          }
        },
        "required": [
          "retained_context"
        ]
      },
      "then": {
        "properties": {
          "retained_context": {
            "properties": {
              "audit_sufficiency_state": {
                "const": "LIMITED"
              },
              "payload_expiry_at_or_null": {
                "type": "string",
                "format": "date-time"
              },
              "limitation_reason_codes": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "anyOf": [
        {
          "properties": {
            "manifest_id": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "manifest_id"
          ]
        },
        {
          "properties": {
            "correlation_context": {
              "type": "object",
              "properties": {
                "submission_record_id": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "submission_record_id"
              ]
            }
          },
          "required": [
            "correlation_context"
          ]
        },
        {
          "properties": {
            "correlation_context": {
              "type": "object",
              "properties": {
                "nightly_batch_run_ref": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "nightly_batch_run_ref"
              ]
            }
          },
          "required": [
            "correlation_context"
          ]
        },
        {
          "properties": {
            "correlation_context": {
              "type": "object",
              "properties": {
                "authority_operation_id": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "authority_operation_id"
              ]
            }
          },
          "required": [
            "correlation_context"
          ]
        }
      ]
    },
    {
      "anyOf": [
        {
          "properties": {
            "actor_ref": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "actor_ref"
          ]
        },
        {
          "properties": {
            "service_ref": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "service_ref"
          ]
        }
      ]
    },
    {
      "if": {
        "properties": {
          "stream_sequence": {
            "const": 0
          }
        },
        "required": [
          "stream_sequence"
        ]
      },
      "then": {
        "properties": {
          "prev_event_hash": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "stream_sequence": {
            "minimum": 1
          }
        },
        "required": [
          "stream_sequence"
        ]
      },
      "then": {
        "properties": {
          "prev_event_hash": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "RunStarted",
              "RunStartClaimRejected"
            ]
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "correlation_context": {
            "type": "object",
            "properties": {
              "manifest_start_claim": {
                "$ref": "https://taxat.dev/schemas/manifest_start_claim_contract.schema.json"
              }
            },
            "required": [
              "manifest_start_claim"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "RunStartClaimRejected"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "ErrorRecorded",
              "ManifestBlocked",
              "ManifestFailed",
              "ReplayBasisCorruptionDetected"
            ]
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "ManifestBlocked",
              "ManifestFailed"
            ]
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "correlation_context": {
            "type": "object",
            "properties": {
              "error_id": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "error_id"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "NightlyBatchAllocated",
              "NightlyPortfolioSelected",
              "NightlyClientExecutionDispatched",
              "NightlyClientExecutionDeferred",
              "NightlyClientExecutionSkipped",
              "NightlyClientExecutionEscalated",
              "NightlyBatchShardClaimed",
              "NightlyBatchShardReclaimed",
              "NightlyBatchQuiesced",
              "NightlyBatchCompleted",
              "NightlyBatchAbandoned",
              "OperatorMorningDigestPublished"
            ]
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "correlation_context": {
            "type": "object",
            "properties": {
              "nightly_batch_run_ref": {
                "type": "string",
                "minLength": 1
              },
              "nightly_window_key": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "nightly_batch_run_ref",
              "nightly_window_key"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "NightlyClientExecutionDispatched",
              "NightlyClientExecutionDeferred",
              "NightlyClientExecutionSkipped",
              "NightlyClientExecutionEscalated"
            ]
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "correlation_context": {
            "type": "object",
            "properties": {
              "selection_disposition": {
                "type": "string",
                "enum": [
                  "EXECUTE_NEW_MANIFEST",
                  "EXECUTE_CONTINUATION_CHILD",
                  "REUSE_EXISTING_TERMINAL_RESULT",
                  "DEFER_ACTIVE_ATTEMPT",
                  "DEFER_RETRY_WINDOW",
                  "ESCALATE_ONLY",
                  "SKIP_INELIGIBLE"
                ]
              }
            },
            "required": [
              "selection_disposition"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "const": "ErrorRecorded"
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "correlation_context": {
            "type": "object",
            "properties": {
              "error_id": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "error_id"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "ReplayPreflightValidated",
              "ReplayBasisCorruptionDetected",
              "FrozenPostSealBasisLoaded",
              "HistoricalAuthorityBasisReused",
              "HistoricalLateDataBasisReused",
              "ReplayOutcomeCompared",
              "ReplayAttested"
            ]
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "correlation_context": {
            "type": "object",
            "properties": {
              "replay_of_manifest_id": {
                "type": "string",
                "minLength": 1
              },
              "replay_class": {
                "type": "string",
                "enum": [
                  "STANDARD_REPLAY",
                  "AUDIT_REPLAY",
                  "COUNTERFACTUAL_ANALYSIS"
                ]
              },
              "comparison_mode": {
                "type": "string",
                "enum": [
                  "EXACT_HASH_MATCH",
                  "COUNTERFACTUAL_DECLARED",
                  "LIMITED_HISTORICAL_COMPARISON",
                  "BASIS_INCOMPLETE",
                  "BASIS_CORRUPT"
                ]
              },
              "basis_validation_state": {
                "type": "string",
                "enum": [
                  "VALID",
                  "RETENTION_LIMITED",
                  "MISSING_DEPENDENCY",
                  "CORRUPT",
                  "SCHEMA_INCOMPATIBLE",
                  "BUILD_UNAVAILABLE"
                ]
              },
              "expected_execution_basis_hash": {
                "type": "string",
                "minLength": 1
              },
              "actual_execution_basis_hash": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "replay_of_manifest_id",
              "replay_class",
              "comparison_mode",
              "basis_validation_state",
              "expected_execution_basis_hash",
              "actual_execution_basis_hash"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "ReplayOutcomeCompared",
              "ReplayAttested"
            ]
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "correlation_context": {
            "type": "object",
            "properties": {
              "expected_deterministic_outcome_hash": {
                "type": "string",
                "minLength": 1
              },
              "actual_deterministic_outcome_hash": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "expected_deterministic_outcome_hash",
              "actual_deterministic_outcome_hash"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "RemediationOpened",
              "RemediationCompleted"
            ]
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "correlation_context": {
            "type": "object",
            "properties": {
              "error_id": {
                "type": "string",
                "minLength": 1
              },
              "task_id": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "error_id",
              "task_id"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "CompensationApplied",
              "CompensationVerified"
            ]
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "correlation_context": {
            "type": "object",
            "properties": {
              "error_id": {
                "type": "string",
                "minLength": 1
              },
              "compensation_id": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "error_id",
              "compensation_id"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "AuthorityOperationPlanned",
              "AuthorityRequestBuilt",
              "AuthorityRequestSent",
              "AuthorityResponseReceived",
              "AuthorityStatusNormalized",
              "AuthorityReconciliationAttempted",
              "AuthorityReconciliationResolved"
            ]
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "correlation_context": {
            "type": "object",
            "properties": {
              "authority_operation_id": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "authority_operation_id"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "SubmissionAttempted",
              "SubmissionReconciled",
              "SubmissionConfirmed",
              "SubmissionRejected",
              "SubmissionUnknown",
              "OutOfBandStateObserved",
              "AmendmentSubmitted",
              "AmendmentConfirmed"
            ]
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "correlation_context": {
            "type": "object",
            "properties": {
              "submission_record_id": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "submission_record_id"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "event_type": {
            "enum": [
              "ExistingDecisionBundleReturned",
              "ManifestContextReused",
              "ManifestAllocated",
              "ContinuationChildAllocated",
              "ConfigInheritanceResolved"
            ]
          }
        },
        "required": [
          "event_type"
        ]
      },
      "then": {
        "properties": {
          "correlation_context": {
            "type": "object",
            "properties": {
              "root_manifest_id": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              },
              "parent_manifest_id": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              },
              "continuation_of_manifest_id": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              },
              "replay_of_manifest_id": {
                "type": [
                  "string",
                  "null"
                ],
                "minLength": 1
              },
              "idempotency_key": {
                "type": "string",
                "minLength": 1
              },
              "access_binding_hash": {
                "type": "string",
                "minLength": 1
              },
              "continuation_basis": {
                "type": "string",
                "minLength": 1
              },
              "manifest_lineage_trace_ref": {
                "type": "string",
                "minLength": 1
              },
              "manifest_branch_decision": {
                "$ref": "https://taxat.dev/schemas/manifest_branch_decision_contract.schema.json"
              }
            },
