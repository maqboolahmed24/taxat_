{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/authority_binding_drift_sentinel_contract.schema.json",
  "title": "AuthorityBindingDriftSentinelContract",
  "description": "Frozen authority binding-drift sentinel for any live authority-side network action. This schema records the exact sealed binding identity that was rechecked, the action class being authorized, duplicate or stronger-truth consultation posture, transmit-claim ownership when applicable, and the named pass or blocked outcome so queued send, reconciliation poll, and recovery read never proceed under silent rebinding or stale authority truth.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "binding_scope_class",
    "sentinel_contract_hash",
    "binding_verification_policy",
    "duplicate_truth_policy",
    "lineage_reuse_policy",
    "checked_action_class",
    "decision_state",
    "checked_at",
    "tenant_id",
    "client_id",
    "authority_binding_ref",
    "authority_link_ref",
    "delegation_grant_ref_or_null",
    "binding_lineage_ref",
    "sealed_token_version_ref",
    "checked_token_version_ref_or_null",
    "subject_ref",
    "acting_party_ref",
    "authority_scope",
    "provider_environment",
    "provider_api_version",
    "access_binding_hash",
    "policy_snapshot_hash",
    "duplicate_meaning_key",
    "duplicate_truth_inputs_state",
    "latest_submission_record_ref_or_null",
    "latest_obligation_mirror_ref_or_null",
    "latest_ingress_receipt_ref_or_null",
    "exclusive_send_claim_state",
    "pass_reason_code_or_null",
    "block_reason_codes"
  ],
  "properties": {
    "contract_version": {
      "const": "AUTHORITY_BINDING_DRIFT_SENTINEL_V1"
    },
    "binding_scope_class": {
      "const": "AUTHORITY_INTERACTION_RECORD"
    },
    "sentinel_contract_hash": {
      "type": "string",
      "minLength": 1
    },
    "binding_verification_policy": {
      "const": "RECHECK_BOUND_IDENTITY_AND_LIVE_AUTHORITY_CONTEXT_BEFORE_NETWORK_ACTION"
    },
    "duplicate_truth_policy": {
      "const": "LATEST_DUPLICATE_AND_STRONGER_TRUTH_MUST_BLOCK_OR_RECONCILE"
    },
    "lineage_reuse_policy": {
      "const": "SEALED_REQUEST_LINEAGE_ONLY_NO_SILENT_REBIND"
    },
    "checked_action_class": {
      "type": "string",
      "enum": [
        "NOT_YET_ATTEMPTED",
        "TRANSMIT_MUTATION",
        "RECONCILIATION_POLL",
        "RECOVERY_READ"
      ]
    },
    "decision_state": {
      "type": "string",
      "enum": [
        "NOT_EVALUATED",
        "CLEAR_TO_PROCEED",
        "BLOCKED"
      ]
    },
    "checked_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "authority_binding_ref": {
      "type": "string",
      "minLength": 1
    },
    "authority_link_ref": {
      "type": "string",
      "minLength": 1
    },
    "delegation_grant_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "binding_lineage_ref": {
      "type": "string",
      "minLength": 1
    },
    "sealed_token_version_ref": {
      "type": "string",
      "minLength": 1
    },
    "checked_token_version_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "subject_ref": {
      "type": "string",
      "minLength": 1
    },
    "acting_party_ref": {
      "type": "string",
      "minLength": 1
    },
    "authority_scope": {
      "type": "string",
      "minLength": 1
    },
    "provider_environment": {
      "type": "string",
      "minLength": 1
    },
    "provider_api_version": {
      "type": "string",
      "minLength": 1
    },
    "access_binding_hash": {
      "type": "string",
      "minLength": 1
    },
    "policy_snapshot_hash": {
      "type": "string",
      "minLength": 1
    },
    "duplicate_meaning_key": {
      "type": "string",
      "minLength": 1
    },
    "duplicate_truth_inputs_state": {
      "type": "string",
      "enum": [
        "NOT_CHECKED",
        "RECHECKED_NO_CONFLICT",
        "NEWER_TRUTH_OR_DUPLICATE_PRESENT"
      ]
    },
    "latest_submission_record_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "latest_obligation_mirror_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "latest_ingress_receipt_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "exclusive_send_claim_state": {
      "type": "string",
      "enum": [
        "NOT_APPLICABLE",
        "CLAIM_HELD",
        "CLAIM_CONFLICT"
      ]
    },
    "pass_reason_code_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "enum": [
        "SEALED_TOKEN_VERSION_REUSED",
        "TOKEN_ROTATED_WITHIN_LINEAGE",
        null
      ]
    },
    "block_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "SEND_CLAIM_CONFLICT",
          "TOKEN_VERSION_NOT_USABLE",
          "BINDING_LINEAGE_DRIFT",
          "AUTHORITY_LINK_NOT_ACTIVE",
          "CLIENT_SUBJECT_SCOPE_DRIFT",
          "PROVIDER_CONTRACT_DRIFT",
          "ACCESS_BINDING_HASH_DRIFT",
          "POLICY_SNAPSHOT_HASH_DRIFT",
          "STEP_UP_OR_APPROVAL_DRIFT",
          "DUPLICATE_BUCKET_CHANGED",
          "STRONGER_EXTERNAL_TRUTH_PRESENT",
          "BODY_COLLISION_PRESENT"
        ]
      },
      "default": [],
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "checked_action_class": {
            "const": "NOT_YET_ATTEMPTED"
          }
        },
        "required": [
          "checked_action_class"
        ]
      },
      "then": {
        "properties": {
          "decision_state": {
            "const": "NOT_EVALUATED"
          },
          "checked_at": {
            "type": "null"
          },
          "checked_token_version_ref_or_null": {
            "type": "null"
          },
          "duplicate_truth_inputs_state": {
            "const": "NOT_CHECKED"
          },
          "exclusive_send_claim_state": {
            "const": "NOT_APPLICABLE"
          },
          "pass_reason_code_or_null": {
            "type": "null"
          },
          "block_reason_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision_state": {
            "const": "NOT_EVALUATED"
          }
        },
        "required": [
          "decision_state"
        ]
      },
      "then": {
        "properties": {
          "checked_action_class": {
            "const": "NOT_YET_ATTEMPTED"
          },
          "checked_at": {
            "type": "null"
          },
          "checked_token_version_ref_or_null": {
            "type": "null"
          },
          "duplicate_truth_inputs_state": {
            "const": "NOT_CHECKED"
          },
          "exclusive_send_claim_state": {
            "const": "NOT_APPLICABLE"
          },
          "pass_reason_code_or_null": {
            "type": "null"
          },
          "block_reason_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision_state": {
            "const": "CLEAR_TO_PROCEED"
          }
        },
        "required": [
          "decision_state"
        ]
      },
      "then": {
        "properties": {
          "checked_action_class": {
            "enum": [
              "TRANSMIT_MUTATION",
              "RECONCILIATION_POLL",
              "RECOVERY_READ"
            ]
          },
          "checked_at": {
            "type": "string",
            "format": "date-time"
          },
          "checked_token_version_ref_or_null": {
            "type": "string",
            "minLength": 1
          },
          "duplicate_truth_inputs_state": {
            "const": "RECHECKED_NO_CONFLICT"
          },
          "pass_reason_code_or_null": {
            "enum": [
              "SEALED_TOKEN_VERSION_REUSED",
              "TOKEN_ROTATED_WITHIN_LINEAGE"
            ]
          },
          "block_reason_codes": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "decision_state": {
            "const": "BLOCKED"
          }
        },
        "required": [
          "decision_state"
        ]
      },
      "then": {
        "properties": {
          "checked_action_class": {
            "enum": [
              "TRANSMIT_MUTATION",
              "RECONCILIATION_POLL",
              "RECOVERY_READ"
            ]
          },
          "checked_at": {
            "type": "string",
            "format": "date-time"
          },
          "checked_token_version_ref_or_null": {
            "type": "null"
          },
          "pass_reason_code_or_null": {
            "type": "null"
          },
          "block_reason_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "checked_action_class": {
            "const": "TRANSMIT_MUTATION"
          }
        },
        "required": [
          "checked_action_class"
        ]
      },
      "then": {
        "properties": {
          "exclusive_send_claim_state": {
            "enum": [
              "CLAIM_HELD",
              "CLAIM_CONFLICT"
            ]
          }
        }
      },
      "else": {
        "properties": {
          "exclusive_send_claim_state": {
            "const": "NOT_APPLICABLE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "exclusive_send_claim_state": {
            "const": "CLAIM_CONFLICT"
          }
        },
        "required": [
          "exclusive_send_claim_state"
        ]
      },
      "then": {
        "properties": {
          "checked_action_class": {
            "const": "TRANSMIT_MUTATION"
          },
          "decision_state": {
            "const": "BLOCKED"
          },
          "block_reason_codes": {
            "contains": {
              "const": "SEND_CLAIM_CONFLICT"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "block_reason_codes": {
            "contains": {
              "enum": [
                "DUPLICATE_BUCKET_CHANGED",
                "STRONGER_EXTERNAL_TRUTH_PRESENT"
              ]
            }
          }
        },
        "required": [
          "block_reason_codes"
        ]
      },
      "then": {
        "properties": {
          "decision_state": {
            "const": "BLOCKED"
          },
          "duplicate_truth_inputs_state": {
            "const": "NEWER_TRUTH_OR_DUPLICATE_PRESENT"
          }
        },
        "anyOf": [
          {
            "properties": {
              "latest_submission_record_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "latest_submission_record_ref_or_null"
            ]
          },
          {
            "properties": {
              "latest_obligation_mirror_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "latest_obligation_mirror_ref_or_null"
            ]
          },
          {
            "properties": {
              "latest_ingress_receipt_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "latest_ingress_receipt_ref_or_null"
            ]
          }
        ]
      }
    }
  ]
}
