{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/twin_interpretation_state.schema.json",
  "title": "TwinInterpretationState",
  "description": "Twin Lens interpretation-state contract. This schema freezes which comparison spaces are available, the default interpretation, compare mode, low-noise ordering/filter posture, pinned object posture, and focus continuity used by the Twin Panel detail surface.",
  "type": "object",
  "required": [
    "artifact_type",
    "twin_interpretation_state_id",
    "twin_id",
    "execution_mode_boundary_contract",
    "generated_from_surface",
    "default_view_space",
    "enabled_view_spaces",
    "compare_mode",
    "pinned_object_ref",
    "active_delta_arc_ref",
    "focus_anchor_ref",
    "show_confidence_overlay",
    "show_freshness_overlay",
    "preserve_focus_across_refresh",
    "default_sort_mode",
    "default_noise_filter",
    "summary_priority_mode",
    "dominant_attention_state",
    "dominant_delta_arc_ref_or_null",
    "dominant_reconciliation_state_ref_or_null",
    "collapse_matches_by_default",
    "suppress_informational_when_higher_severity_present",
    "authority_first_summary"
  ],
  "properties": {
    "artifact_type": {
      "const": "TwinInterpretationState"
    },
    "twin_interpretation_state_id": {
      "type": "string",
      "minLength": 1
    },
    "twin_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode_boundary_contract": {
      "$ref": "https://taxat.dev/schemas/execution_mode_boundary_contract.schema.json"
    },
    "generated_from_surface": {
      "const": "TWIN_PANEL"
    },
    "default_view_space": {
      "type": "string",
      "enum": [
        "SOURCE_SPACE",
        "COMPUTATION_SPACE",
        "AUTHORITY_SPACE"
      ]
    },
    "enabled_view_spaces": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "SOURCE_SPACE",
          "COMPUTATION_SPACE",
          "AUTHORITY_SPACE"
        ]
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "compare_mode": {
      "type": "string",
      "enum": [
        "LOCKED",
        "DELTA_COMPARE",
        "PINNED_COMPARE"
      ]
    },
    "pinned_object_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "active_delta_arc_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "focus_anchor_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "show_confidence_overlay": {
      "type": "boolean"
    },
    "show_freshness_overlay": {
      "type": "boolean"
    },
    "preserve_focus_across_refresh": {
      "type": "boolean"
    },
    "default_sort_mode": {
      "type": "string",
      "enum": [
        "PRIORITY_RANK",
        "TIMELINE",
        "SUBJECT_CLASS"
      ]
    },
    "default_noise_filter": {
      "type": "string",
      "enum": [
        "ACTIONABLE_ONLY",
        "REVIEW_AND_ABOVE",
        "ALL_MISMATCHES"
      ]
    },
    "summary_priority_mode": {
      "type": "string",
      "enum": [
        "ACTIONABILITY_FIRST",
        "AUTHORITY_FIRST",
        "AUDIT_FIRST"
      ]
    },
    "dominant_attention_state": {
      "type": "string",
      "enum": [
        "READY",
        "REVIEW_REQUIRED",
        "WAITING_ON_AUTHORITY",
        "RECONCILIATION_REQUIRED",
        "NON_COMPARABLE",
        "OUT_OF_BAND",
        "CONTRADICTORY"
      ]
    },
    "dominant_delta_arc_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "dominant_reconciliation_state_ref_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "collapse_matches_by_default": {
      "type": "boolean"
    },
    "suppress_informational_when_higher_severity_present": {
      "type": "boolean"
    },
    "authority_first_summary": {
      "type": "boolean"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "default_view_space": {
            "const": "SOURCE_SPACE"
          }
        },
        "required": [
          "default_view_space"
        ]
      },
      "then": {
        "properties": {
          "enabled_view_spaces": {
            "contains": {
              "const": "SOURCE_SPACE"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "default_view_space": {
            "const": "COMPUTATION_SPACE"
          }
        },
        "required": [
          "default_view_space"
        ]
      },
      "then": {
        "properties": {
          "enabled_view_spaces": {
            "contains": {
              "const": "COMPUTATION_SPACE"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "default_view_space": {
            "const": "AUTHORITY_SPACE"
          }
        },
        "required": [
          "default_view_space"
        ]
      },
      "then": {
        "properties": {
          "enabled_view_spaces": {
            "contains": {
              "const": "AUTHORITY_SPACE"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "compare_mode": {
            "const": "LOCKED"
          }
        },
        "required": [
          "compare_mode"
        ]
      },
      "then": {
        "properties": {
          "pinned_object_ref": {
            "type": "null"
          },
          "active_delta_arc_ref": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "compare_mode": {
            "const": "DELTA_COMPARE"
          }
        },
        "required": [
          "compare_mode"
        ]
      },
      "then": {
        "properties": {
          "active_delta_arc_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "compare_mode": {
            "const": "PINNED_COMPARE"
          }
        },
        "required": [
          "compare_mode"
        ]
      },
      "then": {
        "properties": {
          "pinned_object_ref": {
            "type": "string",
            "minLength": 1
          },
          "focus_anchor_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "dominant_attention_state": {
            "const": "READY"
          }
        },
        "required": [
          "dominant_attention_state"
        ]
      },
      "then": {
        "properties": {
          "dominant_delta_arc_ref_or_null": {
            "type": "null"
          },
          "dominant_reconciliation_state_ref_or_null": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "dominant_attention_state": {
            "enum": [
              "WAITING_ON_AUTHORITY",
              "RECONCILIATION_REQUIRED",
              "OUT_OF_BAND",
              "CONTRADICTORY"
            ]
          }
        },
        "required": [
          "dominant_attention_state"
        ]
      },
      "then": {
        "properties": {
          "authority_first_summary": {
            "const": true
          },
          "default_noise_filter": {
            "enum": [
              "ACTIONABLE_ONLY",
              "REVIEW_AND_ABOVE"
            ]
          },
          "summary_priority_mode": {
            "enum": [
              "ACTIONABILITY_FIRST",
              "AUTHORITY_FIRST"
            ]
          },
          "dominant_reconciliation_state_ref_or_null": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "dominant_attention_state": {
            "enum": [
              "REVIEW_REQUIRED",
              "NON_COMPARABLE"
            ]
          }
        },
        "required": [
          "dominant_attention_state"
        ]
      },
      "then": {
        "properties": {
          "default_noise_filter": {
            "enum": [
              "ACTIONABLE_ONLY",
              "REVIEW_AND_ABOVE"
            ]
          },
          "summary_priority_mode": {
            "enum": [
              "ACTIONABILITY_FIRST",
              "AUTHORITY_FIRST"
            ]
          }
        },
        "anyOf": [
          {
            "properties": {
              "dominant_delta_arc_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          {
            "properties": {
              "dominant_reconciliation_state_ref_or_null": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "summary_priority_mode": {
            "const": "AUDIT_FIRST"
          }
        },
        "required": [
          "summary_priority_mode"
        ]
      },
      "then": {
        "properties": {
          "dominant_attention_state": {
            "const": "READY"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
