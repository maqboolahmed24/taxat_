      },
      "then": {
        "properties": {
          "current_submission_ref": {
            "type": "string",
            "minLength": 1
          },
          "current_submission_state": {
            "const": "UNKNOWN"
          },
          "current_packet_ref": {
            "type": "string",
            "minLength": 1
          },
          "packet_state": {
            "const": "SUBMITTED"
          },
          "controlling_proof_bundle_ref": {
            "type": "string",
            "minLength": 1
          },
          "proof_closure_state": {
            "const": "CLOSED"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "REJECTED"
          }
        },
        "required": [
          "lifecycle_state"
