{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/filing_case.schema.json",
  "title": "FilingCase",
  "description": "Authoritative filing-case contract for one client and period. This schema freezes manifest, packet, submission, calculation, and amendment lineage so filing progression cannot drift across implementations.",
  "type": "object",
  "required": [
    "artifact_type",
    "filing_case_id",
    "tenant_id",
    "client_id",
    "period",
    "execution_mode_boundary_contract",
    "lifecycle_state",
    "state_transition_contract",
    "current_manifest_ref",
    "current_trust_ref",
    "current_parity_ref",
    "current_submission_ref",
    "current_submission_state",
    "current_packet_ref",
    "packet_state",
    "calculation_basis_ref",
    "authority_calculation_ref",
    "amendment_case_ref",
    "calculation_request_ref",
    "calculation_id",
    "calculation_type",
    "calculation_hash",
    "readiness_context_ref",
    "trust_currency_state",
    "trust_invalidated_at",
    "trust_invalidation_reason_codes",
    "trust_invalidation_dependency_refs",
    "temporal_propagation_event_refs",
    "user_confirmation_ref",
    "last_transition_at",
    "controlling_proof_bundle_ref",
    "proof_closure_state"
  ],
  "properties": {
    "artifact_type": {
      "const": "FilingCase"
    },
    "filing_case_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": "string",
      "minLength": 1
    },
    "period": {
      "type": "string",
      "minLength": 1
    },
    "execution_mode_boundary_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/execution_mode_boundary_contract.schema.json"
        },
        {
          "properties": {
            "execution_posture": {
              "const": "LIVE_COMPLIANCE"
            },
            "legal_effect_boundary": {
              "const": "COMPLIANCE_CAPABLE"
            }
          }
        }
      ]
    },
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "NOT_STARTED",
        "PREPARING",
        "READY_REVIEW",
        "READY_TO_SUBMIT",
        "SUBMITTED_PENDING",
        "FILED_CONFIRMED",
        "FILED_UNKNOWN",
        "REJECTED",
        "AMENDMENT_ELIGIBLE",
        "AMENDMENT_IN_PROGRESS",
        "AMENDED_CONFIRMED",
        "CLOSED"
      ]
    },
    "state_transition_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/state_transition_contract.schema.json"
        },
        {
          "properties": {
            "object_family": {
              "const": "FILING_CASE"
            },
            "machine_code": {
              "const": "FILING_CASE_LIFECYCLE_V1"
            },
            "state_field_name": {
              "const": "lifecycle_state"
            }
          }
        }
      ]
    },
    "current_manifest_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "current_trust_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "current_parity_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "current_submission_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "current_submission_state": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "INTENT_RECORDED",
        "TRANSMIT_PENDING",
        "TRANSMITTED",
        "PENDING_ACK",
        "CONFIRMED",
        "REJECTED",
        "UNKNOWN",
        "OUT_OF_BAND",
        "SUPERSEDED",
        null
      ]
    },
    "current_packet_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "packet_state": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "DRAFT",
        "PREPARED",
        "APPROVED_TO_SUBMIT",
        "SUBMITTED",
        "VOID",
        "SUPERSEDED",
        null
      ]
    },
    "calculation_basis_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "authority_calculation_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "amendment_case_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "calculation_request_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "calculation_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "calculation_type": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "calculation_hash": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "readiness_context_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "trust_currency_state": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "CURRENT",
        "RECALC_REQUIRED",
        "NOT_APPLICABLE_PRETRUST",
        null
      ]
    },
    "trust_invalidated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "trust_invalidation_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "maxItems": 8,
      "uniqueItems": true
    },
    "trust_invalidation_dependency_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "maxItems": 8,
      "uniqueItems": true
    },
    "temporal_propagation_event_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "maxItems": 8,
      "uniqueItems": true
    },
    "user_confirmation_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "last_transition_at": {
      "type": "string",
      "format": "date-time"
    },
    "controlling_proof_bundle_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "proof_closure_state": {
      "type": "string",
      "enum": [
        "NOT_APPLICABLE",
        "CLOSED",
        "OPEN"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "enum": [
              "PREPARING",
              "READY_REVIEW",
              "READY_TO_SUBMIT",
              "SUBMITTED_PENDING",
              "FILED_CONFIRMED",
              "FILED_UNKNOWN",
              "REJECTED",
              "AMENDMENT_ELIGIBLE",
              "AMENDMENT_IN_PROGRESS",
              "AMENDED_CONFIRMED",
              "CLOSED"
            ]
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "current_manifest_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lifecycle_state": {
            "const": "NOT_STARTED"
          }
        },
        "required": [
          "lifecycle_state"
        ]
      },
      "then": {
        "properties": {
          "current_manifest_ref": {
            "type": "null"
          },
          "current_trust_ref": {
            "type": "null"
          },
          "current_parity_ref": {
            "type": "null"
          },
          "current_submission_ref": {
            "type": "null"
          },
          "current_submission_state": {
            "type": "null"
          },
          "current_packet_ref": {
            "type": "null"
          },
          "packet_state": {
            "type": "null"
          },
          "controlling_proof_bundle_ref": {
            "type": "null"
          },
          "proof_closure_state": {
            "const": "NOT_APPLICABLE"
          },
          "amendment_case_ref": {
            "type": "null"
          },
          "trust_currency_state": {
            "type": "null"
          },
          "readiness_context_ref": {
            "type": "null"
          },
          "trust_invalidated_at": {
            "type": "null"
          },
          "trust_invalidation_reason_codes": {
            "maxItems": 0
          },
          "trust_invalidation_dependency_refs": {
            "maxItems": 0
          }
        }
      }
    },
    {
