          "current_packet_ref": {
            "type": "string",
            "minLength": 1
          },
          "packet_state": {
            "const": "SUBMITTED"
          },
          "controlling_proof_bundle_ref": {
            "type": "string",
            "minLength": 1
          },
          "proof_closure_state": {
            "const": "CLOSED"
