{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/action_strip_state.schema.json",
  "title": "ActionStripState",
  "description": "Low-noise dominant next-step surface contract. This schema freezes one safe primary action or explicit no-safe-action posture, bounded secondary actions, explicit ownership language, deterministic investigation routing, focus-safe detail continuity, and frozen action-dominance metrics.",
  "type": "object",
  "required": [
    "artifact_type",
    "surface_code",
    "source_module_code",
    "actionability_state",
    "mode_safety_posture",
    "primary_action",
    "secondary_actions",
    "available_action_codes",
    "blocked_action_codes",
    "ownership_posture",
    "ownership_label",
    "waiting_on_label",
    "blocking_reason",
    "no_safe_action_reason_code",
    "machine_reason_codes",
    "investigation_entry_point",
    "suggested_detail_surface_code",
    "active_detail_surface_code",
    "focus_anchor_ref",
    "primary_action_score",
    "runner_up_action_score",
    "dominance_margin",
    "suppressed_secondary_count",
    "full_text_ref"
  ],
  "properties": {
    "artifact_type": {
      "const": "ActionStripState"
    },
    "surface_code": {
      "const": "ACTION_STRIP"
    },
    "source_module_code": {
      "const": "WORKFLOW_CHOREOGRAPHER"
    },
    "actionability_state": {
      "type": "string",
      "enum": [
        "ACTION_AVAILABLE",
        "NO_SAFE_ACTION"
      ]
    },
    "mode_safety_posture": {
      "type": "string",
      "enum": [
        "LIVE_COMPLIANCE_MUTATIONS_ALLOWED",
        "NON_LIVE_MUTATIONS_FORBIDDEN"
      ]
    },
    "primary_action": {
      "anyOf": [
        {
          "$ref": "#/$defs/action"
        },
        {
          "type": "null"
        }
      ]
    },
    "secondary_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      },
      "maxItems": 2,
      "uniqueItems": true
    },
    "available_action_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "maxItems": 3,
      "uniqueItems": true
    },
    "blocked_action_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "maxItems": 8,
      "uniqueItems": true
    },
    "ownership_posture": {
      "type": "string",
      "enum": [
        "SELF",
        "HUMAN_REVIEW",
        "APPROVAL_REQUIRED",
        "AUTHORITY_WAIT",
        "CUSTOMER_WAIT",
        "SYSTEM_WAIT",
        "NONE"
      ]
    },
    "ownership_label": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 64
    },
    "waiting_on_label": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 64
    },
    "blocking_reason": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "maxLength": 160
    },
    "no_safe_action_reason_code": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "machine_reason_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "maxItems": 6,
      "uniqueItems": true
    },
    "investigation_entry_point": {
      "anyOf": [
        {
          "$ref": "#/$defs/detailModuleCode"
        },
        {
          "type": "null"
        }
      ]
    },
    "suggested_detail_surface_code": {
      "anyOf": [
        {
          "$ref": "#/$defs/detailModuleCode"
        },
        {
          "type": "null"
        }
      ]
    },
    "active_detail_surface_code": {
      "anyOf": [
        {
          "$ref": "#/$defs/detailModuleCode"
        },
        {
          "type": "null"
        }
      ]
    },
    "focus_anchor_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "primary_action_score": {
      "type": "integer",
      "minimum": 0
    },
    "runner_up_action_score": {
      "type": "integer",
      "minimum": 0
    },
    "dominance_margin": {
      "type": "integer",
      "minimum": 0
    },
    "suppressed_secondary_count": {
      "type": "integer",
      "minimum": 0
    },
    "full_text_ref": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "detailModuleCode": {
      "type": "string",
      "enum": [
        "EVIDENCE_TIDE",
        "PACKET_FORGE",
        "AUTHORITY_TUNNEL",
        "DRIFT_FIELD",
        "FOCUS_LENS",
        "TWIN_PANEL"
      ]
    },
    "action": {
      "type": "object",
      "required": [
        "action_code",
        "label",
        "action_kind",
        "target_object_ref",
        "target_detail_surface_code",
        "requires_live_freshness",
        "mutation_precondition_binding_or_null"
      ],
      "properties": {
        "action_code": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40
        },
        "action_kind": {
          "type": "string",
          "enum": [
            "AUTHORITY_MUTATION",
            "FILING_MUTATION",
            "APPROVAL_MUTATION",
            "OVERRIDE_MUTATION",
            "INVESTIGATE",
            "COMPARE",
            "EXPORT",
            "REQUEST_REVIEW",
            "REFRESH"
          ]
        },
        "target_object_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "target_detail_surface_code": {
          "anyOf": [
            {
              "$ref": "#/$defs/detailModuleCode"
            },
            {
              "type": "null"
            }
          ]
        },
        "requires_live_freshness": {
          "type": "boolean"
        },
        "mutation_precondition_binding_or_null": {
          "anyOf": [
            {
              "$ref": "https://taxat.dev/schemas/mutation_precondition_binding.schema.json"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action_kind": {
                "enum": [
                  "AUTHORITY_MUTATION",
                  "FILING_MUTATION",
                  "APPROVAL_MUTATION",
                  "OVERRIDE_MUTATION"
                ]
              }
            },
            "required": [
              "action_kind"
            ]
          },
          "then": {
            "properties": {
              "target_object_ref": {
                "type": "string",
                "minLength": 1
              },
              "requires_live_freshness": {
                "const": true
              },
              "mutation_precondition_binding_or_null": {
                "$ref": "https://taxat.dev/schemas/mutation_precondition_binding.schema.json"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action_kind": {
                "enum": [
                  "INVESTIGATE",
                  "COMPARE"
                ]
              }
            },
            "required": [
              "action_kind"
            ]
          },
          "then": {
            "properties": {
              "target_detail_surface_code": {
                "$ref": "#/$defs/detailModuleCode"
              },
              "mutation_precondition_binding_or_null": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action_kind": {
                "const": "REFRESH"
              }
            },
            "required": [
              "action_kind"
            ]
          },
          "then": {
            "properties": {
              "target_object_ref": {
                "type": "null"
              },
              "target_detail_surface_code": {
                "type": "null"
              },
              "mutation_precondition_binding_or_null": {
                "type": "null"
              }
            }
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "actionability_state": {
            "const": "ACTION_AVAILABLE"
          }
        },
        "required": [
          "actionability_state"
        ]
      },
      "then": {
        "properties": {
          "primary_action": {
            "$ref": "#/$defs/action"
          },
          "available_action_codes": {
            "minItems": 1,
            "maxItems": 3
          },
          "blocking_reason": {
            "type": "null"
          },
          "waiting_on_label": {
            "type": "null"
          },
          "no_safe_action_reason_code": {
            "type": "null"
          },
          "investigation_entry_point": {
            "type": "null"
          },
          "suggested_detail_surface_code": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "actionability_state": {
            "const": "NO_SAFE_ACTION"
          }
        },
        "required": [
          "actionability_state"
        ]
      },
      "then": {
        "properties": {
          "primary_action": {
            "type": "null"
          },
          "secondary_actions": {
            "maxItems": 0
          },
          "available_action_codes": {
            "maxItems": 0
          },
          "blocking_reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160
          },
          "no_safe_action_reason_code": {
            "type": "string",
            "minLength": 1
          },
          "blocked_action_codes": {
            "minItems": 1
          },
          "investigation_entry_point": {
            "$ref": "#/$defs/detailModuleCode"
          },
          "suggested_detail_surface_code": {
            "$ref": "#/$defs/detailModuleCode"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "primary_action": {
            "type": "object",
            "properties": {
              "action_kind": {
                "enum": [
                  "AUTHORITY_MUTATION",
                  "FILING_MUTATION",
                  "APPROVAL_MUTATION",
                  "OVERRIDE_MUTATION"
                ]
              }
            },
            "required": [
              "action_kind"
            ]
          }
        },
        "required": [
          "primary_action"
        ]
      },
      "then": {
        "properties": {
          "secondary_actions": {
            "items": {
              "allOf": [
                {
                  "$ref": "#/$defs/action"
                },
                {
                  "properties": {
                    "action_kind": {
                      "enum": [
                        "INVESTIGATE",
                        "COMPARE",
                        "EXPORT",
                        "REQUEST_REVIEW",
                        "REFRESH"
                      ]
                    }
                  }
                }
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "mode_safety_posture": {
            "const": "NON_LIVE_MUTATIONS_FORBIDDEN"
          }
        },
        "required": [
          "mode_safety_posture"
        ]
      },
      "then": {
        "properties": {
          "primary_action": {
            "anyOf": [
              {
                "type": "null"
              },
              {
                "allOf": [
                  {
                    "$ref": "#/$defs/action"
                  },
                  {
                    "properties": {
                      "action_kind": {
                        "enum": [
                          "INVESTIGATE",
                          "COMPARE",
                          "EXPORT",
                          "REQUEST_REVIEW",
                          "REFRESH"
                        ]
                      }
                    }
                  }
                ]
              }
            ]
          },
          "secondary_actions": {
            "items": {
              "allOf": [
                {
                  "$ref": "#/$defs/action"
                },
                {
                  "properties": {
                    "action_kind": {
                      "enum": [
                        "INVESTIGATE",
                        "COMPARE",
                        "EXPORT",
                        "REQUEST_REVIEW",
                        "REFRESH"
                      ]
                    }
                  }
                }
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "ownership_posture": {
            "const": "SELF"
          }
        },
        "required": [
          "ownership_posture"
        ]
      },
      "then": {
        "properties": {
          "ownership_label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "waiting_on_label": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "ownership_posture": {
            "enum": [
              "HUMAN_REVIEW",
              "APPROVAL_REQUIRED"
            ]
          }
        },
        "required": [
          "ownership_posture"
        ]
      },
      "then": {
        "properties": {
          "ownership_label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "waiting_on_label": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "ownership_posture": {
            "enum": [
              "AUTHORITY_WAIT",
              "CUSTOMER_WAIT",
              "SYSTEM_WAIT"
            ]
          }
        },
        "required": [
          "ownership_posture"
        ]
      },
      "then": {
        "properties": {
          "actionability_state": {
            "const": "NO_SAFE_ACTION"
          },
          "ownership_label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "waiting_on_label": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "ownership_posture": {
            "const": "NONE"
          }
        },
        "required": [
          "ownership_posture"
        ]
      },
      "then": {
        "properties": {
          "actionability_state": {
            "const": "NO_SAFE_ACTION"
          },
          "ownership_label": {
            "type": "null"
          },
          "waiting_on_label": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "active_detail_surface_code": {
            "$ref": "#/$defs/detailModuleCode"
          }
        },
        "required": [
          "active_detail_surface_code"
        ]
      },
      "then": {
        "properties": {
          "focus_anchor_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "focus_anchor_ref": {
            "type": "string"
          }
        },
        "required": [
          "focus_anchor_ref"
        ]
      },
      "then": {
        "properties": {
          "active_detail_surface_code": {
            "$ref": "#/$defs/detailModuleCode"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "investigation_entry_point": {
            "const": "EVIDENCE_TIDE"
          }
        },
        "required": [
          "investigation_entry_point"
        ]
      },
      "then": {
        "properties": {
          "suggested_detail_surface_code": {
            "const": "EVIDENCE_TIDE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "investigation_entry_point": {
            "const": "PACKET_FORGE"
          }
        },
        "required": [
          "investigation_entry_point"
        ]
      },
      "then": {
        "properties": {
          "suggested_detail_surface_code": {
            "const": "PACKET_FORGE"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "investigation_entry_point": {
            "const": "AUTHORITY_TUNNEL"
          }
        },
        "required": [
          "investigation_entry_point"
        ]
      },
      "then": {
        "properties": {
          "suggested_detail_surface_code": {
            "const": "AUTHORITY_TUNNEL"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "investigation_entry_point": {
            "const": "DRIFT_FIELD"
          }
        },
        "required": [
          "investigation_entry_point"
        ]
      },
      "then": {
        "properties": {
          "suggested_detail_surface_code": {
            "const": "DRIFT_FIELD"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "investigation_entry_point": {
            "const": "FOCUS_LENS"
          }
        },
        "required": [
          "investigation_entry_point"
        ]
      },
      "then": {
        "properties": {
          "suggested_detail_surface_code": {
            "const": "FOCUS_LENS"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "investigation_entry_point": {
            "const": "TWIN_PANEL"
          }
        },
        "required": [
          "investigation_entry_point"
        ]
      },
      "then": {
        "properties": {
          "suggested_detail_surface_code": {
            "const": "TWIN_PANEL"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
