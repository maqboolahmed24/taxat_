{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/low_noise_budget_audit_pack.schema.json",
  "title": "LowNoiseBudgetAuditPack",
  "description": "Deterministic calm-shell budget audit suite. This schema freezes the scenario matrix that proves low-noise shell outputs stay within the governed surface, copy, dominance, and non-material refresh budgets across first view, reconnect, and deterministic detail fallback.",
  "type": "object",
  "required": [
    "contract_version",
    "pack_id",
    "deterministic_seed",
    "suite_profile",
    "run_mode",
    "dominant_story_policy",
    "posture_deduplication_policy",
    "coalescing_policy",
    "copy_budget_policy",
    "cases"
  ],
  "properties": {
    "contract_version": {
      "const": "LOW_NOISE_BUDGET_AUDIT_PACK_V1"
    },
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "deterministic_seed": {
      "type": "integer",
      "minimum": 0
    },
    "suite_profile": {
      "const": "CALM_SHELL_SURFACE_COMPRESSION_AND_NOISE_BUDGET_MATRIX"
    },
    "run_mode": {
      "const": "DETERMINISTIC_SEEDED_ENUMERATION"
    },
    "dominant_story_policy": {
      "const": "ONE_PRIMARY_ISSUE_AND_ONE_SAFE_NEXT_MOVE"
    },
    "posture_deduplication_policy": {
      "const": "ANALYSIS_MASKING_AND_LIMITATION_VISIBLE_ONCE"
    },
    "coalescing_policy": {
      "const": "NON_MATERIAL_DELTAS_COALESCE_BEFORE_ATTENTION_REORDER"
    },
    "copy_budget_policy": {
      "const": "FROZEN_MICROCOPY_BUDGETS_AND_LOSSLESS_DECISIVE_ATOMS"
    },
    "cases": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/auditCase"
      },
      "minItems": 6,
      "uniqueItems": true
    }
  },
  "$defs": {
    "scenarioClass": {
      "type": "string",
      "enum": [
        "FIRST_VIEW",
        "REASON_PRESSURE",
        "NO_SAFE_ACTION",
        "NON_MATERIAL_REFRESH",
        "RECONNECT_CATCH_UP",
        "DETAIL_FALLBACK"
      ]
    },
    "actionabilityState": {
      "type": "string",
      "enum": [
        "ACTION_AVAILABLE",
        "NO_SAFE_ACTION"
      ]
    },
    "modePosture": {
      "type": "string",
      "enum": [
        "LIVE_COMPLIANCE",
        "ANALYSIS_ONLY",
        "REPLAY_ONLY",
        "MASKED_LIMITED",
        "READ_ONLY"
      ]
    },
    "coalescingOutcome": {
      "type": "string",
      "enum": [
        "NONE",
        "COLLAPSE_TO_COUNTS",
        "DETAIL_LOCAL_ONLY",
        "HOLD_UNTIL_MATERIAL"
      ]
    },
    "detailFallbackState": {
      "type": "string",
      "enum": [
        "NOT_APPLICABLE",
        "ACTIVE_MODULE_PRESERVED",
        "FIRST_VALID_ENTRY_SELECTED",
        "SUGGESTED_MODULE_SELECTED",
        "COLLAPSED_ROOT_SELECTED"
      ]
    },
    "detailModuleCode": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "EVIDENCE_TIDE",
        "PACKET_FORGE",
        "AUTHORITY_TUNNEL",
        "DRIFT_FIELD",
        "FOCUS_LENS",
        "TWIN_PANEL",
        null
      ]
    },
    "auditCase": {
      "type": "object",
      "required": [
        "case_id",
        "scenario_class",
        "frame_ref",
        "mode_posture",
        "actionability_state",
        "audit",
        "dominant_question_changed",
        "primary_action_changed",
        "active_detail_surface_code_or_null",
        "expected_coalescing_outcome",
        "expected_fallback_state"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "scenario_class": {
          "$ref": "#/$defs/scenarioClass"
        },
        "frame_ref": {
          "type": "string",
          "minLength": 1
        },
        "mode_posture": {
          "$ref": "#/$defs/modePosture"
        },
        "actionability_state": {
          "$ref": "#/$defs/actionabilityState"
        },
        "audit": {
          "$ref": "https://taxat.dev/schemas/low_noise_budget_audit.schema.json"
        },
        "dominant_question_changed": {
          "type": "boolean"
        },
        "primary_action_changed": {
          "type": "boolean"
        },
        "active_detail_surface_code_or_null": {
          "$ref": "#/$defs/detailModuleCode"
        },
        "expected_coalescing_outcome": {
          "$ref": "#/$defs/coalescingOutcome"
        },
        "expected_fallback_state": {
          "$ref": "#/$defs/detailFallbackState"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
