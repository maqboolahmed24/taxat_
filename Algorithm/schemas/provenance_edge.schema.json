{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/provenance_edge.schema.json",
  "title": "ProvenanceEdge",
  "description": "Typed provenance-graph edge contract. This schema freezes graph topology, support semantics, and explicit cross-manifest lineage boundaries for one directed edge.",
  "type": "object",
  "required": [
    "edge_id",
    "graph_id",
    "manifest_id",
    "tenant_id",
    "client_id",
    "business_partition",
    "period_scope",
    "from_node_id",
    "to_node_id",
    "edge_type",
    "originating_activity_ref",
    "created_at",
    "support_type",
    "support_confidence",
    "support_strength_tier",
    "limitation_codes",
    "from_manifest_id",
    "to_manifest_id",
    "lineage_relation",
    "decisive_support",
    "admissibility_state",
    "contradicted_by_refs",
    "stale_at"
  ],
  "properties": {
    "edge_id": {
      "type": "string",
      "minLength": 1
    },
    "graph_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "tenant_id": {
      "type": "string",
      "minLength": 1
    },
    "client_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "business_partition": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "period_scope": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "from_node_id": {
      "type": "string",
      "minLength": 1
    },
    "to_node_id": {
      "type": "string",
      "minLength": 1
    },
    "edge_type": {
      "type": "string",
      "enum": [
        "ED_USED",
        "ED_GENERATED",
        "ED_DERIVED_FROM",
        "ED_ATTRIBUTED_TO",
        "ED_ASSOCIATED_WITH",
        "ED_ACTED_ON_BEHALF_OF",
        "ED_SUPPORTS",
        "ED_EXTRACTED_FROM",
        "ED_PROMOTED_FROM",
        "ED_AGGREGATES",
        "ED_ADJUSTS",
        "ED_COMPARED_AGAINST",
        "ED_GATED_BY",
        "ED_OVERRIDDEN_BY",
        "ED_ACKNOWLEDGED_BY",
        "ED_RECONCILED_WITH",
        "ED_AUDITED_BY",
        "ED_CAUSED_BY_ERROR",
        "ED_COMPENSATED_BY",
        "ED_CONTINUES",
        "ED_REPLAYS",
        "ED_RECOVERS",
        "ED_SUPERSEDES",
        "ED_BASELINES",
        "ED_LIMITED_BY_RETENTION",
        "ED_ERASED_UNDER",
        "ED_TRIGGERED_WORKFLOW",
        "ED_DEPENDS_ON_CONFIG",
        "ED_REPORTS_AS",
        "ED_CONTRADICTS"
      ]
    },
    "originating_activity_ref": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "support_type": {
      "type": "string",
      "enum": [
        "DIRECT",
        "EXTRACTED",
        "DECLARED",
        "INFERRED",
        "AUTHORITY_CONFIRMED",
        "GOVERNANCE_ONLY"
      ]
    },
    "support_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "support_strength_tier": {
      "type": "string",
      "enum": [
        "TIER_1_AUTHORITY_FINAL",
        "TIER_2_AUTHORITY_REFERENCE",
        "TIER_3_STRUCTURED_EXTERNAL",
        "TIER_4_STRUCTURED_INTERNAL",
        "TIER_5_DOCUMENT_SUPPORT",
        "TIER_6_DECLARED_ONLY",
        "TIER_7_INFERRED",
        "TIER_8_GOVERNANCE_ONLY"
      ]
    },
    "limitation_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "from_manifest_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "to_manifest_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "lineage_relation": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "ED_CONTINUES",
        "ED_REPLAYS",
        "ED_RECOVERS",
        "ED_SUPERSEDES",
        null
      ]
    },
    "decisive_support": {
      "type": "boolean"
    },
    "admissibility_state": {
      "type": "string",
      "enum": [
        "ADMISSIBLE",
        "LIMITED",
        "INADMISSIBLE"
      ]
    },
    "contradicted_by_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "stale_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "edge_type": {
            "enum": [
              "ED_CONTINUES",
              "ED_REPLAYS",
              "ED_RECOVERS",
              "ED_SUPERSEDES"
            ]
          }
        },
        "required": [
          "edge_type"
        ]
      },
      "then": {
        "properties": {
          "from_manifest_id": {
            "type": "string",
            "minLength": 1
          },
          "to_manifest_id": {
            "type": "string",
            "minLength": 1
          },
          "lineage_relation": {
            "enum": [
              "ED_CONTINUES",
              "ED_REPLAYS",
              "ED_RECOVERS",
              "ED_SUPERSEDES"
            ]
          }
        }
      },
      "else": {
        "properties": {
          "from_manifest_id": {
            "type": "null"
          },
          "to_manifest_id": {
            "type": "null"
          },
          "lineage_relation": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "admissibility_state": {
            "const": "ADMISSIBLE"
          }
        },
        "required": [
          "admissibility_state"
        ]
      },
      "then": {
        "properties": {
          "limitation_codes": {
            "maxItems": 0
          },
          "contradicted_by_refs": {
            "maxItems": 0
          },
          "stale_at": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "edge_type": {
            "const": "ED_CONTRADICTS"
          }
        },
        "required": [
          "edge_type"
        ]
      },
      "then": {
        "properties": {
          "contradicted_by_refs": {
            "minItems": 1
          },
          "admissibility_state": {
            "enum": [
              "LIMITED",
              "INADMISSIBLE"
            ]
          },
          "limitation_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "support_type": {
            "const": "INFERRED"
          }
        },
        "required": [
          "support_type"
        ]
      },
      "then": {
        "properties": {
          "support_strength_tier": {
            "const": "TIER_7_INFERRED"
          },
          "limitation_codes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "support_type": {
            "const": "GOVERNANCE_ONLY"
          }
        },
        "required": [
          "support_type"
        ]
      },
      "then": {
        "properties": {
          "support_strength_tier": {
            "const": "TIER_8_GOVERNANCE_ONLY"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "edge_type": {
            "enum": [
              "ED_LIMITED_BY_RETENTION",
              "ED_ERASED_UNDER"
            ]
          }
        },
        "required": [
          "edge_type"
        ]
      },
      "then": {
        "properties": {
          "limitation_codes": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
