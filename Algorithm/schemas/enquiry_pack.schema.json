{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taxat.dev/schemas/enquiry_pack.schema.json",
  "title": "EnquiryPack",
  "description": "Deterministic provenance enquiry-pack contract. This schema freezes the exported explanation bundle, audit anchors, omission declarations, and human or machine-readable renderings for one investigative target.",
  "type": "object",
  "required": [
    "enquiry_pack_id",
    "manifest_id",
    "manifest_refs",
    "partition_contract",
    "graph_ref",
    "target_ref",
    "target_class",
    "primary_path_ref",
    "critical_path_refs",
    "supporting_evidence_refs",
    "transformation_step_refs",
    "config_refs",
    "override_refs",
    "authority_refs",
    "limitation_notes",
    "audit_refs",
    "lineage_boundaries",
    "masking_posture",
    "omission_entries",
    "human_readable_ref",
    "machine_readable_ref",
    "generated_at",
    "proof_bundle_ref",
    "explanation_status",
    "retention_binding",
    "retention_limited_explainability_contract",
    "render_contract",
    "externalization_governance_contract"
  ],
  "properties": {
    "enquiry_pack_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "partition_contract": {
      "$ref": "./provenance_partition_contract.schema.json"
    },
    "graph_ref": {
      "type": "string",
      "minLength": 1
    },
    "target_ref": {
      "type": "string",
      "minLength": 1
    },
    "target_class": {
      "type": "string",
      "enum": [
        "FIGURE",
        "TOTAL",
        "FILING_FIELD",
        "DECISION",
        "LEGAL_STATE",
        "DRIFT",
        "RETENTION_LIMITATION",
        "ERROR_CHAIN"
      ]
    },
    "primary_path_ref": {
      "type": "string",
      "minLength": 1
    },
    "critical_path_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "supporting_evidence_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "transformation_step_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "config_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "override_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "authority_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": [],
      "uniqueItems": true
    },
    "limitation_notes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/limitationNote"
      },
      "default": []
    },
    "audit_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "lineage_boundaries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/lineageBoundary"
      },
      "default": []
    },
    "masking_posture": {
      "type": "string",
      "enum": [
        "NONE",
        "MASKED",
        "REDACTED",
        "LIMITED_EXPORT"
      ]
    },
    "omission_entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/omissionEntry"
      },
      "default": []
    },
    "human_readable_ref": {
      "type": "string",
      "minLength": 1
    },
    "machine_readable_ref": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "proof_bundle_ref": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "explanation_status": {
      "type": "string",
      "enum": [
        "AVAILABLE",
        "LIMITED",
        "FAILED"
      ]
    },
    "retention_binding": {
      "type": "object",
      "required": [
        "retention_tag_ref",
        "limitation_behavior",
        "minimum_available_until"
      ],
      "properties": {
        "retention_tag_ref": {
          "type": "string",
          "minLength": 1
        },
        "limitation_behavior": {
          "type": "string",
          "enum": [
            "FULL",
            "LIMITED",
            "TOMBSTONED",
            "PSEUDONYMISED"
          ]
        },
        "minimum_available_until": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "retention_limited_explainability_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/retention_limited_explainability_contract.schema.json"
        },
        {
          "properties": {
            "boundary_scope": {
              "const": "ENQUIRY_PACK"
            },
            "surface_role": {
              "const": "SCRUTINY_EXPORT_PACK"
            },
            "surface_specific_binding_policy": {
              "const": "ENQUIRY_PACK_RETAINS_LIMITATION_NOTES_OMISSIONS_AND_RETENTION_BINDING"
            }
          }
        }
      ]
    },
    "render_contract": {
      "type": "object",
      "required": [
        "operator_render_ref",
        "reviewer_render_ref",
        "filing_artifact_ref"
      ],
      "properties": {
        "operator_render_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "reviewer_render_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "filing_artifact_ref": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "externalization_governance_contract": {
      "allOf": [
        {
          "$ref": "https://taxat.dev/schemas/externalization_governance_contract.schema.json"
        },
        {
          "properties": {
            "boundary_scope": {
              "const": "ENQUIRY_PACK"
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "lineageBoundary": {
      "type": "object",
      "required": [
        "boundary_id",
        "boundary_edge_ref",
        "from_manifest_id",
        "to_manifest_id",
        "relation",
        "exposed_in_path_refs",
        "decisive_in_path_refs",
        "tenant_id",
        "client_id",
        "partition_scope_refs",
        "period_scope_ref_or_null"
      ],
      "properties": {
        "boundary_id": {
          "type": "string",
          "minLength": 1
        },
        "boundary_edge_ref": {
          "type": "string",
          "minLength": 1
        },
        "from_manifest_id": {
          "type": "string",
          "minLength": 1
        },
        "to_manifest_id": {
          "type": "string",
          "minLength": 1
        },
        "relation": {
          "type": "string",
          "enum": [
            "ED_CONTINUES",
            "ED_REPLAYS",
            "ED_RECOVERS",
            "ED_SUPERSEDES"
          ]
        },
        "exposed_in_path_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "decisive_in_path_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "tenant_id": {
          "type": "string",
          "minLength": 1
        },
        "client_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "partition_scope_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "uniqueItems": true
        },
        "period_scope_ref_or_null": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "limitationNote": {
      "type": "object",
      "required": [
        "note_id",
        "limitation_code",
        "note_class",
        "affected_refs"
      ],
      "properties": {
        "note_id": {
          "type": "string",
          "minLength": 1
        },
        "limitation_code": {
          "type": "string",
          "minLength": 1
        },
        "note_class": {
          "type": "string",
          "enum": [
            "RETENTION",
            "PRIVACY",
            "MASKING",
            "MISSING_SUPPORT",
            "AUTHORITY_LIMIT",
            "SUPERSESSION"
          ]
        },
        "affected_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "omissionEntry": {
      "type": "object",
      "required": [
        "omission_id",
        "omission_class",
        "affected_refs",
        "declared_reason_code"
      ],
      "properties": {
        "omission_id": {
          "type": "string",
          "minLength": 1
        },
        "omission_class": {
          "type": "string",
          "enum": [
            "MASKING",
            "RETENTION",
            "PRIVACY",
            "AUTHORITY_LIMIT",
            "EXTERNAL_LIMITATION"
          ]
        },
        "affected_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "declared_reason_code": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "masking_posture": {
            "const": "NONE"
          }
        },
        "required": [
          "masking_posture"
        ]
      },
      "then": {
        "properties": {
          "omission_entries": {
            "maxItems": 0
          }
        }
      },
      "else": {
        "properties": {
          "omission_entries": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "target_class": {
            "enum": [
              "FIGURE",
              "TOTAL",
              "FILING_FIELD",
              "DECISION",
              "LEGAL_STATE"
            ]
          }
        },
        "required": [
          "target_class"
        ]
      },
      "then": {
        "properties": {
          "proof_bundle_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "target_class": {
            "const": "LEGAL_STATE"
          }
        },
        "required": [
          "target_class"
        ]
      },
      "then": {
        "properties": {
          "authority_refs": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "target_class": {
            "const": "RETENTION_LIMITATION"
          }
        },
        "required": [
          "target_class"
        ]
      },
      "then": {
        "properties": {
          "limitation_notes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lineage_boundaries": {
            "minItems": 1
          }
        },
        "required": [
          "lineage_boundaries"
        ]
      },
      "then": {
        "properties": {
          "manifest_refs": {
            "minItems": 2
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "explanation_status": {
            "const": "AVAILABLE"
          }
        },
        "required": [
          "explanation_status"
        ]
      },
      "then": {
        "properties": {
          "retention_binding": {
            "properties": {
              "limitation_behavior": {
                "const": "FULL"
              }
            }
          },
          "render_contract": {
            "properties": {
              "operator_render_ref": {
                "type": "string",
                "minLength": 1
              },
              "reviewer_render_ref": {
                "type": "string",
                "minLength": 1
              },
              "filing_artifact_ref": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "retention_binding": {
            "properties": {
              "limitation_behavior": {
                "enum": [
                  "LIMITED",
                  "TOMBSTONED",
                  "PSEUDONYMISED"
                ]
              }
            },
            "required": [
              "limitation_behavior"
            ]
          }
        },
        "required": [
          "retention_binding"
        ]
      },
      "then": {
        "properties": {
          "explanation_status": {
            "enum": [
              "LIMITED",
              "FAILED"
            ]
          },
          "omission_entries": {
            "minItems": 1
          },
          "limitation_notes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "explanation_status": {
            "const": "LIMITED"
          }
        },
        "required": [
          "explanation_status"
        ]
      },
      "then": {
        "properties": {
          "render_contract": {
            "anyOf": [
              {
                "properties": {
                  "operator_render_ref": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              {
                "properties": {
                  "reviewer_render_ref": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              {
                "properties": {
                  "filing_artifact_ref": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "explanation_status": {
            "const": "FAILED"
          }
        },
        "required": [
          "explanation_status"
        ]
      },
      "then": {
        "properties": {
          "render_contract": {
            "properties": {
              "operator_render_ref": {
                "type": "null"
              },
              "reviewer_render_ref": {
                "type": "null"
              },
              "filing_artifact_ref": {
                "type": "null"
              }
            }
          },
          "omission_entries": {
            "minItems": 1
          },
          "limitation_notes": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "manifest_refs": {
            "minItems": 2
          }
        },
        "required": [
          "manifest_refs"
        ]
      },
      "then": {
        "properties": {
          "lineage_boundaries": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "lineage_boundaries": {
            "minItems": 1
          }
        },
        "required": [
          "lineage_boundaries"
        ]
      },
      "then": {
        "properties": {
          "manifest_refs": {
            "minItems": 2
          }
        }
      }
    }
  ]
}
